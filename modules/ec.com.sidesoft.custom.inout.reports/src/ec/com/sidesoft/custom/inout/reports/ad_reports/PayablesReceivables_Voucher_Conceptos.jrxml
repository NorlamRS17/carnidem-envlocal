			</textElement>
			<textFieldExpression><![CDATA[$V{TOTAL_CONCEPTO}.setScale($P{NUMBERDECIMAL}, java.math.RoundingMode.HALF_UP)]]></textFieldExpression>
			<patternExpression><![CDATA[$P{NUMBERFORMAT}.toPattern()]]></patternExpression>
		</textField>
