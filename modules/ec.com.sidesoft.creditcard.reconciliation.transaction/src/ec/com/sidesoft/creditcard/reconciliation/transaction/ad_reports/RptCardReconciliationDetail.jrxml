<?xml version="1.0" encoding="UTF-8"?>
<jasperReport xmlns="http://jasperreports.sourceforge.net/jasperreports" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://jasperreports.sourceforge.net/jasperreports http://jasperreports.sourceforge.net/xsd/jasperreport.xsd" name="RptCardReconciliationDetail" pageWidth="1100" pageHeight="726" orientation="Landscape" whenNoDataType="BlankPage" columnWidth="1060" leftMargin="20" rightMargin="20" topMargin="20" bottomMargin="20" uuid="fee87fa3-fa31-4d12-b6ec-b6c6116f298c">
	<property name="ireport.zoom" value="1.5000000000000024"/>
	<property name="ireport.x" value="0"/>
	<property name="ireport.y" value="0"/>
	<property name="net.sf.jasperreports.export.xls.detect.cell.type" value="true"/>
	<property name="net.sf.jasperreports.export.xls.sheet.names.all" value="Detalle Conciliaciones"/>
	<import value="net.sf.jasperreports.engine.*"/>
	<import value="java.util.*"/>
	<import value="org.openbravo.dal.core.OBContext"/>
	<import value="net.sf.jasperreports.engine.data.*"/>
	<parameter name="NUMBERFORMAT" class="java.text.DecimalFormat" isForPrompting="false">
		<defaultValueExpression><![CDATA[new DecimalFormat("###,##0.00;-###,##0.00", new DecimalFormatSymbols())]]></defaultValueExpression>
	</parameter>
	<parameter name="DATEFORMAT" class="java.text.SimpleDateFormat" isForPrompting="false">
		<defaultValueExpression><![CDATA[new SimpleDateFormat("dd/MM/yyyy")]]></defaultValueExpression>
	</parameter>
	<parameter name="Org_ID" class="java.lang.String" isForPrompting="false">
		<defaultValueExpression><![CDATA[OBContext.getOBContext().getCurrentOrganization().getId()]]></defaultValueExpression>
	</parameter>
	<parameter name="User_ID" class="java.lang.String" isForPrompting="false">
		<defaultValueExpression><![CDATA[OBContext.getOBContext().getUser().getId()]]></defaultValueExpression>
	</parameter>
	<parameter name="UserName" class="java.lang.String" isForPrompting="false">
		<defaultValueExpression><![CDATA[OBContext.getOBContext().getUser().getUsername()]]></defaultValueExpression>
	</parameter>
	<parameter name="DateFrom" class="java.util.Date">
		<defaultValueExpression><![CDATA[]]></defaultValueExpression>
	</parameter>
	<parameter name="DateTo" class="java.util.Date">
		<defaultValueExpression><![CDATA[]]></defaultValueExpression>
	</parameter>
	<queryString>
		<![CDATA[SELECT *,
TO_CHAR(now(),'dd/MM/yyyy HH24:MI:SS') as fecha_impresion
FROM (

SELECT lt.documentno, 'Carga' as typetrx,
lot,
recap,
iva,
withh_rent,
withh_iva,
commision_value as commision,
accredit_value as bank
FROM sccrt_card_load_transaction lt
JOIN sccrt_card_load_line ll ON lt.sccrt_card_load_transaction_id = ll.sccrt_card_load_transaction_id
WHERE TRUNC(ll.date_deposit) BETWEEN $P{DateFrom} AND $P{DateTo}
UNION ALL
(SELECT x.documentno,x.typetrx,x.lot,x.recap,
max(iva) iva,
max(withh_rent) withh_rent,
max(withh_iva) withh_iva,
max(commision) as commision,
max(bank)as bank
FROM (SELECT x.documentno,x.typetrx,x.lot,x.recap,
CASE WHEN type = 'IVA' THEN deposit_amount ELSE 0 END as iva,
CASE WHEN type = 'IW' THEN deposit_amount ELSE 0 END as withh_rent,
CASE WHEN type = 'VW' THEN deposit_amount ELSE 0 END as withh_iva,
CASE WHEN type = 'C' THEN deposit_amount ELSE 0 END as commision,
CASE WHEN type = 'B' OR type is null  THEN COALESCE(deposit_amount,amounttrx) ELSE 0 END as bank
 FROM (
	SELECT pcr.documentno,
	CASE WHEN Trxtype='BPD' THEN 'Cobro' ELSE 'Pago' END AS typetrx,
	CASE WHEN Trxtype='BPD' THEN depositamt ELSE paymentamt END AS amounttrx,
	ft.em_ssccr_pos_card_rec_id as ssccr_pos_card_rec_id,
	 em_ssccr_recapno as recap,
	 em_ssccr_lot as lot
	FROM fin_finacc_transaction  ft
		JOIN ssccr_pos_card_rec pcr ON pcr.ssccr_pos_card_rec_id = ft.em_ssccr_pos_card_rec_id
	WHERE TRUNC(ft.statementdate) BETWEEN $P{DateFrom} AND $P{DateTo}
	AND ft.em_ssccr_processor_banck_id IS NULL AND EXISTS (
		SELECT prc.ssccr_pos_card_rec_id
		FROM ssccr_pos_card_rec prc
		JOIN sccrt_card_load_transaction lt ON prc.description ilike '%'||lt.documentno||'%'
		WHERE prc.ssccr_pos_card_rec_id = ft.em_ssccr_pos_card_rec_id
	)) x
	LEFT JOIN ssccr_pos_card_rec_line pl ON pl.ssccr_pos_card_rec_id = x.ssccr_pos_card_rec_id
		AND deposit_amount = x.amounttrx AND typetrx = 'Pago'
	ORDER BY x.documentno) x
	GROUP BY x.documentno,x.typetrx,x.lot,x.recap)
UNION ALL
(SELECT x.documentno,x.typetrx,x.lot,x.recap,
max(iva) iva,
max(withh_rent) withh_rent,
max(withh_iva) withh_iva,
max(commision) as commision,
max(bank)as bank
FROM (SELECT prc.documentno, 'Conciliacion' as typetrx,recap,lot,
CASE WHEN type = 'IVA' THEN deposit_amount ELSE 0 END as iva,
CASE WHEN type = 'IW' THEN deposit_amount ELSE 0 END as withh_rent,
CASE WHEN type = 'VW' THEN deposit_amount ELSE 0 END as withh_iva,
CASE WHEN type = 'C' THEN deposit_amount ELSE 0 END as commision,
CASE WHEN type = 'B' THEN deposit_amount ELSE 0 END as bank
	FROM ssccr_pos_card_rec prc
		JOIN sccrt_card_load_transaction lt ON prc.description ilike '%'||lt.documentno||'%'
		LEFT JOIN ssccr_pos_card_rec_line pl ON pl.ssccr_pos_card_rec_id = prc.ssccr_pos_card_rec_id
	WHERE TRUNC(prc.date_payment) BETWEEN $P{DateFrom} AND $P{DateTo}
	) x
		GROUP BY x.documentno,x.typetrx,x.lot,x.recap)
	ORDER BY 3,4

)x]]>
	</queryString>
