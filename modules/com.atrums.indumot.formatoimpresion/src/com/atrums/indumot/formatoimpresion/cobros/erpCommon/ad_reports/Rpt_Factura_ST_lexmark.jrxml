<?xml version="1.0" encoding="UTF-8"?>
<jasperReport xmlns="http://jasperreports.sourceforge.net/jasperreports" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://jasperreports.sourceforge.net/jasperreports http://jasperreports.sourceforge.net/xsd/jasperreport.xsd" name="Rpt_ATIMV_FacturaM" pageWidth="765" pageHeight="566" orientation="Landscape" columnWidth="713" leftMargin="10" rightMargin="42" topMargin="56" bottomMargin="56">
	<property name="ireport.zoom" value="2.415765000000001"/>
	<property name="ireport.x" value="578"/>
	<property name="ireport.y" value="136"/>
	<parameter name="DOCUMENT_ID" class="java.lang.String"/>
	<parameter name="BASE_DESIGN" class="java.lang.String" isForPrompting="false">
		<defaultValueExpression><![CDATA["C:/Desarrollo/OpenbravoERPIndumoto/modules/com.atrums.indumot.formatoimpresion/src"]]></defaultValueExpression>
	</parameter>
	<queryString>
		<![CDATA[select  p.name, l.name as "DIRECCION",
        coalesce(p.taxid,'') AS "RUC/CI",
        p.value as "COD.CLIENTE",
       coalesce((select username  from ad_user where ad_user_id = i.salesrep_id),'')as "COD.VENDEDOR",
        i.dateinvoiced as "FECHA_EMISION",
        i.documentno as "NUM.DOC",
        (select name from c_paymentterm where c_paymentterm_id = i.c_paymentterm_id) as "FORMA_PAGO",
        coalesce(l.phone,'') as "TELEFONO",
i.totallines,
        (select sum(it.taxamt) from c_invoicetax it where it.c_invoice_id = i.c_invoice_id) as imp,

         CASE when (select m_attributesetinstance_id from c_invoiceline where c_invoice_id = i.c_invoice_id limit 1)
        is null then 0
        else (select coalesce(o.em_atvef_financiamiento,0) from c_orderline o where o.c_order_id = i.c_order_id limit 1) end as finan,

(select
case when (sum(pricelist) - sum(priceactual)) > 0 then round(sum((pricelist-priceactual)*qtyinvoiced),2) else 0 end
from c_invoiceline where c_invoice_id = i.c_invoice_id) as descuento,

(select
case when sum(pricelist) > 0 then round(sum(pricelist*qtyinvoiced),2) else round(sum(priceactual*qtyinvoiced),2) end
from c_invoiceline where c_invoice_id = i.c_invoice_id) as subtotal,

        i.grandtotal,
        (select m_attributesetinstance_id from c_invoiceline where c_invoice_id = i.c_invoice_id limit 1) as "ATRIBUTOS"
from c_invoice as i left join c_bpartner p on(i.c_bpartner_id=p.c_bpartner_id)
left join c_bpartner_location as l on(l.c_bpartner_location_id=i.c_bpartner_location_id)
where i.c_invoice_id = $P{DOCUMENT_ID}]]>
	</queryString>
	<field name="name" class="java.lang.String"/>
	<field name="DIRECCION" class="java.lang.String"/>
	<field name="RUC/CI" class="java.lang.String"/>
	<field name="COD.CLIENTE" class="java.lang.String"/>
	<field name="COD.VENDEDOR" class="java.lang.String"/>
	<field name="FECHA_EMISION" class="java.sql.Timestamp"/>
