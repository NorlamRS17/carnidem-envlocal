<?xml version="1.0" encoding="UTF-8"?>
<jasperReport xmlns="http://jasperreports.sourceforge.net/jasperreports" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://jasperreports.sourceforge.net/jasperreports http://jasperreports.sourceforge.net/xsd/jasperreport.xsd" name="Rpt_atimv_retencion" pageWidth="620" pageHeight="595" orientation="Landscape" columnWidth="580" leftMargin="20" rightMargin="20" topMargin="20" bottomMargin="20">
	<property name="ireport.zoom" value="1.2100000000000006"/>
	<property name="ireport.x" value="0"/>
	<property name="ireport.y" value="0"/>
	<parameter name="DOCUMENT_ID" class="java.lang.String"/>
	<parameter name="BASE_DESIGN" class="java.lang.String" isForPrompting="false">
		<parameterDescription><![CDATA[]]></parameterDescription>
		<defaultValueExpression><![CDATA["C:/DesarrolloLuis/OpenbravoERPNuevo/modules/com.atrums.indumot.formatoimpresion/src"]]></defaultValueExpression>
	</parameter>
	<queryString>
		<![CDATA[select coalesce(tb_cbptl.name,'') as ciudad,
tb_corecm.fecha_emision as fecha,
coalesce(tb_cbpt.name,'') as Nombre,
coalesce(tb_corecm.ruc_bp,'') as cioruc,
'Factura' as documento,
coalesce(tb_civ.em_co_nro_estab,'') || '-' || coalesce(tb_civ.em_co_punto_emision,'') || '-' ||  coalesce(tb_civ.documentno,'') as numero,
coalesce(tb_cbptl.phone,'') as telefono
from
co_retencion_compra as tb_corecm join c_bpartner as tb_cbpt on tb_corecm.c_bpartner_id = tb_cbpt.c_bpartner_id
                                 join c_bpartner_location as tb_cbptl on tb_corecm.c_bpartner_location_id = tb_cbptl.c_bpartner_location_id
                                 join c_invoice as tb_civ on tb_corecm.c_invoice_id = tb_civ.c_invoice_id
                                 join c_doctype as tb_cdt on tb_corecm.c_doctype_id = tb_cdt.c_doctype_id
where tb_corecm.co_retencion_compra_id = $P{DOCUMENT_ID}]]>
	</queryString>
	<field name="ciudad" class="java.lang.String"/>
	<field name="fecha" class="java.sql.Timestamp"/>
	<field name="nombre" class="java.lang.String"/>
	<field name="cioruc" class="java.lang.String"/>
	<field name="documento" class="java.lang.String"/>
	<field name="numero" class="java.lang.String"/>
	<field name="telefono" class="java.lang.String"/>
