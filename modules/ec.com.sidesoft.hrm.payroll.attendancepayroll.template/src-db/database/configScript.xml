    <columnDataChange tablename="AD_VAL_RULE" columnname="CODE" pkRow="8BC0BC0A4B494B0D913CB7BAEFEE5A2D">
      <oldValue><![CDATA[c_bpartner.isemployee='Y']]></oldValue>
      <newValue><![CDATA[(C_BPARTNER.ISEMPLOYEE = 'Y' AND C_BPARTNER.C_BPARTNER_ID in (
	SELECT AU.C_BPARTNER_ID 
	FROM AD_ROLE AROLE
	JOIN AD_USER_ROLES AUR ON AROLE.AD_ROLE_ID = AUR.AD_ROLE_ID 
	JOIN AD_USER AU ON AU.AD_USER_ID = AUR.AD_USER_ID
	WHERE AU.AD_USER_ID = @#AD_USER_ID@
	) 
 	and (coalesce((select 1 
			 from ad_user u 
			 where u.ad_user_id = @#AD_USER_ID@
			 and u.em_shpapr_adminassis = 'Y'
			), 0) = 0
		 )
)
OR
(C_BPARTNER.ISEMPLOYEE = 'Y' 
 	and (coalesce((select 1 
			 from ad_user u 
			 where u.ad_user_id = @#AD_USER_ID@
			 and u.em_shpapr_adminassis = 'Y'
			), 0) = 1
		 )
)]]></newValue>
    </columnDataChange>
