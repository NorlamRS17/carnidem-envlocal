		<defaultValueExpression><![CDATA[Utility.getOrgIdLogin()]]></defaultValueExpression>
	</parameter>
	<parameter name="Org_Name" class="java.lang.String" isForPrompting="false">
		<defaultValueExpression><![CDATA[Utility.getOrgNameLogin()]]></defaultValueExpression>
	</parameter>
	<parameter name="User_ID" class="java.lang.String" isForPrompting="false">
		<defaultValueExpression><![CDATA[Utility.getUserIdLogin()]]></defaultValueExpression>
	</parameter>
	<parameter name="UserName" class="java.lang.String" isForPrompting="false">
		<defaultValueExpression><![CDATA[Utility.getUserNameLogin()]]></defaultValueExpression>
	</parameter>
	<parameter name="NUMBERFORMAT" class="java.text.DecimalFormat" isForPrompting="false">
		<defaultValueExpression><![CDATA[new DecimalFormat("###,##0.00;-###,##0.00", new DecimalFormatSymbols())]]></defaultValueExpression>
	</parameter>
	<parameter name="DATEFORMAT" class="java.text.SimpleDateFormat" isForPrompting="false">
		<defaultValueExpression><![CDATA[new SimpleDateFormat("dd/MM/yyyy")]]></defaultValueExpression>
	</parameter>
	<parameter name="PRICEFORMAT" class="java.text.DecimalFormat" isForPrompting="false">
		<defaultValueExpression><![CDATA[]]></defaultValueExpression>
	</parameter>
	<queryString>
		<![CDATA[SELECT
    COALESCE(wc.documentno, '') AS documentno,
    COALESCE(bp.taxid, '') AS taxid,
    COALESCE(bp.name, '') AS bpname,
    COALESCE(i.documentno, '') AS invno,
    COALESCE(TRUNC(withholding_date), TRUNC(now())) AS withholding_date,
    COALESCE(TRUNC(withholding_date_cancel), TRUNC(now())) AS withholding_date_cancel,
    COALESCE(key_access_auth, '') AS key_access_auth,
    COALESCE(totalwithholdingincome, 0) AS totalwithholdingincome,
    COALESCE(totalwithholdingvat, 0) AS totalwithholdingvat,
    0 AS totalwh,
    COALESCE(u.username, '') AS generatedby,
    TO_CHAR(now(), 'dd/MM/yyyy HH24:MI:SS') fecha_impresion
FROM
    ecswc_withholding_cancel wc
    JOIN c_invoice i ON i.c_invoice_id = wc.c_invoice_id
    JOIN c_bpartner bp ON bp.c_bpartner_id = i.c_bpartner_id
    JOIN ad_user u ON u.ad_user_id = wc.createdby
WHERE
    trunc(withholding_date_cancel) BETWEEN  TRUNC(TO_DATE($P{Start_Date})) AND TRUNC(TO_DATE($P{Finishes_Date}))
   AND (ad_isorgincluded (i.AD_Org_ID,$P{AD_ORG_ID} , i.AD_Client_ID) > 0 OR $P{AD_ORG_ID} IS  NULL)
ORDER BY
    withholding_date_cancel,
    documentno]]>
	</queryString>
