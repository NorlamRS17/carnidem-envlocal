	<field name="taxid" class="java.lang.String"/>
	<field name="bpname" class="java.lang.String"/>
	<field name="invno" class="java.lang.String"/>
	<field name="withholding_date" class="java.sql.Date"/>
	<field name="withholding_date_cancel" class="java.sql.Date"/>
	<field name="key_access_auth" class="java.lang.String"/>
	<field name="totalwithholdingincome" class="java.math.BigDecimal"/>
	<field name="totalwithholdingvat" class="java.math.BigDecimal"/>
	<field name="totalwh" class="java.lang.Integer"/>
	<field name="generatedby" class="java.lang.String"/>
	<field name="fecha_impresion" class="java.lang.String"/>
