<?xml version="1.0" encoding="UTF-8"?>
<jasperReport xmlns="http://jasperreports.sourceforge.net/jasperreports" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://jasperreports.sourceforge.net/jasperreports http://jasperreports.sourceforge.net/xsd/jasperreport.xsd" name="c_purchase_reconcile_totals" pageWidth="1741" pageHeight="25" columnWidth="1741" leftMargin="0" rightMargin="0" topMargin="0" bottomMargin="0" uuid="87d7523f-3aa1-498c-b909-77dca7a5ce08">
	<property name="ireport.zoom" value="1.4641000000000006"/>
	<property name="ireport.x" value="0"/>
	<property name="ireport.y" value="0"/>
	<property name="net.sf.jasperreports.export.xls.detect.cell.type" value="true"/>
	<style name="Crosstab Data Text" hAlign="Center"/>
	<parameter name="DateFrom" class="java.util.Date">
		<defaultValueExpression><![CDATA[]]></defaultValueExpression>
	</parameter>
	<parameter name="DateTo" class="java.util.Date">
		<defaultValueExpression><![CDATA[]]></defaultValueExpression>
	</parameter>
	<parameter name="Posted" class="java.lang.String">
		<defaultValueExpression><![CDATA[]]></defaultValueExpression>
	</parameter>
	<parameter name="C_DocTypeTarget_ID" class="java.lang.String">
		<defaultValueExpression><![CDATA[]]></defaultValueExpression>
	</parameter>
	<parameter name="AD_Org_ID" class="java.lang.String">
		<defaultValueExpression><![CDATA[]]></defaultValueExpression>
	</parameter>
	<parameter name="C_BPartner_ID" class="java.lang.String">
		<defaultValueExpression><![CDATA[]]></defaultValueExpression>
	</parameter>
	<queryString>
		<![CDATA[WITH tax_used AS (
    SELECT DISTINCT t.rate
    FROM c_tax t
    JOIN c_invoicetax it ON t.c_tax_id = it.c_tax_id
    JOIN c_invoice i ON i.c_invoice_id = it.c_invoice_id
    WHERE t.istaxdeductable = 'Y'
      AND t.rate <> 0
      AND i.dateinvoiced::date BETWEEN $P{DateFrom} AND $P{DateTo}
      AND i.issotrx = 'N'
      AND i.docstatus IN ('CO','VO')
      AND (i.posted = $P{Posted} OR $P{Posted} IS NULL)
      AND (i.C_doctypetarget_id = $P{C_DocTypeTarget_ID} OR $P{C_DocTypeTarget_ID} IS NULL)
      AND (i.ad_org_id = $P{AD_Org_ID} OR $P{AD_Org_ID} IS NULL)
      AND (i.c_bpartner_id = $P{C_BPartner_ID} OR $P{C_BPartner_ID} IS NULL)
)
SELECT * FROM (
SELECT 'TOTAL' as etiqueta,
SUM(CASE WHEN c.isreversal = 'N' THEN
	COALESCE((SELECT SUM(taxbaseamt)
	FROM c_invoicetax j
	LEFT JOIN c_tax t ON j.c_tax_id = t.c_tax_id
	WHERE i.c_invoice_id = j.c_invoice_id
	AND t.rate = 0
	AND t.istaxdeductable = 'Y'),0.00)
	ELSE
	COALESCE((SELECT SUM(taxbaseamt)
	FROM c_invoicetax j
	LEFT JOIN c_tax t ON j.c_tax_id = t.c_tax_id
	WHERE i.c_invoice_id = j.c_invoice_id
	AND t.rate = 0
	AND t.istaxdeductable = 'Y'),0.00) * -1 END) AS "sum_basecero",
	SUM(CASE WHEN c.isreversal = 'N' THEN
	COALESCE((SELECT SUM(taxbaseamt)
	FROM c_invoicetax j
	LEFT JOIN c_tax t ON j.c_tax_id = t.c_tax_id
	WHERE i.c_invoice_id = j.c_invoice_id
	AND t.rate <> 0
	AND t.istaxdeductable = 'Y'),0.00)
	ELSE
	COALESCE((SELECT SUM(taxbaseamt)
	FROM c_invoicetax j
	LEFT JOIN c_tax t ON j.c_tax_id = t.c_tax_id
	where i.c_invoice_id = j.c_invoice_id
	AND t.rate <> 0
	AND t.istaxdeductable = 'Y'),0.00) * -1 END) AS "sum_basedoce",
SUM(CASE WHEN c.isreversal = 'N' THEN i.totallines ELSE i.totallines * -1 END) AS "sum_base",
SUM(CASE WHEN c.isreversal = 'N' THEN i.grandtotal ELSE i.grandtotal * -1 END) AS "sum_total",
SUM(i.EM_Sswh_Totalwithholdingincome) AS "sum_imprenta",
SUM(i.EM_Sswh_Totalwithholdingvat) AS "sum_impiva"
FROM c_invoice i
LEFT JOIN c_doctype c ON i.c_doctype_id = c.c_doctype_id
WHERE i.issotrx = 'N'
AND i.docstatus IN ('CO','VO')
AND i.dateinvoiced::date BETWEEN $P{DateFrom} AND $P{DateTo}
AND (i.posted = $P{Posted} OR $P{Posted} IS NULL)
AND (i.C_doctypetarget_id = $P{C_DocTypeTarget_ID} OR $P{C_DocTypeTarget_ID} IS NULL)
AND (i.ad_org_id = $P{AD_Org_ID} OR $P{AD_Org_ID} IS NULL)
AND (i.c_bpartner_id = $P{C_BPartner_ID} OR $P{C_BPartner_ID} IS NULL)
) Consulta
JOIN LATERAL (
    SELECT CASE WHEN t.isdefault = 'Y' THEN -1 ELSE t.rate END AS "rate",
           t.isdefault,
           SUM(COALESCE(it.taxamt, 0.00)) AS taxamt
    FROM c_tax t
    LEFT JOIN c_invoicetax it ON t.c_tax_id = it.c_tax_id
	LEFT JOIN c_invoice i ON it.c_invoice_id = i.c_invoice_id
    WHERE t.istaxdeductable = 'Y'
AND i.issotrx = 'N'
AND i.docstatus IN ('CO','VO')
AND i.dateinvoiced::date BETWEEN $P{DateFrom} AND $P{DateTo}
AND (i.posted = $P{Posted} OR $P{Posted} IS NULL)
AND (i.C_doctypetarget_id = $P{C_DocTypeTarget_ID} OR $P{C_DocTypeTarget_ID} IS NULL)
AND (i.ad_org_id = $P{AD_Org_ID} OR $P{AD_Org_ID} IS NULL)
AND (i.c_bpartner_id = $P{C_BPartner_ID} OR $P{C_BPartner_ID} IS NULL)
      AND t.rate IN (SELECT rate FROM tax_used)
	GROUP BY t.rate,t.isdefault
) tx ON TRUE
ORDER BY rate]]>
	</queryString>
