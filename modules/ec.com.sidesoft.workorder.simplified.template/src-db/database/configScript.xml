    <columnDataChange tablename="AD_VAL_RULE" columnname="CODE" pkRow="07D8B925FC8B4383B6849027895E55B5">
      <oldValue><![CDATA[ ad_ref_list.value in ( SELECT rl.value FROM ad_ref_list rl 
                                            WHERE (rl.isActive = 'Y' OR rl.Value = NULL )
                                            and rl.ad_reference_id ='A59EA6E20C0D4F92BB96158C78BFA6FF'
                                            and (case when @docstatus@='EE' then rl.value in ('EP') 
                                                      when @docstatus@='EP' then rl.value in ('TL','EE')
                                                      when @docstatus@='TL' then rl.value in ('ET','EP')
                                                      when @docstatus@='ET'then rl.value in  ('ET','EP','TL','EE') 
                                                 end)
                                            ORDER BY rl.SeqNo
                            )]]></oldValue>
      <newValue><![CDATA[ad_ref_list.value in ( 
	SELECT rl.value FROM ad_ref_list rl 
	WHERE (rl.isActive = 'Y' OR rl.Value = NULL )
	and rl.ad_reference_id ='A59EA6E20C0D4F92BB96158C78BFA6FF'
	and (case when @docstatus@='EE' then rl.value in ('EP','SSWOS_C') 
		when @docstatus@='SSWOS_C' then rl.value in ('EE') 
		when @docstatus@='EP' then rl.value in ('TL','EE') 
		when @docstatus@='TL' then rl.value in ('ET','EP') 
		when @docstatus@='ET'then rl.value in  ('ET','EP','TL','EE') 
	end) 
	ORDER BY rl.SeqNo
) ]]></newValue>
    </columnDataChange>
