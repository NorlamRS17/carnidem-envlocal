<!--A5FAC4C5F4C645A0A56AE20ACECF2FFF-->  <CODE><![CDATA[@SQL=SELECT  CBP.TAXID
FROM AD_ROLE AROLE
JOIN AD_USER_ROLES AUR ON AROLE.AD_ROLE_ID = AUR.AD_ROLE_ID 
JOIN AD_USER AU ON AU.AD_USER_ID = AUR.AD_USER_ID
JOIN C_BPARTNER CBP ON AU.C_BPARTNER_ID = CBP.C_BPARTNER_ID 
WHERE AU.C_BPARTNER_ID  IS NOT NULL
AND AU.AD_USER_ID = @#AD_USER_ID@]]></CODE>
