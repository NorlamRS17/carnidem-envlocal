<!--8205626509AA4DEFA8F2E48A16525F06-->  <WHERECLAUSE><![CDATA[(CASE WHEN COALESCE((SELECT  1 FROM AD_ROLE AROLE
JOIN AD_USER_ROLES AUR ON AROLE.AD_ROLE_ID = AUR.AD_ROLE_ID 
JOIN AD_USER AU ON AU.AD_USER_ID = AUR.AD_USER_ID
        WHERE EM_SSPTDL_TELECOMM_DIALING = 'Y' AND AUR.ISACTIVE='Y'  
        AND AU.AD_USER_ID =  @#AD_USER_ID@  
        AND AROLE.AD_ROLE_ID = @#AD_ROLE_ID@),0) = 1 THEN TRUE ELSE ssptdl_telecomm_dialing.createdby = @#AD_USER_ID@ END)
]]></WHERECLAUSE>
