<!--8205626509AA4DEFA8F2E48A16525F06-->  <HQLWHERECLAUSE><![CDATA[(EXISTS (SELECT 1
            FROM ADRole arole
            JOIN arole.aDUserRolesList aur 
            JOIN aur.userContact au
            WHERE arole.ssptdlTelecommDialing = true
              AND aur.active= true 
              AND au.id = @#AD_USER_ID@ 
              AND arole.id = @#AD_ROLE_ID@) 
    OR e.createdBy.id = @#AD_USER_ID@)]]></HQLWHERECLAUSE>
