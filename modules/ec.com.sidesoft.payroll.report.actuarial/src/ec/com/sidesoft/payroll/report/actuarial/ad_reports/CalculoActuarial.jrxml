<?xml version="1.0" encoding="UTF-8"?>
<jasperReport xmlns="http://jasperreports.sourceforge.net/jasperreports" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://jasperreports.sourceforge.net/jasperreports http://jasperreports.sourceforge.net/xsd/jasperreport.xsd" name="CalculoActuarial" pageWidth="2550" pageHeight="842" whenNoDataType="NoDataSection" columnWidth="2510" leftMargin="20" rightMargin="20" topMargin="20" bottomMargin="20" uuid="4eedbb89-b4f6-4469-9ab6-f642a1688cf7">
	<property name="ireport.scriptlethandling" value="0"/>
	<property name="ireport.encoding" value="UTF-8"/>
	<property name="ireport.zoom" value="1.650000000000002"/>
	<property name="ireport.x" value="361"/>
	<property name="ireport.y" value="0"/>
	<property name="net.sf.jasperreports.export.xls.detect.cell.type" value="true"/>
	<property name="com.jaspersoft.studio.data.sql.SQLQueryDesigner.sash.w1" value="161"/>
	<property name="com.jaspersoft.studio.data.sql.SQLQueryDesigner.sash.w2" value="828"/>
	<property name="net.sf.jasperreports.awt.ignore.missing.font" value="true"/>
	<property name="com.jaspersoft.studio.unit." value="pixel"/>
	<property name="com.jaspersoft.studio.unit.pageHeight" value="pixel"/>
	<property name="com.jaspersoft.studio.unit.pageWidth" value="pixel"/>
	<property name="com.jaspersoft.studio.unit.topMargin" value="pixel"/>
	<property name="com.jaspersoft.studio.unit.bottomMargin" value="pixel"/>
	<property name="com.jaspersoft.studio.unit.leftMargin" value="pixel"/>
	<property name="com.jaspersoft.studio.unit.rightMargin" value="pixel"/>
	<property name="com.jaspersoft.studio.unit.columnWidth" value="pixel"/>
	<property name="com.jaspersoft.studio.unit.columnSpacing" value="pixel"/>
	<property name="com.jaspersoft.studio.report.description" value=""/>
	<import value="org.openbravo.erpCommon.utility.OBDateUtils"/>
	<import value="net.sf.jasperreports.engine.*"/>
	<import value="java.util.*"/>
	<import value="net.sf.jasperreports.engine.data.*"/>
	<import value="org.apache.commons.lang.StringUtils"/>
	<style name="default" fontName="Bitstream Vera Sans" fontSize="10"/>
	<style name="Report_Title" fontName="Bitstream Vera Sans" fontSize="18">
		<box leftPadding="5"/>
	</style>
	<style name="Group_Data_Label" fontName="Bitstream Vera Sans" fontSize="11" isBold="true"/>
	<style name="Report_Subtitle" forecolor="#555555" fontName="Bitstream Vera Sans" fontSize="14">
		<box leftPadding="5"/>
	</style>
	<style name="Total_Field" mode="Opaque" forecolor="#000000" backcolor="#CCCCCC">
		<box leftPadding="5"/>
	</style>
	<style name="Detail_Header" mode="Opaque" forecolor="#FFFFFF" backcolor="#555555">
		<box leftPadding="5">
			<leftPen lineWidth="1.0" lineStyle="Solid" lineColor="#FFFFFF"/>
			<rightPen lineWidth="1.0" lineStyle="Solid" lineColor="#FFFFFF"/>
		</box>
	</style>
	<style name="GroupHeader_DarkGray" mode="Opaque" forecolor="#FFFFFF" backcolor="#555555" fontName="Bitstream Vera Sans" fontSize="14">
		<box leftPadding="5"/>
	</style>
	<style name="GroupHeader_Gray" mode="Opaque" backcolor="#999999"/>
	<style name="Detail_Line">
		<conditionalStyle>
			<conditionExpression><![CDATA[new Boolean($V{REPORT_COUNT}.intValue()%2==1)]]></conditionExpression>
			<style mode="Opaque" backcolor="#CCCCCC"/>
		</conditionalStyle>
	</style>
	<style name="Total_Gray" mode="Opaque" forecolor="#000000" backcolor="#CCCCCC"/>
	<parameter name="AMOUNTFORMAT" class="java.text.DecimalFormat"/>
	<parameter name="AD_Org_ID" class="java.lang.String" isForPrompting="false"/>
	<parameter name="c_year_id" class="java.lang.String" isForPrompting="false"/>
	<parameter name="ad_user_id" class="java.lang.String" isForPrompting="false"/>
	<queryString>
		<![CDATA[SELECT
		case
			when bp.EM_SSPR_Documenttype = 'NI' then 'C'
			when bp.EM_SSPR_Documenttype = 'P' then 'P'
			else ' '
		END AS employee_doctype ,
		bp.EM_SSPR_DocumentNo AS employee_docno,
		(
		select	case when count(*) > 0 then 'A'
			else 'S'
			end
		from SSPR_Contract ctr 
		LEFT join c_bpartner cbp ON cbp.c_bpartner_id = ctr.c_bpartner_id
		where cbp.c_bpartner_id = bp.c_bpartner_id
		AND (Date(ctr.startdate) <= Date(concat(y.year,'-12-31')) AND Date(ctr.enddate) >= Date(concat(y.year,'-12-31')))
		) as employee_status,
		bp.EM_Sspr_Lastname AS last_name,
		bp.EM_Sspr_Firstname AS first_name,
		(SELECT ps.name
		  FROM SSPR_Contract ctr
		   LEFT JOIN SSPR_Contract_Position cp ON ctr.SSPR_Contract_id = cp.SSPR_Contract_id
		   LEFT JOIN Sspr_Position ps ON cp.Sspr_Position_ID = ps.Sspr_Position_ID
		  WHERE ctr.c_bpartner_id = bp.c_bpartner_id
		  AND (date_part('year', cp.startdate) <= CAST (y.year AS DOUBLE PRECISION) AND date_part('year', cp.enddate) >= CAST (y.year AS DOUBLE PRECISION))
		  ORDER BY cp.created desc
		  LIMIT 1) AS contract_pos,
		cs.name AS cost_center,
		(CASE WHEN bp.EM_Sshr_Gender ilike 'masc%' THEN 'M' ELSE 'F' END) AS gender,
		(
		SELECT amount FROM sfpr_evolution_salary sal where sal.SSPR_Contract_id IN
		(SELECT ctr.SSPR_Contract_id
				  FROM SSPR_Contract ctr
				   LEFT JOIN SSPR_Contract_Position cp ON ctr.SSPR_Contract_id = cp.SSPR_Contract_id
				   LEFT JOIN Sspr_Position ps ON cp.Sspr_Position_ID = ps.Sspr_Position_ID
				  WHERE ctr.c_bpartner_id = bp.c_bpartner_id
				  AND (date_part('year', cp.startdate) <= CAST (y.year AS DOUBLE PRECISION) AND date_part('year', cp.enddate) >= CAST (y.year AS DOUBLE PRECISION))
				  ORDER BY cp.created desc
				  LIMIT 1
		)
		AND (date_part('year', sal.startdate) <= CAST (y.year AS DOUBLE PRECISION) AND date_part('year', sal.enddate) >= CAST (y.year AS DOUBLE PRECISION))
		ORDER BY (sal.startdate, sal.enddate, sal.created) desc
		LIMIT 1
		) AS salary,
		(SELECT sum(Coalesce(ptc.amount, 0))
		  FROM SSPR_Payroll_Ticket_Concept ptc
		   JOIN SSPR_Payroll_Ticket pt1 ON pt1.SSPR_Payroll_Ticket_id = ptc.SSPR_Payroll_Ticket_id
		   JOIN SSPR_Payroll pr ON pt1.SSPR_Payroll_id = pr.SSPR_Payroll_id
		   JOIN C_Period p1 ON pr.c_period_id = p1.c_period_id
		 WHERE EXISTS (SELECT 1
					    FROM Sspr_Concept c
					   WHERE c.Sspr_Concept_id = ptc.Sspr_Concept_id
					    AND c.concepttypepayroll = 'SPRAL_CM')
		  AND p1.enddate = (SELECT max(p2.enddate)
							 FROM SSPR_Payroll prll1
							  JOIN C_Period p2 ON prll1.c_period_id = p2.c_period_id
							  JOIN C_Year y2 ON p2.c_year_id = y2.c_year_id
							WHERE p2.c_year_id = y.c_year_id
							 AND prll1.Ispayroll = 'Y'
							 AND prll1.isliquidation = 'N'
							 AND (prll1.ad_org_id= $P{AD_Org_ID} OR ad_isorgincluded(prll1.ad_org_id, $P{AD_Org_ID}, prll1.ad_client_id) <> -1 )
							)
		  AND pr.Ispayroll = 'Y'
		  AND pr.isliquidation = 'N'
		  AND pt1.c_bpartner_id = pt.c_bpartner_id
		  AND (pr.ad_org_id= $P{AD_Org_ID} OR ad_isorgincluded(pr.ad_org_id, $P{AD_Org_ID}, pr.ad_client_id) <> -1 )
		) AS comissions,
		(SELECT sum(Coalesce(ptc.amount, 0))
		  FROM SSPR_Payroll_Ticket_Concept ptc
		   JOIN SSPR_Payroll_Ticket pt1 ON pt1.SSPR_Payroll_Ticket_id = ptc.SSPR_Payroll_Ticket_id
		   JOIN SSPR_Payroll pr ON pt1.SSPR_Payroll_id = pr.SSPR_Payroll_id
		   JOIN C_Period p1 ON pr.c_period_id = p1.c_period_id
		  WHERE EXISTS (SELECT 1
					     FROM Sspr_Concept c
					    WHERE c.Sspr_Concept_id = ptc.Sspr_Concept_id
					    AND c.concepttypepayroll IN ('HO', 'HF', 'HT', 'XT'))
		   AND p1.enddate = (SELECT max(p2.enddate)
							  FROM SSPR_Payroll prll1
							   JOIN C_Period p2 ON prll1.c_period_id = p2.c_period_id
							   JOIN C_Year y2 ON p2.c_year_id = y2.c_year_id
							 WHERE p2.c_year_id = y.c_year_id
							  AND prll1.Ispayroll = 'Y'
							  AND prll1.isliquidation = 'N'
							  AND (prll1.ad_org_id= $P{AD_Org_ID} OR ad_isorgincluded(prll1.ad_org_id, $P{AD_Org_ID}, prll1.ad_client_id) <> -1 )
							)
		   AND pr.Ispayroll = 'Y'
		   AND pr.isliquidation = 'N'
		   AND pt1.c_bpartner_id = pt.c_bpartner_id
		   AND (pr.ad_org_id= $P{AD_Org_ID} OR ad_isorgincluded(pr.ad_org_id, $P{AD_Org_ID}, pr.ad_client_id) <> -1 )
		) AS avg_extrahours,
		(SELECT count(distinct pr1.SSPR_Payroll_id)
		  FROM SSPR_Payroll pr1
		   JOIN C_Period p1 ON pr1.c_period_id = p1.c_period_id
		  WHERE pr1.Ispayroll = 'Y'
		   AND pr1.isliquidation = 'N'
		   AND EXISTS (SELECT 1
					    FROM SSPR_Payroll_Ticket pt1
					   WHERE pt1.SSPR_Payroll_id = pr1.SSPR_Payroll_id
					   AND pt1.c_bpartner_id = bp.c_bpartner_id
					  )
		   AND p1.c_year_id = y.c_year_id
		   AND (pr1.ad_org_id= $P{AD_Org_ID} OR ad_isorgincluded(pr1.ad_org_id, $P{AD_Org_ID}, pr1.ad_client_id) <> -1 )
		)::numeric(10,2) AS worked_months,
		(SELECT sum(Coalesce(ptc.amount, 0))
		  FROM SSPR_Payroll_Ticket_Concept ptc
		   JOIN SSPR_Payroll_Ticket pt1 ON pt1.SSPR_Payroll_Ticket_id = ptc.SSPR_Payroll_Ticket_id
		   JOIN SSPR_Payroll pr ON pt1.SSPR_Payroll_id = pr.SSPR_Payroll_id
		   JOIN C_Period p1 ON pr.c_period_id = p1.c_period_id
		  WHERE EXISTS (SELECT 1
					  	 FROM Sspr_Concept c
					  	WHERE c.Sspr_Concept_id = ptc.Sspr_Concept_id
					     AND c.concepttypepayroll = 'IE')
		   AND p1.enddate = (SELECT max(p2.enddate)
							  FROM SSPR_Payroll prll1
							   JOIN C_Period p2 ON prll1.c_period_id = p2.c_period_id
							   JOIN C_Year y2 ON p2.c_year_id = y2.c_year_id
							  WHERE p2.c_year_id = y.c_year_id
							   AND prll1.Ispayroll = 'Y'
							   AND prll1.isliquidation = 'N'
							   AND (prll1.ad_org_id= $P{AD_Org_ID} OR ad_isorgincluded(prll1.ad_org_id, $P{AD_Org_ID}, prll1.ad_client_id) <> -1 )
							)
		   AND pr.Ispayroll = 'Y'
		   AND pr.isliquidation = 'N'
		   AND pt1.c_bpartner_id = pt.c_bpartner_id
		   AND (pr.ad_org_id= $P{AD_Org_ID} OR ad_isorgincluded(pr.ad_org_id, $P{AD_Org_ID}, pr.ad_client_id) <> -1 )
		) AS avg_inout,
		bp.EM_SSPR_Birthday AS birthday,
		(SELECT min(ct.startdate)
		  FROM SSPR_Contract ct
		  WHERE ct.c_bpartner_id = bp.c_bpartner_id) AS start_date,
		(SELECT max(ct.enddate)
		  FROM SSPR_Contract ct
		  WHERE ct.c_bpartner_id = bp.c_bpartner_id
		   AND bp.EM_SSPR_Status = 'L'
		   AND ct.statusliquidation = 'Y'
		   AND ct.enddate <= (SELECT max(p2.enddate)
							   FROM SSPR_Payroll prll1
								JOIN C_Period p2 ON prll1.c_period_id = p2.c_period_id
								JOIN C_Year y2 ON p2.c_year_id = y2.c_year_id
							   WHERE p2.c_year_id = y.c_year_id
								AND prll1.Ispayroll = 'Y'
								AND prll1.isliquidation = 'N'
								AND (prll1.ad_org_id= $P{AD_Org_ID} OR ad_isorgincluded(prll1.ad_org_id, $P{AD_Org_ID}, prll1.ad_client_id) <> -1 )
								)) AS end_date,
		(SELECT string_agg(rr.startdate, ',')
		FROM ( SELECT concat(
		(case When (date_part('year', r.startdate) <= CAST (y.year AS DOUBLE PRECISION)) Then 
		to_char(r.startdate)
		else
		''
		end)
		,', ', 
		(case When (date_part('year', r.enddate) <= CAST (y.year AS DOUBLE PRECISION)) Then 
		to_char(r.enddate)
		else
		''
		end)
		)AS startdate
		 FROM sspr_readmissions r
		 WHERE r.c_bpartner_id = bp.c_bpartner_id
		 ORDER BY r.startdate) rr) AS remissions,
		(CASE WHEN CAST(coalesce(y.year, '0') AS integer) - date_part('year',(SELECT min(r.startdate)
																			   FROM sspr_readmissions r
																			   WHERE r.c_bpartner_id = bp.c_bpartner_id)) >= 20
		      THEN (SELECT sum(Coalesce(ptc.amount, 0))
					 FROM SSPR_Payroll_Ticket_Concept ptc
					  JOIN SSPR_Concept cpt ON cpt.SSPR_Concept_id = ptc.SSPR_Concept_id
					  JOIN SSPR_Payroll_Ticket pt1 ON pt1.SSPR_Payroll_Ticket_id = ptc.SSPR_Payroll_Ticket_id
					  JOIN SSPR_Payroll pr ON pt1.SSPR_Payroll_id = pr.SSPR_Payroll_id
					  JOIN C_Period p1 ON pr.c_period_id = p1.c_period_id
					  JOIN C_Year y2 ON p1.c_year_id = y2.c_year_id
					 WHERE EXISTS (SELECT 1
								     FROM Sspr_Concept c
								     WHERE c.Sspr_Concept_id = ptc.Sspr_Concept_id
								      AND c.concepttypepayroll = 'SL')
					   AND y2.year = y.year
					   AND pr.Ispayroll = 'Y'
					   AND (cpt.Isiess = 'Y' AND cpt.Conceptsubtype = 'In')
					   AND pr.isliquidation = 'N'
					   AND pt1.c_bpartner_id = bp.c_bpartner_id
					   AND (pr.ad_org_id= $P{AD_Org_ID} OR ad_isorgincluded(pr.ad_org_id, $P{AD_Org_ID}, pr.ad_client_id) <> -1 )
					)
		  ELSE 0 END) AS level1,
		  (CASE WHEN CAST(coalesce(y.year, '0') AS integer) - date_part('year',(SELECT min(r.startdate)
																			   FROM sspr_readmissions r
																			   WHERE r.c_bpartner_id = bp.c_bpartner_id)) >= 20
			  THEN (SELECT sum(Coalesce(ptc.amount, 0))
					 FROM SSPR_Payroll_Ticket_Concept ptc
					  JOIN SSPR_Concept cpt ON cpt.SSPR_Concept_id = ptc.SSPR_Concept_id
					  JOIN SSPR_Payroll_Ticket pt1 ON pt1.SSPR_Payroll_Ticket_id = ptc.SSPR_Payroll_Ticket_id
					  JOIN SSPR_Payroll pr ON pt1.SSPR_Payroll_id = pr.SSPR_Payroll_id
					  JOIN C_Period p1 ON pr.c_period_id = p1.c_period_id
					  JOIN C_Year y2 ON p1.c_year_id = y2.c_year_id
					  WHERE EXISTS (SELECT 1
								     FROM Sspr_Concept c
								     WHERE c.Sspr_Concept_id = ptc.Sspr_Concept_id
								      AND c.concepttypepayroll = 'SL')
					   AND ((cast(coalesce(y2.year, '0') AS integer)) = (cast(coalesce(y.year, '0') AS integer) -1))  
					   AND pr.Ispayroll = 'Y'
					   AND (cpt.Isiess = 'Y' AND cpt.Conceptsubtype = 'In')
					   AND pr.isliquidation = 'N'
					   AND pt1.c_bpartner_id = bp.c_bpartner_id
					   AND (pr.ad_org_id= $P{AD_Org_ID} OR ad_isorgincluded(pr.ad_org_id, $P{AD_Org_ID}, pr.ad_client_id) <> -1 )
					)
		      ELSE 0 end) AS level2,
		(CASE WHEN CAST(coalesce(y.year, '0') AS integer) - date_part('year',(SELECT min(r.startdate)
																			   FROM sspr_readmissions r
																			   WHERE r.c_bpartner_id = bp.c_bpartner_id)) >= 20
		  	  THEN (SELECT sum(Coalesce(ptc.amount, 0))
					 FROM SSPR_Payroll_Ticket_Concept ptc
					  JOIN SSPR_Concept cpt ON cpt.SSPR_Concept_id = ptc.SSPR_Concept_id
				      JOIN SSPR_Payroll_Ticket pt1 ON pt1.SSPR_Payroll_Ticket_id = ptc.SSPR_Payroll_Ticket_id
				      JOIN SSPR_Payroll pr ON pt1.SSPR_Payroll_id = pr.SSPR_Payroll_id
				      JOIN C_Period p1 ON pr.c_period_id = p1.c_period_id
				 	  JOIN C_Year y2 ON p1.c_year_id = y2.c_year_id
					 WHERE EXISTS (SELECT 1
							  		FROM Sspr_Concept c
							  		WHERE c.Sspr_Concept_id = ptc.Sspr_Concept_id
							  		 AND c.concepttypepayroll = 'SL')
					  AND ((cast(coalesce(y2.year, '0') AS integer)) = (cast(coalesce(y.year, '0') AS integer) -2)) 
					  AND pr.Ispayroll = 'Y'
					  AND (cpt.Isiess = 'Y' AND cpt.Conceptsubtype = 'In')
					  AND pr.isliquidation = 'N'
					  AND pt1.c_bpartner_id = bp.c_bpartner_id
					  AND (pr.ad_org_id= $P{AD_Org_ID} OR ad_isorgincluded(pr.ad_org_id, $P{AD_Org_ID}, pr.ad_client_id) <> -1 )
				  )
		  	  ELSE 0 END) as level3,
		(CASE WHEN CAST(coalesce(y.year, '0') AS integer) - date_part('year',(SELECT min(r.startdate)
																		       FROM sspr_readmissions r
																		  	   WHERE r.c_bpartner_id = bp.c_bpartner_id)) >= 20
		  	  THEN (SELECT sum(Coalesce(ptc.amount, 0))
					 FROM SSPR_Payroll_Ticket_Concept ptc
					  JOIN SSPR_Concept cpt ON cpt.SSPR_Concept_id = ptc.SSPR_Concept_id
					  JOIN SSPR_Payroll_Ticket pt1 ON pt1.SSPR_Payroll_Ticket_id = ptc.SSPR_Payroll_Ticket_id
					  JOIN SSPR_Payroll pr ON pt1.SSPR_Payroll_id = pr.SSPR_Payroll_id
					  JOIN C_Period p1 ON pr.c_period_id = p1.c_period_id
					  JOIN C_Year y2 ON p1.c_year_id = y2.c_year_id
					WHERE EXISTS (SELECT 1
								   FROM Sspr_Concept c
								   WHERE c.Sspr_Concept_id = ptc.Sspr_Concept_id
								    AND c.concepttypepayroll = 'SL')
					 AND ((cast(coalesce(y2.year, '0') AS integer)) = (cast(coalesce(y.year, '0') AS integer) -3)) 
					 AND pr.Ispayroll = 'Y'
					 AND (cpt.Isiess = 'Y' AND cpt.Conceptsubtype = 'In')
					 AND pr.isliquidation = 'N'
					 AND pt1.c_bpartner_id = bp.c_bpartner_id
					 AND (pr.ad_org_id= $P{AD_Org_ID} OR ad_isorgincluded(pr.ad_org_id, $P{AD_Org_ID}, pr.ad_client_id) <> -1 )
					)
		  	  ELSE 0 END) AS level4,
	    (CASE WHEN CAST(coalesce(y.year, '0') AS integer) - date_part('year',(SELECT min(r.startdate)
																			   FROM sspr_readmissions r
																			   WHERE r.c_bpartner_id = bp.c_bpartner_id)) >= 20
		      THEN (SELECT sum(Coalesce(ptc.amount, 0))
					 FROM SSPR_Payroll_Ticket_Concept ptc
					  JOIN SSPR_Concept cpt ON cpt.SSPR_Concept_id = ptc.SSPR_Concept_id
					  JOIN SSPR_Payroll_Ticket pt1 ON pt1.SSPR_Payroll_Ticket_id = ptc.SSPR_Payroll_Ticket_id
					  JOIN SSPR_Payroll pr ON pt1.SSPR_Payroll_id = pr.SSPR_Payroll_id
					  JOIN C_Period p1 ON pr.c_period_id = p1.c_period_id
					  JOIN C_Year y2 ON p1.c_year_id = y2.c_year_id
					 WHERE EXISTS (SELECT 1
							        FROM Sspr_Concept c
							        WHERE c.Sspr_Concept_id = ptc.Sspr_Concept_id
							         AND c.concepttypepayroll = 'SL')
					  AND ((cast(coalesce(y2.year, '0') AS integer)) = (cast(coalesce(y.year, '0') AS integer) -4)) 
					  AND pr.Ispayroll = 'Y'
					  AND (cpt.Isiess = 'Y' AND cpt.Conceptsubtype = 'In')
					  AND pr.isliquidation = 'N'
					  AND pt1.c_bpartner_id = bp.c_bpartner_id
					  AND (pr.ad_org_id= $P{AD_Org_ID} OR ad_isorgincluded(pr.ad_org_id, $P{AD_Org_ID}, pr.ad_client_id) <> -1 )
				)
		  	  ELSE 0 END) AS level5,
 		(select o.name from ad_org o where o.ad_org_id = $P{AD_Org_ID}) AS organization,
 		y.year AS period_year,
 		(SELECT name FROM ad_user WHERE ad_user_id = $P{ad_user_id}) AS user_selected,
 		now() as current_date
 FROM SSPR_Payroll prll
 JOIN C_Period p ON prll.c_period_id = p.c_period_id
 JOIN C_Year y ON p.c_year_id = y.c_year_id
 LEFT JOIN SSPR_Payroll_Ticket pt ON pt.SSPR_Payroll_id = prll.SSPR_Payroll_id
 JOIN c_bpartner bp ON bp.c_bpartner_id = pt.c_bpartner_id
 JOIN c_costcenter cs ON bp.EM_Sspr_Costcenter_ID = cs.C_Costcenter_ID
WHERE (prll.ad_org_id= $P{AD_Org_ID} OR ad_isorgincluded(prll.ad_org_id, $P{AD_Org_ID}, prll.ad_client_id) <> -1 )
 AND prll.Ispayroll = 'Y'
 AND y.c_year_id = $P{c_year_id}
 AND prll.isliquidation = 'N'
GROUP BY bp.EM_SSPR_Documenttype, bp.EM_SSPR_DocumentNo, bp.EM_SSPR_Status, bp.EM_Sspr_Lastname, bp.EM_Sspr_Firstname,
		bp.EM_Sspr_Costcenter_ID, bp.c_bpartner_id, y.year, y.c_year_id, pt.c_bpartner_id, cs.name
ORDER BY bp.EM_Sspr_Lastname]]>
	</queryString>
	<field name="employee_doctype" class="java.lang.String"/>
	<field name="employee_docno" class="java.lang.String"/>
	<field name="employee_status" class="java.lang.String"/>
	<field name="last_name" class="java.lang.String"/>
	<field name="first_name" class="java.lang.String"/>
	<field name="contract_pos" class="java.lang.String"/>
	<field name="cost_center" class="java.lang.String"/>
	<field name="gender" class="java.lang.String"/>
	<field name="salary" class="java.math.BigDecimal"/>
	<field name="comissions" class="java.math.BigDecimal"/>
	<field name="avg_extrahours" class="java.math.BigDecimal"/>
	<field name="worked_months" class="java.math.BigDecimal"/>
