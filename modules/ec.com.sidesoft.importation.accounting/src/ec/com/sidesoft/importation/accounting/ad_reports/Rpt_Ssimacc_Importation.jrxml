						<topPen lineWidth="1.0"/>
						<leftPen lineWidth="1.0"/>
						<bottomPen lineWidth="1.0"/>
						<rightPen lineWidth="1.0"/>
					</box>
					<textFieldExpression><![CDATA[$F{importation}]]></textFieldExpression>
				</textField>
				<textField isBlankWhenNull="true">
					<reportElement x="1008" y="0" width="100" height="20" uuid="7a49c9a1-73a9-4450-8af0-a3e9521df64c"/>
					<box>
						<topPen lineWidth="1.0"/>
						<leftPen lineWidth="1.0"/>
						<bottomPen lineWidth="1.0"/>
						<rightPen lineWidth="1.0"/>
