	<queryString>
		<![CDATA[select
(select ad_org_id from ad_org where   ad_orgtype_id = '1' ) as organizationid,
to_char(now(),'dd/MM/yyyyy HH24:MM') as fecha_imp
,(select name from ad_user where ad_user_id =$P{AD_USER_ID} ) as usuario
from dual]]>
	</queryString>
