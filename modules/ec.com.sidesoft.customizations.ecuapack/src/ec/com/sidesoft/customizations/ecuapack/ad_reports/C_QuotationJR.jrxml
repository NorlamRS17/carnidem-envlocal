	<queryString>
		<![CDATA[SELECT
 org.ad_org_id organizationid,
 org.name organization,
 dtt.showlogo,
 dtt.showcompanydata,
 dtt.headermargin,
 o.c_order_id,
 o.documentno,
 o.dateordered,
 o.validuntil,
 o.em_scmecu_delivery_time,
 o.em_scmecu_warranty_time,
 dt.name doc_type,
 pl.istaxincluded,
 bp.name bp_name,
 bp.taxid bp_taxid,
 bp.EM_EEI_Email,
 bpl.phone,
 sr.name sr_name,
 pm.name pm_name,
 ubp.name ubp_name
FROM c_order o
 JOIN ad_org org ON org.ad_org_id = o.ad_org_id
 JOIN c_doctype dt ON dt.c_doctype_id = o.c_doctypetarget_id
 JOIN c_poc_doctype_template dtt ON dtt.c_doctype_id = dt.c_doctype_id
 JOIN m_pricelist pl ON pl.m_pricelist_id = o.m_pricelist_id
 JOIN c_bpartner bp ON bp.c_bpartner_id = o.c_bpartner_id
 JOIN c_bpartner_location bpl ON bpl.c_bpartner_location_id = o.c_bpartner_location_id
 LEFT JOIN fin_paymentmethod pm ON pm.fin_paymentmethod_id = o.fin_paymentmethod_id
 JOIN ad_user u ON u.ad_user_id = o.createdby
 LEFT JOIN c_bpartner ubp ON ubp.c_bpartner_id = u.c_bpartner_id
 LEFT JOIN ad_user sru ON sru.ad_user_id = o.salesrep_id
 LEFT JOIN c_bpartner sr ON sr.c_bpartner_id = sru.c_bpartner_id
WHERE o.c_order_id = $P{DOCUMENT_ID}]]>
	</queryString>
