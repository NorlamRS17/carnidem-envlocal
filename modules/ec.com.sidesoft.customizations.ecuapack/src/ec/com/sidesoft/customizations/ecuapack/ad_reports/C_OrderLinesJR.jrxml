	<parameter name="C_ORDER_ID" class="java.lang.String">
		<defaultValueExpression><![CDATA["'1000069'"]]></defaultValueExpression>
	</parameter>
	<parameter name="NUMBERFORMAT" class="java.text.DecimalFormat" isForPrompting="false">
		<defaultValueExpression><![CDATA[new DecimalFormat("###,##0.00;-###,##0.00", new DecimalFormatSymbols())]]></defaultValueExpression>
	</parameter>
	<parameter name="LOCALE" class="java.util.Locale" isForPrompting="false"/>
	<parameter name="ISTAXINCLUDED" class="java.lang.String"/>
	<queryString>
		<![CDATA[SELECT
 pr_name,
 pri_actual,
 qtyordered,
 linenetamt,
 discount,
 rate,
 (linenetamt-discount)*tax linetaxamt,
 EM_Sproctm_Ad_Img_Task_ID,
 image,
 description
FROM (
 SELECT
  pr.name pr_name,
  ol.priceactual pri_actual,
  ol.qtyordered,
  ol.priceactual*ol.qtyordered linenetamt,
  CASE WHEN ol.pricelist != ol.priceactual THEN (ol.pricelist-ol.priceactual)*ol.qtyordered ELSE 0 END discount,
  tax.rate,
  tax.rate/100 tax,
  ol.EM_Sproctm_Ad_Img_Task_ID,
  CASE WHEN i.binarydata IS NOT NULL THEN encode(i.binarydata,'base64') ELSE NULL END image,
  coalesce(ol.description,'') description
 FROM c_orderline ol
  JOIN m_product pr ON pr.m_product_id = ol.m_product_id
  JOIN c_tax tax ON tax.c_tax_id = ol.c_tax_id
  LEFT JOIN ad_image i ON i.ad_image_id = ol.EM_Sproctm_Ad_Img_Task_ID
 WHERE ol.c_order_id = $P{C_ORDER_ID}
) tmp]]>
	</queryString>
	<field name="pr_name" class="java.lang.String"/>
	<field name="pri_actual" class="java.math.BigDecimal"/>
	<field name="qtyordered" class="java.math.BigDecimal"/>
	<field name="linenetamt" class="java.math.BigDecimal"/>
	<field name="discount" class="java.math.BigDecimal"/>
	<field name="rate" class="java.math.BigDecimal"/>
	<field name="linetaxamt" class="java.math.BigDecimal"/>
	<field name="em_sproctm_ad_img_task_id" class="java.lang.String"/>
	<field name="image" class="java.lang.String"/>
	<field name="description" class="java.lang.String"/>
	<variable name="SUM_LINENETAMT" class="java.math.BigDecimal" calculation="Sum">
		<variableExpression><![CDATA[$F{linenetamt}]]></variableExpression>
	</variable>
	<variable name="SUM_DISCOUNT" class="java.math.BigDecimal" calculation="Sum">
		<variableExpression><![CDATA[$F{discount}]]></variableExpression>
	</variable>
	<variable name="SUM_LINETAXAMT" class="java.math.BigDecimal" calculation="Sum">
		<variableExpression><![CDATA[$F{linetaxamt}]]></variableExpression>
	</variable>
	<variable name="TOTAL" class="java.math.BigDecimal">
		<variableExpression><![CDATA[$V{SUM_LINENETAMT}.subtract($V{SUM_DISCOUNT}).add($V{SUM_LINETAXAMT})]]></variableExpression>
	</variable>
