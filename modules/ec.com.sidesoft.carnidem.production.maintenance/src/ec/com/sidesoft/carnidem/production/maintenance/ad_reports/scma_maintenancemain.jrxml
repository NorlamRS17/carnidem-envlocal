	<queryString>
		<![CDATA[SELECT
  mmp.ad_org_id AS org_id,
  TO_CHAR(NOW(), 'YYYY-MM-DD HH24:MI:SS') AS fecha_imp,
  mmp.MA_Maint_Part_id as id,
  mms.Scheduleddate AS fecha,
  mms.EM_Scma_Infrastructure AS infraestructura,
  mm.name AS maquina,
  mms.EM_Scma_Area AS area,
  CASE
    WHEN mms.Maintenance_Type = 'P' THEN 'Preventivo'
    WHEN mms.Maintenance_Type = 'C' THEN 'Correctivo'
    WHEN mms.Maintenance_Type = 'U' THEN 'Correctivo (urgente)'
  END AS tipo_mantenimiento,
  mms.EM_Scma_Workbedone AS trabajo_realizar,
  mms.EM_Scma_Usedparts AS repuestos_usados,
  case
    when mms.EM_Scma_Tempsolution='N' then 'NO'
    else 'SI'
    end solucion_temporal,
  case
    when mms.EM_Scma_Definitivesolution='N' then 'NO'
    else 'SI'
    end solucion_definitiva,
  mms.EM_Scma_Changeproposal AS fecha_parcial,
  mms.EM_Scma_Actualchange AS fecha_real,
  case
    when mms.EM_Scma_Acceptarrangement='N' then 'NO'
    else 'SI'
    end acepta_arreglo,
  cb.name AS nombre_acepta,

  case
    when mms.EM_Scma_Cleanorder='N' then 'NO'
    else 'SI'
  end area_check,
  case
    when mms.EM_Scma_Cleandesprod='N' then 'NO'
    else 'SI'
  end limpieza_check,
  case
    when mms.EM_Scma_Pollutant='N' then 'NO'
    else 'SI'
  end contaminante_check,
  mms.EM_Scma_Correct_Area AS observ1,
  mms.EM_Scma_Correct_Clean AS observ2,
  mms.EM_Scma_Correct_Tools AS observ3,
  mms.Observation AS observaciones,
  (
    SELECT string_agg(DISTINCT cb_resp.name, ', ')
    FROM MA_Maint_Worker mmw2
    LEFT JOIN c_bpartner cb_resp ON cb_resp.c_bpartner_id = mmw2.c_bpartner_id
    WHERE mmw2.MA_Maint_Part_id = mmp.MA_Maint_Part_id
  ) AS tecnico
FROM MA_Maint_Part mmp
LEFT JOIN MA_Maint_Scheduled mms ON mms.MA_Maint_Part_id = mmp.MA_Maint_Part_id
LEFT JOIN MA_Machine mm ON mm.MA_Machine_id = mms.MA_Machine_id
LEFT JOIN c_bpartner cb ON cb.c_bpartner_id = mms.EM_Scma_Acceptname
LEFT JOIN MA_Maint_Worker mmw ON mmw.MA_Maint_Part_id = mmp.MA_Maint_Part_id
LEFT JOIN c_bpartner cb_sol ON cb_sol.c_bpartner_id = mmw.EM_Scma_Applicant
LEFT JOIN ma_section ms ON ms.ma_section_id = mmw.EM_Scma_Section_ID
where mmp.MA_Maint_Part_id=$P{DOCUMENT_ID}
GROUP BY
  mmp.ad_org_id, mms.Scheduleddate, mms.EM_Scma_Infrastructure,
  mm.name, mms.EM_Scma_Area, mms.Maintenance_Type,
  mms.EM_Scma_Workbedone, mms.EM_Scma_Usedparts, mms.EM_Scma_Tempsolution,
  mms.EM_Scma_Definitivesolution, mms.EM_Scma_Changeproposal, mms.EM_Scma_Actualchange,
  mms.EM_Scma_Acceptarrangement, cb.name, mms.EM_Scma_Cleanorder,
  mms.EM_Scma_Cleandesprod, mms.EM_Scma_Pollutant, mms.EM_Scma_Correct_Area,
  mms.EM_Scma_Correct_Clean, mms.EM_Scma_Correct_Tools, mms.Observation,
  tecnico,mmp.MA_Maint_Part_id
ORDER BY mms.Scheduleddate;]]>
	</queryString>
