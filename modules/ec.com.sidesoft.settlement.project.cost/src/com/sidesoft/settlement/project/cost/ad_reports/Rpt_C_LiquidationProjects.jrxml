<?xml version="1.0" encoding="UTF-8"?>
<jasperReport xmlns="http://jasperreports.sourceforge.net/jasperreports" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://jasperreports.sourceforge.net/jasperreports http://jasperreports.sourceforge.net/xsd/jasperreport.xsd" name="Rpt_C_LiquidationProjects" pageWidth="807" pageHeight="842" columnWidth="779" leftMargin="14" rightMargin="14" topMargin="14" bottomMargin="14">
	<property name="ireport.zoom" value="1.0"/>
	<property name="ireport.x" value="0"/>
	<property name="ireport.y" value="0"/>
	<parameter name="DateFrom" class="java.lang.String">
		<defaultValueExpression><![CDATA[]]></defaultValueExpression>
	</parameter>
	<parameter name="C_Costcenter_ID" class="java.lang.String">
		<defaultValueExpression><![CDATA[]]></defaultValueExpression>
	</parameter>
	<parameter name="AD_User_ID" class="java.lang.String">
		<defaultValueExpression><![CDATA[]]></defaultValueExpression>
	</parameter>
	<parameter name="DateTo" class="java.lang.String">
		<defaultValueExpression><![CDATA[]]></defaultValueExpression>
	</parameter>
	<queryString>
		<![CDATA[select acctvalue as cuenta,
acctdescription as descripcion,
sum(amtacctdr) as debito,
sum(amtacctcr) as credito,
b.name as proyecto,
c.documentno,
to_char('Usuario: ') || (select coalesce(to_char(cbp.name), to_char(au.name)) from ad_user au left join c_bpartner cbp on cbp.c_bpartner_id = au.c_bpartner_id where au.ad_user_id = $P{AD_User_ID}) AS "usuario",
'Fecha de Impresión:  ' || TO_CHAR(NOW(),'dd/MM/yyyy HH24:MI:SS') as fecha_impresion,
c.ad_org_id as organizationid
from fact_acct a
left join c_costcenter b on a.c_costcenter_id = b.c_costcenter_id
left join sstpc_liquidation_projects c on a.record_id = c.sstpc_liquidation_projects_id
where docbasetype = 'SSTPC_LQ' and
(a.c_costcenter_id = $P{C_Costcenter_ID} or $P{C_Costcenter_ID} is null) and
c.datedoc between $P{DateFrom} and $P{DateTo}
group by b.c_costcenter_id, a.acctvalue, a.acctdescription, a.record_id, c.documentno, c.ad_org_id
order by c.documentno]]>
	</queryString>
	<field name="cuenta" class="java.lang.String"/>
	<field name="descripcion" class="java.lang.String"/>
	<field name="debito" class="java.math.BigDecimal"/>
	<field name="credito" class="java.math.BigDecimal"/>
	<field name="proyecto" class="java.lang.String"/>
	<field name="documentno" class="java.lang.String"/>
	<field name="usuario" class="java.lang.String"/>
	<field name="fecha_impresion" class="java.lang.String"/>
	<field name="organizationid" class="java.lang.String"/>
	<variable name="v_TotalDebe" class="java.math.BigDecimal" calculation="Sum">
		<variableExpression><![CDATA[$F{debito}]]></variableExpression>
	</variable>
	<variable name="v_TotalCredito" class="java.math.BigDecimal" calculation="Sum">
		<variableExpression><![CDATA[$F{credito}]]></variableExpression>
	</variable>
