<!--A2DF3F45F3D0438BA92511EB97907DE2-->  <NAME><![CDATA[SHPAPR_IsEmployee]]></NAME>
<!--A2DF3F45F3D0438BA92511EB97907DE2-->  <TYPE><![CDATA[S]]></TYPE>
<!--A2DF3F45F3D0438BA92511EB97907DE2-->  <CODE><![CDATA[(C_BPARTNER.ISEMPLOYEE = 'Y'  and  C_BPARTNER.C_BPARTNER_ID in (
	SELECT AU.C_BPARTNER_ID 
	FROM AD_ROLE AROLE
	JOIN AD_USER_ROLES AUR ON AROLE.AD_ROLE_ID = AUR.AD_ROLE_ID 
	JOIN AD_USER AU ON AU.AD_USER_ID = AUR.AD_USER_ID
	WHERE AU.C_BPARTNER_ID  IS NOT NULL
	AND AU.AD_USER_ID = @#AD_USER_ID@
	)
 	and (coalesce((select 1 
			 from ad_user u 
			 where u.ad_user_id = @#AD_USER_ID@
			 and u.em_shpapr_adminassis = 'Y'
			), 0) = 0
		 )
)
OR
(C_BPARTNER.ISEMPLOYEE = 'Y'  and  C_BPARTNER.C_BPARTNER_ID in (
	SELECT AU.C_BPARTNER_ID 
	FROM AD_ROLE AROLE
	JOIN AD_USER_ROLES AUR ON AROLE.AD_ROLE_ID = AUR.AD_ROLE_ID 
	JOIN AD_USER AU ON AU.AD_USER_ID = AUR.AD_USER_ID
	WHERE AU.C_BPARTNER_ID  IS NOT NULL
	)
 	and (coalesce((select 1 
			 from ad_user u 
			 where u.ad_user_id = @#AD_USER_ID@
			 and u.em_shpapr_adminassis = 'Y'
			), 0) = 1
		 )
)]]></CODE>
