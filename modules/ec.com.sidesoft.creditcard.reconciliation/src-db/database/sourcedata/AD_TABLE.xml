<!--65C7190151DA4722896331211DD8440A-->  <HQLQUERY><![CDATA[select fat.id
    ,  e.transactionDate 
    , sbt.commercialName
    , pb.name
    , toc.name
    , ct.name
    , fat.organization.name
    , e.lotName
    , e.depositAmount
    , e.referenceNo
From Ssccr_Finacc_Trans_V as e 
    left join e.ssfiBanktransfer as sbt
    left join e.processorBanck as pb
    left join e.typesOfCredit as toc
    left join e.cardsTypes as ct
    left join e.financialAccountTransaction as fat
Where @additional_filters@
and @whereClause@]]></HQLQUERY>
