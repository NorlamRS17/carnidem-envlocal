			</staticText>
			<textField pattern="$#,##0.00">
				<reportElement mode="Opaque" x="527" y="54" width="66" height="20" backcolor="#FFFFFF" uuid="d9be612d-a232-4595-8f56-ef73b3647c70"/>
				<box rightPadding="2">
					<pen lineWidth="0.5"/>
				</box>
				<textElement textAlignment="Right" verticalAlignment="Middle">
