<?xml version="1.0" encoding="UTF-8"?>
<jasperReport xmlns="http://jasperreports.sourceforge.net/jasperreports" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://jasperreports.sourceforge.net/jasperreports http://jasperreports.sourceforge.net/xsd/jasperreport.xsd" name="Rpt_PlanProductionCostVersion" pageWidth="842" pageHeight="595" orientation="Landscape" columnWidth="802" leftMargin="20" rightMargin="20" topMargin="20" bottomMargin="20" uuid="96ce726d-8b9b-4822-8296-2253622c8788">
	<property name="ireport.zoom" value="1.0000000000000095"/>
	<property name="ireport.x" value="0"/>
	<property name="ireport.y" value="0"/>
	<parameter name="DOCUMENT_ID" class="java.lang.String"/>
	<parameter name="Org_ID" class="java.lang.String" isForPrompting="false"/>
	<parameter name="User_ID" class="java.lang.String" isForPrompting="false"/>
	<parameter name="SUBREPORT_DIR" class="java.lang.String" isForPrompting="false">
		<defaultValueExpression><![CDATA["/opt/openbravo/carnidem/modules/ec.com.sidesoft.production/src/ec/com/sidesoft/production/ad_reports/"]]></defaultValueExpression>
	</parameter>
	<queryString>
		<![CDATA[SELECT
            -- Información de la Versión
            v.documentno as version_codigo,
            pp.name as plan_nombre,
            v.ad_org_id as organizationid,

            -- Información de la Secuencia
            seq.seqno as secuencia_num,
            seq.name as secuencia_nombre,
            seq.ma_sequence_id as secuencia_id,

            -- Centro de Costo (nombre desde MA_CostCenter)
            cc.name as centro_costo,

            -- Tiempo Estimado (Estimatedtime de MA_Sequence)
            COALESCE(seq.Estimatedtime, 0) as tiempo_estimado,

            -- MO $/h (desde MA_CostCenter_Version -> MA_CostCenter_Employee -> C_Salary_Category_Cost)
            COALESCE(
                (SELECT SUM(cce.quantity * (
                    SELECT cscc.cost
                    FROM c_salary_category_cost cscc
                    WHERE cscc.c_salary_category_id = cce.c_salary_category_id
                      AND cscc.datefrom <= CURRENT_DATE
                    ORDER BY cscc.datefrom DESC
                    LIMIT 1
                ))
                FROM ma_costcenter_employee cce
                WHERE cce.ma_costcenter_version_id = ccv.ma_costcenter_version_id
                  AND cce.isactive = 'Y'
                ), 0
            ) as costo_mo_hora,

            -- Maquinaria $/h (desde MA_CostCenter_Version -> MA_CostCenter_Machine -> MA_Machine_Cost)
            COALESCE(
                (SELECT SUM(ccm.use * (
                    SELECT mc.cost
                    FROM ma_machine_cost mc
                    WHERE mc.ma_machine_id = ccm.ma_machine_id
                      AND mc.validfrom <= CURRENT_DATE
                      AND mc.isactive = 'Y'
                    ORDER BY mc.validfrom DESC
                    LIMIT 1
                ))
                FROM ma_costcenter_machine ccm
                WHERE ccm.ma_costcenter_version_id = ccv.ma_costcenter_version_id
                  AND ccm.isactive = 'Y'
                ), 0
            ) as costo_maq_hora,

            -- Indirectos $/h (desde MA_CostCenter_Version -> MA_CostCenter_IC -> MA_Indirect_Cost_Value)
            COALESCE(
                (SELECT SUM(
                    (SELECT icv.cost
                    FROM ma_indirect_cost_value icv
                    WHERE icv.ma_indirect_cost_id = ccic.ma_indirect_cost_id
                      AND icv.datefrom <= CURRENT_DATE
                      AND (icv.dateto IS NULL OR icv.dateto >= CURRENT_DATE)
                      AND icv.isactive = 'Y'
                    ORDER BY icv.datefrom DESC
                    LIMIT 1)
                )
                FROM ma_costcenter_ic ccic
                WHERE ccic.ma_costcenter_version_id = ccv.ma_costcenter_version_id
                  AND ccic.isactive = 'Y'
                ), 0
            ) as costo_ind_hora

        FROM ma_processplan_version v
        JOIN ma_processplan pp ON v.ma_processplan_id = pp.ma_processplan_id
        JOIN ma_sequence seq ON seq.ma_processplan_version_id = v.ma_processplan_version_id
        LEFT JOIN ma_process proc ON seq.ma_process_id = proc.ma_process_id
        LEFT JOIN ma_costcenter cc ON proc.ma_costcenter_id = cc.ma_costcenter_id
        LEFT JOIN ma_costcenter_version ccv ON cc.ma_costcenter_id = ccv.ma_costcenter_id AND ccv.isactive = 'Y'

        WHERE v.ma_processplan_version_id = $P{DOCUMENT_ID}
          AND v.isactive = 'Y'
          AND seq.isactive = 'Y'

        ORDER BY seq.seqno]]>
	</queryString>
	<field name="version_codigo" class="java.lang.String"/>
	<field name="plan_nombre" class="java.lang.String"/>
	<field name="organizationid" class="java.lang.String"/>
	<field name="secuencia_num" class="java.math.BigDecimal"/>
	<field name="secuencia_nombre" class="java.lang.String"/>
	<field name="secuencia_id" class="java.lang.String"/>
	<field name="centro_costo" class="java.lang.String"/>
	<field name="tiempo_estimado" class="java.math.BigDecimal"/>
	<field name="costo_mo_hora" class="java.math.BigDecimal"/>
	<field name="costo_maq_hora" class="java.math.BigDecimal"/>
	<field name="costo_ind_hora" class="java.math.BigDecimal"/>
	<variable name="costo_maquinaria" class="java.math.BigDecimal">
		<variableExpression><![CDATA[$F{tiempo_estimado}.multiply($F{costo_maq_hora})]]></variableExpression>
	</variable>
	<variable name="costo_mo" class="java.math.BigDecimal">
		<variableExpression><![CDATA[$F{tiempo_estimado}.multiply($F{costo_mo_hora})]]></variableExpression>
	</variable>
	<variable name="costo_indirectos" class="java.math.BigDecimal">
		<variableExpression><![CDATA[$F{tiempo_estimado}.multiply($F{costo_ind_hora})]]></variableExpression>
	</variable>
	<variable name="total_secuencia" class="java.math.BigDecimal">
		<variableExpression><![CDATA[$V{costo_mo}.add($V{costo_maquinaria}).add($V{costo_indirectos})]]></variableExpression>
	</variable>
	<variable name="sum_costo_mo" class="java.math.BigDecimal" calculation="Sum">
		<variableExpression><![CDATA[$V{costo_mo}]]></variableExpression>
	</variable>
	<variable name="sum_costo_maquinaria" class="java.math.BigDecimal" calculation="Sum">
		<variableExpression><![CDATA[$V{costo_maquinaria}]]></variableExpression>
	</variable>
	<variable name="sum_costo_indirectos" class="java.math.BigDecimal" calculation="Sum">
		<variableExpression><![CDATA[$V{costo_indirectos}]]></variableExpression>
	</variable>
	<variable name="sum_total_secuencia" class="java.math.BigDecimal" calculation="Sum">
		<variableExpression><![CDATA[$V{total_secuencia}]]></variableExpression>
	</variable>
	<variable name="sum_total_productos_p" class="java.math.BigDecimal" calculation="Sum">
		<variableExpression><![CDATA[$V{sum_total_productos_p}]]></variableExpression>
	</variable>
	<variable name="costo_total_produccion" class="java.math.BigDecimal">
		<variableExpression><![CDATA[$V{sum_total_secuencia}.add($V{sum_total_productos_p})]]></variableExpression>
	</variable>
