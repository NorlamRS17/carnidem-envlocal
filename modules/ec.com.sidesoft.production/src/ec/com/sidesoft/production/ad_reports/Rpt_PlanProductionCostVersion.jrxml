	<summary>
		<band height="115" splitType="Stretch">
			<staticText>
				<reportElement mode="Opaque" x="0" y="54" width="527" height="20" backcolor="#FFFFFF" uuid="e77ddae0-8e4f-4110-96fb-e107b3c664c7"/>
