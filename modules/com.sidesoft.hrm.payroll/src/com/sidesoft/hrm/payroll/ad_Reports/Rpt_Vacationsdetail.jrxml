<?xml version="1.0" encoding="UTF-8"?>
<jasperReport xmlns="http://jasperreports.sourceforge.net/jasperreports" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://jasperreports.sourceforge.net/jasperreports http://jasperreports.sourceforge.net/xsd/jasperreport.xsd" name="Rpt_Vacationsdetail" pageWidth="1486" pageHeight="612" orientation="Landscape" columnWidth="1446" leftMargin="20" rightMargin="20" topMargin="20" bottomMargin="20" uuid="b9aecf39-1cdb-40ab-8f4c-28b77d9e0cf8">
	<property name="ireport.zoom" value="1.3310000000000086"/>
	<property name="ireport.x" value="841"/>
