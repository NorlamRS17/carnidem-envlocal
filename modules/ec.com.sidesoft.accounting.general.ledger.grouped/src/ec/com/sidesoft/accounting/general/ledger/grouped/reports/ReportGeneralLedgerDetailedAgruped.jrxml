	<parameter name="DATEFROM" class="java.util.Date"/>
	<parameter name="DATETO" class="java.util.Date"/>
	<parameter name="ACCOUNTFROM" class="java.lang.String"/>
	<parameter name="ACCOUNTTO" class="java.lang.String"/>
	<parameter name="PARTNERID" class="java.lang.String"/>
	<parameter name="AD_USER_ID" class="java.lang.String"/>
	<parameter name="c_costcenter_id" class="java.lang.String"/>
	<parameter name="DATEFORMAT" class="java.text.SimpleDateFormat" isForPrompting="false">
		<defaultValueExpression><![CDATA[new SimpleDateFormat("dd/MM/yyyy")]]></defaultValueExpression>
	</parameter>
	<queryString>
		<![CDATA[WITH
usuario AS (
  SELECT ad_user_id, UPPER(name) AS name
  FROM ad_user
  WHERE ad_user_id = $P{AD_USER_ID}
),
cuenta_d AS (
  SELECT c_elementvalue_id, UPPER(name) AS name, value
  FROM c_elementvalue
  WHERE c_elementvalue_id = $P{ACCOUNTFROM} OR $P{ACCOUNTFROM} IS NULL
  ORDER BY value ASC LIMIT 1
),
cuenta_h AS (
  SELECT c_elementvalue_id, UPPER(name) AS name, value
  FROM c_elementvalue
  WHERE c_elementvalue_id = $P{ACCOUNTTO} OR $P{ACCOUNTTO} IS NULL
  ORDER BY value DESC LIMIT 1
),
doctype_signatures AS (
  SELECT
    dt.name AS doctype_name,
    spd.line,
    UPPER(spd.name) AS sign_name
  FROM c_doctype dt
  LEFT JOIN scsdc_signaturesperdoc spd
         ON dt.c_doctype_id = spd.c_doctype_id
  WHERE dt.name = 'LIBRO MAYOR DETALLADO'
)
SELECT
	COALESCE(fac.cuenta_desde, '') AS cuenta_desde,
  	COALESCE(fac.cuenta_hasta, '') AS cuenta_hasta,
	u.name AS usuario,
	to_char(NOW(), 'DD-MM-YYYY HH24:MI:SS') AS fecha_actual,
	fac.value,
	fac.name,
	fac.dateacct,
	SUM(amtacctdr) AS amtacctdr,
	SUM(amtacctcr) AS amtacctcr,
	(SUM(amtacctdr) - SUM(amtacctcr)) AS total,
	fac.fact_acct_group_id,
	MIN(fac.description) AS description,
	totalacctdr,
	totalacctcr,
	(totalacctdr - totalacctcr) AS totalacctsub,
	0 AS previousdebit,
	0 AS previouscredit,
	0 AS previoustotal,
    0 AS finaldebit,
	0 AS finalcredit,
	0 AS finaltotal,
	TO_CHAR(DATEACCT,'J') AS dateacctnumber,
	fac.ad_org_id,
	fac.nameorg,
	CASE WHEN (SELECT em_sacgld_noshow_client FROM c_elementvalue WHERE c_elementvalue_id = fac.value_id) = 'Y' THEN ''
	ELSE fac.bpname END AS bpname,
	(SELECT sign_name FROM doctype_signatures WHERE line = 10) AS elaborado_por,
  	(SELECT sign_name FROM doctype_signatures WHERE line = 40) AS autorizado_por,
  	(SELECT sign_name FROM doctype_signatures WHERE line = 20) AS revisado_por,
  	(SELECT sign_name FROM doctype_signatures WHERE line = 30) AS aprobado_por,
	fac.trans_documentno,
	fac.trans_description,
	fac.costcenter,
	fac.trans_reference,
	fac.tablename,
	fac.user1,
	fac.user2,
	CASE WHEN TRIM(fac.trans_sequentialno) != '' THEN
		trans_sequentialno
	ELSE trans_documentno END AS transactionno
FROM
(SELECT
	COALESCE(evf.name, '') AS cuenta_desde,
  	COALESCE(evt.name, '') AS cuenta_hasta,
	fac.account_id AS value_id,
	fac.acctvalue AS value,
	fac.acctdescription AS name,
	fac.dateacct,
	fac.amtacctdr,
	fac.amtacctcr,
	fac.fact_acct_group_id,
	fac.description,
	CASE WHEN fac.amtacctdr <> 0 THEN 'Y' ELSE 'N' END AS isdebit,
	fac.ad_org_id,
	UPPER(org.name) AS nameorg,
	COALESCE(ts.totalacctdr, 0) AS totalacctdr,
	COALESCE(ts.totalacctcr,0) AS totalacctcr,
	bp.name AS bpname,
	sacgld_factacct_docn(tn.tablename, fac.record_id,'es_ES') AS trans_documentno,
	sacgld_factacct_des(tn.tablename, fac.record_id,'es_ES') AS trans_description,
	sacgld_factacct_ref(tn.tablename, fac.record_id,'es_ES') AS trans_reference,
	sacgld_factacct_transno(tn.tablename, fac.record_id,'es_ES') AS trans_sequentialno,
	cc.name AS costcenter,
	tn.tablename,
	us1.name AS user1,
	us2.name AS user2
FROM fact_acct fac
	LEFT JOIN ad_org org ON org.ad_org_id = fac.ad_org_id
	LEFT JOIN c_bpartner bp ON bp.c_bpartner_id = fac.c_bpartner_id
	LEFT JOIN ad_table tn ON tn.ad_table_id = fac.ad_table_id
	LEFT JOIN c_costcenter cc ON cc.c_costcenter_id = fac.c_costcenter_id
	LEFT JOIN user1 us1 ON us1.user1_id = fac.user1_id
	LEFT JOIN fin_payment fp2 ON fp2.fin_payment_id = fac.record_id
	LEFT JOIN user2 us2 ON us2.user2_id = fp2.user2_id
	LEFT JOIN cuenta_d evf ON TRUE
	LEFT JOIN cuenta_h evt ON TRUE
	LEFT JOIN (
		SELECT account_id,
        	SUM(amtacctdr) AS totalacctdr,
         	SUM(amtacctcr) AS totalacctcr
  		FROM fact_acct
  		WHERE dateacct < $P{DATEFROM}
  		GROUP BY account_id
	) ts ON ts.account_id = fac.account_id
	LEFT JOIN(
		SELECT account_id, record_id2, SUM(amtacctdr - amtacctcr) AS SUM
		FROM fact_acct f1
		WHERE 5 = 5
			GROUP BY account_id, record_id2
	) f2 ON fac.account_id = f2.account_id AND fac.record_id2 = f2.record_id2
WHERE 3 = 3
AND dateacct >= $P{DATEFROM} AND dateacct <= $P{DATETO}
AND fac.account_id IN (
	SELECT c_elementvalue_id
  	FROM c_elementvalue
	WHERE (value >= (SELECT value FROM cuenta_d))
    AND (value <= (SELECT value FROM cuenta_h))
)
AND (fac.c_bpartner_id = $P{PARTNERID} OR $P{PARTNERID} IS NULL)
AND (cc.c_costcenter_id = $P{c_costcenter_id} OR $P{c_costcenter_id} IS NULL)
) fac
LEFT JOIN cuenta_d evf ON TRUE
LEFT JOIN cuenta_h evt ON TRUE
LEFT JOIN usuario u ON TRUE
WHERE 6 = 6
GROUP BY u.name,fac.cuenta_desde,fac.cuenta_hasta,fac.costcenter, fac.value, fac.name, fac.value_id, fac.dateacct, fac.fact_acct_group_id, fac.isdebit,
fac.ad_org_id, fac.nameorg, fac.totalacctdr, fac.totalacctcr, fac.trans_reference, fac.trans_documentno,
fac.trans_description, fac.tablename, fac.user1, fac.user2, fac.trans_sequentialno,
CASE WHEN (SELECT em_sacgld_noshow_client FROM c_elementvalue WHERE c_elementvalue_id = fac.value_id) = 'Y' THEN ''
ELSE fac.bpname END
HAVING SUM(fac.amtacctdr) - SUM(fac.amtacctcr) <> 0
ORDER BY fac.value, fac.name, fac.value_id, fac.dateacct, fac.fact_acct_group_id, fac.isdebit]]>
	</queryString>
