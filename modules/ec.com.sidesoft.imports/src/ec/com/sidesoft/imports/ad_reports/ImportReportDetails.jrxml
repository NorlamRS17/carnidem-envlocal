<?xml version="1.0" encoding="UTF-8"?>
<jasperReport xmlns="http://jasperreports.sourceforge.net/jasperreports" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://jasperreports.sourceforge.net/jasperreports http://jasperreports.sourceforge.net/xsd/jasperreport.xsd" name="ImportReport" pageWidth="968" pageHeight="1067" columnWidth="968" leftMargin="0" rightMargin="0" topMargin="0" bottomMargin="0" uuid="1da5dde7-aca0-4fe0-83fc-d21862e7a8f3">
	<property name="ireport.zoom" value="1.2100000000000228"/>
	<property name="ireport.x" value="0"/>
	<property name="ireport.y" value="0"/>
	<parameter name="ad_user" class="java.lang.String">
		<defaultValueExpression><![CDATA[]]></defaultValueExpression>
	</parameter>
	<parameter name="documentno" class="java.lang.String"/>
	<queryString>
		<![CDATA[SELECT
INVL.transactiondate AS "fecha",
CBP.name AS "proovedor",
INVL.documenttype AS "tipodocumento",
TRIM(REGEXP_REPLACE(TRIM(INVL.documentnumber),TRIM(INV.documentno),'','g')) AS "facturacompra",
(CASE WHEN ADCS.name IS NULL THEN '' ELSE ADCS.name END) AS "costoadicional",
CASE
    WHEN INVL.amountnet = olq.valorlinea THEN INVL.amountnet
    ELSE olq.valorlinea
END AS "valor",
olq.name AS "concepto",
INVL.poreference as "nofactura"
FROM c_order INV
LEFT JOIN ssip_costimport INVL ON INVL.c_order_id = INV.c_order_id
LEFT JOIN ssip_additionalcosts ADCS ON ADCS.ssip_additionalcosts_id = INVL.ssip_additionalcosts_id
LEFT JOIN c_invoice FCP ON FCP.documentno = TRIM(REGEXP_REPLACE(TRIM(INVL.documentnumber),TRIM(INV.documentno),'','g'))
LEFT JOIN (
	SELECT ci.documentno, mp.name as name,cil.em_ssip_campaign_id as import, cil.linenetamt as valorlinea
	FROM c_invoice ci
	LEFT JOIN c_invoiceline cil ON cil.c_invoice_id = ci.c_invoice_id
	LEFT JOIN m_product mp ON mp.m_product_id = cil.m_product_id
	AND cil.em_ssip_campaign_id IS NOT NULL
) olq ON olq.documentno = FCP.documentno
LEFT JOIN c_bpartner CBP ON FCP.c_bpartner_id = CBP.c_bpartner_id
LEFT JOIN c_campaign cca ON cca.c_campaign_id = INV.c_campaign_id
WHERE INV.em_ssip_isimports = 'Y'
AND FCP.issotrx = 'N'
AND INV.documentno = $P{documentno}
AND olq.import IS NOT NULL
AND olq.import = INV.c_campaign_id

UNION

SELECT
INVL.transactiondate AS "fecha",
'' AS "proovedor",
INVL.documenttype AS "tipodocumento",
INVL.documentnumber AS "facturacompra",
(CASE WHEN ADCS.name IS NULL THEN '' ELSE ADCS.name END) AS "costoadicional",
INVL.amountnet::numeric AS "valor",
GLJL.description AS "concepto",
'' as "nofactura"
FROM c_order INV
LEFT JOIN ssip_costimport INVL ON INVL.c_order_id = INV.c_order_id
LEFT JOIN ssip_additionalcosts ADCS ON ADCS.ssip_additionalcosts_id = INVL.ssip_additionalcosts_id
INNER JOIN gl_journalbatch FCP ON FCP.documentno = INVL.documentnumber
LEFT JOIN gl_journal GLJ ON FCP.gl_journalbatch_ID = GLJ.gl_journalbatch_id
LEFT JOIN gl_journalline GLJL ON GLJ.GL_Journal_ID = GLJL.gl_journal_id
LEFT JOIN c_campaign cca ON cca.c_campaign_id = INV.c_campaign_id
WHERE INV.em_ssip_isimports = 'Y'
AND INV.documentno = $P{documentno}
ORDER BY fecha ASC]]>
	</queryString>
	<field name="fecha" class="java.sql.Timestamp"/>
	<field name="proovedor" class="java.lang.String"/>
	<field name="tipodocumento" class="java.lang.String"/>
	<field name="facturacompra" class="java.lang.String"/>
	<field name="costoadicional" class="java.lang.String"/>
	<field name="valor" class="java.math.BigDecimal"/>
	<field name="concepto" class="java.lang.String"/>
	<field name="nofactura" class="java.lang.String"/>
	<variable name="SUM_TOTAL" class="java.math.BigDecimal" calculation="Sum">
		<variableExpression><![CDATA[$F{valor}]]></variableExpression>
	</variable>
