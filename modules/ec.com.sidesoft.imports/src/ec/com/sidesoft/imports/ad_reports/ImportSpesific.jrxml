<?xml version="1.0" encoding="UTF-8"?>
<jasperReport xmlns="http://jasperreports.sourceforge.net/jasperreports" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://jasperreports.sourceforge.net/jasperreports http://jasperreports.sourceforge.net/xsd/jasperreport.xsd" name="ImportSpesific" pageWidth="595" pageHeight="842" columnWidth="555" leftMargin="20" rightMargin="20" topMargin="20" bottomMargin="20">
	<property name="ireport.zoom" value="1.3310000000000006"/>
	<property name="ireport.x" value="0"/>
	<property name="ireport.y" value="0"/>
	<parameter name="BASE_WEB" class="java.lang.String"/>
	<parameter name="DOCUMENT_ID" class="java.lang.String"/>
	<parameter name="SUBREPORT_DIR" class="java.lang.String" isForPrompting="false">
		<defaultValueExpression><![CDATA[$P{BASE_WEB}+"/ec/com/sidesoft/imports/ad_reports/"]]></defaultValueExpression>
	</parameter>
	<queryString>
		<![CDATA[Select ord.documentno,cbp.name, pt1.name as pllegada, pt2.name as psalida,pdt.name as prodcut, pdt.value as prodcod, ordl.qtyordered as qtyordered, ordl.em_ssip_costorigin as priceactual, ordl.em_ssip_realcost as realcost

from c_order ord

left join c_bpartner cbp on  ord.c_bpartner_id  = cbp.c_bpartner_id

left join ssip_importdata dip on dip.c_order_id = ord.c_order_id

left join ssip_porttype pt1 on pt1.ssip_porttype_id=dip.portarrival

left join ssip_porttype pt2 on pt2.ssip_porttype_id=dip.outputport

left join c_orderline  ordl on ordl.c_order_id=ord.c_order_id

left join m_product pdt on pdt.m_product_id=ordl.m_product_id

where ord.c_order_id=$P{DOCUMENT_ID}]]>
	</queryString>
	<field name="documentno" class="java.lang.String"/>
	<field name="name" class="java.lang.String"/>
	<field name="pllegada" class="java.lang.String"/>
	<field name="psalida" class="java.lang.String"/>
	<field name="prodcut" class="java.lang.String"/>
	<field name="prodcod" class="java.lang.String"/>
	<field name="qtyordered" class="java.math.BigDecimal"/>
	<field name="priceactual" class="java.math.BigDecimal"/>
	<field name="realcost" class="java.math.BigDecimal"/>
	<variable name="Suma" class="java.lang.String" calculation="Sum"/>
	<variable name="FOB" class="java.math.BigDecimal">
		<variableExpression><![CDATA[$F{qtyordered}.multiply($F{priceactual})]]></variableExpression>
	</variable>
	<variable name="CIF" class="java.math.BigDecimal">
		<variableExpression><![CDATA[$F{qtyordered}.multiply($F{realcost} )]]></variableExpression>
	</variable>
	<variable name="DIF" class="java.math.BigDecimal"/>
	<variable name="SFOB" class="java.math.BigDecimal" calculation="Sum">
		<variableExpression><![CDATA[$V{FOB}]]></variableExpression>
	</variable>
	<variable name="SCIF" class="java.math.BigDecimal" calculation="Sum">
		<variableExpression><![CDATA[$F{qtyordered}.multiply($F{realcost} )]]></variableExpression>
	</variable>
	<variable name="SDIF" class="java.math.BigDecimal" calculation="Sum">
		<variableExpression><![CDATA[$F{qtyordered}.multiply( $F{realcost} ).subtract( $F{qtyordered}.multiply( $F{priceactual}) )]]></variableExpression>
	</variable>
