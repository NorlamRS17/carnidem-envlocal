<?xml version="1.0" encoding="UTF-8"?>
<jasperReport xmlns="http://jasperreports.sourceforge.net/jasperreports" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://jasperreports.sourceforge.net/jasperreports http://jasperreports.sourceforge.net/xsd/jasperreport.xsd" name="Rpt_SafetyQualityLabel" pageWidth="108" pageHeight="270" columnWidth="108" leftMargin="0" rightMargin="0" topMargin="0" bottomMargin="0" uuid="c2d9e88f-a359-5fd7-a95b-5771299b0612">
	<property name="ireport.zoom" value="2.0"/>
	<property name="net.sf.jasperreports.print.keep.full.text" value="true"/>
	<property name="ireport.x" value="0"/>
	<property name="ireport.y" value="112"/>
	<parameter name="sscgr_inoutsc_id" class="java.lang.String">
		<defaultValueExpression><![CDATA[""]]></defaultValueExpression>
	</parameter>
	<parameter name="sscgr_productsc_id" class="java.lang.String">
		<defaultValueExpression><![CDATA[]]></defaultValueExpression>
	</parameter>
	<parameter name="sscgr_ticketsc" class="java.lang.String">
		<defaultValueExpression><![CDATA["1"]]></defaultValueExpression>
	</parameter>
	<parameter name="sscgr_qualitycontroltype" class="java.lang.String">
		<defaultValueExpression><![CDATA[]]></defaultValueExpression>
	</parameter>
	<parameter name="sscgr_inoutsc_id_safe" class="java.lang.String">
		<defaultValueExpression><![CDATA[$P{sscgr_inoutsc_id} != null ? $P{sscgr_inoutsc_id}.toString().split(";")[0].trim() : ""]]></defaultValueExpression>
	</parameter>
	<parameter name="sscgr_productsc_id_safe" class="java.lang.String">
		<defaultValueExpression><![CDATA[$P{sscgr_productsc_id} != null ? $P{sscgr_productsc_id}.toString().split(";")[0].trim() : ""]]></defaultValueExpression>
	</parameter>
	<parameter name="sscgr_qualitycontroltype_safe" class="java.lang.String">
		<defaultValueExpression><![CDATA[$P{sscgr_qualitycontroltype} != null ? $P{sscgr_qualitycontroltype}.toString().split(";")[0].trim() : ""]]></defaultValueExpression>
	</parameter>
	<parameter name="sscgr_ticketsc_safe" class="java.lang.String">
		<defaultValueExpression><![CDATA[($P{sscgr_ticketsc} != null && $P{sscgr_ticketsc}.toString().trim().length() > 0) ? $P{sscgr_ticketsc}.toString().split(";")[0].trim() : "1"]]></defaultValueExpression>
	</parameter>
	<queryString>
		<![CDATA[SELECT data.ad_org_id, data.producto, data.cantidad, data.codigo_compra,
  data.fecha_recepcion, data.fecha_elaboracion, data.fecha_caducidad,
  COALESCE(data.titulo_estado, '') AS titulo_estado
FROM (
  SELECT
    io.AD_Org_ID AS ad_org_id,
    mp.name AS producto,
    TRIM(COALESCE(iol.movementqty::text, '') || ' ' || COALESCE(uom.name, '')) AS cantidad,
    COALESCE(asi.description, '') AS codigo_compra,
    to_char(io.movementdate, 'DD/MM/YYYY') AS fecha_recepcion,
    to_char(io.movementdate, 'DD/MM/YYYY') AS fecha_elaboracion,
    CASE
      WHEN mas.isguaranteedate = 'Y' AND mas.guaranteedays IS NOT NULL THEN to_char(io.movementdate + COALESCE(mas.guaranteedays, 0), 'DD/MM/YYYY')
      ELSE NULL
    END AS fecha_caducidad,
    (SELECT cps.name FROM crprqy_params_status cps
     WHERE cps.crprqy_params_status_id = mms.em_crprod_status_id
     AND cps.isactive = 'Y'
     AND mms.em_crprod_status_id IS NOT NULL
     LIMIT 1) AS titulo_estado
  FROM M_InOut io
  JOIN M_InOutLine iol ON iol.M_InOut_ID = io.M_InOut_ID AND iol.movementqty <> 0
  JOIN M_Product mp ON mp.M_Product_ID = iol.M_Product_ID
  LEFT JOIN M_AttributeSetInstance asi ON asi.M_AttributeSetInstance_ID = iol.M_AttributeSetInstance_ID
  LEFT JOIN M_AttributeSet mas ON mas.M_AttributeSet_ID = mp.M_AttributeSet_ID
  LEFT JOIN C_UOM uom ON uom.C_UOM_ID = iol.C_UOM_ID
  LEFT JOIN (
    SELECT DISTINCT ON (em_spquly_inout_id) em_spquly_inout_id, em_crprod_status_id
    FROM ma_measure_shift
    WHERE em_spquly_inout_id IS NOT NULL
      AND em_ssfdc_status = 'CP'
    ORDER BY em_spquly_inout_id, measuredate DESC NULLS LAST
  ) mms ON mms.em_spquly_inout_id = io.M_InOut_ID
  WHERE COALESCE(TRIM($P{sscgr_inoutsc_id_safe}), '') <> ''
    AND io.M_InOut_ID::text = TRIM($P{sscgr_inoutsc_id_safe})
    AND (COALESCE(TRIM($P{sscgr_productsc_id_safe}), '') = '' OR iol.M_Product_ID::text = TRIM($P{sscgr_productsc_id_safe}))
) data
CROSS JOIN generate_series(1, (
  SELECT CASE
    WHEN COALESCE(TRIM(COALESCE($P{sscgr_ticketsc_safe}, $P{sscgr_ticketsc}, '1')), '') = '' THEN 1
    ELSE GREATEST(1, CAST(TRIM(COALESCE($P{sscgr_ticketsc_safe}, $P{sscgr_ticketsc}, '1')) AS INTEGER))
  END
)) AS s(num)
ORDER BY data.producto, s.num]]>
	</queryString>
