		<defaultValueExpression><![CDATA[]]></defaultValueExpression>
	</parameter>
	<parameter name="lote" class="java.lang.String"/>
	<parameter name="qtyact" class="java.math.BigDecimal" isForPrompting="false"/>
	<parameter name="attributesetinstance_id" class="java.lang.String"/>
	<parameter name="locator_id" class="java.lang.String"/>
	<queryString>
		<![CDATA[SELECT
  mt.M_AttributeSetInstance_ID,
  ROUND((ABS(SUM(mt.MovementQty))/COUNT(mt.MovementQty)),2) AS test
FROM
  m_transaction mt
JOIN
  m_attributesetinstance mta ON mta.M_AttributeSetInstance_ID = mt.M_AttributeSetInstance_ID
WHERE
  mt.movementtype = 'C-'
  AND (
    mt.movementdate <= NOW()
    OR mt.movementdate >= NOW() - INTERVAL '60 days'
  )
  AND (mta.m_attributesetinstance_id = $P{attributesetinstance_id} OR $P{attributesetinstance_id} IS NULL)
  AND (mt.m_product_id = $P{M_Product_ID} OR $P{M_Product_ID} IS NULL)
  AND (mt.m_locator_id = $P{locator_id} OR $P{locator_id} IS NULL)
GROUP BY
  mt.M_AttributeSetInstance_ID
ORDER BY
  mt.M_AttributeSetInstance_ID;]]>
	</queryString>
	<field name="m_attributesetinstance_id" class="java.lang.String"/>
	<field name="test" class="java.math.BigDecimal"/>
	<variable name="REPORT_PAGE" class="java.lang.Integer" resetType="None" incrementType="Page">
		<variableExpression><![CDATA[$V{PAGE_NUMBER}]]></variableExpression>
	</variable>
	<variable name="promedio" class="java.math.BigDecimal" calculation="Average">
		<variableExpression><![CDATA[$F{test}]]></variableExpression>
	</variable>
	<variable name="division" class="java.math.BigDecimal">
		<variableExpression><![CDATA[]]></variableExpression>
	</variable>
