	<property name="ireport.y" value="0"/>
	<property name="net.sf.jasperreports.export.xls.detect.cell.type" value="true"/>
	<style name="colorimetria">
		<conditionalStyle>
			<conditionExpression><![CDATA[$F{userful_life} >= 0 && $F{userful_life} <= 19]]></conditionExpression>
			<style mode="Opaque" backcolor="#E74C3C"/>
		</conditionalStyle>
		<conditionalStyle>
			<conditionExpression><![CDATA[$F{userful_life} >= 20 && $F{userful_life} <= 50]]></conditionExpression>
			<style mode="Opaque" backcolor="#F39C12"/>
		</conditionalStyle>
		<conditionalStyle>
			<conditionExpression><![CDATA[$F{userful_life} >= 51 && $F{userful_life} <= 70]]></conditionExpression>
			<style mode="Opaque" backcolor="#F1C40F"/>
		</conditionalStyle>
		<conditionalStyle>
			<conditionExpression><![CDATA[$F{userful_life} >= 71]]></conditionExpression>
			<style mode="Opaque" backcolor="#2ECC71"/>
		</conditionalStyle>
	</style>
