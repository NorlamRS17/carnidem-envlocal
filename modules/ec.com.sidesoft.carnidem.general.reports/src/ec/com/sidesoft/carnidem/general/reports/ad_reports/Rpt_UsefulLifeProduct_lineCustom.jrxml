	</parameter>
	<parameter name="colorimetry_condition" class="java.lang.String" isForPrompting="false">
		<parameterDescription><![CDATA[]]></parameterDescription>
		<defaultValueExpression><![CDATA[$P{colorimetry} != null ?
($P{colorimetry}.equals("lt") ? "x.userful_life between 20 and 50":
 $P{colorimetry}.equals("rw") ?"x.userful_life between 51 and 70" :
 $P{colorimetry}.equals("apt") ?"x.userful_life between 71 and 100" :
 $P{colorimetry}.equals("lst") ?"x.userful_life between 0 and 19":"1=1" ):"1=1"]]></defaultValueExpression>
	</parameter>
	<parameter name="M_Warehouse_ID" class="java.lang.String">
		<defaultValueExpression><![CDATA[]]></defaultValueExpression>
	</parameter>
