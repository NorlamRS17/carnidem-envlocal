<?xml version="1.0" encoding="UTF-8"?>
<jasperReport xmlns="http://jasperreports.sourceforge.net/jasperreports" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://jasperreports.sourceforge.net/jasperreports http://jasperreports.sourceforge.net/xsd/jasperreport.xsd" name="ESTADO CXC - DETALLADO" pageWidth="2400" pageHeight="595" orientation="Landscape" whenNoDataType="BlankPage" columnWidth="2340" leftMargin="30" rightMargin="30" topMargin="20" bottomMargin="20" uuid="8bbb3f3d-db6c-4249-9a2d-11676a24efe3">
	<property name="ireport.zoom" value="1.0"/>
	<property name="ireport.x" value="0"/>
	<property name="ireport.y" value="0"/>
	<property name="ireport.scriptlethandling" value="0"/>
	<property name="ireport.encoding" value="UTF-8"/>
	<property name="net.sf.jasperreports.export.xls.detect.cell.type" value="true"/>
	<property name="net.sf.jasperreports.export.xls.sheet.names.all" value="ESTADO CXC - DETALLADO"/>
	<import value="net.sf.jasperreports.engine.*"/>
	<import value="org.openbravo.dal.core.OBContext"/>
	<import value="java.util.*"/>
	<import value="net.sf.jasperreports.engine.data.*"/>
	<parameter name="NUMBERFORMAT" class="java.text.DecimalFormat" isForPrompting="false">
		<defaultValueExpression><![CDATA[new DecimalFormat("###,##0.00;-###,##0.00", new DecimalFormatSymbols())]]></defaultValueExpression>
	</parameter>
	<parameter name="NUMBERDECIMAL" class="java.lang.Integer" isForPrompting="false">
		<defaultValueExpression><![CDATA[2]]></defaultValueExpression>
	</parameter>
	<parameter name="Dateto" class="java.util.Date"/>
	<parameter name="Docstatus" class="java.lang.String"/>
	<parameter name="C_BPartner_ID" class="java.lang.String"/>
	<parameter name="AD_USER_ID" class="java.lang.String">
		<defaultValueExpression><![CDATA[]]></defaultValueExpression>
	</parameter>
	<parameter name="Ad_Org_ID" class="java.lang.String" isForPrompting="false">
		<defaultValueExpression><![CDATA[]]></defaultValueExpression>
	</parameter>
	<parameter name="User_ID" class="java.lang.String" isForPrompting="false">
		<defaultValueExpression><![CDATA[OBContext.getOBContext().getUser().getId()]]></defaultValueExpression>
	</parameter>
	<parameter name="UserName" class="java.lang.String" isForPrompting="false">
		<defaultValueExpression><![CDATA[OBContext.getOBContext().getUser().getUsername()]]></defaultValueExpression>
	</parameter>
	<parameter name="advanced" class="java.lang.String"/>
	<parameter name="consolidated" class="java.lang.String"/>
	<parameter name="Org_ID" class="java.lang.String" isForPrompting="false">
		<defaultValueExpression><![CDATA[OBContext.getOBContext().getCurrentOrganization().getId()]]></defaultValueExpression>
	</parameter>
	<parameter name="format_collection" class="java.lang.String"/>
	<queryString>
		<![CDATA[select
(select name from ad_org where ad_org_id = organization) AS organizationame,
to_char($P{Dateto}::date,'dd/MM/yyyy') as fhasta
,TO_CHAR((select max(duedate)::date from fin_payment_schedule where c_invoice_id=xxx.c_invoice_id),'dd/MM/yyyy') as fecha_venc
,(select description from c_invoice ci where ci.c_invoice_id=xxx.c_invoice_id ) as descrp_invoice
,"tercero" as "tercero",
identificador as "identificador",
"factura" as "factura",
coalesce((
select to_char(inv.dateinvoiced::date,'dd/MM/yyyy')
from c_invoice  inv
where  inv.c_invoice_id= xxx.c_invoice_id
),(
select to_char(fin.Paymentdate::date,'dd/MM/yyyy')
from FIN_Payment  fin
inner join c_bpartner bp on bp.c_bpartner_id = fin.c_bpartner_id
where  fin.documentno  =xxx.factura
and fin.ad_org_id = xxx.organization
and bp.name =xxx.tercero
and
(select count(*)
from FIN_Payment  fin
inner join c_bpartner bp on bp.c_bpartner_id = fin.c_bpartner_id
where  fin.documentno  =xxx.factura
and fin.ad_org_id = xxx.organization
and bp.name =xxx.tercero
)<=1
)
) as "documentdate",
sum("GrandTotalConvert") as "valor"
, TO_CHAR(now(),'dd/MM/yyyy HH24:MI:SS') "fecha_impresion"
,"organization"  as "organization"
, (select name from c_doctype where c_doctype_id = (
select c_doctype_id from c_invoice ci where ci.c_invoice_id=xxx.c_invoice_id)
)as "tipo_doc"
,(select grandtotal from c_invoice ci where ci.c_invoice_id=xxx.c_invoice_id ) as "amountinvoice"
,(select totalpaid from c_invoice ci where ci.c_invoice_id=xxx.c_invoice_id ) as "amountreceivable"
,$P{Dateto}::date - (select max(duedate)::date from fin_payment_schedule where c_invoice_id=xxx.c_invoice_id) as dueday
, direccion ,city, telf1 ,telf2,email, name_c , email_c, telf_c, telf_alt_c, cargo_c
from
(
SELECT
    arp.ad_org_id                      AS "organization",
    arp.doctype                        AS "tipo_doc",
    arp.bpartner_name                  AS "tercero",
    bp.taxid                           AS "identificador",

    SPLIT_PART(arp.invoice,'-',1)
    || SPLIT_PART(arp.invoice,'-',2)
    || LPAD(
         SPLIT_PART(arp.invoice,'-',3),
         15
         - LENGTH(SPLIT_PART(arp.invoice,'-',1))
         - LENGTH(SPLIT_PART(arp.invoice,'-',2)),
         '0'
       )                               AS "factura",

    arp.applied                        AS "aplicado",
    arp.documentdate                   AS "fecha_doc",
    arp.poreference                    AS "referencia_fac",
    arp.duedate                        AS "fecha_vencimiento",
    arp.grandtotal                     AS "Valor",
    arp.dateacct                       AS "dateacct",
    arp.grandtotal                     AS "GrandTotalConvert",
    arp.doctype                        AS "doctype",
    arp.costcenter                     AS "costcenter",

    arp.c_invoice_id,
    arp.grandtotal                     AS "amountinvoice",
    0.00                               AS "amountreceivable",

    loc.address1                       AS "direccion",
    loc.city                           AS "city",
    bpl.phone                          AS "telf1",
    bpl.phone2                         AS "telf2",
    bp.em_eei_email                    AS "email",

    (us.firstname || ' ' || us.lastname) AS "name_c",
    us.email                           AS "email_c",
    us.phone                           AS "telf_c",
    us.phone2                          AS "telf_alt_c",
    us.title                           AS "cargo_c"

FROM (
    SELECT 'FC'::text AS doc_code,
    to_char(''::text) AS exclusiveid,
    'Factura Cliente'::text AS doc_type,
    bp.name AS bpartner_name,
    i.documentno AS invoice,
    i.documentno AS applied,
    i.dateinvoiced AS documentdate,
    i.dateacct,
    i.poreference,
    to_char(i.description) AS description,
    psiv.duedate,
        CASE
            WHEN dt.isreversal = 'N'::bpchar THEN psiv.expected
            ELSE abs(psiv.expected) * '-1'::integer::numeric
        END AS grandtotal,
        CASE
            WHEN dt.isreversal = 'N'::bpchar THEN c_currency_convert(i.grandtotal, i.c_currency_id, '100'::character varying, i.dateinvoiced, NULL::character varying, i.ad_client_id, i.ad_org_id)
            ELSE c_currency_convert(i.grandtotal, i.c_currency_id, '100'::character varying, i.dateinvoiced, NULL::character varying, i.ad_client_id, i.ad_org_id) * '-1'::integer::numeric
        END AS grandtotalconverted,
    dt.name AS doctype,
    cc.name AS costcenter,
    cc.c_costcenter_id,
    i.issotrx AS isclient,
    i.posted,
    i.c_bpartner_id,
    NULL::text AS fin_payment_id,
    i.c_currency_id,
    i.ad_client_id,
    i.ad_org_id,
    i.c_invoice_id,
    to_char(''::text) AS em_sswh_withholdingref,
    to_number(0) AS em_sswh_totalwithholdingincome,
    to_number(0) AS em_sswh_totalwithholdingvat
   FROM c_invoice i
     LEFT JOIN c_bpartner bp ON i.c_bpartner_id::text = bp.c_bpartner_id::text
     LEFT JOIN fin_payment_sched_inv_v psiv ON i.c_invoice_id::text = psiv.c_invoice_id::text AND psiv.expected <> 0::numeric
     LEFT JOIN c_doctype dt ON i.c_doctype_id::text = dt.c_doctype_id::text
     LEFT JOIN c_costcenter cc ON i.c_costcenter_id::text = cc.c_costcenter_id::text
  WHERE i.issotrx = 'Y'::bpchar AND i.docstatus::text = 'CO'::text
UNION ALL
SELECT 'CC'::text AS doc_code,
    to_char(''::text) AS exclusiveid,
    'Cobro Cliente'::text AS doc_type,
    bp.name AS bpartner_name,
    i.documentno AS invoice,
    pdv.paymentno AS applied,
    pdv.paymentdate AS documentdate,
    pdv.paymentdate AS dateacct,
    i.poreference,
    to_char(i.description) AS description,
    psiv.duedate,
    pdv.paidconverted * '-1'::integer::numeric AS grandtotal,
    c_currency_convert(pdv.paidconverted, pdv.c_currency_id, '100'::character varying, pdv.paymentdate, NULL::character varying, pdv.ad_client_id, pdv.ad_org_id) * '-1'::integer::numeric AS grandtotalconverted,
    dt.name AS doctype,
    cc.name AS costcenter,
    cc.c_costcenter_id,
    i.issotrx AS isclient,
    i.posted,
    i.c_bpartner_id,
    NULL::text AS fin_payment_id,
    pdv.c_currency_id,
    pdv.ad_client_id,
    pdv.ad_org_id,
    i.c_invoice_id,
    to_char(''::text) AS em_sswh_withholdingref,
    to_number(0) AS em_sswh_totalwithholdingincome,
    to_number(0) AS em_sswh_totalwithholdingvat
   FROM c_invoice i
     LEFT JOIN c_bpartner bp ON i.c_bpartner_id::text = bp.c_bpartner_id::text
     LEFT JOIN fin_payment_sched_inv_v psiv ON i.c_invoice_id::text = psiv.c_invoice_id::text AND psiv.expected <> 0::numeric
     LEFT JOIN fin_payment_detail_v pdv ON psiv.fin_payment_sched_inv_v_id::text = pdv.fin_payment_sched_inv_v_id::text AND pdv.fin_payment_detail_v_id IS NOT NULL AND pdv.status::text <> 'SSWS_WTH'::text
     LEFT JOIN c_doctype dt ON i.c_doctype_id::text = dt.c_doctype_id::text
     LEFT JOIN c_costcenter cc ON i.c_costcenter_id::text = cc.c_costcenter_id::text
  WHERE pdv.paidconverted IS NOT NULL AND i.issotrx = 'Y'::bpchar AND i.docstatus::text = 'CO'::text
UNION ALL
SELECT 'ACSI'::text AS doc_code,
    to_char(''::text) AS exclusiveid,
    'Anticipo Cliente'::text AS doc_type,
    bp.name AS bpartner_name,
    p.documentno AS invoice,
    p.documentno AS applied,
    p.paymentdate AS documentdate,
    p.paymentdate AS dateacct,
    p.referenceno AS poreference,
    to_char(p.description) AS description,
    p.paymentdate AS duedate,
    pd.amount * '-1'::integer::numeric AS grandtotal,
    c_currency_convert(pd.amount, p.c_currency_id, '100'::character varying, p.paymentdate, NULL::character varying, p.ad_client_id, p.ad_org_id) * '-1'::integer::numeric AS grandtotalconverted,
    dt.name AS doctype,
    cc.name AS costcenter,
    cc.c_costcenter_id,
    p.isreceipt AS isclient,
    p.posted,
    p.c_bpartner_id,
    NULL::text AS fin_payment_id,
    p.c_currency_id,
    p.ad_client_id,
    p.ad_org_id,
    to_char(''::text) AS c_invoice_id,
    to_char(''::text) AS em_sswh_withholdingref,
    to_number(0) AS em_sswh_totalwithholdingincome,
    to_number(0) AS em_sswh_totalwithholdingvat
   FROM fin_payment p
     LEFT JOIN fin_payment_detail pd ON p.fin_payment_id::text = pd.fin_payment_id::text
     LEFT JOIN c_bpartner bp ON p.c_bpartner_id::text = bp.c_bpartner_id::text
     LEFT JOIN fin_financial_account fa ON p.fin_financial_account_id::text = fa.fin_financial_account_id::text
     LEFT JOIN c_doctype dt ON p.c_doctype_id::text = dt.c_doctype_id::text
     LEFT JOIN c_costcenter cc ON p.c_costcenter_id::text = cc.c_costcenter_id::text
  WHERE fa.name::text ~~ '%Anticipo Cliente SI%'::text
UNION ALL
SELECT 'AC'::text AS doc_code,
    to_char(''::text) AS exclusiveid,
    'Anticipo Cliente'::text AS doc_type,
    ( SELECT c_bpartner.name
           FROM c_bpartner
          WHERE c_bpartner.c_bpartner_id::text = p.c_bpartner_id::text) AS bpartner_name,
    p.documentno AS invoice,
    p.documentno AS applied,
    p.paymentdate AS documentdate,
    p.paymentdate AS dateacct,
    p.referenceno AS poreference,
    to_char(p.description) AS description,
    NULL::timestamp without time zone AS duedate,
    pdv.paidamt * '-1'::integer::numeric AS grandtotal,
    c_currency_convert(pdv.paidamt, p.c_currency_id, '100'::character varying, p.paymentdate, NULL::character varying, p.ad_client_id, p.ad_org_id) * '-1'::integer::numeric AS grandtotalconverted,
    dt.name AS doctype,
    cc.name AS costcenter,
    cc.c_costcenter_id,
    p.isreceipt AS isclient,
    p.posted,
    p.c_bpartner_id,
    p.fin_payment_id,
    p.c_currency_id,
    p.ad_client_id,
    p.ad_org_id,
    to_char(''::text) AS c_invoice_id,
    to_char(''::text) AS em_sswh_withholdingref,
    to_number(0) AS em_sswh_totalwithholdingincome,
    to_number(0) AS em_sswh_totalwithholdingvat
   FROM fin_payment p
     LEFT JOIN ssfi_fin_payment_detail_v pdv ON p.fin_payment_id::text = pdv.fin_payment_id::text
     LEFT JOIN fin_payment_detail pd ON p.fin_payment_id::text = pd.fin_payment_id::text
     LEFT JOIN c_doctype dt ON p.c_doctype_id::text = dt.c_doctype_id::text
     LEFT JOIN c_costcenter cc ON p.c_costcenter_id::text = cc.c_costcenter_id::text
     LEFT JOIN fin_payment_credit pc ON p.fin_payment_id::text = pc.fin_payment_id::text
  WHERE (p.status::text = 'RDNC'::text OR p.status::text = 'RPPC'::text OR p.status::text = 'RPR'::text) AND pdv.glitemname IS NULL AND pdv.fin_payment_sched_inv_id IS NULL AND p.isreceipt = 'Y'::bpchar AND pd.isprepayment = 'Y'::bpchar AND p.generated_credit = pdv.paidamt
UNION ALL
SELECT 'AC'::text AS doc_code,
    to_char(''::text) AS exclusiveid,
    'Anticipo Cliente'::text AS doc_type,
    ( SELECT c_bpartner.name
           FROM c_bpartner
          WHERE c_bpartner.c_bpartner_id::text = p.c_bpartner_id::text) AS bpartner_name,
    p.documentno AS invoice,
    p.documentno AS applied,
    c.paymentdate AS documentdate,
    c.paymentdate AS dateacct,
    p.referenceno AS poreference,
    to_char(p.description) AS description,
    NULL::timestamp without time zone AS duedate,
    b.amount AS grandtotal,
    c_currency_convert(b.amount, p.c_currency_id, '100'::character varying, p.paymentdate, NULL::character varying, p.ad_client_id, p.ad_org_id) AS grandtotalconverted,
    dt.name AS doctype,
    cc.name AS costcenter,
    cc.c_costcenter_id,
    p.isreceipt AS isclient,
    p.posted,
    p.c_bpartner_id,
    NULL::text AS fin_payment_id,
    p.c_currency_id,
    p.ad_client_id,
    p.ad_org_id,
    to_char(''::text) AS c_invoice_id,
    to_char(''::text) AS em_sswh_withholdingref,
    to_number(0) AS em_sswh_totalwithholdingincome,
    to_number(0) AS em_sswh_totalwithholdingvat
   FROM fin_payment p
     LEFT JOIN ssfi_fin_payment_detail_v pdv ON p.fin_payment_id::text = pdv.fin_payment_id::text
     LEFT JOIN fin_payment_detail pd ON p.fin_payment_id::text = pd.fin_payment_id::text
     LEFT JOIN c_doctype dt ON p.c_doctype_id::text = dt.c_doctype_id::text
     LEFT JOIN c_costcenter cc ON p.c_costcenter_id::text = cc.c_costcenter_id::text
     LEFT JOIN fin_payment_credit b ON p.fin_payment_id::text = b.fin_payment_id_used::text
     LEFT JOIN fin_payment c ON b.fin_payment_id::text = c.fin_payment_id::text
  WHERE p.amount <> 0::numeric AND (p.status::text = 'RDNC'::text OR p.status::text = 'RPPC'::text OR p.status::text = 'RPR'::text) AND pdv.glitemname IS NULL AND pdv.fin_payment_sched_inv_id IS NULL AND p.isreceipt = 'Y'::bpchar AND pd.isprepayment = 'Y'::bpchar AND p.generated_credit = pdv.paidamt
UNION ALL
 SELECT 'RC'::text AS doc_code,
    to_char(''::text) AS exclusiveid,
    'RETENCION CLIENTE'::text AS doc_type,
    c.name AS bpartner_name,
    d.documentno AS invoice,
    a.documentno AS applied,
    a.withholdingdate AS documentdate,
    a.dateacct,
    d.poreference,
    to_char(a.description) AS description,
    a.withholdingdate AS duedate,
    (a.totalwhrentalamt + a.totalwhivaamt) * '-1'::integer::numeric AS grandtotal,
    c_currency_convert(a.totalwhrentalamt + a.totalwhivaamt, a.c_currency_id, '100'::character varying, a.withholdingdate, NULL::character varying, a.ad_client_id, a.ad_org_id) * '-1'::integer::numeric AS grandtotalconverted,
    e.name AS doctype,
    NULL::character varying AS costcenter,
    NULL::character varying AS c_costcenter_id,
        CASE
            WHEN a.withholdingtype::text = 'WS'::text THEN 'Y'::text
            ELSE 'N'::text
        END AS isclient,
    a.posted,
    a.c_bpartner_id,
    NULL::text AS fin_payment_id,
    a.c_currency_id,
    a.ad_client_id,
    a.ad_org_id,
    d.c_invoice_id,
    to_char(''::text) AS em_sswh_withholdingref,
    to_number(0) AS em_sswh_totalwithholdingincome,
    to_number(0) AS em_sswh_totalwithholdingvat
   FROM ssws_withholdingsale a
     LEFT JOIN c_bpartner c ON a.c_bpartner_id::text = c.c_bpartner_id::text
     LEFT JOIN c_invoice d ON a.c_invoice_id::text = d.c_invoice_id::text
     LEFT JOIN c_doctype e ON a.c_doctype_id::text = e.c_doctype_id::text
  WHERE a.docstatus::text = 'CO'::text AND a.withholdingtype::text = 'WS'::text AND a.paidinvoice = 'N'::bpchar

) arp

JOIN c_bpartner bp ON bp.c_bpartner_id = arp.c_bpartner_id

LEFT JOIN c_bpartner_location bpl ON bpl.c_bpartner_id = bp.c_bpartner_id
 AND bpl.created = (SELECT MAX(created) FROM c_bpartner_location  WHERE c_bpartner_id = bp.c_bpartner_id)

LEFT JOIN ad_user us ON us.c_bpartner_id = bp.c_bpartner_id
 AND us.created = ( SELECT MAX(created) FROM ad_user WHERE c_bpartner_id = bp.c_bpartner_id )

LEFT JOIN c_location loc ON loc.c_location_id = bpl.c_location_id

WHERE arp.isclient = 'Y'
	and case when $P{advanced} = 'Y'
	   then arp.doc_type not in ('Anticipo Cliente')
	   else 1=1 end
        and arp.documentdate::date <= $P{Dateto}
        and ($P{Docstatus} is null or arp.posted = $P{Docstatus})
        and ($P{C_BPartner_ID} is null or arp.c_bpartner_id = $P{C_BPartner_ID})
	and ($P{Ad_Org_ID} is null or arp.ad_org_id = $P{Ad_Org_ID})
ORDER BY 2, 3
) xxx
group by "tercero",identificador, "factura", "organization",c_invoice_id, direccion, city, telf1 ,telf2,email, name_c , email_c, telf_c, telf_alt_c, cargo_c
order by 1,5,8,9 desc]]>
	</queryString>
	<field name="organizationame" class="java.lang.String"/>
	<field name="fhasta" class="java.lang.String"/>
	<field name="fecha_venc" class="java.lang.String"/>
	<field name="descrp_invoice" class="java.lang.String"/>
	<field name="tercero" class="java.lang.String"/>
	<field name="identificador" class="java.lang.String"/>
	<field name="factura" class="java.lang.String"/>
	<field name="documentdate" class="java.lang.String"/>
	<field name="valor" class="java.math.BigDecimal"/>
	<field name="fecha_impresion" class="java.lang.String"/>
	<field name="organization" class="java.lang.String"/>
	<field name="tipo_doc" class="java.lang.String"/>
	<field name="amountinvoice" class="java.math.BigDecimal"/>
	<field name="amountreceivable" class="java.math.BigDecimal"/>
	<field name="dueday" class="java.lang.Integer"/>
	<field name="direccion" class="java.lang.String"/>
	<field name="city" class="java.lang.String"/>
	<field name="telf1" class="java.lang.String"/>
	<field name="telf2" class="java.lang.String"/>
	<field name="email" class="java.lang.String"/>
	<field name="name_c" class="java.lang.String"/>
	<field name="email_c" class="java.lang.String"/>
	<field name="telf_c" class="java.lang.String"/>
	<field name="telf_alt_c" class="java.lang.String"/>
	<field name="cargo_c" class="java.lang.String"/>
	<variable name="vtotal" class="java.math.BigDecimal" calculation="Sum">
		<variableExpression><![CDATA[$F{valor}]]></variableExpression>
	</variable>
	<variable name="vtotalgroup" class="java.math.BigDecimal" resetType="Group" resetGroup="Tercero" calculation="Sum">
		<variableExpression><![CDATA[$F{valor}]]></variableExpression>
	</variable>
	<group name="Tercero">
		<groupExpression><![CDATA[$F{tercero}]]></groupExpression>
		<groupFooter>
			<band height="39">
				<printWhenExpression><![CDATA[$P{consolidated}.equals("Y")]]></printWhenExpression>
				<staticText>
					<reportElement key="staticText-5" stretchType="RelativeToBandHeight" x="0" y="8" width="793" height="18" uuid="f6563d23-09e2-495e-97af-55b958620e60"/>
					<box leftPadding="0" rightPadding="3">
						<topPen lineWidth="0.0" lineStyle="Solid" lineColor="#000000"/>
						<leftPen lineWidth="0.0" lineStyle="Solid" lineColor="#000000"/>
						<bottomPen lineWidth="0.0" lineColor="#000000"/>
						<rightPen lineWidth="0.0" lineStyle="Solid" lineColor="#000000"/>
					</box>
					<textElement textAlignment="Right">
						<font fontName="Calibri" size="10" isBold="true"/>
					</textElement>
					<text><![CDATA[TOTAL :]]></text>
				</staticText>
				<textField isStretchWithOverflow="true" isBlankWhenNull="true">
					<reportElement stretchType="RelativeToBandHeight" x="793" y="10" width="59" height="17" uuid="100b2007-5893-431d-b51b-2a229f3f5993"/>
					<textElement textAlignment="Right">
						<font fontName="Calibri" isBold="true"/>
					</textElement>
					<textFieldExpression><![CDATA[$V{vtotalgroup}]]></textFieldExpression>
				</textField>
				<line>
					<reportElement x="793" y="9" width="59" height="1" uuid="d31904a3-51cc-438e-8402-a88e6f85f9db"/>
				</line>
			</band>
		</groupFooter>
	</group>
	<title>
		<band height="50" splitType="Stretch">
			<textField>
				<reportElement x="1037" y="0" width="119" height="50" uuid="9f3c5872-9104-4f80-b826-fbaa2a8c0eb3"/>
				<textElement markup="html">
					<font fontName="Calibri" size="9"/>
				</textElement>
