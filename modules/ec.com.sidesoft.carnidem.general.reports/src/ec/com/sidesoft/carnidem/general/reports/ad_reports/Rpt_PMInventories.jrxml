<?xml version="1.0" encoding="UTF-8"?>
<jasperReport xmlns="http://jasperreports.sourceforge.net/jasperreports" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://jasperreports.sourceforge.net/jasperreports http://jasperreports.sourceforge.net/xsd/jasperreport.xsd" name="Rpt_PMInventories" pageWidth="1740" pageHeight="595" orientation="Landscape" columnWidth="1700" leftMargin="20" rightMargin="20" topMargin="20" bottomMargin="20" uuid="9e83b194-2a6c-4f52-9c30-ef8763581492">
