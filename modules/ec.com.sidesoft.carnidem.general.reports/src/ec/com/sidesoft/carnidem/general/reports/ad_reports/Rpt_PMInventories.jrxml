		<defaultValueExpression><![CDATA[new DecimalFormat("###,##0.00;-###,##0.00", new DecimalFormatSymbols())]]></defaultValueExpression>
	</parameter>
	<parameter name="BASE_DESIGN" class="java.lang.String" isForPrompting="false">
		<defaultValueExpression><![CDATA["/opt/openbravo/carnidem/modules/ec.com.sidesoft.carnidem.general.reports/src"]]></defaultValueExpression>
	</parameter>
	<parameter name="AD_User_ID" class="java.lang.String" isForPrompting="false">
		<defaultValueExpression><![CDATA["100"]]></defaultValueExpression>
	</parameter>
	<parameter name="SscgrProductCatId" class="java.lang.String" isForPrompting="false">
		<defaultValueExpression><![CDATA[]]></defaultValueExpression>
	</parameter>
	<parameter name="SscgrProductId" class="java.lang.String" isForPrompting="false">
		<defaultValueExpression><![CDATA[]]></defaultValueExpression>
	</parameter>
	<parameter name="M_AttributeInstance_ID" class="java.lang.String" isForPrompting="false">
		<defaultValueExpression><![CDATA[]]></defaultValueExpression>
	</parameter>
	<parameter name="SscgrDateFrom" class="java.util.Date">
		<defaultValueExpression><![CDATA[]]></defaultValueExpression>
	</parameter>
	<parameter name="SscgrDateTo" class="java.util.Date">
		<defaultValueExpression><![CDATA[]]></defaultValueExpression>
	</parameter>
	<parameter name="SUBREPORT_DIR" class="java.lang.String" isForPrompting="false">
		<defaultValueExpression><![CDATA["/opt/openbravo/carnidem/modules/ec.com.sidesoft.carnidem.general.reports/src/ec/com/sidesoft/carnidem/general/reports/ad_reports/"]]></defaultValueExpression>
	</parameter>
	<queryString>
		<![CDATA[SELECT
    mp.ad_org_id                                                    AS org_id,
    (select name from ad_org where issummary='Y')                                                      AS org_name,
    u.username                                                      AS printing_user,
    TO_CHAR(NOW(),'YYYY-MM-DD HH24:MI:SS')                          AS printing_date,

    /* ► nombres de los filtros, para cabecera de informe  ----------- */
    COALESCE(mp_f.name ,'')                                         AS mpname,
    COALESCE(mpc_f.name,'')                                         AS mpcname,
    COALESCE(masi_f.description,'')                                 AS codcompname,

    /* ► datos de cada línea ----------------------------------------- */
    mp.name                         AS "Producto",
    mp.m_product_id                 AS mpID
--    ci.documentno                   AS "Nº Documento",
--    ci.poreference                  AS "Factura Proveedor",

    /* precios                                                            */
--    ROUND(cil.priceactual * (COALESCE(ct.rate,0)+100)/100, cur.stdprecision)                        AS "PrecioUIva",
--    ROUND(cil.priceactual,                                           cur.stdprecision)              AS "PrecioUSIva",
--    ROUND(cil.priceactual * (COALESCE(ct.rate,0)+100)/100 * cil.qtyinvoiced, cur.stdprecision)      AS "Precio Total"
FROM
    c_invoice           ci
    /* tablas obligatorias (INNER JOIN)  ------------------------------ */
    JOIN c_invoiceline  cil  ON cil.c_invoice_id  = ci.c_invoice_id
    JOIN m_product      mp   ON mp.m_product_id   = cil.m_product_id
    JOIN c_tax          ct   ON ct.c_tax_id       = cil.c_tax_id
    JOIN c_currency     cur  ON cur.c_currency_id = '100'            -- divisa fija

    JOIN ad_org         o    ON o.ad_org_id       = ci.ad_org_id

    JOIN ad_user        u    ON u.ad_user_id      = $P{AD_User_ID}

    /* opcionales (LEFT JOIN) ----------------------------------------- */
    LEFT JOIN m_inoutline             mil   ON mil.m_inoutline_id = cil.m_inoutline_id
    LEFT JOIN m_inout                 mi    ON mi.m_inout_id      = mil.m_inout_id
    LEFT JOIN m_attributesetinstance  masi  ON masi.m_attributesetinstance_id = mil.m_attributesetinstance_id

    /* ► look-ups SOLO para mostrar nombres de los filtros ------------- */
    LEFT JOIN m_product               mp_f   ON mp_f.m_product_id            = $P{SscgrProductId}
    LEFT JOIN m_product_category      mpc_f  ON mpc_f.m_product_category_id  = $P{SscgrProductCatId}
    LEFT JOIN m_attributesetinstance  masi_f ON masi_f.m_attributesetinstance_id = $P{M_AttributeInstance_ID}

WHERE
      ci.issotrx = 'N'                       -- compras
  AND ci.poreference IS NOT NULL

  /* ---------- filtros dinámicos (solo actúan si viene parámetro) ---- */
  AND ( $P{SscgrProductCatId}      IS NULL OR mp.m_product_category_id      = $P{SscgrProductCatId} )
  AND ( $P{SscgrProductId}         IS NULL OR mp.m_product_id               = $P{SscgrProductId} )
  AND ( $P{M_AttributeInstance_ID} IS NULL OR masi.m_attributesetinstance_id= $P{M_AttributeInstance_ID} )
  AND (ci.dateinvoiced::date >= $P{SscgrDateFrom}::date or coalesce(to_char($P{SscgrDateFrom}),'nd')='nd')
  AND (ci.dateinvoiced::date <= $P{SscgrDateTo}::date or coalesce(to_char($P{SscgrDateTo}),'nd')='nd')
Group by 1,2,3,4,5,6,7,8,9
ORDER BY mp.name;]]>
	</queryString>
