	<field name="org_name" class="java.lang.String"/>
	<field name="printing_user" class="java.lang.String"/>
	<field name="printing_date" class="java.lang.String"/>
	<field name="mpname" class="java.lang.String"/>
	<field name="mpcname" class="java.lang.String"/>
	<field name="codcompname" class="java.lang.String"/>
	<field name="Producto" class="java.lang.String"/>
	<field name="mpid" class="java.lang.String"/>
