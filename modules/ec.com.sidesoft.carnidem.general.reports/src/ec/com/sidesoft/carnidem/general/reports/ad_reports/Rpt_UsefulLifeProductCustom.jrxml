<?xml version="1.0" encoding="UTF-8"?>
<jasperReport xmlns="http://jasperreports.sourceforge.net/jasperreports" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://jasperreports.sourceforge.net/jasperreports http://jasperreports.sourceforge.net/xsd/jasperreport.xsd" name="Rpt_UsefulLifeProduct" pageWidth="1200" pageHeight="595" orientation="Landscape" whenNoDataType="BlankPage" columnWidth="1172" leftMargin="14" rightMargin="14" topMargin="14" bottomMargin="14" isSummaryWithPageHeaderAndFooter="true" uuid="cfaf7223-c06e-4591-8e0f-b406a2336150">
	<property name="ireport.zoom" value="2.0"/>
	<property name="ireport.x" value="1525"/>
	<property name="ireport.y" value="0"/>
	<property name="net.sf.jasperreports.export.xls.detect.cell.type" value="true"/>
	<style name="colorimetria">
		<conditionalStyle>
			<conditionExpression><![CDATA[$F{userful_life} >= 0 && $F{userful_life} < 19]]></conditionExpression>
			<style mode="Opaque" backcolor="#E74C3C"/>
		</conditionalStyle>
		<conditionalStyle>
			<conditionExpression><![CDATA[$F{userful_life} >= 19 && $F{userful_life} < 50]]></conditionExpression>
			<style mode="Opaque" backcolor="#F39C12"/>
		</conditionalStyle>
		<conditionalStyle>
			<conditionExpression><![CDATA[$F{userful_life} >= 50 && $F{userful_life} < 71]]></conditionExpression>
			<style mode="Opaque" backcolor="#F1C40F"/>
		</conditionalStyle>
		<conditionalStyle>
			<conditionExpression><![CDATA[$F{userful_life} >= 71]]></conditionExpression>
			<style mode="Opaque" backcolor="#2ECC71"/>
		</conditionalStyle>
	</style>
	<parameter name="DATEFORMAT" class="java.text.SimpleDateFormat" isForPrompting="false">
		<defaultValueExpression><![CDATA[new SimpleDateFormat("dd/MM/yyyy")]]></defaultValueExpression>
	</parameter>
	<parameter name="NUMBERFORMAT" class="java.text.DecimalFormat" isForPrompting="false">
		<defaultValueExpression><![CDATA[new DecimalFormat("###,##0.00;-###,##0.00", new DecimalFormatSymbols())]]></defaultValueExpression>
	</parameter>
	<parameter name="NUMBERDECIMAL" class="java.lang.Integer" isForPrompting="false">
		<defaultValueExpression><![CDATA[2]]></defaultValueExpression>
	</parameter>
	<parameter name="BASE_DESIGN" class="java.lang.String">
		<defaultValueExpression><![CDATA["/home/openbravo/Escritorio/reportes/4435/ec.com.sidesoft.sanfelipe.inventory/ec.com.sidesoft.sanfelipe.inventory/src"]]></defaultValueExpression>
	</parameter>
	<parameter name="SOURCE_PATH" class="java.lang.String" isForPrompting="false"/>
	<parameter name="M_Product_ID" class="java.lang.String">
		<defaultValueExpression><![CDATA[]]></defaultValueExpression>
	</parameter>
	<parameter name="DateTo" class="java.util.Date">
		<defaultValueExpression><![CDATA[]]></defaultValueExpression>
	</parameter>
	<parameter name="colorimetry" class="java.lang.String">
		<defaultValueExpression><![CDATA[]]></defaultValueExpression>
	</parameter>
	<parameter name="colorimetry_condition" class="java.lang.String" isForPrompting="false">
		<parameterDescription><![CDATA[]]></parameterDescription>
		<defaultValueExpression><![CDATA[$P{colorimetry} != null ?
($P{colorimetry}.equals("lt") ? "trunc(x.userful_life) between 20 and 50":
 $P{colorimetry}.equals("rw") ?"trunc(x.userful_life) between 51 and 70" :
 $P{colorimetry}.equals("apt") ?"trunc(x.userful_life) between 71 and 100" :
 $P{colorimetry}.equals("lst") ?"trunc(x.userful_life) between 0 and 19":"1=1" ):"1=1"]]></defaultValueExpression>
	</parameter>
	<parameter name="M_Warehouse_ID" class="java.lang.String">
		<defaultValueExpression><![CDATA[]]></defaultValueExpression>
	</parameter>
	<parameter name="Org_ID" class="java.lang.String" isForPrompting="false">
		<defaultValueExpression><![CDATA[]]></defaultValueExpression>
	</parameter>
	<parameter name="User_ID" class="java.lang.String" isForPrompting="false">
		<defaultValueExpression><![CDATA[]]></defaultValueExpression>
	</parameter>
	<parameter name="UserName" class="java.lang.String" isForPrompting="false">
		<defaultValueExpression><![CDATA[]]></defaultValueExpression>
	</parameter>
	<parameter name="SUBREPORT_DIR" class="java.lang.String" isForPrompting="false">
		<defaultValueExpression><![CDATA["/home/openbravo/Escritorio/reportes/4435/ec.com.sidesoft.sanfelipe.inventory/src"]]></defaultValueExpression>
	</parameter>
	<queryString>
		<![CDATA[SELECT *,
  CASE
    WHEN $P{colorimetry}='lt' THEN 'Limite'
    WHEN $P{colorimetry}='rw' THEN 'Revisión'
    WHEN $P{colorimetry}='apt' THEN 'Adecuado'
    WHEN $P{colorimetry}='lst' THEN 'Pérdida'
    ELSE 'Todos'
  END AS val_color,
  CASE
    WHEN round(x.userful_life) BETWEEN 20 AND 50 THEN 'Limite'
    WHEN round(x.userful_life) BETWEEN 51 AND 70 THEN 'Revisión'
    WHEN round(x.userful_life) BETWEEN 71 AND 100 THEN 'Adecuado'
    WHEN round(x.userful_life) BETWEEN 0 AND 19 THEN 'Pérdida'
  END AS texto_color
FROM (
  SELECT
    p.ad_org_id,
    TO_CHAR(NOW(),'dd/mm/yyyy HH24:MI:SS') AS fecha_impresion,
  TO_CHAR(NOW(),'dd/mm/yyyy') AS fecha_actual,
    trim(p.value) AS code,
    trim(p.name) AS product,
    trim(p.m_product_id) AS product_id,
    sum (qtyonhand) AS qty,
    round((to_number(qtyonhand) - to_number(reservedqty)),2) AS qtyact,
    reservedqty,
    uom.name AS unit,
    CASE
      WHEN COALESCE(ms.guaranteedays,0) = 0 THEN null
      ELSE abs(DATE_PART('day', (pp.endtime + COALESCE(ms.guaranteedays,0)) - NOW()) * 100 / NULLIF(ms.guaranteedays,0))
    END AS userful_life,
    l.m_locator_id AS locator_id,
    w.name AS bodega,
    op.name AS org_name,
    mt.m_attributesetinstance_id AS attributesetinstance_id,
    mt.description AS lote,
    pp.endtime AS fabricacion,
    pp.endtime + COALESCE(ms.guaranteedays,0) AS fven,
    DATE_PART('day', (pp.endtime + COALESCE(ms.guaranteedays,0)) - NOW()) AS dven,
    COALESCE(ms.guaranteedays,0) AS dgarantiav
  FROM
    m_production pt
    LEFT JOIN m_productionplan pp ON pp.m_production_id = pt.m_production_id
    LEFT JOIN m_productionline pl ON pl.m_productionplan_id = pp.m_productionplan_id
    JOIN m_storage_detail sd ON sd.m_product_id = pl.m_product_id AND sd.m_attributesetinstance_id = pl.m_attributesetinstance_id
    LEFT JOIN m_attributesetinstance mt ON mt.m_attributesetinstance_id = sd.m_attributesetinstance_id
    JOIN m_locator l ON l.m_locator_id = sd.m_locator_id
    JOIN m_warehouse w ON w.m_warehouse_id = l.m_warehouse_id
    JOIN m_product p ON p.m_product_id = sd.m_product_id
    JOIN m_attributeset ms ON ms.m_attributeset_id = p.m_attributeset_id
    JOIN ad_org org ON org.ad_org_id = p.ad_org_id
    JOIN c_uom_trl uom ON uom.c_uom_id = p.c_uom_id AND uom.ad_language = 'es_ES'
    LEFT JOIN (
      SELECT org.name
      FROM ad_org_tree ot
      JOIN ad_org org ON org.ad_org_id=ot.ad_org_id
      WHERE levelno=2 AND ad_parent_org_id='0' AND org.ad_orgtype_id = '1'
    ) op ON 1=1
  WHERE
    qtyonhand <> 0
    AND p.issold='Y'
    AND p.isstocked='Y'
    AND p.producttype='I'
    AND pt.issotrx = 'N'
    AND (p.m_product_id=$P{M_Product_ID} OR $P{M_Product_ID} IS NULL)
    AND (w.m_warehouse_id = COALESCE($P{M_Warehouse_ID}, w.m_warehouse_id) OR $P{M_Warehouse_ID} IS NULL)
group by p.ad_org_id, p.value, p.name, p.m_product_id, sd.qtyonhand,sd.reservedqty, uom.name, ms.guaranteedays, pp.endtime, w.name,
op.name, mt.m_attributesetinstance_id, l.m_locator_id
  ORDER BY w.name, pp.endtime, p.value
) x
WHERE $P!{colorimetry_condition};]]>
	</queryString>
