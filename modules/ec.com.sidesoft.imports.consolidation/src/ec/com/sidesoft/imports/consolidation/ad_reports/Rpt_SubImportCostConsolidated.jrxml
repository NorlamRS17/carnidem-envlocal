<?xml version="1.0" encoding="UTF-8"?>
<jasperReport xmlns="http://jasperreports.sourceforge.net/jasperreports" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://jasperreports.sourceforge.net/jasperreports http://jasperreports.sourceforge.net/xsd/jasperreport.xsd" name="Rpt_SubImportCost" pageWidth="505" pageHeight="842" whenNoDataType="BlankPage" columnWidth="505" leftMargin="0" rightMargin="0" topMargin="0" bottomMargin="0" isFloatColumnFooter="true" uuid="cfaf7223-c06e-4591-8e0f-b406a2336150">
	<property name="ireport.zoom" value="1.5"/>
	<property name="ireport.x" value="0"/>
	<property name="ireport.y" value="0"/>
	<property name="net.sf.jasperreports.export.xls.detect.cell.type" value="true"/>
	<property name="net.sf.jasperreports.export.xls.sheet.names.all" value="Reporte de Stock Nacional"/>
	<parameter name="NUMBERFORMAT" class="java.text.DecimalFormat" isForPrompting="false">
		<defaultValueExpression><![CDATA[new DecimalFormat("###,##0.00;-###,##0.00", new DecimalFormatSymbols())]]></defaultValueExpression>
	</parameter>
	<parameter name="ad_org_id" class="java.lang.String" isForPrompting="false"/>
	<parameter name="AD_USER_ID" class="java.lang.String" isForPrompting="false"/>
	<parameter name="costimport_id" class="java.lang.String">
		<defaultValueExpression><![CDATA[]]></defaultValueExpression>
	</parameter>
	<queryString>
		<![CDATA[SELECT
	COALESCE(p.name, e.value||'-'||UPPER(e.name)) detalle,
	bp.name tercero,
	COALESCE(i.POReference, j.documentno) documento,
	ci.amountnet valor,
	1 orden
FROM c_order o
	JOIN (SELECT c_order_id FROM SSIP_Costimport WHERE SSIP_Costimport_id = $P{costimport_id}) r ON r.c_order_id = o.c_order_id
	JOIN SSIP_Costimport ci ON ci.c_order_id = o.c_order_id
	JOIN ssimpcn_imp_consol_line icl ON icl.c_campaign_id = o.c_campaign_id
    JOIN ssimpcn_imp_consol_detail icd ON icd.ssimpcn_imp_consol_line_id = icl.ssimpcn_imp_consol_line_id
        AND ROUND(icd.amountnet,2) = ROUND(ci.amountnet,2)
	LEFT JOIN c_invoice i ON TRIM(i.documentno)=SPLIT_PART(ci.documentnumber, ' ', 1)
	LEFT JOIN c_invoiceline il ON il.c_invoice_id = i.c_invoice_id
		AND il.em_ssimpcn_imp_consol_id = icl.ssimpcn_imp_consolidation_id
		AND il.em_ssimpcn_type = 'C'
		AND il.EM_Ssimacc_Dataimport = 'N'
        AND il.c_invoiceline_id = icd.c_invoiceline_id
	LEFT JOIN m_product p ON p.m_product_id = il.m_product_id
	LEFT JOIN c_bpartner bp ON bp.c_bpartner_id = i.c_bpartner_id
	LEFT JOIN gl_journalbatch jb ON TRIM(jb.documentno)= SPLIT_PART(ci.documentnumber, ' ', 1)
	LEFT JOIN gl_journal j ON  j.gl_journalbatch_id = jb.gl_journalbatch_id
	LEFT JOIN GL_JournalLine jl ON jl.gl_journal_id = j.gl_journal_id
		AND jl.em_ssimpcn_imp_consol_id = icl.ssimpcn_imp_consolidation_id
		AND jl.em_ssimpcn_type = 'C'
        AND jl.gl_journalline_id = icd.gl_journalline_id
	LEFT JOIN C_ValidCombination vg ON vg.C_ValidCombination_ID = jl.C_ValidCombination_ID
	LEFT JOIN c_elementvalue e ON e.c_elementvalue_id = vg.Account_ID
WHERE o.issotrx = 'N' AND COALESCE(il.LineNetAmt, jl.AmtSourceDr) <> 0

UNION

SELECT
	pr.name detalle,
	bp.name tercero,
	COALESCE(i.POReference, i.documentno) documento,
	il.LineNetAmt valor,
	2 orden
FROM c_order o
	JOIN (SELECT c_order_id FROM SSIP_Costimport WHERE SSIP_Costimport_id = $P{costimport_id}) r ON r.c_order_id = o.c_order_id
	JOIN c_invoiceline il ON il.EM_Ssip_Campaign_ID = o.C_Campaign_ID
		AND il.EM_Ssip_Importtype = 'Y'
		AND il.EM_Ssimacc_Dataimport = 'Y'
	JOIN c_invoice i ON i.c_invoice_id = il.c_invoice_id AND i.docstatus = 'CO'
	JOIN c_bpartner bp ON bp.c_bpartner_id = i.c_bpartner_id
	JOIN m_product pr ON pr.m_product_id = il.m_product_id

ORDER BY orden, documento, detalle]]>
	</queryString>
