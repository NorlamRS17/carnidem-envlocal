	<field name="c_unitario" class="java.math.BigDecimal"/>
	<field name="fob" class="java.math.BigDecimal"/>
	<field name="usuario" class="java.lang.String"/>
	<field name="consolidated" class="java.lang.String"/>
	<variable name="TOTAL_PAGINAS" class="java.lang.Integer">
		<variableExpression><![CDATA[$V{PAGE_NUMBER}]]></variableExpression>
	</variable>
	<variable name="total_costo" class="java.math.BigDecimal" calculation="Sum">
		<variableExpression><![CDATA[$F{c_total}]]></variableExpression>
	</variable>
	<variable name="total_fob" class="java.math.BigDecimal" calculation="Sum">
		<variableExpression><![CDATA[$F{fob}]]></variableExpression>
	</variable>
