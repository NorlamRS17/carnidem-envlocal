				<subreportExpression><![CDATA[$P{BASE_DESIGN} + "/ec/com/sidesoft/imports/consolidation/ad_reports/Rpt_SubImportCostConsolidated.jasper"]]></subreportExpression>
			</subreport>
		</band>
	</summary>
</jasperReport>
