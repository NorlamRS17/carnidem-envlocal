	<import value="org.openbravo.dal.core.OBContext"/>
	<parameter name="DATEFORMAT" class="java.text.SimpleDateFormat" isForPrompting="false">
		<defaultValueExpression><![CDATA[new SimpleDateFormat("dd/MM/yyyy")]]></defaultValueExpression>
	</parameter>
	<parameter name="NUMBERFORMAT" class="java.text.DecimalFormat" isForPrompting="false">
		<defaultValueExpression><![CDATA[new DecimalFormat("###,##0.00;-###,##0.00", new DecimalFormatSymbols())]]></defaultValueExpression>
	</parameter>
	<parameter name="NUMBERDECIMAL" class="java.lang.Integer" isForPrompting="false">
		<defaultValueExpression><![CDATA[2]]></defaultValueExpression>
	</parameter>
	<parameter name="BASE_WEB" class="java.lang.String" isForPrompting="false"/>
	<parameter name="SOURCE_PATH" class="java.lang.String" isForPrompting="false"/>
	<parameter name="DateFrom" class="java.util.Date">
		<defaultValueExpression><![CDATA[]]></defaultValueExpression>
	</parameter>
	<parameter name="DateTo" class="java.util.Date">
		<defaultValueExpression><![CDATA[]]></defaultValueExpression>
	</parameter>
	<queryString>
		<![CDATA[SELECT REPLACE(TRIM(bp.name),',','.') as tercero
,REPLACE(TRIM(EM_Atimdm_Email),',','.') as email
,COALESCE(bpl.phone,bpl.phone2) as phone
,REPLACE(TRIM(bpl.name),',','.') as dir
--,REPLACE(TRIM(o.description),',','.') as instrucciones
,REPLACE(TRIM(p.name),',','.') as producto
,qtyordered
,ol.linenetamt+olt.taxamt as total
,bpl.em_sspsi_latitude
,bpl.em_sspsi_longitude
,lc.city
,o.documentno as numero_pedido_venta
FROM c_orderline ol
JOIN m_product p ON p.m_product_id=ol.m_product_id
JOIN c_order o ON o.c_order_id=ol.c_order_id
JOIN c_bpartner bp ON bp.c_bpartner_id=o.c_bpartner_id
JOIN c_bpartner_location bpl ON bpl.c_bpartner_location_id=o.c_bpartner_location_id
JOIN c_location lc ON lc.c_location_id=bpl.c_location_id
LEFT JOIN (SELECT sum(taxamt) as taxamt,c_orderline_id FROM c_orderlinetax
GROUP BY c_orderline_id) olt ON olt.c_orderline_id=ol.c_orderline_id
JOIN c_doctype d ON d.c_doctype_id=o.c_doctype_id
LEFT JOIN c_location l ON l.c_location_id=bpl.c_location_id
WHERE o.issotrx='Y'
AND d.IsReturn='N'
AND (d.DocBaseType='SOO' or o.c_doctypetarget_id is not null)
AND o.DocStatus = 'CO'
AND o.dateordered between $P{DateFrom} AND $P{DateTo}
AND bp.Customer_Blocking = 'N'
ORDER BY o.dateordered,o.documentno,ol.line]]>
	</queryString>
