<?xml version="1.0" encoding="UTF-8"?>
<jasperReport xmlns="http://jasperreports.sourceforge.net/jasperreports" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://jasperreports.sourceforge.net/jasperreports http://jasperreports.sourceforge.net/xsd/jasperreport.xsd" name="Atindpo_Prefactura" pageWidth="595" pageHeight="842" columnWidth="555" leftMargin="20" rightMargin="20" topMargin="20" bottomMargin="20" uuid="25e714c0-3d3f-4b5f-b279-e4dad8fd407e">
	<property name="ireport.zoom" value="2.0"/>
	<property name="ireport.x" value="0"/>
	<property name="ireport.y" value="240"/>
	<parameter name="BASE_DESIGN" class="java.lang.String">
		<defaultValueExpression><![CDATA["/opt/ecuapack/modules/com.atrums.indumot.postventa/src"]]></defaultValueExpression>
	</parameter>
	<parameter name="DOCUMENT_ID" class="java.lang.String"/>
	<parameter name="SOURCE_PATH" class="java.lang.String" isForPrompting="false">
		<defaultValueExpression><![CDATA[]]></defaultValueExpression>
	</parameter>
	<queryString>
		<![CDATA[select (SELECT o.AD_ORG_ID FROM AD_ORG o JOIN AD_OrgType t USING (AD_ORGTYPE_ID) WHERE IsAcctLegalEntity = 'Y' ) as ad_org_id
	, (SELECT o.name FROM AD_ORG o JOIN AD_OrgType t USING (AD_ORGTYPE_ID) WHERE IsAcctLegalEntity = 'Y' ) as org_name
	,coalesce(ap.documentno,null) as DOCUMENTNO
	, to_char(NOW(),'DD/MM/YYYY') as FECHA
	, coalesce(cb.name,null) as NAME
	, coalesce(cb.taxid,' ') as TAXID
	, coalesce(cl.phone,' ') as PHONE
	, coalesce(c.address1,' ') as ADDRESS1
	, coalesce(b.name,' ') as MARCA
	, coalesce(mp.name,' ') as MODELO
	, y.name as ANIO
	, coalesce(ap.numeromotor,' ') as NUMEROMOTOR
	, coalesce(ap.numerochasis,' ') as NUMEROCHASIS
	, coalesce(ap.placa,' ') as PLACA
	, coalesce(col.name,' ') as LSCOLOR
	, coalesce(ap.atindpo_postventa_id,' ') as ATINDPO_POSTVENTA_ID
	, (case when ap.lstipovehiculo = 'MT' then 'MOTO' else ' ' end) as TIPO
	, coalesce(ap.descripcioncliente,' ') as DESCRIPCION
	, (select coalesce(cbp.name,' ') from c_bpartner cbp where cbp.c_bpartner_id = ap.c_bpartner_emp_id) as MECANICO
	, coalesce((ap.nombre || ' ' || ap.apellido || ' / ' || coalesce('CI: '||ap.cedula,'')),'') as CONDUCTOR
	, coalesce(ap.orden_trabajo,'') as orden_trabajo
	, 'Pre-Factura No. '||ap.documentno as pre
	,Kmhoras as "Kmhoras"
	 , coalesce(ap.EM_Satmac_Name,'') as nombre_producto
	 , coalesce(mt.name,'')  as maquina
	 , coalesce(ag.name,'') as agente_com
	 , coalesce(cpp.name,'') as proyecto
	,coalesce(ap.nombre,'') as nombre_cont
	,coalesce(ap.cedula,'') as cedula_cont
	,coalesce(ap.telefono,'') as tel_cont
	,coalesce(ap.celular,'') as cel_cont
	,coalesce(ap.direccion,'') as dir_cont
	,coalesce(ap.email,'') as email_cl
	,coalesce(cpm.name,'') as payment_term
	, (SELECT i.TaxID FROM AD_Org o JOIN AD_OrgType t  USING (AD_ORGTYPE_ID) JOIN AD_Orginfo i
	   on i.ad_org_id = o.ad_org_id WHERE IsAcctLegalEntity = 'Y' ) as tax_org
from atindpo_postventa ap
	Join c_bpartner cb on ap.c_bpartner_id = cb.c_bpartner_id
	Join c_bpartner_location cl on cl.c_bpartner_location_id = ap.c_bpartner_location_id
	Join c_location c on c.c_location_id=cl.c_location_id
	Left Join ssfi_model_prod mp on mp.ssfi_model_prod_id = ap.em_sswos_ssfi_model_prod_id
	Left Join m_brand b on b.m_brand_id = ap.em_sswos_m_brand_id
	Left Join sswos_color col on col.sswos_color_id = ap.em_sswos_color_id
	Left Join sswos_year y on y.sswos_year_id = ap.em_sswos_year_id
    	LEFT JOIN satmac_machine_type mt on mt.satmac_machine_type_ID = ap.EM_Satmac_Machine_Type_ID
   	LEFT JOIN ad_user ag on ag.ad_user_id = ap.EM_Satmac_Salesrep_ID
  	LEFT JOIN c_project cpp on cpp.c_project_id = ap.EM_Satmac_Project_ID
	LEFT JOIN C_Paymentterm cpm on ap.C_Paymentterm_ID=cpm.C_Paymentterm_ID
where ap.atindpo_postventa_id=$P{DOCUMENT_ID}]]>
	</queryString>
