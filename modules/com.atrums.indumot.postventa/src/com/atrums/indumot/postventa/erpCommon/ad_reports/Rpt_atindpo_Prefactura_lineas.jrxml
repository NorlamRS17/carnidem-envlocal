	<style name="Detail" fontName="Arial" fontSize="12"/>
	<parameter name="DOCUMENT_ID" class="java.lang.String"/>
	<parameter name="NUMBERFORMAT" class="java.text.DecimalFormat" isForPrompting="false">
		<defaultValueExpression><![CDATA[new DecimalFormat("###,##0.00;-###,##0.00", new DecimalFormatSymbols())]]></defaultValueExpression>
	</parameter>
	<parameter name="NUMBERDECIMAL" class="java.lang.Integer">
		<defaultValueExpression><![CDATA[2]]></defaultValueExpression>
	</parameter>
	<queryString>
		<![CDATA[select
      COALESCE(mp.value, '') AS "codigo"
    , COALESCE(mp.NAME, atpt.descripcion) AS "NAME_PRODUCT"
    , (case When mp.producttype = 'S' Then atpt.cantidad
	ELSE	atpt.em_sswos_transfer END) AS "cantidad"
    , atpt.atindpo_pricelist AS "TARIFA"
    , (atpt.atindpo_pricelist * (case When mp.producttype = 'S' Then atpt.cantidad
	ELSE	atpt.em_sswos_transfer END)) AS "TOTAL_SINDESCUENTO"
    , atpt.atindpo_discount AS "DESCUENTO"
    , atpt.atindpo_valdescuento AS "V_DESCUENTO"
    ,  (case When mp.producttype = 'S' Then ROUND((atpt.cantidad*atpt.atindpo_pricelist),2)
	ELSE	 ROUND((atpt.em_sswos_transfer*atpt.atindpo_pricelist),2) END)
	AS "NETO"
    ,  (case When mp.producttype = 'S' Then ROUND((atpt.cantidad*atpt.atindpo_pricelist)*0.12,2)
	ELSE	 ROUND((atpt.em_sswos_transfer*atpt.atindpo_pricelist)*0.12,2) END)
	AS "IVA"
    ,  (case When mp.producttype = 'S' Then ROUND((atpt.cantidad*atpt.atindpo_pricelist),2) + ROUND((atpt.cantidad*atpt.atindpo_pricelist)*0.12,2)
	ELSE	 ROUND((atpt.em_sswos_transfer*atpt.atindpo_pricelist),2) + ROUND((atpt.em_sswos_transfer*atpt.atindpo_pricelist)*0.12,2) END)
	AS "TOTAL" 
    , CASE WHEN mp.producttype = 'I' THEN 'Repuestos'
         WHEN mp.producttype = 'S' THEN 'Servicios' END AS "tipo"
    , coalesce(sc.name,'Sin subcategoría') as "sub_categoria"
from atindpo_postventalinea as atpt
	Left join m_product as mp on (atpt.m_product_id = mp.m_product_id)
	Left join slps_product_category sc on sc.slps_product_category_id = mp.em_slps_product_category_id
where atpt.atindpo_postventa_id = $P{DOCUMENT_ID}
AND  (case When mp.producttype = 'S' Then atpt.cantidad > 0
	ELSE atpt.em_sswos_transfer > 0 END)
order by "tipo",sc.name]]>
	</queryString>
