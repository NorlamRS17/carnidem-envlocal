<?xml version="1.0" encoding="UTF-8"?>
<jasperReport xmlns="http://jasperreports.sourceforge.net/jasperreports" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://jasperreports.sourceforge.net/jasperreports http://jasperreports.sourceforge.net/xsd/jasperreport.xsd" name="Rpt_atindpo_Prefactura_subreport1" pageWidth="555" pageHeight="802" columnWidth="535" leftMargin="0" rightMargin="0" topMargin="0" bottomMargin="0" uuid="2be491a7-90c0-4293-ba6a-522377c0c733">
	<property name="ireport.zoom" value="1.6105100000000023"/>
	<property name="ireport.x" value="0"/>
	<property name="ireport.y" value="0"/>
