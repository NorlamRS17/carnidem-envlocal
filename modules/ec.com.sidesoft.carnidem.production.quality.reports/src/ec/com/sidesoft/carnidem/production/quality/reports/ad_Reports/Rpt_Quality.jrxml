	</parameter>
	<queryString>
		<![CDATA[SELECT bp.name as proveedor
,p.name as material
,COALESCE(s.observation,'') AS observation
,ROW_NUMBER() OVER (PARTITION BY s.ma_measure_shift_id ORDER BY v.SeqNo) rn
,em_spquly_deliverdate as fecha_entrega
,COALESCE(em_spquly_samplesize,'') as t_muestra
,COALESCE(ai.description,'') as lote
,s.measuredate as fecha_medida
,ord.dateordered as fecha_pedido
,s.em_crprod_documentno as documentno
,inorg.name as lugar_entrega
,stat.value as estado_analisis
,s.em_crprod_unitprice as iva_unitprice
,s.em_spquly_licenseplate as placa
,s.em_spquly_checkin as h_arribo
,s.em_spquly_outsidecleanliness as l_exterior
,s.em_spquly_insidecleanliness as l_interior
,s.em_spquly_protectionpollution as p_cont
,s.EM_Spquly_Totalqty as qty_reb
,mc.name as p_control
,v.valuetype
,SUM(COALESCE(v_number,0)) as v_number
,AVG(COALESCE(v_number,0)) as v_number_prom
,cg.name as grupo
,op.name as org_name
,s.ad_org_id
,mc.ma_ccp_id
,COALESCE(um.name,'') as unidad
,usr.username as f1_name
,usr.Title as f1_cargo
,sig.name as f2_name
,sig.position as f2_cargo
,COALESCE(cg.description, '') as description
FROM ma_measure_shift s
LEFT JOIN c_doctype dtype ON dtype.c_doctype_id = s.em_crprod_c_doctypetarget_id
LEFT JOIN (
	SELECT DISTINCT ON (c_doctype_id) c_doctype_id, name, line, position
	FROM scsdc_signaturesperdoc
	Where isactive = 'Y'
	ORDER BY c_doctype_id, line ASC
) sig ON sig.c_doctype_id = dtype.c_doctype_id
LEFT JOIN ad_user usr ON usr.ad_user_id = s.createdby
LEFT JOIN crprqy_params_status stat ON stat.crprqy_params_status_id = s.em_crprod_status_id
LEFT JOIN M_InOut ino ON ino.M_InOut_id = s.em_spquly_inout_id
LEFT JOIN AD_Org inorg ON inorg.AD_Org_id = s.AD_Org_id
LEFT JOIN c_orderline ol ON ol.c_orderline_id = s.em_crprod_orderline_id
LEFT JOIN c_order ord ON ord.c_order_id = ol.c_order_id
LEFT JOIN c_uom_trl um ON um.c_uom_id=s.EM_Spquly_Uom_ID
LEFT JOIN c_bpartner bp ON bp.c_bpartner_id=s.em_spquly_supplier_id
LEFT JOIN m_product p ON p.m_product_id=s.em_spquly_product_id
LEFT JOIN m_attributesetinstance ai ON ai.m_attributesetinstance_id=s.em_spquly_attrsi_id
JOIN ma_measure_group g ON g.ma_measure_shift_id=s.ma_measure_shift_id
JOIN ma_ccp_group cg ON cg.ma_ccp_group_id=g.ma_ccp_group_id
JOIN ma_measure_time t ON t.ma_measure_group_id=g.ma_measure_group_id
JOIN ma_measure_values v ON v.ma_measure_time_id=t.ma_measure_time_id
LEFT JOIN ma_ccp mc ON mc.ma_ccp_id=v.ma_ccp_id
LEFT JOIN (SELECT org.name
FROM ad_org_tree ot
JOIN ad_org org ON org.ad_org_id=ot.ad_org_id
WHERE levelno=2 AND ad_parent_org_id='0'
AND org.ad_orgtype_id = '1') op ON 1=1
WHERE s.ma_measure_shift_id= $P{DOCUMENT_ID}
GROUP BY s.ma_measure_shift_id,bp.name,material,lote,p_control,v.valuetype,grupo,org_name,mc.ma_ccp_id,unidad, ord.dateordered, inorg.name, stat.value, usr.username, usr.Title, sig.name, sig.position,v.seqno, cg.description
order by v.seqno]]>
	</queryString>
