	<parameter name="SUBREPORT_DIR" class="java.lang.String" isForPrompting="false">
		<defaultValueExpression><![CDATA["C:\\FormatosImpresion\\Pedido de Venta Originales\\"]]></defaultValueExpression>
	</parameter>
	<parameter name="BASE_DESIGN" class="java.lang.String" isForPrompting="false"/>
	<parameter name="M_AttributeInstance_ID" class="java.lang.String">
		<defaultValueExpression><![CDATA[]]></defaultValueExpression>
	</parameter>
	<parameter name="bpid" class="java.lang.String"/>
	<parameter name="DATE_TO" class="java.util.Date"/>
	<parameter name="DATE_FROM" class="java.util.Date"/>
	<parameter name="Average" class="java.lang.String"/>
	<parameter name="Summation" class="java.lang.String"/>
	<parameter name="Monitoring_type" class="java.lang.String"/>
	<parameter name="Type_safety_monitoring" class="java.lang.String"/>
	<queryString>
		<![CDATA[select
ms.Measuredate as fechamedida,
bp.name as bpname,
ms.EM_Crprod_Documentno as documentno,
COALESCE(ccp.name, '') as spainTypeMonitor,
mp.name as product,
Coalesce(sum(val.v_number), 0) as calificacion

from MA_Measure_Values val
INNER JOIN MA_Measure_Time mt ON mt.MA_Measure_Time_id = val.MA_Measure_Time_id
INNER JOIN MA_Measure_Group mg ON mg.MA_Measure_Group_id = mt.MA_Measure_Group_id
INNER JOIN MA_Measure_Shift ms ON ms.MA_Measure_Shift_id = mg.MA_Measure_Shift_id

LEFT JOIN c_bpartner bp on bp.c_bpartner_id = ms.EM_Spquly_Supplier_ID
LEFT JOIN m_product mp on mp.m_product_id = ms.EM_Spquly_Product_ID

LEFT JOIN MA_CCP_Group ccp ON ccp.MA_CCP_Group_ID = ms.EM_Spquly_Ccp_ID

LEFT JOIN ad_ref_list arl ON arl.value = ms.EM_Spquly_Qualitycontroltype AND arl.ad_reference_id = '6B8AF41C5C624034840F993F342D321B'
LEFT JOIN ad_ref_list_trl art ON art.ad_ref_list_id = arl.ad_ref_list_id AND art.ad_language = 'es_ES'
where ($P{DATE_FROM} <= ms.Measuredate AND $P{DATE_TO} >= ms.Measuredate)
AND (ms.EM_Spquly_Supplier_ID = $P{bpid})
AND ($P{Type_safety_monitoring} = ms.EM_Spquly_Qualitycontroltype )
AND (ms.EM_Spquly_Ccp_ID = $P{Monitoring_type} or $P{Monitoring_type} IS NULL)
AND ms.em_ssfdc_status = 'CP'
group by ms.Measuredate, bp.name, ms.EM_Crprod_Documentno, ccp.name, mp.name
order by ms.Measuredate]]>
	</queryString>
	<field name="fechamedida" class="java.sql.Timestamp"/>
	<field name="bpname" class="java.lang.String"/>
	<field name="documentno" class="java.lang.String"/>
	<field name="spaintypemonitor" class="java.lang.String"/>
	<field name="product" class="java.lang.String"/>
	<field name="calificacion" class="java.math.BigDecimal"/>
	<variable name="sumatoria" class="java.math.BigDecimal" calculation="Sum">
		<variableExpression><![CDATA[$F{calificacion}]]></variableExpression>
		<initialValueExpression><![CDATA[0]]></initialValueExpression>
	</variable>
	<variable name="promedio" class="java.lang.String"/>
	<variable name="CountValues" class="java.math.BigDecimal" calculation="Count">
		<variableExpression><![CDATA[$F{calificacion}]]></variableExpression>
		<initialValueExpression><![CDATA[0]]></initialValueExpression>
	</variable>
