<?xml version="1.0" encoding="UTF-8"?>
<jasperReport xmlns="http://jasperreports.sourceforge.net/jasperreports" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://jasperreports.sourceforge.net/jasperreports http://jasperreports.sourceforge.net/xsd/jasperreport.xsd" name="Rpt_CarnidemProductionCost" pageWidth="1750" pageHeight="842" columnWidth="1710" leftMargin="20" rightMargin="20" topMargin="20" bottomMargin="20" uuid="6047e1bf-ba94-410d-af53-0170088b6001">
	<property name="ireport.zoom" value="1.0000000000000044"/>
	<property name="ireport.x" value="0"/>
	<property name="ireport.y" value="0"/>
	<property name="net.sf.jasperreports.export.xls.detect.cell.type" value="true"/>
	<parameter name="NUMBERFORMAT" class="java.text.DecimalFormat" isForPrompting="false">
		<defaultValueExpression><![CDATA[new DecimalFormat("###,##0.00;-###,##0.00", new DecimalFormatSymbols())]]></defaultValueExpression>
	</parameter>
	<parameter name="NUMBERDECIMAL" class="java.lang.Integer" isForPrompting="false">
		<defaultValueExpression><![CDATA[2]]></defaultValueExpression>
	</parameter>
	<parameter name="STARTDATE" class="java.util.Date">
		<defaultValueExpression><![CDATA[]]></defaultValueExpression>
	</parameter>
	<parameter name="ENDDATE" class="java.util.Date">
		<defaultValueExpression><![CDATA[]]></defaultValueExpression>
	</parameter>
	<parameter name="M_PRODUCT_ID" class="java.lang.String">
		<defaultValueExpression><![CDATA[]]></defaultValueExpression>
	</parameter>
	<parameter name="MA_WORKREQUIREMENT_ID" class="java.lang.String">
		<defaultValueExpression><![CDATA[]]></defaultValueExpression>
	</parameter>
	<queryString>
		<![CDATA[SELECT
producto
,codigo
,max(starttime) AS starttime
,max(endtime) AS endtime
,orden_fabricacion
,(cantidad) AS cantidad
,materia_prima
,mano_obra
,costo_directo
,maquina
,costo
,fechaimpresion
,max(fechacreacion) AS fechacreacion
,ad_org_id
,parte_produccion
,totalorden
,priceprod
,nombre_ccosto
,( CASE WHEN costo>0 AND cantidad >0 THEN (costo/cantidad) ELSE 0 END) AS costunit
FROM
(
  SELECT
  mprod.name AS producto
  , mprod.value AS codigo,
  ( TO_CHAR(mpplan.starttime,'DD') || (
  CASE
  WHEN TO_CHAR(mpplan.starttime,'MM') = '01' THEN '-Enero-'
  WHEN TO_CHAR(mpplan.starttime,'MM') = '02' THEN '-Febrero-'
  WHEN TO_CHAR(mpplan.starttime,'MM') = '03' THEN '-Marzo-'
  WHEN TO_CHAR(mpplan.starttime,'MM') = '04' THEN '-Abril-'
  WHEN TO_CHAR(mpplan.starttime,'MM') = '05' THEN '-Mayo-'
  WHEN TO_CHAR(mpplan.starttime,'MM') = '06' THEN '-Junio-'
  WHEN TO_CHAR(mpplan.starttime,'MM') = '07' THEN '-Julio-'
  WHEN TO_CHAR(mpplan.starttime,'MM') = '08' THEN '-Agosto-'
  WHEN TO_CHAR(mpplan.starttime,'MM') = '09' THEN '-Septiembre-'
  WHEN TO_CHAR(mpplan.starttime,'MM') = '10' THEN '-Octubre-'
  WHEN TO_CHAR(mpplan.starttime,'MM') = '11' THEN '-Noviembre-'
  WHEN TO_CHAR(mpplan.starttime,'MM') = '12' THEN '-Diciembre-'
        END) || TO_CHAR(mpplan.starttime,'YYYY')) AS starttime
  , (TO_CHAR(mpplan.endtime,'DD') || (
  CASE
  WHEN TO_CHAR(mpplan.endtime,'MM') = '01' THEN '-Enero-'
  WHEN TO_CHAR(mpplan.endtime,'MM') = '02' THEN '-Febrero-'
  WHEN TO_CHAR(mpplan.endtime,'MM') = '03' THEN '-Marzo-'
  WHEN TO_CHAR(mpplan.endtime,'MM') = '04' THEN '-Abril-'
  WHEN TO_CHAR(mpplan.endtime,'MM') = '05' THEN '-Mayo-'
  WHEN TO_CHAR(mpplan.endtime,'MM') = '06' THEN '-Junio-'
  WHEN TO_CHAR(mpplan.endtime,'MM') = '07' THEN '-Julio-'
  WHEN TO_CHAR(mpplan.endtime,'MM') = '08' THEN '-Agosto-'
  WHEN TO_CHAR(mpplan.endtime,'MM') = '09' THEN '-Septiembre-'
  WHEN TO_CHAR(mpplan.endtime,'MM') = '10' THEN '-Octubre-'
  WHEN TO_CHAR(mpplan.endtime,'MM') = '11' THEN '-Noviembre-'
  WHEN TO_CHAR(mpplan.endtime,'MM') = '12' THEN '-Diciembre-'
        END) ||
  TO_CHAR(mpplan.endtime,'YYYY')) AS  endtime
  , mwr.documentno AS orden_fabricacion
  , mp.documentno AS parte_produccion
  , (mpplan.ProductionQty) AS cantidad
  , coalesce(mprim.materia_prima,0) AS materia_prima
  , coalesce(mobra.mano_obra,0) AS mano_obra
  , coalesce(cdirecto.costo_directo,0) AS costo_directo
  , coalesce(maq.maquina,0) AS maquina
  , (coalesce(round(mprim.materia_prima,2),0)+
    coalesce(round(mobra.mano_obra,2),0) +
    coalesce(round(cdirecto.costo_directo,2),0)+
    coalesce(round(maq.maquina,2),0))   AS costo
  , now() AS fechaimpresion
  , mp.movementdate AS fechacreacion
  , mp.ad_org_id
  ,totalorden
  ,priceprod
  ,(COALESCE(mccv.documentno,'') || ' - ' || COALESCE(mcc.value,'') || ' - ' || COALESCE(TO_CHAR(mccv.validfrom,'DD/MM/YYYY'),'')) AS nombre_ccosto
  --,mpplan.M_ProductionPlan_id
  FROM M_Production mp
  JOIN M_ProductionPlan mpplan ON mp.M_Production_id = mpplan.M_Production_id
  LEFT JOIN MA_CostCenter_Version mccv ON mccv.MA_CostCenter_Version_ID = mpplan.MA_CostCenter_Version_ID
  LEFT JOIN MA_CostCenter mcc ON mcc.MA_CostCenter_ID = mccv.MA_CostCenter_ID
  JOIN MA_WRPhase mwp ON mwp.MA_WRPhase_id = mpplan.MA_WRPhase_id
  JOIN MA_WorkRequirement mwr ON mwr.MA_WorkRequirement_id =mwp.MA_WorkRequirement_id
  LEFT JOIN (
    SELECT * FROM M_ProductionLine WHERE  productiontype='+'

  ) mpplineprod ON mpplineprod.M_ProductionPlan_id = mpplan.M_ProductionPlan_id

  LEFT JOIN m_product mprod ON mprod.m_product_id = mpplineprod.m_product_id

  LEFT JOIN (

    SELECT mwp.MA_WorkRequirement_id,sum(trunc(materia_prima,2)) AS materia_prima
      ,mpplan.m_production_id
    FROM
    (SELECT
      sum(mtc.cost) AS materia_prima
      ,mpl.M_ProductionPlan_id
      FROM m_transaction mt
        JOIN m_transaction_cost mtc ON mtc.m_transaction_id = mt.m_transaction_id
        JOIN M_ProductionLine mpl ON mt.M_ProductionLine_ID = mpl.M_ProductionLine_ID
      LEFT JOIN (
        SELECT MAX(mtc.costdate) AS datec,mt.M_ProductionLine_ID
        FROM m_transaction mt
          JOIN m_transaction_cost mtc ON mtc.m_transaction_id = mt.m_transaction_id
          JOIN M_ProductionLine mpl ON mt.M_ProductionLine_ID = mpl.M_ProductionLine_ID
        WHERE (COSTDATE)::date BETWEEN $P{STARTDATE} AND  $P{ENDDATE}
        GROUP BY mt.M_ProductionLine_ID
      ) ccost ON ( ccost.M_ProductionLine_ID = mpl.M_ProductionLine_ID AND ccost.datec = mtc.costdate )
      WHERE productiontype='-'
      GROUP BY mpl.M_ProductionLine_ID
    ) rep
      JOIN M_ProductionPlan mpplan ON rep.M_ProductionPlan_id = mpplan.M_ProductionPlan_id
      JOIN MA_WRPhase mwp ON mwp.MA_WRPhase_id = mpplan.MA_WRPhase_id
      JOIN MA_WorkRequirement mwr ON mwr.MA_WorkRequirement_id =mwp.MA_WorkRequirement_id
    WHERE (TRUNC(mpplan.endtime) BETWEEN $P{STARTDATE} AND $P{ENDDATE})
      AND (TRUNC(mpplan.starttime) BETWEEN $P{STARTDATE} AND $P{ENDDATE})
    GROUP BY mwp.MA_WorkRequirement_id,mpplan.m_production_id

  ) mprim ON mprim.MA_WorkRequirement_id = mwp.MA_WorkRequirement_id AND mprim.m_production_id = mp.m_production_id

  LEFT JOIN (
    SELECT round(sum(mppline.calccost),2) AS mano_obra,mwr.MA_WorkRequirement_id
      ,mpplan.m_production_id
    FROM MA_PL_Employee mppline
      JOIN M_ProductionPlan mpplan ON mpplan.M_ProductionPlan_id = mppline.M_ProductionPlan_id
      JOIN MA_WRPhase mwp ON mwp.MA_WRPhase_id = mpplan.MA_WRPhase_id
      JOIN MA_WorkRequirement mwr ON mwr.MA_WorkRequirement_id =mwp.MA_WorkRequirement_id
    WHERE (TRUNC(mpplan.endtime) BETWEEN $P{STARTDATE} AND $P{ENDDATE})
      AND (TRUNC(mpplan.starttime) BETWEEN $P{STARTDATE} AND $P{ENDDATE})
    GROUP BY mwr.MA_WorkRequirement_id,mpplan.m_production_id
  ) mobra ON mobra.MA_WorkRequirement_id = mwr.MA_WorkRequirement_id AND mobra.m_production_id = mp.m_production_id

  LEFT JOIN (
    SELECT round(sum(mppline.calccost),2) AS costo_directo,mwr.MA_WorkRequirement_id
      ,mpplan.m_production_id
    FROM MA_PL_IC mppline
      JOIN M_ProductionPlan mpplan ON mpplan.M_ProductionPlan_id = mppline.M_ProductionPlan_id
      JOIN MA_WRPhase mwp ON mwp.MA_WRPhase_id = mpplan.MA_WRPhase_id
      JOIN MA_WorkRequirement mwr ON mwr.MA_WorkRequirement_id = mwp.MA_WorkRequirement_id
    WHERE (TRUNC(mpplan.endtime) BETWEEN $P{STARTDATE} AND $P{ENDDATE})
      AND (TRUNC(mpplan.starttime) BETWEEN $P{STARTDATE} AND $P{ENDDATE})
    GROUP BY mwr.MA_WorkRequirement_id,mpplan.m_production_id
  ) cdirecto ON cdirecto.MA_WorkRequirement_id = mwr.MA_WorkRequirement_id AND cdirecto.m_production_id = mp.m_production_id

  LEFT JOIN (
    SELECT round(sum(mppline.calccost),2) AS maquina, mwr.MA_WorkRequirement_id
      ,mpplan.m_production_id
    FROM MA_PL_Machine mppline
      JOIN M_ProductionPlan mpplan ON mpplan.M_ProductionPlan_id = mppline.M_ProductionPlan_id
      JOIN MA_WRPhase mwp ON mwp.MA_WRPhase_id = mpplan.MA_WRPhase_id
      JOIN MA_WorkRequirement mwr ON mwr.MA_WorkRequirement_id =mwp.MA_WorkRequirement_id
    WHERE (TRUNC(mpplan.endtime) BETWEEN $P{STARTDATE} AND $P{ENDDATE})
      AND (TRUNC(mpplan.starttime) BETWEEN $P{STARTDATE} AND $P{ENDDATE})
    GROUP BY mwr.MA_WorkRequirement_id,mpplan.m_production_id
  ) maq ON maq.MA_WorkRequirement_id = mwr.MA_WorkRequirement_id AND maq.m_production_id = mp.m_production_id

  LEFT JOIN (
      SELECT
      sum(cantidad) AS totalorden
      ,MA_WorkRequirement_id
      FROM
      (SELECT DISTINCT
        mwr.MA_WorkRequirement_id
        , (mpplan.ProductionQty) AS cantidad
        , mpplan.M_ProductionPlan_id
        FROM M_Production mp
          JOIN M_ProductionPlan mpplan ON mp.M_Production_id = mpplan.M_Production_id
          JOIN MA_WRPhase mwp ON mwp.MA_WRPhase_id = mpplan.MA_WRPhase_id
          JOIN MA_WorkRequirement mwr ON mwr.MA_WorkRequirement_id =mwp.MA_WorkRequirement_id
        WHERE mpplan.processed='Y'
        AND (TRUNC(mpplan.endtime) BETWEEN $P{STARTDATE} AND $P{ENDDATE})
        AND (TRUNC(mpplan.starttime) BETWEEN  $P{STARTDATE} AND $P{ENDDATE})
        ) repcant
      GROUP BY MA_WorkRequirement_id
  ) canttot ON canttot.MA_WorkRequirement_id = mwr.MA_WorkRequirement_id
  LEFT JOIN (
    SELECT * FROM (SELECT mpr.m_product_id,mpv.Validfrom,coalesce(pricestd,0) AS priceprod,mpv.name,p.name AS producto
    ,ROW_NUMBER() OVER (PARTITION BY mpr.m_product_id ORDER BY mpr.m_product_id, Validfrom desc ) AS rn
    FROM m_pricelist mp
      JOIN m_pricelist_version mpv ON mpv.m_pricelist_id = mp.m_pricelist_id
      JOIN m_productprice mpr ON mpr.m_pricelist_version_id = mpv.m_pricelist_version_id
      JOIN m_product p ON mpr.m_product_id = p.m_product_id
    WHERE mp.issopricelist = 'Y' AND mp.isactive = 'Y'
      AND mpv.isactive='Y' AND mpr.isactive='Y' AND p.isactive='Y'
      AND TRUNC(Validfrom) <= TRUNC(NOW())
    ) AS ln WHERE ln.rn = 1
  ) costprod ON costprod.m_product_id = mpplineprod.m_product_id
  WHERE mpplan.processed='Y'
    AND mpplineprod.productiontype = '+'
    AND (TRUNC(mpplan.endtime) BETWEEN $P{STARTDATE} AND $P{ENDDATE})
    AND (TRUNC(mpplan.starttime) BETWEEN $P{STARTDATE} AND $P{ENDDATE})
    AND (mpplineprod.m_product_id =$P{M_PRODUCT_ID}  OR $P{M_PRODUCT_ID} IS NULL)
    AND (mwr.MA_WorkRequirement_id=$P{MA_WORKREQUIREMENT_ID} OR $P{MA_WORKREQUIREMENT_ID} IS NULL)
) rep
GROUP BY 1,2,5,6,7,8,9,10,11,12,14,parte_produccion,totalorden,priceprod,nombre_ccosto
ORDER BY 5]]>
	</queryString>
	<field name="producto" class="java.lang.String"/>
	<field name="codigo" class="java.lang.String"/>
	<field name="starttime" class="java.lang.String"/>
	<field name="endtime" class="java.lang.String"/>
	<field name="orden_fabricacion" class="java.lang.String"/>
	<field name="cantidad" class="java.math.BigDecimal"/>
	<field name="materia_prima" class="java.math.BigDecimal"/>
	<field name="mano_obra" class="java.math.BigDecimal"/>
	<field name="costo_directo" class="java.math.BigDecimal"/>
	<field name="maquina" class="java.math.BigDecimal"/>
	<field name="costo" class="java.math.BigDecimal"/>
	<field name="fechaimpresion" class="java.sql.Timestamp"/>
	<field name="fechacreacion" class="java.sql.Timestamp"/>
	<field name="ad_org_id" class="java.lang.String"/>
	<field name="parte_produccion" class="java.lang.String"/>
	<field name="totalorden" class="java.math.BigDecimal"/>
	<field name="priceprod" class="java.math.BigDecimal"/>
	<field name="nombre_ccosto" class="java.lang.String"/>
	<field name="costunit" class="java.math.BigDecimal"/>
