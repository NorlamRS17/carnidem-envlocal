	</parameter>
	<queryString>
		<![CDATA[SELECT *, x.periodicidad,
CASE WHEN x.qty_stock > 0 and calc_periodicidad>0 THEN  ROUND(x.qty_stock/calc_periodicidad,6)
ELSE 0 END AS promedio_inv
 FROM (SELECT TO_CHAR(NOW(),'dd/mm/yyyy HH24:MI:SS') as fecha_impresion
,p.value as code
,p.name as producto
,op.name as org_parent
,mpc.name as categoria
,u.name as unit
,CASE WHEN $P{Periodicity}='S' THEN 'SEMANAL'
WHEN $P{Periodicity}='M' THEN 'MENSUAL'
END as periodicidad
,sum(qtyinvoiced) as qty_invoiced
,max(COALESCE(stock,0)) as qty_stock
,sum(COALESCE(promedio_stock,0)) as promedio_stock
,CASE WHEN $P{Periodicity}='S' THEN (COALESCE($P{DateTo},TRUNC(NOW()))-COALESCE($P{DateFrom},TRUNC(NOW()))+1)/7
WHEN $P{Periodicity}='M' THEN (
    CASE WHEN (SELECT EXTRACT(MONTH FROM COALESCE($P{DateFrom},TRUNC(NOW())))) = 2 AND (SELECT EXTRACT(MONTH FROM COALESCE($P{DateTo},TRUNC(NOW())))) = 2
    AND (COALESCE($P{DateTo},TRUNC(NOW()))-COALESCE($P{DateFrom},TRUNC(NOW()))) + 1 = EXTRACT(DAY FROM DATE_TRUNC('month',COALESCE($P{DateTo},TRUNC(NOW()))) + INTERVAL '1 MONTH' - INTERVAL '1 DAY')
    THEN 1
    ElSE (COALESCE($P{DateTo},TRUNC(NOW()))-COALESCE($P{DateFrom},TRUNC(NOW()))+1)/ 30 END
)
END as calc_periodicidad
, st.warehouse_name as warehouse_name
, ROUND(abs(COALESCE(pe.stock_avg,0))) as stock_avg
, COALESCE(sl.sales,0) as sales
, COALESCE(CASE WHEN TRUNC(abs(pe.stock_avg)) != 0 THEN sl.i_rotation/TRUNC(abs(pe.stock_avg))
ELSE 0 END,0) as inv_rotation
FROM c_invoice i
JOIN c_invoiceline il ON il.c_invoice_id=i.c_invoice_id
left join c_doctype cdt on cdt.c_doctype_id = i.c_doctype_id
JOIN m_product p ON p.m_product_id=il.m_product_id
LEFT JOIN m_product_category mpc ON mpc.m_product_category_id=p.m_product_category_id
LEFT JOIN c_uom_trl u ON u.c_uom_id=p.c_uom_id AND ad_language='es_ES'
LEFT JOIN m_warehouse mwh ON mwh.m_warehouse_id=p.em_ssrs_m_warehouse_id
LEFT JOIN (SELECT avg(movementqty) as promedio_stock,sum(movementqty) as stock, m_product_id
, CASE WHEN ($P{M_Warehouse_ID} is null OR $P{M_Warehouse_ID} = '') THEN null
ELSE wh.m_warehouse_id END as m_warehouse_idd
, CASE WHEN ($P{M_Warehouse_ID} is null OR $P{M_Warehouse_ID} = '') THEN null
ELSE wh.name END as warehouse_name
FROM m_transaction mt
LEFT JOIN m_locator lt ON lt.m_locator_id = mt.m_locator_id
LEFT JOIN m_warehouse wh ON wh.m_warehouse_id = lt.m_warehouse_id
WHERE movementdate <= $P{DateTo}
AND (wh.m_warehouse_id = $P{M_Warehouse_ID} OR $P{M_Warehouse_ID} is null)
GROUP BY m_product_id, m_warehouse_idd, warehouse_name) st ON st.m_product_id=p.m_product_id

LEFT JOIN (SELECT (sum(movementqty)/pq.qty_period) as stock_avg, m_product_id
, CASE WHEN ($P{M_Warehouse_ID} is null OR $P{M_Warehouse_ID} = '') THEN null
ELSE wh.m_warehouse_id END as m_warehouse_idd
FROM m_transaction mt
LEFT JOIN m_locator lt ON lt.m_locator_id = mt.m_locator_id
LEFT JOIN m_warehouse wh ON wh.m_warehouse_id = lt.m_warehouse_id
LEFT JOIN (select CASE WHEN $P{Periodicity}='S' THEN (COALESCE($P{DateTo},TRUNC(NOW()))-COALESCE($P{DateFrom},TRUNC(NOW()))+1)/7
WHEN $P{Periodicity}='M' THEN (
    CASE WHEN (SELECT EXTRACT(MONTH FROM COALESCE($P{DateFrom},TRUNC(NOW())))) = 2 AND (SELECT EXTRACT(MONTH FROM COALESCE($P{DateTo},TRUNC(NOW())))) = 2
    AND (COALESCE($P{DateTo},TRUNC(NOW()))-COALESCE($P{DateFrom},TRUNC(NOW()))) + 1 = EXTRACT(DAY FROM DATE_TRUNC('month',COALESCE($P{DateTo},TRUNC(NOW()))) + INTERVAL '1 MONTH' - INTERVAL '1 DAY')
    THEN 1
    ElSE (COALESCE($P{DateTo},TRUNC(NOW()))-COALESCE($P{DateFrom},TRUNC(NOW()))+1)/ 30 END
)
END AS qty_period
FROM dual) pq on 1=1
WHERE movementdate <= $P{DateTo}
AND movementdate >= $P{DateFrom}
AND (wh.m_warehouse_id = $P{M_Warehouse_ID} OR $P{M_Warehouse_ID} is null)
GROUP BY m_product_id,pq.qty_period,m_warehouse_idd) pe ON pe.m_product_id=p.m_product_id

LEFT JOIN (SELECT TRUNC(abs(sum(movementqty))) as sales, abs(sum(movementqty)/pq.qty_period) as i_rotation, m_product_id
, CASE WHEN ($P{M_Warehouse_ID} is null OR $P{M_Warehouse_ID} = '') THEN null
ELSE wh.m_warehouse_id END as m_warehouse_idd
FROM m_transaction mt
LEFT JOIN m_locator lt ON lt.m_locator_id = mt.m_locator_id
LEFT JOIN m_warehouse wh ON wh.m_warehouse_id = lt.m_warehouse_id
LEFT JOIN (select CASE WHEN $P{Periodicity}='S' THEN (COALESCE($P{DateTo},TRUNC(NOW()))-COALESCE($P{DateFrom},TRUNC(NOW()))+1)/7
WHEN $P{Periodicity}='M' THEN (
    CASE WHEN (SELECT EXTRACT(MONTH FROM COALESCE($P{DateFrom},TRUNC(NOW())))) = 2 AND (SELECT EXTRACT(MONTH FROM COALESCE($P{DateTo},TRUNC(NOW())))) = 2
    AND (COALESCE($P{DateTo},TRUNC(NOW()))-COALESCE($P{DateFrom},TRUNC(NOW()))) + 1 = EXTRACT(DAY FROM DATE_TRUNC('month',COALESCE($P{DateTo},TRUNC(NOW()))) + INTERVAL '1 MONTH' - INTERVAL '1 DAY')
    THEN 1
    ElSE (COALESCE($P{DateTo},TRUNC(NOW()))-COALESCE($P{DateFrom},TRUNC(NOW()))+1)/ 30 END
)
END AS qty_period
FROM dual) pq on 1=1
WHERE movementdate <= $P{DateTo}
AND movementdate >= $P{DateFrom}
AND movementtype = 'C-'
AND (wh.m_warehouse_id = $P{M_Warehouse_ID} OR $P{M_Warehouse_ID} is null)
GROUP BY m_product_id,pq.qty_period,m_warehouse_idd) sl ON sl.m_product_id=p.m_product_id

LEFT JOIN (SELECT org.name
FROM ad_org_tree ot
JOIN ad_org org ON org.ad_org_id=ot.ad_org_id
WHERE levelno=2 AND ad_parent_org_id='0'
AND org.ad_orgtype_id = '1') op ON 1=1
WHERE docstatus='CO'
AND i.issotrx='Y'
AND dateinvoiced BETWEEN $P{DateFrom} AND $P{DateTo}
AND (p.m_product_id = $P{M_Product_ID} OR $P{M_Product_ID} is null)
AND (mpc.m_product_category_id = $P{M_Product_Category_ID} OR $P{M_Product_Category_ID} is null)
AND (st.m_warehouse_idd = $P{M_Warehouse_ID} OR $P{M_Warehouse_ID} is null)
and (cdt.DocBaseType<>'ARC' or cdt.Isreversal<>'N')
and p.issold = 'Y'
and p.isstocked = 'Y'
and p.producttype = 'I'
and $P{DateTo} > $P{DateFrom}
and CASE WHEN $P{Periodicity} = 'S' and (COALESCE($P{DateTo},TRUNC(NOW()))-COALESCE($P{DateFrom},TRUNC(NOW())))+1 >= 7 THEN true
WHEN $P{Periodicity} = 'M' THEN (
    CASE WHEN (SELECT EXTRACT(MONTH FROM COALESCE($P{DateFrom},TRUNC(NOW())))) = 2 AND (SELECT EXTRACT(MONTH FROM COALESCE($P{DateTo},TRUNC(NOW())))) = 2
    AND (COALESCE($P{DateTo},TRUNC(NOW()))-COALESCE($P{DateFrom},TRUNC(NOW()))) + 1 = EXTRACT(DAY FROM DATE_TRUNC('month',COALESCE($P{DateTo},TRUNC(NOW()))) + INTERVAL '1 MONTH' - INTERVAL '1 DAY')
    THEN true
    WHEN (COALESCE($P{DateTo},TRUNC(NOW()))-COALESCE($P{DateFrom},TRUNC(NOW())))+1 >= 30 THEN true END
) END
GROUP BY p.m_product_id,org_parent,mpc.name,u.name, warehouse_name, stock_avg, sales, inv_rotation
ORDER BY mpc.name) x]]>
	</queryString>
	<field name="fecha_impresion" class="java.lang.String"/>
	<field name="code" class="java.lang.String"/>
	<field name="producto" class="java.lang.String"/>
	<field name="org_parent" class="java.lang.String"/>
	<field name="categoria" class="java.lang.String"/>
	<field name="unit" class="java.lang.String"/>
	<field name="periodicidad" class="java.lang.String"/>
	<field name="qty_invoiced" class="java.math.BigDecimal"/>
	<field name="qty_stock" class="java.math.BigDecimal"/>
	<field name="promedio_stock" class="java.math.BigDecimal"/>
	<field name="calc_periodicidad" class="java.lang.Integer"/>
	<field name="warehouse_name" class="java.lang.String"/>
	<field name="stock_avg" class="java.math.BigDecimal"/>
	<field name="sales" class="java.math.BigDecimal"/>
	<field name="inv_rotation" class="java.math.BigDecimal"/>
	<field name="promedio_inv" class="java.math.BigDecimal"/>
	<variable name="REPORT_PAGE" class="java.lang.Integer" resetType="None" incrementType="Page">
		<variableExpression><![CDATA[$V{PAGE_NUMBER}]]></variableExpression>
	</variable>
	<variable name="TOTAL_VF" class="java.math.BigDecimal" calculation="Sum">
		<variableExpression><![CDATA[$F{qty_invoiced}]]></variableExpression>
	</variable>
	<variable name="TOTAL_PROMEDIO_INV" class="java.math.BigDecimal" calculation="Sum">
		<variableExpression><![CDATA[$F{promedio_stock}]]></variableExpression>
	</variable>
	<variable name="TOTAL_ROT" class="java.math.BigDecimal" calculation="Sum">
		<variableExpression><![CDATA[BigDecimal.ZERO.compareTo($F{promedio_stock}) == 0 ? BigDecimal.ZERO:$F{qty_invoiced}.divide($F{promedio_stock},$P{NUMBERDECIMAL},java.math.RoundingMode.HALF_DOWN)]]></variableExpression>
	</variable>
	<variable name="ivn_rot" class="java.lang.Double" calculation="Sum">
		<variableExpression><![CDATA[$F{inv_rotation}]]></variableExpression>
		<initialValueExpression><![CDATA[0]]></initialValueExpression>
	</variable>
	<variable name="count_line" class="java.lang.Double" calculation="Count">
		<variableExpression><![CDATA[$F{inv_rotation}]]></variableExpression>
	</variable>
