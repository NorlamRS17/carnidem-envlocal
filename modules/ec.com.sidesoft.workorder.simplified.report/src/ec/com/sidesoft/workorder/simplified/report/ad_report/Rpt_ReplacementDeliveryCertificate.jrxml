	<property name="ireport.y" value="96"/>
	<parameter name="BASE_DESIGN" class="java.lang.String" isForPrompting="false">
		<defaultValueExpression><![CDATA["C:/DesarrolloLuis/OpenbravoERPindumot/modules/com.atrums.indumot.postventa/src"]]></defaultValueExpression>
	</parameter>
	<parameter name="DOCUMENT_ID" class="java.lang.String"/>
	<parameter name="SOURCE_PATH" class="java.lang.String" isForPrompting="false">
		<defaultValueExpression><![CDATA[]]></defaultValueExpression>
	</parameter>
	<queryString>
		<![CDATA[Select ap.documentno as "n_orden_servicio"
	, cb.taxid as "cedula"
	, cb.name as "cliente"
	, c.address1 as "direccion"
	, ap.fecha as "fecha"
	, cl.phone as "telefono"
	-- Vehiculos
	, rlvv.name  as "tipo"
	, mp.name as "modelo"
	, ap.numeromotor as "numero_motor"
	, b.name as "marca"
	, y.name as "anio"
	, ap.numerochasis as "numero_chasis"
	, col.name as "color"
	, ap.placa as "placa"
	-- Datos del Conductor
	, ap.nombre as "con_nombre"
	, ap.apellido  as "con_apellido"
	, ap.cedula as "con_cedula"
	, ap.telefono as "con_telefono"
	, ap.celular as "con_celular"
	, mbp.name as "mecanico"
	, ap.orden_trabajo as "orden_trabajo"
	, ap.atindpo_postventa_id as ATINDPO_POSTVENTA_ID
	, ap.descripcioncliente as DESCRIPCION
From atindpo_postventa ap
	Join c_bpartner cb on ap.c_bpartner_id = cb.c_bpartner_id
	Join c_bpartner mbp on mbp.c_bpartner_id = ap.c_bpartner_emp_id
	Join c_bpartner_location cl on cl.c_bpartner_location_id = ap.c_bpartner_location_id
	Join c_location c on c.c_location_id=cl.c_location_id
	Left Join ssfi_model_prod mp on mp.ssfi_model_prod_id = ap.em_sswos_ssfi_model_prod_id
	Left Join m_brand b on b.m_brand_id = ap.em_sswos_m_brand_id
	Left Join sswos_color col on col.sswos_color_id = ap.em_sswos_color_id
	Left Join sswos_year y on y.sswos_year_id = ap.em_sswos_year_id
	Left Join ad_ref_list_v rlvv on rlvv.value = ap.lstipovehiculo and rlvv.ad_language = 'es_ES' and rlvv.ad_reference_id = 'B7D5195562CB492B86E6BB4DFEBD377E'
Where ap.atindpo_postventa_id = $P{DOCUMENT_ID}]]>
	</queryString>
