	<parameter name="DOCUMENT_ID" class="java.lang.String"/>
	<parameter name="NUMBERFORMAT" class="java.text.DecimalFormat" isForPrompting="false">
		<defaultValueExpression><![CDATA[new DecimalFormat("###,##0.00;-###,##0.00", new DecimalFormatSymbols())]]></defaultValueExpression>
	</parameter>
	<parameter name="NUMBERDECIMAL" class="java.lang.Integer">
		<defaultValueExpression><![CDATA[2]]></defaultValueExpression>
	</parameter>
	<queryString>
		<![CDATA[select mp.value AS "codigo"
	, mp.name AS "producto"
	, atpt.cantidad AS "cantidad"
	, atpt.atindpo_unitprice as "precio"
	, atpt.atindpo_iva as "iva"
	, atpt.atindpo_total as "total"
	, coalesce(sc.name,'Sin subcategoría') as "sub_categoria"
From atindpo_postventalinea atpt
	Left join m_product as mp on atpt.m_product_id = mp.m_product_id
	Left join slps_product_category sc on sc.slps_product_category_id = mp.em_slps_product_category_id
Where atpt.atindpo_postventa_id = $P{DOCUMENT_ID}
Order by sc.name, mp.name]]>
	</queryString>
