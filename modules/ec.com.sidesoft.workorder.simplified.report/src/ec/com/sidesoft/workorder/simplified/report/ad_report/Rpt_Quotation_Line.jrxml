	<field name="total" class="java.math.BigDecimal"/>
	<field name="sub_categoria" class="java.lang.String"/>
	<variable name="SUM_Total" class="java.math.BigDecimal" calculation="Sum">
		<variableExpression><![CDATA[$F{total}]]></variableExpression>
	</variable>
	<variable name="SUM_SubTotal" class="java.math.BigDecimal" resetType="Group" resetGroup="Sub_Category" calculation="Sum">
