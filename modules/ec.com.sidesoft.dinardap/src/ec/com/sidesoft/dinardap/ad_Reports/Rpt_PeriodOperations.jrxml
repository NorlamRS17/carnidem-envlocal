			<textField isStretchWithOverflow="true" isBlankWhenNull="true">
				<reportElement x="510" y="0" width="175" height="20"/>
				<box rightPadding="3"/>
				<textElement verticalAlignment="Middle"/>
				<textFieldExpression class="java.math.BigDecimal"><![CDATA[$F{total_cartera_periodo}]]></textFieldExpression>
			</textField>
			<textField isStretchWithOverflow="true" isBlankWhenNull="true">
				<reportElement x="288" y="0" width="113" height="20"/>
