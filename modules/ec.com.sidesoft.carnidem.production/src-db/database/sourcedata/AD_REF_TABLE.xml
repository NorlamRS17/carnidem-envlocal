<!--A0058979978A4CBC8739F50C2645704E-->  <WHERECLAUSE><![CDATA[M_ProductionPlan_ID IN (
  SELECT mpp.M_ProductionPlan_ID
  FROM M_ProductionPlan mpp
  JOIN MA_WRPhase mwp ON mpp.MA_WRPhase_ID = mwp.MA_WRPhase_ID
  JOIN MA_WorkRequirement mwr ON mwp.MA_WorkRequirement_ID = mwr.MA_WorkRequirement_ID
  JOIN M_Movement mm ON mm.EM_Ssfin_Ma_Workreq_ID = mwr.MA_WorkRequirement_ID
  WHERE mm.M_Movement_ID = @M_Movement_ID@
    AND mpp.Processed = 'Y'
    AND COALESCE(mpp.ProductionQty, 0) > 0
)
]]></WHERECLAUSE>
