  FROM M_Movement mm
  JOIN MA_WorkRequirement mwr ON mm.EM_Ssfin_Ma_Workreq_ID = mwr.MA_WorkRequirement_ID
  JOIN MA_WRPhase mwp ON mwp.MA_WorkRequirement_ID = mwr.MA_WorkRequirement_ID
  JOIN M_ProductionPlan mpp ON mpp.MA_WRPhase_ID = mwp.MA_WRPhase_ID
  WHERE mpp.Processed = 'Y'
    AND COALESCE(mpp.ProductionQty, 0) > 0
)
