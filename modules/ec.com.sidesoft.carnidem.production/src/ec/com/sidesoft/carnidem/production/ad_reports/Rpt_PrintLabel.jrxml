<?xml version="1.0" encoding="UTF-8"?>
<jasperReport xmlns="http://jasperreports.sourceforge.net/jasperreports" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://jasperreports.sourceforge.net/jasperreports http://jasperreports.sourceforge.net/xsd/jasperreport.xsd" name="Rpt_UsefulLifeProduct" pageWidth="255" pageHeight="85" orientation="Landscape" whenNoDataType="BlankPage" columnWidth="245" leftMargin="10" rightMargin="0" topMargin="0" bottomMargin="0" isSummaryWithPageHeaderAndFooter="true" uuid="cfaf7223-c06e-4591-8e0f-b406a2336150">
	<property name="ireport.zoom" value="1.9965000000000006"/>
	<property name="ireport.x" value="0"/>
	<property name="ireport.y" value="0"/>
	<property name="net.sf.jasperreports.export.xls.detect.cell.type" value="true"/>
	<parameter name="DATEFORMAT" class="java.text.SimpleDateFormat" isForPrompting="false">
		<defaultValueExpression><![CDATA[new SimpleDateFormat("dd/MM/yyyy")]]></defaultValueExpression>
	</parameter>
	<parameter name="NUMBERFORMAT" class="java.text.DecimalFormat" isForPrompting="false">
		<defaultValueExpression><![CDATA[new DecimalFormat("###,##0.00;-###,##0.00", new DecimalFormatSymbols())]]></defaultValueExpression>
	</parameter>
	<parameter name="NUMBERDECIMAL" class="java.lang.Integer" isForPrompting="false">
		<defaultValueExpression><![CDATA[2]]></defaultValueExpression>
	</parameter>
	<parameter name="BASE_WEB" class="java.lang.String" isForPrompting="false"/>
	<parameter name="SOURCE_PATH" class="java.lang.String" isForPrompting="false"/>
	<parameter name="DOCUMENT_ID" class="java.lang.String"/>
	<queryString>
		<![CDATA[select mm.name,mm.movementdate::date,concat(mwr.documentno, ' - ', mwr.Launchdate::date) as orden_fabricacion,mp.documentno,  ROUND(COALESCE(SUM(mml.movementqty), 0), 6) as cantidad_mov
from m_movement mm
left join MA_WorkRequirement mwr on mwr.MA_WorkRequirement_id = mm.EM_Ssfin_Ma_Workreq_ID
left join M_ProductionPlan mpp on mpp.M_ProductionPlan_id=mm.em_crprod_prodplan_id
left join m_production mp on mp.m_production_id=mpp.m_production_id
left join M_ProductionLine prodline on prodline.M_ProductionPlan_id=mpp.M_ProductionPlan_id and prodline.productiontype='+'
left join m_movementline mml on mml.m_movement_id=mm.m_movement_id
where mm.m_movement_id=$P{DOCUMENT_ID}
group by  mm.name,mm.movementdate,mwr.documentno,mwr.Launchdate,mp.documentno]]>
	</queryString>
	<field name="name" class="java.lang.String"/>
	<field name="movementdate" class="java.sql.Date"/>
	<field name="orden_fabricacion" class="java.lang.String"/>
	<field name="documentno" class="java.lang.String"/>
	<field name="cantidad_mov" class="java.math.BigDecimal"/>
	<variable name="REPORT_PAGE" class="java.lang.Integer" resetType="None" incrementType="Page">
		<variableExpression><![CDATA[$V{PAGE_NUMBER}]]></variableExpression>
	</variable>
