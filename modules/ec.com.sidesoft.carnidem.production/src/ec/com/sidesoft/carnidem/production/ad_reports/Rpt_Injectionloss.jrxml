<?xml version="1.0" encoding="UTF-8"?>
<jasperReport xmlns="http://jasperreports.sourceforge.net/jasperreports" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://jasperreports.sourceforge.net/jasperreports http://jasperreports.sourceforge.net/xsd/jasperreport.xsd" name="Rpt_Injectionloss" pageWidth="1325" pageHeight="842" columnWidth="1285" leftMargin="20" rightMargin="20" topMargin="20" bottomMargin="20" uuid="a1b2c3d4-e5f6-4a01-8001-000000000001">
	<property name="ireport.zoom" value="1.2100000000000155"/>
	<property name="ireport.x" value="613"/>
	<property name="ireport.y" value="0"/>
	<property name="net.sf.jasperreports.export.xls.detect.cell.type" value="true"/>
	<property name="net.sf.jasperreports.export.xls.wrap.text" value="false"/>
	<parameter name="DateFrom" class="java.util.Date"/>
	<parameter name="DateTo" class="java.util.Date"/>
	<parameter name="crprod_mproduct_id" class="java.lang.String"/>
	<parameter name="AD_User_ID" class="java.lang.String" isForPrompting="false"/>
	<parameter name="BASE_DESIGN" class="java.lang.String">
		<defaultValueExpression><![CDATA[]]></defaultValueExpression>
	</parameter>
	<parameter name="BASE_WEB" class="java.lang.String" isForPrompting="false"/>
	<queryString>
		<![CDATA[WITH wr_en_rango AS (
			SELECT ma_workrequirement_id FROM ma_workrequirement wr
			WHERE DATE(wr.launchdate) >= DATE($P{DateFrom}) AND DATE(wr.launchdate) <= DATE($P{DateTo})
		),
		coccion_pminus AS (
			SELECT DISTINCT ON (mwp.ma_workrequirement_id)
				mwp.ma_workrequirement_id,
				mpl_p.m_product_id AS pminus_product_id,
				mpl_p.m_attributesetinstance_id AS pminus_asi_id
			FROM ma_wrphase mwp
			JOIN wr_en_rango w ON w.ma_workrequirement_id = mwp.ma_workrequirement_id
			JOIN m_productionplan mpp_c ON mpp_c.ma_wrphase_id = mwp.ma_wrphase_id
			JOIN ma_costcenter_version ccv_c ON ccv_c.ma_costcenter_version_id = mpp_c.ma_costcenter_version_id
				AND ccv_c.ma_costcenter_id = '14451B6783C443EAB3D3F256A3F5A6FE'
			JOIN m_productionline mpl_p ON mpl_p.m_productionplan_id = mpp_c.m_productionplan_id
				AND mpl_p.productiontype = '-'
			ORDER BY mwp.ma_workrequirement_id, mpl_p.movementqty DESC NULLS LAST
		),
		curados_plan AS (
			SELECT DISTINCT ON (cp.ma_workrequirement_id)
				cp.ma_workrequirement_id,
				mpp_cu.m_productionplan_id AS curados_plan_id,
				COALESCE(mp_cu.documentno, '') AS parte_curados
			FROM coccion_pminus cp
			JOIN m_productionline mpl_plus ON mpl_plus.m_product_id = cp.pminus_product_id
				AND (mpl_plus.m_attributesetinstance_id = cp.pminus_asi_id OR (mpl_plus.m_attributesetinstance_id IS NULL AND cp.pminus_asi_id IS NULL))
				AND mpl_plus.productiontype = '+'
			JOIN m_productionplan mpp_cu ON mpp_cu.m_productionplan_id = mpl_plus.m_productionplan_id
			JOIN m_production mp_cu ON mp_cu.m_production_id = mpp_cu.m_production_id
			JOIN ma_costcenter_version ccv_cu ON ccv_cu.ma_costcenter_version_id = mpp_cu.ma_costcenter_version_id
				AND ccv_cu.ma_costcenter_id = '64A61E9EA1914D0C86D002759BFE5278'
			ORDER BY cp.ma_workrequirement_id, mpp_cu.m_productionplan_id
		),
		peso_por_orden AS (
			SELECT cp.ma_workrequirement_id,
				cp.parte_curados,
				(SELECT MAX(mpl_kg.movementqty)
				 FROM m_productionline mpl_kg
				 WHERE mpl_kg.m_productionplan_id = cp.curados_plan_id
				   AND mpl_kg.productiontype = '-'
				   AND mpl_kg.c_uom_id = '72BA247D31F745F3AF11F74A5E2CCBEF') AS peso_original_pmenos
			FROM curados_plan cp
		),
		suma_coccion AS (
			SELECT mwp.ma_workrequirement_id,
				COALESCE(SUM(mpl_c.movementqty), 0) AS suma_pplus_coccion
			FROM ma_wrphase mwp
			JOIN wr_en_rango w ON w.ma_workrequirement_id = mwp.ma_workrequirement_id
			JOIN m_productionplan mpp_c ON mpp_c.ma_wrphase_id = mwp.ma_wrphase_id
			JOIN ma_costcenter_version ccv_c ON ccv_c.ma_costcenter_version_id = mpp_c.ma_costcenter_version_id
				AND ccv_c.ma_costcenter_id = '14451B6783C443EAB3D3F256A3F5A6FE'
			JOIN m_productionline mpl_c ON mpl_c.m_productionplan_id = mpp_c.m_productionplan_id
				AND mpl_c.m_product_id::text = $P{crprod_mproduct_id}
				AND mpl_c.productiontype = '+'
			GROUP BY mwp.ma_workrequirement_id
		),
		orden_peso_merma AS (
			SELECT
				COALESCE(po.ma_workrequirement_id, sc.ma_workrequirement_id) AS ma_workrequirement_id,
				po.parte_curados,
				po.peso_original_pmenos,
				(COALESCE(sc.suma_pplus_coccion, 0) - COALESCE(po.peso_original_pmenos, 0)) AS merma
			FROM peso_por_orden po
			FULL OUTER JOIN suma_coccion sc ON sc.ma_workrequirement_id = po.ma_workrequirement_id
		)
		-- Una fila por orden de fabricación; las líneas de detalle las renderiza el subreporte
		SELECT DISTINCT ON (wr.ma_workrequirement_id)
			wr.ma_workrequirement_id::text AS ma_workrequirement_id,
			opm.peso_original_pmenos,
			COALESCE(opm.parte_curados, '') AS parte_curados,
			opm.merma,
			CASE WHEN opm.peso_original_pmenos IS NOT NULL AND opm.peso_original_pmenos <> 0
				THEN (opm.merma / opm.peso_original_pmenos) * (-1) * 100 ELSE NULL END AS pct_merma,
			CASE WHEN opm.peso_original_pmenos IS NOT NULL AND opm.peso_original_pmenos <> 0
				THEN 100 - ((opm.merma / opm.peso_original_pmenos) * (-1) * 100) ELSE NULL END AS eficiencia,
			COALESCE(sc.suma_pplus_coccion, 0) AS suma_pplus,
			mps.name AS producto_seleccionado,
			mp.ad_org_id AS organizationid,
			now() AS fechaimpresion,
			(SELECT au.name FROM ad_user au WHERE au.ad_user_id = $P{AD_User_ID}) AS usuario
		FROM m_productionline mpl
		JOIN m_productionplan mpp ON mpp.m_productionplan_id = mpl.m_productionplan_id
		JOIN ma_wrphase mwp ON mwp.ma_wrphase_id = mpp.ma_wrphase_id
		JOIN ma_workrequirement wr ON wr.ma_workrequirement_id = mwp.ma_workrequirement_id
		JOIN m_production mp ON mp.m_production_id = mpp.m_production_id
		JOIN m_product mps ON mps.m_product_id = mpl.m_product_id
		LEFT JOIN orden_peso_merma opm ON opm.ma_workrequirement_id = wr.ma_workrequirement_id
		LEFT JOIN suma_coccion sc ON sc.ma_workrequirement_id = wr.ma_workrequirement_id
		WHERE mpl.m_product_id::text = $P{crprod_mproduct_id}
			AND mpl.productiontype = '+'
			AND DATE(wr.launchdate) >= DATE($P{DateFrom})
			AND DATE(wr.launchdate) <= DATE($P{DateTo})
		ORDER BY wr.ma_workrequirement_id, wr.documentno]]>
	</queryString>
	<field name="ma_workrequirement_id" class="java.lang.String"/>
	<field name="suma_pplus" class="java.math.BigDecimal"/>
	<field name="peso_original_pmenos" class="java.math.BigDecimal"/>
	<field name="parte_curados" class="java.lang.String"/>
	<field name="merma" class="java.math.BigDecimal"/>
	<field name="pct_merma" class="java.math.BigDecimal"/>
	<field name="eficiencia" class="java.math.BigDecimal"/>
	<field name="organizationid" class="java.lang.String"/>
	<field name="fechaimpresion" class="java.sql.Timestamp"/>
	<field name="usuario" class="java.lang.String"/>
	<field name="producto_seleccionado" class="java.lang.String"/>
	<variable name="total_suma_pplus" class="java.math.BigDecimal" calculation="Sum">
		<variableExpression><![CDATA[$F{suma_pplus}]]></variableExpression>
	</variable>
	<variable name="total_peso_original_pmenos" class="java.math.BigDecimal" calculation="Sum">
		<variableExpression><![CDATA[$F{peso_original_pmenos}]]></variableExpression>
	</variable>
	<variable name="total_merma" class="java.math.BigDecimal" calculation="Sum">
		<variableExpression><![CDATA[$F{merma}]]></variableExpression>
	</variable>
