<?xml version="1.0" encoding="UTF-8"?>
<jasperReport xmlns="http://jasperreports.sourceforge.net/jasperreports" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://jasperreports.sourceforge.net/jasperreports http://jasperreports.sourceforge.net/xsd/jasperreport.xsd" name="cheques" pageWidth="439" pageHeight="212" orientation="Landscape" columnWidth="439" leftMargin="0" rightMargin="0" topMargin="0" bottomMargin="0" uuid="0f25ab70-c5e0-4f82-8e58-183717c54493">
	<property name="ireport.zoom" value="1.3310000000000006"/>
	<property name="ireport.x" value="0"/>
	<property name="ireport.y" value="0"/>
	<parameter name="DOCUMENT_ID" class="java.lang.String">
		<defaultValueExpression><![CDATA[]]></defaultValueExpression>
	</parameter>
	<parameter name="BASE_WEB" class="java.lang.String"/>
	<queryString>
		<![CDATA[select (clo.city||', '||to_char(p.paymentdate,'YYYY-MM-DD')) as paymentdate
,coalesce(to_char(SUBSTR(cbp.name,1,37))
,to_char(' ')) as name
,p.amount
,SESCR_convert_numbertoletters(p.amount) as amountletters
from fin_payment p
JOIN ad_org org ON org.ad_org_id = p.ad_org_id
JOIN AD_OrgInfo orgi ON orgi.ad_org_id = org.ad_org_id
JOIN c_location clo ON clo.c_location_id = orgi.c_location_id
left join c_bpartner cbp on p.c_bpartner_id=cbp.c_bpartner_id
where p.fin_payment_id=$P{DOCUMENT_ID}]]>
	</queryString>
	<field name="paymentdate" class="java.lang.String"/>
	<field name="name" class="java.lang.String"/>
	<field name="amount" class="java.math.BigDecimal"/>
	<field name="amountletters" class="java.lang.String"/>
	<background>
		<band splitType="Stretch"/>
	</background>
	<summary>
		<band height="212" splitType="Stretch">
			<textField>
				<reportElement x="5" y="46" width="288" height="21" uuid="dbed6d54-4ee6-4b10-bf81-4b16b57bcdbd"/>
				<textElement verticalAlignment="Bottom">
					<font fontName="SansSerif" size="12" isBold="false" pdfFontName="Helvetica"/>
				</textElement>
				<textFieldExpression><![CDATA[$F{name}]]></textFieldExpression>
			</textField>
			<textField pattern="#,##0.00">
				<reportElement x="294" y="48" width="82" height="21" uuid="f6c57e0b-cd18-4e10-a723-2559aa526c70"/>
				<textElement verticalAlignment="Bottom">
					<font fontName="SansSerif" size="12" isBold="false" pdfFontName="Helvetica"/>
				</textElement>
				<textFieldExpression><![CDATA[$F{amount}]]></textFieldExpression>
			</textField>
			<textField>
				<reportElement x="4" y="72" width="399" height="35" uuid="01d92978-ce6c-443e-b7b9-1d56ea69a08a"/>
				<textElement>
					<font fontName="SansSerif" size="12" isBold="false" pdfFontName="Helvetica"/>
					<paragraph lineSpacing="1_1_2"/>
				</textElement>
				<textFieldExpression><![CDATA[$F{amountletters}]]></textFieldExpression>
			</textField>
			<textField pattern="">
				<reportElement x="5" y="107" width="398" height="19" uuid="6f9b2d49-fdc0-479b-af25-3512a2e05337"/>
				<textElement>
					<font fontName="SansSerif" size="12" isBold="false" pdfFontName="Helvetica"/>
				</textElement>
				<textFieldExpression><![CDATA[$F{paymentdate}]]></textFieldExpression>
			</textField>
		</band>
	</summary>
</jasperReport>
