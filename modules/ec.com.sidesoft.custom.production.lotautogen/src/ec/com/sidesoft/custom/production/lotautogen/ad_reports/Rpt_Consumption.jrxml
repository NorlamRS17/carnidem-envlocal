	</parameter>
	<queryString>
		<![CDATA[SELECT code
,nameplan
,org_parent
,value
,product
,TO_CHAR(NOW(),'dd/mm/yyyy HH24:MI:SS') as fecha_impresion
,sum(enero) as enero
,sum(febrero) as febrero
,sum(marzo) as marzo
,sum(abril) as abril
,sum(mayo) as mayo
,sum(junio) as junio
,sum(julio) as julio
,sum(agosto) as agosto
,sum(septiembre) as septiembre
,sum(octubre) as octubre
,sum(noviembre) as noviembre
,sum(diciembre) as diciembre
,sum(total) as total
,y.year
,unidadp
 FROM (SELECT TRIM(mpl.value) as code
, TRIM(mpl.name) as nameplan
,op.name as org_parent
,trim(p.value) as value
,trim(p.name) as product
,case extract(month from pt.movementdate)
when 1 then COALESCE(movementqty,0) ELSE 0
end as  enero
,case extract(month from pt.movementdate)
when 2 then COALESCE(movementqty,0) ELSE 0
end as  febrero
,case extract(month from pt.movementdate)
when 3 then COALESCE(movementqty,0) ELSE 0
end as  marzo
,case extract(month from pt.movementdate)
when 4 then COALESCE(movementqty,0) ELSE 0
end as  abril
,case extract(month from pt.movementdate)
when 5 then COALESCE(movementqty,0) ELSE 0
end as  mayo
,case extract(month from pt.movementdate)
when 6 then COALESCE(movementqty,0) ELSE 0
end as  junio
,case extract(month from pt.movementdate)
when 7 then COALESCE(movementqty,0) ELSE 0
end as  julio
,case extract(month from pt.movementdate)
when 8 then COALESCE(movementqty,0) ELSE 0
end as  agosto
,case extract(month from pt.movementdate)
when 9 then COALESCE(movementqty,0) ELSE 0
end as  septiembre
,case extract(month from pt.movementdate)
when 10 then COALESCE(movementqty,0) ELSE 0
end as  octubre
,case extract(month from pt.movementdate)
when 11 then COALESCE(movementqty,0) ELSE 0
end as  noviembre
,case extract(month from pt.movementdate)
when 12 then COALESCE(movementqty,0) ELSE 0
end as  diciembre
,COALESCE(movementqty,0) as total
,uo.name as unidadp
FROM ma_processplan mpl
JOIN ma_workrequirement wr ON wr.ma_processplan_id=mpl.ma_processplan_id
JOIN ma_wrphase wp ON wp.ma_workrequirement_id=wr.ma_workrequirement_id
JOIN m_productionplan pp ON pp.ma_wrphase_id=wp.ma_wrphase_id
JOIN m_productionline pl ON pl.m_productionplan_id=pp.m_productionplan_id
LEFT JOIN c_uom_trl uo ON uo.c_uom_id=pl.c_uom_id AND ad_language='es_ES'
JOIN m_product p ON p.m_product_id=pl.m_product_id
JOIN m_production pt ON pt.m_production_id=pp.m_production_id
LEFT JOIN (SELECT org.name
FROM ad_org_tree ot
JOIN ad_org org ON org.ad_org_id=ot.ad_org_id
WHERE levelno=2 AND ad_parent_org_id='0'
AND org.ad_orgtype_id = '1') op ON 1=1
WHERE EXISTS (SELECT 1 FROM c_year where c_year_id=$P{c_year_id} AND year=TO_CHAR(pt.movementdate,'YYYY') )
AND pt.processed='Y' AND trim(mpl.value)=$P{value} AND pl.productiontype='-'
ORDER BY value,product) x,c_year y
where c_year_id=$P{c_year_id}
GROUP BY code ,nameplan,org_parent,value,product,y.year,unidadp]]>
	</queryString>
