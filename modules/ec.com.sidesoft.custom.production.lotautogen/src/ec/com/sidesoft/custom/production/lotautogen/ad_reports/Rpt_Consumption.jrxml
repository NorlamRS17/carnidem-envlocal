		<variableExpression><![CDATA[$F{enero}.add($F{febrero}).add($F{marzo}).add($F{abril}).add($F{mayo}).add($F{junio}).add($F{julio}).add($F{agosto}).add($F{septiembre}).add($F{octubre}).add($F{noviembre}).add($F{diciembre})]]></variableExpression>
