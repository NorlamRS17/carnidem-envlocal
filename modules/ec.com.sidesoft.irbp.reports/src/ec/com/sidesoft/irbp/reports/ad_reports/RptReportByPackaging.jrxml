<?xml version="1.0" encoding="UTF-8"?>
<jasperReport xmlns="http://jasperreports.sourceforge.net/jasperreports" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://jasperreports.sourceforge.net/jasperreports http://jasperreports.sourceforge.net/xsd/jasperreport.xsd" name="RptM_Movement" pageWidth="1100" pageHeight="726" orientation="Landscape" columnWidth="1060" leftMargin="20" rightMargin="20" topMargin="20" bottomMargin="20" uuid="fee87fa3-fa31-4d12-b6ec-b6c6116f298c">
	<property name="ireport.zoom" value="1.363636363636365"/>
	<property name="ireport.x" value="719"/>
	<property name="ireport.y" value="0"/>
	<property name="net.sf.jasperreports.export.xls.detect.cell.type" value="true"/>
	<import value="net.sf.jasperreports.engine.*"/>
	<import value="java.util.*"/>
	<import value="org.openbravo.dal.core.OBContext"/>
	<import value="net.sf.jasperreports.engine.data.*"/>
	<parameter name="NUMBERFORMAT" class="java.text.DecimalFormat" isForPrompting="false">
		<defaultValueExpression><![CDATA[new DecimalFormat("###,##0.00;-###,##0.00", new DecimalFormatSymbols())]]></defaultValueExpression>
	</parameter>
	<parameter name="DATEFORMAT" class="java.text.SimpleDateFormat" isForPrompting="false">
		<defaultValueExpression><![CDATA[new SimpleDateFormat("dd/MM/yyyy")]]></defaultValueExpression>
	</parameter>
	<parameter name="Org_ID" class="java.lang.String" isForPrompting="false">
		<defaultValueExpression><![CDATA[OBContext.getOBContext().getCurrentOrganization().getId()]]></defaultValueExpression>
	</parameter>
	<parameter name="User_ID" class="java.lang.String" isForPrompting="false">
		<defaultValueExpression><![CDATA[OBContext.getOBContext().getUser().getId()]]></defaultValueExpression>
	</parameter>
	<parameter name="UserName" class="java.lang.String" isForPrompting="false">
		<defaultValueExpression><![CDATA[OBContext.getOBContext().getUser().getUsername()]]></defaultValueExpression>
	</parameter>
	<parameter name="DATEFROM" class="java.util.Date">
		<defaultValueExpression><![CDATA[]]></defaultValueExpression>
	</parameter>
	<parameter name="DATETO" class="java.util.Date">
		<defaultValueExpression><![CDATA[]]></defaultValueExpression>
	</parameter>
	<parameter name="m_product_id" class="java.lang.String">
		<defaultValueExpression><![CDATA[]]></defaultValueExpression>
	</parameter>
	<parameter name="Slplag_Kindpackage_ID" class="java.lang.String">
		<defaultValueExpression><![CDATA[]]></defaultValueExpression>
	</parameter>
	<queryString>
		<![CDATA[select
to_char($P{DATEFROM}::date,'dd/MM/yyyy') as "fechainicio",
to_char($P{DATETO}::date,'dd/MM/yyyy') as "fechafin",
to_char('Fecha de impresión: ') || to_char(now(),'dd/MM/yyyy') as "fecha_impresion"
, to_char(now(),'dd/MM/yyyy') as "fecha_movimiento"
, (select name from ad_org where ad_org_id = $P{Org_ID} ) as organization
, (select name from ad_user where ad_user_id = $P{User_ID} ) as usuario
, (select name from m_product where m_product_id = $P{m_product_id}) as printprod
, (select name from slplag_kindpackage where slplag_kindpackage_id = $P{Slplag_Kindpackage_ID}) as printpack
,p.documentno as docnum,
		p.MovementDate as movdate,
 		coalesce(pp.ProductionQty,0) as cantprod,
		coalesce(pl.Rejectedquantity,0) as cantrech,
		(coalesce(pp.ProductionQty, 0) - coalesce(pl.Rejectedquantity,0)) as canttotal,
-- 		pl.m_product_id as producto,
		prod.name as prodname,
		prod.em_slplag_mantainpackage_id as kindpack,
		kp.name as kindname,
-- 		pl.M_AttributeSetInstance_ID as attribID,
		ai.description as attributevalue,
		case
			when pl.Productiontype = '-' then 'P-'
			when pl.Productiontype = '+' then 'P+'
			when pl.Productiontype = 'N' then 'Producto NO almacenado'
		end as tipoproduccion,
		pl.m_locator_id,
		loc.value
from M_Production p
left join M_ProductionPlan pp on pp.M_Production_id = p.M_Production_id
left join M_ProductionLine pl on pl.M_ProductionPlan_id = pp.M_ProductionPlan_id
left join M_product prod on prod.M_product_id = pl.M_Product_id
left join slplag_kindpackage kp on kp.slplag_kindpackage_id = prod.em_slplag_mantainpackage_id
left join m_attributesetinstance ai on ai.m_attributesetinstance_id = pl.M_AttributeSetInstance_ID
left join m_locator loc on loc.m_locator_id = pl.m_locator_id
left join ad_user au on au.ad_user_id = p.createdby
left join ad_org o on o.ad_org_id = p.ad_org_id
where

p.MovementDate::date BETWEEN $P{DATEFROM} AND $P{DATETO}
and ( prod.M_Product_id = $P{m_product_id} or $P{m_product_id} is null)
and ( prod.em_slplag_mantainpackage_id = $P{Slplag_Kindpackage_ID} or $P{Slplag_Kindpackage_ID} is null)
and pl.Productiontype = '+'
and p.issotrx = 'N'
order by p.MovementDate desc, p.documentno
;]]>
	</queryString>
