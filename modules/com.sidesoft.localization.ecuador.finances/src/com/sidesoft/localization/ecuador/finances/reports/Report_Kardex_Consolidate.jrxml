<?xml version="1.0" encoding="UTF-8"?>
<jasperReport xmlns="http://jasperreports.sourceforge.net/jasperreports" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://jasperreports.sourceforge.net/jasperreports http://jasperreports.sourceforge.net/xsd/jasperreport.xsd" name="Report_Kardex" pageWidth="1600" pageHeight="1161" orientation="Landscape" columnWidth="1540" leftMargin="30" rightMargin="30" topMargin="20" bottomMargin="20" uuid="d8ed4a1b-1876-43f7-a0d4-9b2e5451f629">
	<property name="ireport.scriptlethandling" value="0"/>
	<property name="ireport.encoding" value="UTF-8"/>
	<property name="ireport.zoom" value="1.000000000000026"/>
	<property name="ireport.x" value="631"/>
	<property name="ireport.y" value="0"/>
	<property name="net.sf.jasperreports.export.xls.detect.cell.type" value="true"/>
	<import value="net.sf.jasperreports.engine.*"/>
	<import value="java.util.*"/>
	<import value="net.sf.jasperreports.engine.data.*"/>
	<parameter name="DateFrom" class="java.util.Date">
		<defaultValueExpression><![CDATA[new Date()]]></defaultValueExpression>
	</parameter>
	<parameter name="DateTo" class="java.util.Date">
		<defaultValueExpression><![CDATA[new Date()]]></defaultValueExpression>
	</parameter>
	<parameter name="M_Product_ID" class="java.lang.String">
		<defaultValueExpression><![CDATA[""]]></defaultValueExpression>
	</parameter>
	<parameter name="Category_ID" class="java.lang.String"/>
	<parameter name="BASE_DESIGN" class="java.lang.String"/>
	<queryString>
		<![CDATA[select org.name as "ORGANIZACION", p.value as "PRODUCTO", category.name as "CATEGORIA", p.name as "PRODUCTO_NOMBRE", p.m_product_id as "ID",uom.uomsymbol AS "UM",
0.0  as "COSTOINICIAL",0.0 as "CANTINICIAL", ml.value as "BODEGA",
case when mt.MovementType = 'C+' Then 'Devolución del cliente'
	 when mt.MovementType = 'V-' Then 'Devolución proveedor'
	 when mt.MovementType = 'W+' Then 'Solicitud de trabajo +'
	 when mt.MovementType = 'W-' Then 'Solicitud de trabajo -'
	 when mt.MovementType = 'V+' Then 'Albarán proveedor'
	 when mt.MovementType = 'I+' Then 'Entrada inventario'
	 when mt.MovementType = 'M-' Then 'Mover desde'
	 when mt.MovementType = 'M+' Then 'Mover a'
	 when mt.MovementType = 'I-' Then 'Salida inventario'
	 when mt.MovementType = 'P-' Then 'Producción -'
	 when mt.MovementType = 'P+' Then 'Producción +'
	 when mt.MovementType = 'C-' Then 'Albarán cliente'
 	 when mt.MovementType = 'D-' Then 'Consumo Interno -'
	 when mt.MovementType = 'D+' Then 'Consumo Interno +'
else 'No Definido'
end as "DOCUMENTO",
mt.MovementType as "TIPO_MOVIMIENTO",
case when mt.MovementType like '%+%' then 'I' when mt.MovementType like '%-%' then 'E' end as "TIPOMOVIMIENTO",
coalesce(cast(io.documentno as varchar(60)), cast(m.documentno as varchar(60)), cast(it.documentno as varchar(60)), cast(pt.documentno as varchar(60))) as "DOCUMENTNO",
coalesce((select name from c_bpartner  where c_bpartner_id = io.c_bpartner_id), '') as "TERCERO",
case when INV.POReference is null then INV.documentno when INV.POReference = ''  then INV.documentno else INV.POReference END as "DOCUMENTNOFAC",
mt.trxprocessdate as "FECHA",
mt.movementqty as "CANT",
case when mt.MovementType like '%+%' then mt.movementqty else 0 end as "CANTI",
case when mt.MovementType like '%-%' then -mt.movementqty else 0 end as "CANTE",
mt.transactioncost as "VALOR",
mcost.cost as "COSTOTR",
ROUND(ABS(mcost.cost/mt.movementqty), 2)  as "COSTOIE",
abs(mcost.cost/mt.movementqty)  as "COSTT",
COALESCE(asi.lot, asi.serno, asi.description, '') AS "ATRIBUTO",
asi.description AS "DESCRIPCION_ATRIBUTO"
from m_transaction mt
join ad_org org on org.ad_org_id = mt.ad_org_id
left join m_product p on p.m_product_id = mt.m_product_id
left join m_product_category category on category.m_product_category_ID = p.m_product_category_ID
join c_uom uom on mt.c_uom_id = uom.c_uom_id
left join m_locator ml on ml.m_locator_id = mt.m_locator_id
left join M_TRANSACTION_COST mcost on mcost.m_transaction_id = mt.m_transaction_id
left join m_attributesetinstance asi ON asi.m_attributesetinstance_id = mt.m_attributesetinstance_id

left join m_costing c on c.m_transaction_id = mt.m_transaction_id
left join (
  m_inoutline iol
  join m_inout io on io.m_inout_id = iol.m_inout_id
  join c_doctype dtio on io.c_doctype_id = dtio.c_doctype_id
) on iol.m_inoutline_id = mt.m_inoutline_id

left join C_InvoiceLine INVL on  INVL.M_InOutLine_ID = iol.M_InOutLine_ID
left join c_invoice INV on INV.c_invoice_id = INVL.c_invoice_id
left join (
  m_movementline mll
  join m_movement m on m.m_movement_id = mll.m_movement_id
) on mll.m_movementline_id = mt.m_movementline_id

left join (
  m_inventoryline itl
  join m_inventory it on it.m_inventory_id = itl.m_inventory_id
) on itl.m_inventoryline_id = mt.m_inventoryline_id

left join (
  m_productionline ptl
  join m_production pt on pt.m_production_id = ptl.m_product_id
) on ptl.m_productionline_id = mt.m_productionline_id

where mt.movementdate between $P{DateFrom} and $P{DateTo}
and
   (
     (COALESCE($P{M_Product_ID}, '') = '')
     or
     (p.m_product_id = $P{M_Product_ID})
   )
and ( $P{Category_ID} is null or category.m_product_category_id = $P{Category_ID})
order by p.name, mt.trxprocessdate]]>
	</queryString>
