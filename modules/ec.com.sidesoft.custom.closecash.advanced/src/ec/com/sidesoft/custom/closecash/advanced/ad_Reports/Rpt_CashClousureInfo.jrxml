<?xml version="1.0" encoding="UTF-8"?>
<jasperReport xmlns="http://jasperreports.sourceforge.net/jasperreports" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://jasperreports.sourceforge.net/jasperreports http://jasperreports.sourceforge.net/xsd/jasperreport.xsd" name="Rpt_CashClousureInfo" pageWidth="1332" pageHeight="595" orientation="Landscape" columnWidth="1292" leftMargin="20" rightMargin="20" topMargin="20" bottomMargin="20">
	<property name="ireport.zoom" value="1.6105100000000099"/>
	<property name="ireport.x" value="1249"/>
	<property name="ireport.y" value="0"/>
	<parameter name="AD_USER_ID" class="java.lang.String">
		<defaultValueExpression><![CDATA[]]></defaultValueExpression>
	</parameter>
	<parameter name="AD_ORG_ID" class="java.lang.String">
		<defaultValueExpression><![CDATA[]]></defaultValueExpression>
	</parameter>
	<parameter name="Datefrom" class="java.util.Date">
		<defaultValueExpression><![CDATA[]]></defaultValueExpression>
	</parameter>
	<parameter name="Dateto" class="java.util.Date">
		<defaultValueExpression><![CDATA[]]></defaultValueExpression>
	</parameter>
	<parameter name="FIN_PAYMENTMETHOD_ID" class="java.lang.String">
		<defaultValueExpression><![CDATA[]]></defaultValueExpression>
	</parameter>
	<parameter name="EM_Scca_Card_Type" class="java.lang.String">
		<defaultValueExpression><![CDATA[]]></defaultValueExpression>
	</parameter>
	<parameter name="Fin_Financial_Account_ID" class="java.lang.String">
		<defaultValueExpression><![CDATA[]]></defaultValueExpression>
	</parameter>
	<queryString>
		<![CDATA[SELECT sq.* FROM ((SELECT ao.name AS "organizacion"
,cc.name AS "nombre"
,cc.closingdate AS "fecha"
,pm.name AS "metodopago"
,CASE WHEN ccl.em_scca_card_type ='ME' THEN
'MEDIANET'
 WHEN  ccl.em_scca_card_type ='DT' THEN
'DATAFAST'
END AS "tipotarjeta"
,fa.name AS "cuentafinanciera"
,CASE WHEN typeaccount='EXP' THEN
abs(ccl.amount)*-1
ELSE
ccl.amount END
 AS "valor"
,TO_CHAR('RESTAURANTE') AS "tipolinea"
,TO_DATE(now()) AS "fechaimpresion"
,(select coalesce(to_char(cbp.name), to_char(au.name)) from ad_user au left join c_bpartner cbp on cbp.c_bpartner_id = au.c_bpartner_id where au.ad_user_id = $P{AD_USER_ID}) AS "usuario"
,cc.ad_org_id
,CASE WHEN ccl.typeaccount= 'INC' THEN
'INGRESOS'
WHEN ccl.typeaccount ='EXP' THEN
'EGRESOS'
END AS "tipo cuenta",
ccl.em_scca_lot
FROM sccc_cash_clousure cc
LEFT JOIN ad_org ao ON cc.ad_org_id = ao.ad_org_id
LEFT JOIN sccc_cash_clousureline ccl ON cc.sccc_cash_clousure_id = ccl.sccc_cash_clousure_id
LEFT JOIN fin_paymentmethod pm ON ccl.fin_paymentmethod_id = pm.fin_paymentmethod_id
LEFT JOIN fin_financial_account fa ON ccl.em_scca_financial_account_id = fa.fin_financial_account_id
WHERE
(cc.ad_org_id=$P{AD_ORG_ID} OR $P{AD_ORG_ID} IS NULL)
AND (ccl.fin_paymentmethod_id=$P{FIN_PAYMENTMETHOD_ID} OR $P{FIN_PAYMENTMETHOD_ID} IS NULL)
AND (ccl.em_scca_card_type=$P{EM_Scca_Card_Type} OR $P{EM_Scca_Card_Type} IS NULL)
AND (ccl.em_scca_financial_account_id=$P{Fin_Financial_Account_ID} OR $P{Fin_Financial_Account_ID} IS NULL)
AND (TO_DATE($P{Datefrom}) IS NULL OR TO_DATE($P{Datefrom},'yyyy-MM-dd') <= TO_DATE(cc.closingdate,'dd-MM-yyyy'))
AND (TO_DATE($P{Dateto}) IS NULL OR TO_DATE($P{Dateto},'yyyy-MM-dd') >= TO_DATE(cc.closingdate,'dd-MM-yyyy'))
AND ccl.amount<>0  AND cc.docstatus='SCCC_PR')

UNION ALL

(SELECT ao.name AS "nameorg"
,cc.name AS "nombre"
,cc.closingdate AS "fecha"
,pm.name AS "metodopago"
,CASE WHEN ccl.card_type ='ME' THEN
'MEDIANET'
 WHEN  ccl.card_type ='DT' THEN
'DATAFAST'
END AS "tipotarjeta"
,fa.name AS "cuentafinanciera"
,CASE WHEN typeaccount='EXP' THEN
abs(ccl.amount)*-1
ELSE
ccl.amount END
 AS "valor"
,TO_CHAR('HELADERÍA') AS "tipolinea"
,TO_DATE(now()) AS "fechaimpresion"
,(select coalesce(to_char(cbp.name), to_char(au.name)) from ad_user au left join c_bpartner cbp on cbp.c_bpartner_id = au.c_bpartner_id where au.ad_user_id = $P{AD_USER_ID}) AS "usuario"
,cc.ad_org_id
,CASE WHEN ccl.typeaccount= 'INC' THEN
'INGRESOS'
WHEN ccl.typeaccount ='EXP' THEN
'EGRESOS'
END AS "tipo cuenta",
ccl.lot
FROM sccc_cash_clousure cc
LEFT JOIN ad_org ao ON cc.ad_org_id = ao.ad_org_id
LEFT JOIN scca_cash_clousureline2 ccl ON cc.sccc_cash_clousure_id = ccl.sccc_cash_clousure_id
LEFT JOIN fin_paymentmethod pm ON ccl.fin_paymentmethod_id = pm.fin_paymentmethod_id
LEFT JOIN fin_financial_account fa ON ccl.fin_financial_account_id = fa.fin_financial_account_id
WHERE
(cc.ad_org_id=$P{AD_ORG_ID} OR $P{AD_ORG_ID} IS NULL)
AND (ccl.fin_paymentmethod_id=$P{FIN_PAYMENTMETHOD_ID} OR $P{FIN_PAYMENTMETHOD_ID} IS NULL)
AND (ccl.card_type=$P{EM_Scca_Card_Type} OR $P{EM_Scca_Card_Type} IS NULL)
AND (ccl.fin_financial_account_id=$P{Fin_Financial_Account_ID} OR $P{Fin_Financial_Account_ID} IS NULL)
AND (TO_DATE($P{Datefrom}) IS NULL OR TO_DATE($P{Datefrom},'yyyy-MM-dd') <= TO_DATE(cc.closingdate,'dd-MM-yyyy'))
AND (TO_DATE($P{Dateto}) IS NULL OR TO_DATE($P{Dateto},'yyyy-MM-dd') >= TO_DATE(cc.closingdate,'dd-MM-yyyy'))
AND ccl.amount<>0 AND cc.docstatus='SCCC_PR'
)) SQ
ORDER BY organizacion,fecha desc,metodopago,tipotarjeta,cuentafinanciera,nombre]]>
	</queryString>
