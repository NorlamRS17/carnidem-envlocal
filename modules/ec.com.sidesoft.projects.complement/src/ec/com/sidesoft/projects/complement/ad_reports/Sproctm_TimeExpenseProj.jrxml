<?xml version="1.0" encoding="UTF-8"?>
<jasperReport xmlns="http://jasperreports.sourceforge.net/jasperreports" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://jasperreports.sourceforge.net/jasperreports http://jasperreports.sourceforge.net/xsd/jasperreport.xsd" name="Sproctm_TimeExpenseProj" pageWidth="595" pageHeight="842" columnWidth="555" leftMargin="20" rightMargin="20" topMargin="20" bottomMargin="20" uuid="dfd9cdbb-2879-4c75-9489-4c1e39901e0b">
	<property name="ireport.zoom" value="1.0"/>
	<property name="ireport.x" value="0"/>
	<property name="ireport.y" value="0"/>
	<parameter name="AD_USER_ID" class="java.lang.String">
		<defaultValueExpression><![CDATA[]]></defaultValueExpression>
	</parameter>
	<parameter name="S_TimeExpense_ID" class="java.lang.String">
		<defaultValueExpression><![CDATA[]]></defaultValueExpression>
	</parameter>
	<queryString>
		<![CDATA[select
now() as fecha_actual, o.name org, o.ad_org_id,
coalesce((select name from ad_user where ad_user_id=$P{AD_USER_ID}),'') as usuario,
p.name as producto,
t.S_TimeExpense_id, t.documentno,bp.name as tercero, t.datereport as fecha_informe
, tl.line, tl.dateexpense as fecha_gasto, tl.qty as cantidad,
tl.invoiceprice as  gasto , tl.expenseamt as gasto_total , tl.IsInvoiced as refacturable
 	,split_part( signatures.etiquetas, ',-,', 1) as "label_firma_1"
	,split_part( signatures.etiquetas, ',-,', 2) as "label_firma_2"
	,split_part( signatures.etiquetas, ',-,', 3) as "label_firma_3"
	,CASE WHEN split_part( signatures.auditoria, ',-,', 1) = 'N' THEN split_part( signatures.nombres, ',-,', 1)
     ELSE (SELECT coalesce(firstname,'') || ' ' || coalesce(lastname,'') as name
        FROM ad_user WHERE ad_user_id = tl.createdby) END  as "nombre_firma_1"
	,CASE WHEN split_part( signatures.auditoria, ',-,', 2) = 'N' THEN split_part( signatures.nombres, ',-,', 2)
     ELSE (SELECT coalesce(firstname,'') || ' ' || coalesce(lastname,'') as name
        FROM ad_user WHERE ad_user_id = tl.createdby) END  as "nombre_firma_2"
	,CASE WHEN split_part( signatures.auditoria, ',-,', 3) = 'N' THEN split_part( signatures.nombres, ',-,', 3)
     ELSE (SELECT coalesce(firstname,'') || ' ' || coalesce(lastname,'') as name
        FROM ad_user WHERE ad_user_id = tl.createdby) END  as "nombre_firma_3"
	,split_part( signatures.cargos, ',-,', 1) as "nombre_cargos_1"
	,split_part( signatures.cargos, ',-,', 2) as "nombre_cargos_2"
	,split_part( signatures.cargos, ',-,', 3) as "nombre_cargos_3"
,tk.name as tarea
,ph.name as fase
,pj.name proyecto
from S_TimeExpenseLine tl
left join S_TimeExpense t on t.S_TimeExpense_id = tl.S_TimeExpense_id
LEFT JOIN c_projecttask tk on t.em_sproctm_c_projecttask_id=tk.c_projecttask_id
LEFT JOIN c_projectphase ph on t.em_sproctm_c_projectphase_id=ph.c_projectphase_id
LEFT JOIN c_project pj on t.em_sproctm_c_project_id=pj.c_project_id
inner join m_product p on p.m_product_id=tl.m_product_id
inner join ad_org o on o.ad_org_id = t.ad_org_id
inner join c_bpartner bp on bp.c_bpartner_id = t.c_bpartner_id
Left JOIN (SELECT
    z.c_doctype_id
    , STRING_AGG(COALESCE(y.label,''),to_char(',-,') ORDER BY y.line ASC) as "etiquetas"
    , STRING_AGG(COALESCE(y.name,''),to_char(',-,') ORDER BY y.line ASC) as "nombres"
    , STRING_AGG(COALESCE(y.position,''),to_char(',-,') ORDER BY y.line ASC) as "cargos"
    , STRING_AGG(COALESCE(y.isaudit,'N'),to_char(',-,') ORDER BY y.line ASC) as "auditoria"
    FROM c_doctype z join scsdc_signaturesperdoc y on y.c_doctype_id = z.c_doctype_id
    GROUP BY z.c_doctype_id
    ) signatures on signatures.c_doctype_id = t.EM_Sproctm_C_Doctype_ID
where  tl.S_TimeExpense_id = $P{S_TimeExpense_ID}
ORDER BY tl.line]]>
	</queryString>
