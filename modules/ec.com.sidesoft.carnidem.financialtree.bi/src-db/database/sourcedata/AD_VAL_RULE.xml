<!--EE2111F28F08430CAE8E5C6377352CFF-->  <CODE><![CDATA[EXISTS (
  SELECT 1
  FROM scft_acct_account saa
  JOIN scft_acctclassif sa ON sa.scft_acctclassif_id = saa.scft_acctclassif_id
  JOIN c_elementvalue ce ON ce.c_elementvalue_id = saa.c_elementvalue_id
  WHERE sa.account_type = ce.accounttype
    AND saa.scft_acct_account_id = @scft_acct_account_id@
)]]></CODE>
