	</variable>
	<variable name="PORtot" class="java.lang.Double" calculation="Sum">
		<variableExpression><![CDATA[$F{porcentaje}]]></variableExpression>
		<initialValueExpression><![CDATA[0]]></initialValueExpression>
	</variable>
