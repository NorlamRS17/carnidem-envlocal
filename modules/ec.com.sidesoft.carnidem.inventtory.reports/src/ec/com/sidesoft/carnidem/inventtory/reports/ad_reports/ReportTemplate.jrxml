	<pageFooter>
		<band height="25" splitType="Stretch">
			<staticText>
				<reportElement x="0" y="15" width="810" height="10" uuid="8919ddfc-d92c-4c5f-a621-bb7923a6c209"/>
				<box leftPadding="5" rightPadding="5"/>
				<textElement verticalAlignment="Middle">
					<font size="6"/>
				</textElement>
				<text><![CDATA[com.sidesoft.hrm.payroll/src/com/sidesoft/hrm/payroll/ad_Reports/Rpt_FinalSettlement.jrxml]]></text>
			</staticText>
			<textField evaluationTime="Report">
				<reportElement x="390" y="0" width="420" height="15" uuid="1c64e189-44d8-4dc6-b988-d3dfbbaf94c4"/>
				<box topPadding="0" leftPadding="0" bottomPadding="0" rightPadding="0"/>
				<textElement verticalAlignment="Middle">
					<font size="8"/>
				</textElement>
				<textFieldExpression><![CDATA[" "+$V{PAGE_NUMBER}]]></textFieldExpression>
