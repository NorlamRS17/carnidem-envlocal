<?xml version="1.0" encoding="UTF-8"?>
<jasperReport xmlns="http://jasperreports.sourceforge.net/jasperreports" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://jasperreports.sourceforge.net/jasperreports http://jasperreports.sourceforge.net/xsd/jasperreport.xsd" name="ReportTemplate" pageWidth="850" pageHeight="595" orientation="Landscape" columnWidth="810" leftMargin="20" rightMargin="20" topMargin="20" bottomMargin="20" uuid="9e83b194-2a6c-4f52-9c30-ef8763581492">
	<property name="ireport.zoom" value="1.2418426461183132"/>
	<property name="ireport.x" value="265"/>
	<property name="ireport.y" value="0"/>
	<property name="net.sf.jasperreports.export.xls.detect.cell.type" value="true"/>
	<property name="net.sf.jasperreports.export.jxl.cell.complex.format" value="true"/>
	<parameter name="NUMBERFORMAT" class="java.text.DecimalFormat" isForPrompting="false">
		<defaultValueExpression><![CDATA[new DecimalFormat("###,##0.00;-###,##0.00", new DecimalFormatSymbols())]]></defaultValueExpression>
	</parameter>
	<parameter name="AD_User_ID" class="java.lang.String" isForPrompting="false">
		<defaultValueExpression><![CDATA["100"]]></defaultValueExpression>
	</parameter>
	<parameter name="DateFrom" class="java.util.Date">
		<defaultValueExpression><![CDATA[]]></defaultValueExpression>
	</parameter>
	<parameter name="DateTo" class="java.util.Date">
		<defaultValueExpression><![CDATA[]]></defaultValueExpression>
	</parameter>
	<parameter name="DOCUMENT_ID" class="java.lang.String"/>
	<queryString>
		<![CDATA[WITH const AS (
  SELECT $P{DateFrom}::date AS date_from,
          $P{DateTo}::date AS date_to
),
trans AS (
  SELECT
        mt.m_product_id,
        mt.m_locator_id,

        SUM( CASE
                WHEN mt.movementdate < (SELECT date_from FROM const)
                THEN mt.movementqty ELSE 0
            END)                         AS saldo_inicial,

        SUM( CASE
                WHEN mt.movementdate BETWEEN (SELECT date_from FROM const)
                                         AND  (SELECT date_to   FROM const)
                     AND mt.movementqty > 0
                THEN mt.movementqty ELSE 0
            END)                         AS entradas,

        SUM( CASE
                WHEN mt.movementdate BETWEEN (SELECT date_from FROM const)
                                         AND  (SELECT date_to   FROM const)
                     AND mt.movementqty < 0
                THEN mt.movementqty ELSE 0
            END)                         AS salidas
  FROM  m_transaction mt
  GROUP BY mt.m_product_id,
           mt.m_locator_id
)

SELECT
	o.ad_org_id org_id
	, o.name org_name
	, u.username printing_user
	, TO_CHAR(NOW(),'yyyy-MM-dd HH24:MI:SS') printing_date,
	mwar.name as alm,
    (SELECT TO_CHAR(date_from,'dd-MM-yyyy') FROM const) as date_from,
    (SELECT TO_CHAR(date_to,'dd-MM-yyyy') FROM const) as date_to,
    mp.value                                  AS codigo,
    mp.name                                   AS producto,
    mpc.name                                  AS categoria,

    ROUND(COALESCE(t.saldo_inicial,0),z.stdprecision)               AS saldo_inicial,
    ROUND(COALESCE(t.entradas,0),z.stdprecision)                    AS entradas,
    ROUND(ABS(COALESCE(t.salidas,0)),z.stdprecision)                AS salidas,

    ROUND(mil.qtybook,z.stdprecision)                               AS cant_teorica,
    ROUND(mil.qtycount,z.stdprecision)                              AS cant_fisica,
    ROUND(mil.qtycount - mil.qtybook, z.stdprecision)                AS diferencia,

    CASE
        WHEN COALESCE(t.salidas,0) = 0 THEN 0
        ELSE ROUND( ABS(mil.qtycount - mil.qtybook)
                    / ABS(t.salidas) * 100 ,
                    z.stdprecision)
    END                                        AS porcentaje
FROM   m_inventory          mi

JOIN ad_org o ON o.ad_orgtype_id = '1'
JOIN ad_user u ON u.ad_user_id = $P{AD_User_ID}

CROSS JOIN (SELECT stdprecision
                       FROM c_currency
                      WHERE c_currency_id = '100') z
JOIN   m_inventoryline      mil ON mil.m_inventory_id = mi.m_inventory_id
JOIN   m_product            mp  ON mp.m_product_id    = mil.m_product_id
LEFT   JOIN m_product_category mpc
                               ON mpc.m_product_category_id = mp.m_product_category_id
LEFT   JOIN trans            t  ON t.m_product_id     = mil.m_product_id
                                AND t.m_locator_id    = mil.m_locator_id
LEFT   JOIN m_warehouse mwar on mwar.m_warehouse_id = mi.m_warehouse_id
WHERE  mil.m_inventory_id = $P{DOCUMENT_ID}
ORDER  BY mpc.name, mp.name;]]>
	</queryString>
