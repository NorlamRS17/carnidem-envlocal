	<field name="porcentaje" class="java.math.BigDecimal"/>
	<variable name="SItot" class="java.lang.Number" calculation="Sum">
		<variableExpression><![CDATA[$F{saldo_inicial}]]></variableExpression>
		<initialValueExpression><![CDATA[0]]></initialValueExpression>
	</variable>
	<variable name="ENTtot" class="java.lang.Number" calculation="Sum">
		<variableExpression><![CDATA[$F{entradas}]]></variableExpression>
		<initialValueExpression><![CDATA[0]]></initialValueExpression>
	</variable>
	<variable name="SALtot" class="java.lang.Number" calculation="Sum">
