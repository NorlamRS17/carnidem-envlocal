	<property name="ireport.zoom" value="2.0"/>
	<property name="ireport.x" value="0"/>
	<property name="ireport.y" value="0"/>
	<property name="ireport.scriptlethandling" value="0"/>
	<property name="net.sf.jasperreports.export.xls.detect.cell.type" value="true"/>
	<property name="net.sf.jasperreports.export.xls.sheet.names.all" value="Orden de Fabricación"/>
	<property name="ireport.encoding" value="UTF-8"/>
	<import value="net.sf.jasperreports.engine.*"/>
	<import value="java.util.*"/>
	<import value="net.sf.jasperreports.engine.data.*"/>
	<parameter name="document_id" class="java.lang.String"/>
	<parameter name="BASE_DESIGN" class="java.lang.String" isForPrompting="false">
		<defaultValueExpression><![CDATA["/opt/EntornosOP/webapps/indumot/src-loc/design"]]></defaultValueExpression>
	</parameter>
	<queryString>
		<![CDATA[SELECT
ROW_NUMBER () OVER (ORDER BY pp.m_production_id) as row,
p.value as code,
p.name as name,
mt.description as lote,
pl.movementqty as qty,
pt.documentno as prod_documentno,
u.x12de355 as unit
FROM m_productionplan pp
LEFT JOIN m_production pt on pt.m_production_id=pp.m_production_id
LEFT JOIN m_productionline pl on pl.m_productionplan_id=pp.m_productionplan_id
LEFT JOIN m_product p on p.m_product_id=pl.m_product_id
LEFT JOIN c_uom u on u.c_uom_id=pl.c_uom_id
LEFT JOIN m_attributesetinstance mt on mt.m_attributesetinstance_id=pl.m_attributesetinstance_id
WHERE pt.m_production_id=$P{document_id}
AND pl.Productiontype='-']]>
	</queryString>
	<field name="row" class="java.lang.Long"/>
	<field name="code" class="java.lang.String"/>
	<field name="name" class="java.lang.String"/>
	<field name="lote" class="java.lang.String"/>
	<field name="qty" class="java.math.BigDecimal"/>
	<field name="prod_documentno" class="java.lang.String"/>
	<field name="unit" class="java.lang.String"/>
	<variable name="REPORT_PAGE" class="java.lang.Integer" resetType="None" incrementType="Page">
		<variableExpression><![CDATA[$V{PAGE_NUMBER}]]></variableExpression>
	</variable>
