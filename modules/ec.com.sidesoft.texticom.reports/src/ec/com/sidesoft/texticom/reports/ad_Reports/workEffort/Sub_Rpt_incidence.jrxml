	<import value="net.sf.jasperreports.engine.*"/>
	<import value="java.util.*"/>
	<import value="net.sf.jasperreports.engine.data.*"/>
	<parameter name="document_id" class="java.lang.String"/>
	<parameter name="BASE_DESIGN" class="java.lang.String" isForPrompting="false">
		<defaultValueExpression><![CDATA["/opt/EntornosOP/webapps/indumot/src-loc/design"]]></defaultValueExpression>
	</parameter>
	<queryString>
		<![CDATA[SELECT
ROW_NUMBER () OVER (ORDER BY ma_weincidence_id) as row,
coalesce(i.name,' ')||' '||coalesce(w.description,' ') as description,
to_char(starttime,'dd/MM/yyyy') as starttime,
to_char(endtime,'dd/MM/yyyy') as endtime
FROM ma_weincidence w
LEFT JOIN ma_incidence i on i.ma_incidence_id=w.ma_incidence_id
WHERE
m_production_id=$P{document_id}]]>
	</queryString>
	<field name="row" class="java.lang.Long"/>
	<field name="description" class="java.lang.String"/>
	<field name="starttime" class="java.lang.String"/>
	<field name="endtime" class="java.lang.String"/>
	<variable name="REPORT_PAGE" class="java.lang.Integer" resetType="None" incrementType="Page">
		<variableExpression><![CDATA[$V{PAGE_NUMBER}]]></variableExpression>
	</variable>
