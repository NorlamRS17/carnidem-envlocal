	<property name="net.sf.jasperreports.export.xls.sheet.names.all" value="Informe de parte de trabajo"/>
	<property name="ireport.encoding" value="UTF-8"/>
	<import value="net.sf.jasperreports.engine.*"/>
	<import value="java.util.*"/>
	<import value="net.sf.jasperreports.engine.data.*"/>
	<parameter name="document_id" class="java.lang.String"/>
	<parameter name="ma_workrequirement_id" class="java.lang.String"/>
	<parameter name="BASE_DESIGN" class="java.lang.String">
		<defaultValueExpression><![CDATA["/opt/EntornosOP/webapps/indumot/src-loc/design"]]></defaultValueExpression>
	</parameter>
	<queryString>
		<![CDATA[SELECT
p.ad_org_id,
p.documentno,
to_char(pl.starttime,'dd/MM/yyyy') as starttime,
to_char(pl.endtime,'dd/MM/yyyy') as endtime,
w.documentno as docno_requirement,
mp.value as code,
mp.name as name_plan,
pr.name as area,
to_char(w.launchdate,'dd/MM/yyyy') as launchdate,
mp.secondaryunit
FROM m_production p
LEFT JOIN m_productionplan pl on pl.m_production_id=p.m_production_id
LEFT JOIN ma_wrphase mw on mw.ma_wrphase_id=pl.ma_wrphase_id
LEFT JOIN ma_workrequirement w on w.ma_workrequirement_id=mw.ma_workrequirement_id
LEFT JOIN ma_processplan mp on mp.ma_processplan_id=w.ma_processplan_id
LEFT JOIN ma_process pr on pr.ma_process_id=mw.ma_process_id
WHERE
p.m_production_id=$P{document_id}]]>
	</queryString>
	<field name="ad_org_id" class="java.lang.String"/>
	<field name="documentno" class="java.lang.String"/>
	<field name="starttime" class="java.lang.String"/>
	<field name="endtime" class="java.lang.String"/>
	<field name="docno_requirement" class="java.lang.String"/>
	<field name="code" class="java.lang.String"/>
	<field name="name_plan" class="java.lang.String"/>
	<field name="area" class="java.lang.String"/>
	<field name="launchdate" class="java.lang.String"/>
	<field name="secondaryunit" class="java.lang.String"/>
	<variable name="REPORT_PAGE" class="java.lang.Integer" resetType="None" incrementType="Page">
		<variableExpression><![CDATA[$V{PAGE_NUMBER}]]></variableExpression>
	</variable>
