<?xml version="1.0" encoding="UTF-8"?>
<jasperReport xmlns="http://jasperreports.sourceforge.net/jasperreports" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://jasperreports.sourceforge.net/jasperreports http://jasperreports.sourceforge.net/xsd/jasperreport.xsd" name="Rpt_Production_Incidents" pageWidth="1200" pageHeight="842" columnWidth="1160" leftMargin="20" rightMargin="20" topMargin="20" bottomMargin="20" uuid="6aa393cc-dc2e-47c0-be3a-4ad3a34a98b1">
	<property name="ireport.zoom" value="1.210000000000015"/>
	<property name="ireport.x" value="0"/>
	<property name="ireport.y" value="0"/>
	<parameter name="DATE_FROM" class="java.util.Date"/>
	<parameter name="DATE_TO" class="java.util.Date"/>
	<parameter name="MA_Incidence" class="java.lang.String"/>
	<queryString>
		<![CDATA[select
to_char(mpd.movementdate,'dd/MM/yyyy') as "fecha"
,COALESCE(mpd.documentno,'') as "parte"
,mwr.documentno as "orden_fabricacion"
,string_agg(TRIM(cbp.name),', ') as "operador"
,mwi.description as "novedad"
,maws.name as "puestotrabajo"
,msec.name as "area"
,COALESCE(mai.name, '--') as "tipo"
,to_char(mwi.starttime,'HH24:MI') as "horainicio"
,to_char(mwi.endtime,'HH24:MI') as "horafin"
,mpd.ad_org_id as "organizationid"
,now() as "fechacreacion"
,now() as "fechaimpresion"
, (select name from ma_incidence where ma_incidence_id =$P{MA_Incidence} ) as "incidencia"
from m_production mpd
join ma_weincidence mwi ON mwi.m_production_id = mpd.m_production_id
LEFT JOIN ma_incidence mai ON mai.ma_incidence_id = mwi.ma_incidence_id
left join m_productionplan mpp on mpp.m_production_id = mpd.m_production_id
left join ma_weemployee  mwa ON mwa.m_production_id = mpd.m_production_id
left join c_bpartner cbp on cbp.c_bpartner_id = mwa.c_bpartner_id
left join ma_wrphase mwp on mwp.ma_wrphase_id = mpp.ma_wrphase_id
left join ma_process mapr on mapr.ma_process_id = mwp.ma_process_id
left join MA_Workstation maws on maws.MA_Workstation_id = mapr.MA_Workstation_id
left join ma_section msec on msec.ma_section_id = maws.ma_section_id
left join MA_WorkRequirement mwr on mwr.MA_WorkRequirement_id = mwp.MA_WorkRequirement_id
WHERE mpd.movementdate between $P{DATE_FROM} AND $P{DATE_TO}
AND mpp.processed='Y'
and (mwi.MA_Incidence_ID = $P{MA_Incidence} or $P{MA_Incidence} is null)
GROUP BY mpd.movementdate, mpd.documentno, mwr.documentno, mwi.description, maws.name,msec.name,mai.name,mwi.starttime,mwi.endtime, mpd.ad_org_id
ORDER BY mpd.movementdate]]>
	</queryString>
	<field name="fecha" class="java.lang.String"/>
	<field name="parte" class="java.lang.String"/>
	<field name="orden_fabricacion" class="java.lang.String"/>
	<field name="operador" class="java.lang.String"/>
