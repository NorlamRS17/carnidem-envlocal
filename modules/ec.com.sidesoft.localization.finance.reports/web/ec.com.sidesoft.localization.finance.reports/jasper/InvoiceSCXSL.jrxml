	<parameter name="org_id" class="java.lang.String">
		<parameterDescription><![CDATA[]]></parameterDescription>
	</parameter>
	<queryString language="SQL">
		<![CDATA[select * from (
(select  coalesce(cir.documentno, ci.documentno) as documentno, 
'' as pay_documentno,
case when ci.issotrx = 'Y' then '' else  coalesce(ci.POReference, '') end as reference,
case when ci.issotrx = 'Y'
         then (case when ci.em_scnr_isref_inv = 'Y' then 'NC'
                            when cd.EM_Sswh_Doctype = 'I' then 'FA' else  cd.EM_Sswh_Doctype end)
         else (case  when coalesce (cd.EM_Sswh_Doctype, 'FA') = 'CN' then 'NC' else coalesce(cd.EM_Sswh_Doctype, 'FA') end ) end  as document_type,
to_char(ci.dateinvoiced, 'yyyy-MM-dd') as dateinvoiced,  
ci.dateinvoiced as dateinvoicedc,  
to_char(fpi.expecteddate, 'yyyy-MM-dd') as expecteddate , 
coalesce (ci.description, '') as description, 
fa.account_id,
fa.amtacctdr, 
fa.amtacctcr as amtacctcr, 
(fa.amtacctdr + (fa.amtacctcr*-1)) as saldo,
1 as orden, 
 coalesce(cir.documentno, '') as ref_invoice, 
 '' as referenceno,
 (case when ci.em_scnr_isref_inv = 'Y' then ci.em_scnr_invoice_id else ci.c_invoice_id end) as invoice_id,
 (case when ci.em_scnr_isref_inv = 'Y' then 1 else 0 end) as invoice_type
 from fact_acct fa
  inner join c_invoice ci on ci.c_invoice_id = fa.record_id
  inner join c_doctype cd on cd.c_doctype_id = ci.c_doctype_id
  inner join (select fps3.expecteddate, fps3.c_invoice_id
                from fin_payment_schedule fps3
               where fps3.expecteddate = (select max(expecteddate)
                 from fin_payment_schedule fps4 where fps4.c_invoice_id = fps3.c_invoice_id )) as fpi on fpi.c_invoice_id = ci.c_invoice_id
  left join c_invoice cir on cir.c_invoice_id = ci.em_scnr_invoice_id
  where fa.ad_table_id = '318' AND ci.docstatus='CO'
         and $P!{accounts_query_inv}
         and ci.issotrx = $P!{issotrx_str}
         and ci.c_bpartner_id = $P!{bpartner_id_query}
         and ci.dateinvoiced  >=  TO_DATE($P!{date_fromstr})
         and  ci.dateinvoiced  <= TO_DATE($P!{date_tostr})
 )
 union
 (select ci3.documentno, 
wh.documentno as pay_documentno,
 case when ci3.issotrx = 'Y' then '' else  coalesce(ci3.POReference, '') end as reference,
  'RTV' as document_type,
   to_char(wh.withholdingdate, 'yyyy-MM-dd') as dateinvoiced, 
wh.withholdingdate as dateinvoiced, 
to_char(fpi1.expectedDate, 'yyyy-MM-dd') as  expecteddate, 
coalesce (wh.description, '') as description,
        fa3.account_id ,fa3.amtacctdr as amtacctdr , 
(fa3.amtacctcr) as amtacctcr, 
(fa3.amtacctdr + (fa3.amtacctcr*-1)) as saldo  ,2 as orden, '' as ref_invoice, '' as referenceno,
 (case when ci3.em_scnr_isref_inv = 'Y' then ci3.em_scnr_invoice_id else ci3.c_invoice_id end) as invoice_id,
 (case when ci3.em_scnr_isref_inv = 'Y' then 1 else 0 end) as invoice_type
  from fact_acct fa3
   inner join SSWS_WithholdingSale wh on wh.ssws_withholdingsale_id  = fa3.record_id
   inner join c_invoice ci3 on ci3.c_invoice_id = wh.c_invoice_id
   left  join (select fps3.Duedate as expecteddate, fps3.c_invoice_id
                from fin_payment_schedule fps3
               where fps3.Duedate = (select max(Duedate)
                 from fin_payment_schedule fps4 where fps4.c_invoice_id = fps3.c_invoice_id )) as fpi1 on fpi1.c_invoice_id = ci3.c_invoice_id
   where fa3.ad_table_id = '211492B753264EAEBE328BA4FED1F066'
   and $P!{accounts_query_rtv}
         and ci3.issotrx = $P!{issotrx_str}
         and ci3.c_bpartner_id = $P!{bpartner_id_query}
         and ci3.dateinvoiced  >=  TO_DATE($P!{date_fromstr})
         and ci3.dateinvoiced  <= TO_DATE($P!{date_tostr})
)
 union
 (select coalesce(ci2.documentno,'') as documentno , fp.documentno as pay_documentno,
 case when fp.isReceipt ='Y' and ci2.issotrx = 'Y' then '' else  coalesce(ci2.POReference, '') end as reference,
 'PA' as document_type, 
 coalesce (to_char(fp.paymentdate, 'yyyy-MM-dd'), '') as  dateinvoiced, 
fp.paymentdate as  dateinvoicedc, 
 coalesce (to_char(fps2.expecteddate,'yyyy-MM-dd'), '') as expecteddate, 
 coalesce (fp.EM_Ssfi_Description, '') as description, fa2.account_id,
  fa2.amtacctdr , fa2.amtacctcr as amtacctcr, (fa2.amtacctdr + (fa2.amtacctcr*-1)) as saldo ,3 as orden, '' as ref_invoice, fp.referenceno,
  (case when ci2.em_scnr_isref_inv = 'Y' then ci2.em_scnr_invoice_id else ci2.c_invoice_id end) as invoice_id,
  (case when ci2.em_scnr_isref_inv = 'Y' then 1 else 0 end) as invoice_type
   from fact_acct fa2
    inner join fin_payment fp on fp.fin_payment_id = fa2.record_id
    inner join fin_payment_detail fpd on fpd.fin_payment_id  = fp.fin_payment_id
    inner join fin_payment_scheduledetail fps on fps.fin_payment_detail_id = fpd.fin_payment_detail_id
    left join fin_payment_schedule fps2 on fps2.fin_payment_schedule_id = fps.fin_payment_schedule_invoice
    left join c_invoice ci2 on ci2.c_invoice_id = fps2.c_invoice_id
   where fa2.ad_table_id = 'D1A97202E832470285C9B1EB026D54E2'
         and $P!{accounts_query_pymt}
         and fp.isReceipt = $P!{issotrx_str}
         and fp.c_bpartner_id = $P!{bpartner_id_query}
         and fp.paymentdate  >=  TO_DATE($P!{date_fromstr})
         and fp.paymentdate  <= TO_DATE($P!{date_tostr})
          and case when ci2.em_scnr_isref_inv = 'Y'
					       then not exists( select 1
                                                          from fin_payment fp01
		                                                     inner join fin_payment_detail fpd01 on fpd01.fin_payment_id  = fp01.fin_payment_id
															 inner join fin_payment_scheduledetail fps01 on fps01.fin_payment_detail_id = fpd01.fin_payment_detail_id
															 inner join fin_payment_schedule fps201 on fps201.fin_payment_schedule_id = fps01.fin_payment_schedule_invoice
															 inner join c_invoice ci201 on ci201.c_invoice_id = fps201.c_invoice_id
												   		 where fp01.fin_payment_id = fp.fin_payment_id and ci201.c_invoice_id <> ci2.c_invoice_id  and ci201.em_scnr_isref_inv = 'N'
													)
					        else not exists (select 1
                                                    	  from fin_payment fp02
                                                     		inner join fin_payment_detail fpd02 on fpd02.fin_payment_id  = fp02.fin_payment_id
													        inner join fin_payment_scheduledetail fps02 on fps02.fin_payment_detail_id = fpd02.fin_payment_detail_id
														    inner join fin_payment_schedule fps202 on fps202.fin_payment_schedule_id = fps02.fin_payment_schedule_invoice
													        inner join c_invoice ci202 on ci202.c_invoice_id = fps202.c_invoice_id
												        where fp02.fin_payment_id = fp.fin_payment_id and ci202.c_invoice_id <> ci2.c_invoice_id  and ci202.em_scnr_isref_inv = 'Y' )	end
					   group by  coalesce(ci2.documentno,'') , fp.documentno ,
			           case when fp.isReceipt ='Y' and ci2.issotrx = 'Y' then '' else  coalesce(ci2.POReference, '') end ,
			           coalesce (to_char(ci2.dateinvoiced, 'yyyy-MM-dd'), '') ,
			           coalesce (to_char(fps2.expecteddate,'yyyy-MM-dd'), '') ,
			           coalesce (fp.EM_Ssfi_Description, '') , fa2.account_id, fa2.amtacctdr , fa2.amtacctcr, fa2.dateacct, fp.referenceno,
                       ci2.em_scnr_invoice_id, ci2.c_invoice_id, ci2.em_scnr_isref_inv, fp.paymentdate
                      order by fa2.dateacct asc)
 ) as  pp
 order by  pp.documentno, pp.dateinvoicedc, pp.orden, pp.invoice_id,pp.invoice_type,pp.dateinvoiced asc]]>
	</queryString>
	<field name="documentno" class="java.lang.String"/>
	<field name="pay_documentno" class="java.lang.String"/>
	<field name="document_type" class="java.lang.String"/>
	<field name="dateinvoiced" class="java.lang.String"/>
	<field name="description" class="java.lang.String"/>
	<field name="account_id" class="java.lang.String"/>
	<field name="amtacctdr" class="java.math.BigDecimal"/>
	<field name="amtacctcr" class="java.math.BigDecimal"/>
	<field name="saldo" class="java.math.BigDecimal"/>
	<field name="expecteddate" class="java.lang.String"/>
	<field name="reference" class="java.lang.String"/>
	<field name="ref_invoice" class="java.lang.String"/>
	<field name="referenceno" class="java.lang.String"/>
	<field name="orden" class="java.lang.Integer"/>
	<field name="invoice_id" class="java.lang.String"/>
	<field name="invoice_type" class="java.lang.Integer"/>
	<field name="dateinvoicedc" class="java.sql.Timestamp"/>
	<variable name="v_saldo" class="java.math.BigDecimal" resetType="Column">
		<variableExpression><![CDATA[$V{v_saldo}.add($F{saldo})]]></variableExpression>
		<initialValueExpression><![CDATA[$P{initial_balance}]]></initialValueExpression>
	</variable>
	<variable name="v_debito" class="java.math.BigDecimal" calculation="Sum">
		<variableExpression><![CDATA[$F{amtacctdr}]]></variableExpression>
	</variable>
	<variable name="v_credito" class="java.math.BigDecimal" calculation="Sum">
		<variableExpression><![CDATA[$F{amtacctcr}]]></variableExpression>
	</variable>
	<variable name="v_saldo_total" class="java.math.BigDecimal">
		<variableExpression><![CDATA[($V{v_debito}.add($V{v_credito}.multiply(new BigDecimal(-1))).add($P{initial_balance}))]]></variableExpression>
	</variable>
	<group name="Gruppo1">
		<groupExpression><![CDATA[$F{documentno}]]></groupExpression>
	</group>
