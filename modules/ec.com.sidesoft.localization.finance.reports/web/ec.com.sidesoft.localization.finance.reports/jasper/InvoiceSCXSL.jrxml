		<defaultValueExpression><![CDATA["'"+new SimpleDateFormat("dd-MM-yyyy").format($P{date_from})+"'"]]></defaultValueExpression>
	</parameter>
	<parameter name="issotrx_str" class="java.lang.String">
		<defaultValueExpression><![CDATA[$P{issotrx} == true? "'Y'" : "'N'"]]></defaultValueExpression>
	</parameter>
