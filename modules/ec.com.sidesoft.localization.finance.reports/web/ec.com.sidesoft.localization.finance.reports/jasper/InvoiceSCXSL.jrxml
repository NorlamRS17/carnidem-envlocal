	<parameter name="issotrx" class="java.lang.Boolean"/>
	<parameter name="bpartner_id_query" class="java.lang.String">
		<defaultValueExpression><![CDATA["'"+$P{bpartner_id}.getString("value")+"'"]]></defaultValueExpression>
	</parameter>
