	<parameter name="User1_ID" class="java.lang.String">
		<defaultValueExpression><![CDATA[]]></defaultValueExpression>
	</parameter>
	<queryString>
		<![CDATA[SELECT REPLACE(sq2.Costcenter,'X-','') AS costcenter FROM (SELECT DISTINCT (CASE WHEN COALESCE(cos.name,'NA') = 'NA' THEN CONCAT('X-',COALESCE(cos.name,'NA')) ELSE COALESCE(cos.name,'NA') END) AS Costcenter
            FROM fact_acct fa
            LEFT JOIN c_costcenter cos ON fa.c_costcenter_id = cos.c_costcenter_id
	WHERE (cos.c_costcenter_id IS NULL OR cos.c_costcenter_id =(CASE WHEN $P{C_Costcenter_ID} IS NULL THEN cos.c_costcenter_id ELSE $P{C_Costcenter_ID} END ))
AND (CASE WHEN ($P{C_Costcenter_ID} IS NOT NULL AND cos.c_costcenter_id IS NULL) THEN FALSE ELSE TRUE END) order by costcenter desc ) AS sq2]]>
	</queryString>
	<field name="costcenter" class="java.lang.String"/>
	<background>
		<band splitType="Stretch"/>
	</background>
	<detail>
		<band height="15" splitType="Stretch">
			<textField isStretchWithOverflow="true">
				<reportElement positionType="Float" stretchType="RelativeToTallestObject" x="0" y="0" width="88" height="15" isPrintWhenDetailOverflows="true" uuid="f9ac9e19-3a3f-45d0-9fda-c8642fe839b6"/>
				<textElement textAlignment="Center" verticalAlignment="Middle">
