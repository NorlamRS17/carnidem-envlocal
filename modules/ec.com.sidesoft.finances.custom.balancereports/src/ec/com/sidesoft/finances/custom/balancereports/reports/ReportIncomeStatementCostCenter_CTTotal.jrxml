<?xml version="1.0" encoding="UTF-8"?>
<jasperReport xmlns="http://jasperreports.sourceforge.net/jasperreports" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://jasperreports.sourceforge.net/jasperreports http://jasperreports.sourceforge.net/xsd/jasperreport.xsd" name="ReportIncomeStatementCostCenter_CTTotal" columnCount="200" printOrder="Horizontal" pageWidth="17600" pageHeight="23" columnWidth="88" leftMargin="0" rightMargin="0" topMargin="0" bottomMargin="0" whenResourceMissingType="Error" uuid="00ab118b-9e86-47b8-8051-f9fdb9e1ca03">
	<property name="ireport.zoom" value="1.0"/>
	<property name="ireport.x" value="0"/>
	<property name="ireport.y" value="0"/>
	<parameter name="ad_org_id" class="java.lang.String">
		<defaultValueExpression><![CDATA[]]></defaultValueExpression>
	</parameter>
	<parameter name="AD_USER_ID" class="java.lang.String">
		<defaultValueExpression><![CDATA[]]></defaultValueExpression>
	</parameter>
	<parameter name="BASE_DESIGN" class="java.lang.String">
		<defaultValueExpression><![CDATA[]]></defaultValueExpression>
	</parameter>
	<parameter name="C_Costcenter_ID" class="java.lang.String">
		<defaultValueExpression><![CDATA[]]></defaultValueExpression>
	</parameter>
	<parameter name="datefrom" class="java.util.Date">
		<defaultValueExpression><![CDATA[]]></defaultValueExpression>
	</parameter>
	<parameter name="dateto" class="java.util.Date">
		<defaultValueExpression><![CDATA[]]></defaultValueExpression>
	</parameter>
	<parameter name="nivel" class="java.lang.String">
		<defaultValueExpression><![CDATA[]]></defaultValueExpression>
	</parameter>
	<parameter name="sfcbr_accountlevel" class="java.lang.String">
		<defaultValueExpression><![CDATA[]]></defaultValueExpression>
	</parameter>
	<parameter name="sfcbr_showzeroaccount" class="java.lang.String">
		<defaultValueExpression><![CDATA[]]></defaultValueExpression>
	</parameter>
	<parameter name="User1_ID" class="java.lang.String">
		<defaultValueExpression><![CDATA[]]></defaultValueExpression>
	</parameter>
	<parameter name="accounttype" class="java.lang.String">
		<defaultValueExpression><![CDATA[]]></defaultValueExpression>
	</parameter>
	<parameter name="account_t" class="java.lang.String">
		<defaultValueExpression><![CDATA[]]></defaultValueExpression>
	</parameter>
	<queryString>
		<![CDATA[SELECT SUM(sq.amount) AS amount, REPLACE(sq.Costcenter,'X-','') AS Costcenter FROM ((SELECT COALESCE(SUM(fa.AmtAcctDr)-SUM(fa.AmtAcctCr),0.00) AS amount ,(CASE WHEN COALESCE(cos.name,'NA') = 'NA' THEN CONCAT('X-',COALESCE(cos.name,'NA')) ELSE COALESCE(cos.name,'NA') END) AS Costcenter
FROM fact_acct fa
	LEFT JOIN c_elementvalue ev ON fa.account_id = ev.c_elementvalue_id
	LEFT JOIN sfcbr_tree_acounting_v ta ON ta.id = ev.c_elementvalue_id
	LEFT JOIN c_costcenter cos ON fa.c_costcenter_id = cos.c_costcenter_id
WHERE fa.dateacct BETWEEN $P{datefrom} AND $P{dateto}
AND fa.factaccttype <> 'R'
AND fa.factaccttype <> 'C'
AND fa.factaccttype = 'N'
AND fa.isactive = 'Y'
AND ta.p6 = $P{account_t}
AND fa.ad_org_id = (CASE WHEN $P{ad_org_id} = '0' THEN fa.ad_org_id ELSE $P{ad_org_id} END )
AND (cos.c_costcenter_id IS NULL OR cos.c_costcenter_id = (CASE WHEN $P{C_Costcenter_ID} IS NULL THEN cos.c_costcenter_id ELSE $P{C_Costcenter_ID} END))
AND (CASE WHEN ($P{C_Costcenter_ID} IS NOT NULL AND cos.c_costcenter_id IS NULL) THEN FALSE ELSE TRUE END)
GROUP BY cos.name,ta.p6,ta.P5,ta.p4,ta.p3,ta.p2,ta.p1,ev.accounttype
ORDER BY ta.p6,ta.P5,ta.p4,ta.p3,ta.p2,ta.p1)
union all
(
SELECT 0.00 AS amount,
       (CASE WHEN COALESCE(ub2.name,'NA') = 'NA' THEN CONCAT('X-',COALESCE(ub2.name,'NA')) ELSE COALESCE(ub2.name,'NA') END) AS Costcenter
FROM (
            SELECT DISTINCT cos.name, cos.c_costcenter_id
            FROM fact_acct fa
            LEFT JOIN c_costcenter cos ON fa.c_costcenter_id = cos.c_costcenter_id
	WHERE (cos.c_costcenter_id IS NULL OR cos.c_costcenter_id = (CASE WHEN $P{C_Costcenter_ID} IS NULL THEN cos.c_costcenter_id ELSE $P{C_Costcenter_ID} END ))
AND (CASE WHEN ($P{C_Costcenter_ID} IS NOT NULL AND cos.c_costcenter_id IS NULL) THEN FALSE ELSE TRUE END)
          ) ub2)) as sq
GROUP BY sq.Costcenter
ORDER BY sq.Costcenter]]>
	</queryString>
	<field name="amount" class="java.math.BigDecimal"/>
	<field name="costcenter" class="java.lang.String"/>
	<background>
		<band splitType="Stretch"/>
	</background>
	<detail>
		<band height="23" splitType="Stretch">
			<textField pattern="#,##0.00;-#,##0.00">
				<reportElement x="0" y="0" width="88" height="23" uuid="d609c106-23ae-4ee9-ac17-27d2dde7872e"/>
				<textElement textAlignment="Right" verticalAlignment="Top">
					<font size="13" isBold="true"/>
				</textElement>
				<textFieldExpression><![CDATA[$F{amount}]]></textFieldExpression>
			</textField>
		</band>
	</detail>
</jasperReport>
