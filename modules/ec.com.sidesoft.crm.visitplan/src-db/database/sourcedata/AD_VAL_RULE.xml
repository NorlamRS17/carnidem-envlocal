<!--2F22656F6ACD4ECFBBB3DDB33153F41C-->  <CODE><![CDATA[C_Period.C_Period_ID IN (
SELECT
	pc.c_period_id
FROM c_periodcontrol pc
	JOIN c_period p ON p.c_period_id=pc.c_period_id
GROUP BY pc.c_period_id
HAVING max(pc.periodstatus) = min(pc.periodstatus) AND min(pc.periodstatus) = 'O'
)]]></CODE>
