<!--FBAFC67FE8654F0DB7A10D69232CC5C9-->  <TYPE><![CDATA[S]]></TYPE>
<!--FBAFC67FE8654F0DB7A10D69232CC5C9-->  <CODE><![CDATA[exists 
(
select 
1 
from scrvro_route_week srw  
join scrvro_route_day srd on srw.scrvro_route_week_id = srd.scrvro_route_week_id  
where srd.scrvro_route_day_id = @scrvro_route_day_id@  
and srw.c_bpartner_id = c_bpartner.salesrep_id  
)]]></CODE>
