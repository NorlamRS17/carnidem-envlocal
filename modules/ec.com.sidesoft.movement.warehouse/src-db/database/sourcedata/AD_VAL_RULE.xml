<!--04D8F09BAFDC44BA970462B1E72B69DD-->  <ISACTIVE><![CDATA[Y]]></ISACTIVE>
<!--04D8F09BAFDC44BA970462B1E72B69DD-->  <NAME><![CDATA[Org Locator Included]]></NAME>
<!--04D8F09BAFDC44BA970462B1E72B69DD-->  <DESCRIPTION><![CDATA[Include locators linked organization adding the locators linked to the main organization]]></DESCRIPTION>
<!--04D8F09BAFDC44BA970462B1E72B69DD-->  <TYPE><![CDATA[S]]></TYPE>
<!--04D8F09BAFDC44BA970462B1E72B69DD-->  <CODE><![CDATA[m_locator_id in (
select mloc.m_locator_id
		from AD_org_warehouse adowh
		left join m_locator mloc on mloc.m_warehouse_id = adowh.m_warehouse_id
		where adowh.ad_org_id = @ad_org_id@
		or adowh.ad_org_id in (select ad_org_id from ad_org where issummary = 'Y')
                and mloc.isactive = 'Y'
)]]></CODE>
<!--04D8F09BAFDC44BA970462B1E72B69DD-->  <AD_MODULE_ID><![CDATA[DFE0DD3106FF487FA3BAA680D68B317E]]></AD_MODULE_ID>
