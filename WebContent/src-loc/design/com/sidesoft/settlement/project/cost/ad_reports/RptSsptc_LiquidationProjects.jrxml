<?xml version="1.0" encoding="UTF-8"?>
<jasperReport xmlns="http://jasperreports.sourceforge.net/jasperreports" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://jasperreports.sourceforge.net/jasperreports http://jasperreports.sourceforge.net/xsd/jasperreport.xsd" name="RptSsptc_LiquidationProjects" pageWidth="807" pageHeight="842" columnWidth="779" leftMargin="14" rightMargin="14" topMargin="14" bottomMargin="14">
	<property name="ireport.zoom" value="1.0"/>
	<property name="ireport.x" value="0"/>
	<property name="ireport.y" value="0"/>
	<parameter name="BASE_DESIGN" class="java.lang.String" isForPrompting="false"/>
	<parameter name="DOCUMENT_ID" class="java.lang.String"/>
	<queryString>
		<![CDATA[select
row_number() over (order by scl.sstpc_liquidation_projects_id nulls last) as rownum,
cd.name as "tipo_documento"
,slp.documentno as "documento"
, adrv.name as "tipo_liquidacion",
 CBP.name as "tercero"
,adrv.ad_ref_list_id
,cc.name as "proyecto"
,to_char(slp.dateliqproj,'dd/MM/yyyy') as "fecha_liquidacion"
,trunc((scl.line/10),0) as "linea"
,mp.value as "codigo"
,mp.name as "producto"
,scl.uom as "unidad_medida"
,scl.qtyconsumption as "cantidad"
,case when scl.qtyconsumption < 0 then (scl.costconsumption / scl.qtyconsumption) * (-1) else (scl.costconsumption / scl.qtyconsumption) end as "costo"
,scl.costconsumption as "total_linea"
,TO_CHAR('FECHA REPORTE: ') || to_char(now(),'dd/MM/yyyy') as "fecha_impresion"
,TO_CHAR('DESCRIPCIÓN: ')|| COALESCE(TO_CHAR(slp.description_liq),TO_CHAR('')) as "descripcion"
,slp.ad_org_id as "organizationid",
slp.total_cost
from sstpc_liquidation_projects slp
left join c_bpartner CBP on CBP.c_bpartner_id = slp.c_bpartner_id
left join c_doctype cd on slp.c_doctype_id = cd.c_doctype_id
left join ad_ref_list_v adrv on adrv.value = slp.type_liquidation and adrv.ad_language = 'es_ES' and adrv.ad_reference_id = '5D4EF6EAA16349B6A837EE7BF0D2D6D5'
left join c_costcenter cc on cc.c_costcenter_id = slp.c_costcenter_id
left join sstpc_consumption_line scl on scl.sstpc_liquidation_projects_id = slp.sstpc_liquidation_projects_id
left join m_product mp on mp.m_product_id = scl.m_product_id
where slp.sstpc_liquidation_projects_id =  $P{DOCUMENT_ID}
AND scl.liquidate = 'Y'
and (slp.docstatuslist ='LQ' or slp.posted='Y')]]>
	</queryString>
