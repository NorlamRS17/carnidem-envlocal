<?xml version="1.0" encoding="UTF-8"?>
<jasperReport xmlns="http://jasperreports.sourceforge.net/jasperreports" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://jasperreports.sourceforge.net/jasperreports http://jasperreports.sourceforge.net/xsd/jasperreport.xsd" name="CxcStatusReport" pageWidth="1600" pageHeight="1000" orientation="Landscape" columnWidth="1560" leftMargin="20" rightMargin="20" topMargin="20" bottomMargin="20" uuid="21b6cc2d-a625-4516-908d-ba3357b9a7d1">
	<property name="ireport.zoom" value="1.5"/>
	<property name="ireport.x" value="1424"/>
	<property name="ireport.y" value="0"/>
	<property name="net.sf.jasperreports.export.xls.detect.cell.type" value="true"/>
	<property name="com.jaspersoft.studio.data.defaultdataadapter" value="Happypreprod"/>
	<parameter name="AD_Org_ID" class="java.lang.String"/>
	<parameter name="Portfolio_Type" class="java.lang.String" isForPrompting="false"/>
	<parameter name="DocumentNo" class="java.lang.String" isForPrompting="false"/>
	<parameter name="Cutoffdate" class="java.util.Date"/>
	<parameter name="AD_User" class="java.lang.String"/>
	<queryString>
		<![CDATA[SELECT DISTINCT
    ao.ad_org_id AS organizationid,
    ao.name AS organization,
    si.documentno,
    si.dateinvoiced,
    fpm.name AS paymentmethod,
    CASE WHEN $P{AD_Org_ID} IS NULL THEN '' ELSE (SELECT ao.name FROM ad_org WHERE ad_org_id = $P{AD_Org_ID}) END AS nameorganization,
    bp.value AS identifier,
    bp.name2 AS customer,
    si.EM_Sig_Opcredito AS opcredito,
    si.EM_Sig_Opalterno AS opalterno,
    si.grandtotal AS importetotal,
    fps.paidamt,
    fps.outstandingamt,
    (SELECT COALESCE(CB.NAME, AU.NAME) FROM ad_user AU LEFT JOIN c_bpartner CB ON CB.c_bpartner_id = AU.c_bpartner_id WHERE AU.ad_user_id = $P{AD_User}) AS "usuario",
    NOW() AS "fechaimpresion",
(
    case when $P{Portfolio_Type} IS NULL then '' else (select rlt.name from ad_ref_list  rl
left join ad_ref_list_trl rlt ON rl.ad_ref_list_id=rlt.ad_ref_list_id
where ad_reference_id  ='B584DF08B7C74A8B80193B4881197516' and ad_language='es_ES' and value=$P{Portfolio_Type}) end
) as portfoliotype,
(
    CASE
    WHEN (si.EM_Shspr_Portfolio_Type = '001') THEN 'V. Vigente'
    WHEN (si.EM_Shspr_Portfolio_Type = '002') THEN 'V. Castigada'
    WHEN (si.EM_Shspr_Portfolio_Type is null) THEN ''
    END
) AS portfoliotype1
FROM c_invoice si
INNER JOIN ad_org ao ON si.ad_org_id = ao.ad_org_id
INNER JOIN c_doctype cd ON si.c_doctype_id = cd.c_doctype_id
INNER JOIN fin_payment_schedule fps ON fps.c_invoice_id = si.c_invoice_id
LEFT JOIN fin_payment_scheduledetail fpsd ON fpsd.fin_payment_schedule_invoice = fps.fin_payment_schedule_id
LEFT JOIN fin_payment_detail fpd ON fpd.fin_payment_detail_id = fpsd.fin_payment_detail_id
LEFT JOIN fin_payment fp ON fpd.fin_payment_id = fp.fin_payment_id
INNER JOIN fin_paymentmethod fpm ON si.fin_paymentmethod_id = fpm.fin_paymentmethod_id
INNER JOIN c_bpartner bp ON si.c_bpartner_id = bp.c_bpartner_id
WHERE si.issotrx = 'Y'
    AND si.docstatus = 'CO'
    AND cd.DocBaseType = 'ARI'
    AND fps.outstandingamt <> 0
    AND (si.EM_Shspr_Portfolio_Type= $P{Portfolio_Type} OR $P{Portfolio_Type} IS NULL)
    AND (si.documentno = $P{DocumentNo} OR $P{DocumentNo} IS NULL)
    AND (si.ad_org_id = $P{AD_Org_ID} OR $P{AD_Org_ID} IS NULL)
    AND (TRUNC(si.DATEORDERED) <= TO_DATE($P{Cutoffdate}::DATE) OR $P{Cutoffdate}::DATE  IS NULL);]]>
	</queryString>
