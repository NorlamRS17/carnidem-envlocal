<?xml version="1.0" encoding="UTF-8"?>
<jasperReport xmlns="http://jasperreports.sourceforge.net/jasperreports" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://jasperreports.sourceforge.net/jasperreports http://jasperreports.sourceforge.net/xsd/jasperreport.xsd" name="ANTICIPOS POR LIQUIDAR" pageWidth="700" pageHeight="842" whenNoDataType="BlankPage" columnWidth="640" leftMargin="30" rightMargin="30" topMargin="20" bottomMargin="20" uuid="9a7d6219-3c22-4dad-8ba3-1330fd4e092c">
	<property name="ireport.zoom" value="1.1289478601075547"/>
	<property name="ireport.x" value="0"/>
	<property name="ireport.y" value="0"/>
	<property name="ireport.scriptlethandling" value="0"/>
	<property name="ireport.encoding" value="UTF-8"/>
