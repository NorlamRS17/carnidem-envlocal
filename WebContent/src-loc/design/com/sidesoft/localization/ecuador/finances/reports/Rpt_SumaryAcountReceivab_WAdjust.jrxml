	<import value="java.util.*"/>
	<import value="net.sf.jasperreports.engine.data.*"/>
	<parameter name="NUMBERFORMAT" class="java.text.DecimalFormat" isForPrompting="false">
		<defaultValueExpression><![CDATA[new DecimalFormat("###,##0.00;-###,##0.00", new DecimalFormatSymbols())]]></defaultValueExpression>
	</parameter>
	<parameter name="NUMBERDECIMAL" class="java.lang.Integer" isForPrompting="false">
		<defaultValueExpression><![CDATA[2]]></defaultValueExpression>
	</parameter>
	<parameter name="Dateto" class="java.util.Date"/>
	<parameter name="Docstatus" class="java.lang.String"/>
	<parameter name="C_BPartner_ID" class="java.lang.String"/>
	<parameter name="Org_ID" class="java.lang.String" isForPrompting="false">
		<defaultValueExpression><![CDATA[OBContext.getOBContext().getCurrentOrganization().getId()]]></defaultValueExpression>
	</parameter>
	<parameter name="User_ID" class="java.lang.String" isForPrompting="false">
		<defaultValueExpression><![CDATA[OBContext.getOBContext().getUser().getId()]]></defaultValueExpression>
	</parameter>
	<parameter name="UserName" class="java.lang.String" isForPrompting="false">
		<defaultValueExpression><![CDATA[OBContext.getOBContext().getUser().getUsername()]]></defaultValueExpression>
	</parameter>
	<queryString>
		<![CDATA[WITH acsi AS (
  SELECT DISTINCT
      'ACSI' AS doc_code,
      'Anticipo Cliente' AS doc_type,
      bp.name AS bpartner_name,
      bp.taxid,
      p.documentno AS invoice,
      p.documentno AS applied,
      p.paymentdate AS documentdate,
      p.paymentdate AS dateacct,
      p.referenceno AS poreference,
      to_char(p.description) AS description,
      p.paymentdate AS duedate,
      pd.amount * -1 AS grandtotal,
      c_currency_convert(pd.amount, p.c_currency_id, '100', p.paymentdate, NULL, p.ad_client_id, p.ad_org_id) * -1 AS grandtotalconverted,
      dt.name AS doctype,
      cc.name AS costcenter,
      cc.c_costcenter_id,
      p.isreceipt AS isclient,
      p.posted,
      p.c_bpartner_id,
      NULL AS fin_payment_id,
      p.c_currency_id,
      p.ad_client_id,
      p.ad_org_id,
      to_char('') AS c_invoice_id,
      to_char('') AS em_sswh_withholdingref,
      to_number(0) AS em_sswh_totalwithholdingincome,
      to_number(0) AS em_sswh_totalwithholdingvat
  FROM fin_payment p
  JOIN fin_payment_detail pd ON p.fin_payment_id = pd.fin_payment_id
  LEFT JOIN c_bpartner bp ON p.c_bpartner_id = bp.c_bpartner_id
  LEFT JOIN fin_financial_account fa ON p.fin_financial_account_id = fa.fin_financial_account_id
  LEFT JOIN c_doctype dt ON p.c_doctype_id = dt.c_doctype_id
  LEFT JOIN c_costcenter cc ON p.c_costcenter_id = cc.c_costcenter_id
  WHERE fa.name ~~ '%Anticipo Cliente SI%'
    AND p.isreceipt = 'Y'
    AND p.paymentdate <= $P{Dateto}
    AND ($P{Docstatus} IS NULL OR p.posted = $P{Docstatus})
    AND ($P{C_BPartner_ID} IS NULL OR p.c_bpartner_id = $P{C_BPartner_ID})
),
gen AS (
  SELECT
      p.fin_payment_id,
      p.c_bpartner_id,
      p.documentno,
      p.paymentdate,
      p.c_currency_id,
      p.ad_client_id,
      p.ad_org_id,
      p.referenceno,
      p.description,
      SUM(pdv.paidamt) AS amount_generated
  FROM fin_payment p
  JOIN fin_payment_detail pd ON p.fin_payment_id = pd.fin_payment_id
  JOIN ssfi_fin_payment_detail_v pdv ON p.fin_payment_id = pdv.fin_payment_id
  WHERE p.amount <> 0
    AND p.status IN ('RDNC', 'RPPC', 'RPR')
    AND pdv.glitemname IS NULL
    AND pdv.fin_payment_sched_inv_id IS NULL
    AND p.isreceipt = 'Y'
    AND pd.isprepayment = 'Y'
    AND p.generated_credit = pdv.paidamt
    AND p.paymentdate <= $P{Dateto}
    AND ($P{Docstatus} IS NULL OR p.posted = $P{Docstatus})
    AND ($P{C_BPartner_ID} IS NULL OR p.c_bpartner_id = $P{C_BPartner_ID})
  GROUP BY p.fin_payment_id, p.c_bpartner_id, p.documentno, p.paymentdate,
           p.c_currency_id, p.ad_client_id, p.ad_org_id, p.referenceno, p.description
),
gen_rows AS (
  SELECT
      'AC' AS doc_code,
      'Anticipo Cliente' AS doc_type,
      bp.name AS bpartner_name,
      bp.taxid,
      p.documentno AS invoice,
      p.documentno AS applied,
      p.paymentdate AS documentdate,
      p.paymentdate AS dateacct,
      p.referenceno AS poreference,
      to_char(p.description) AS description,
      NULL AS duedate,
      (g.amount_generated * -1) AS grandtotal,
      c_currency_convert(g.amount_generated, p.c_currency_id, '100', p.paymentdate, NULL, p.ad_client_id, p.ad_org_id) * -1 AS grandtotalconverted,
      dt.name AS doctype,
      cc.name AS costcenter,
      cc.c_costcenter_id,
      p.isreceipt AS isclient,
      p.posted,
      p.c_bpartner_id,
      p.fin_payment_id,
      p.c_currency_id,
      p.ad_client_id,
      p.ad_org_id,
      to_char('') AS c_invoice_id,
      to_char('') AS em_sswh_withholdingref,
      to_number(0) AS em_sswh_totalwithholdingincome,
      to_number(0) AS em_sswh_totalwithholdingvat
  FROM gen g
  JOIN fin_payment p ON p.fin_payment_id = g.fin_payment_id
  LEFT JOIN c_bpartner bp ON bp.c_bpartner_id = p.c_bpartner_id
  LEFT JOIN c_doctype dt ON dt.c_doctype_id = p.c_doctype_id
  LEFT JOIN c_costcenter cc ON cc.c_costcenter_id = p.c_costcenter_id
),
used AS (
  SELECT
      b.fin_payment_id_used AS fin_payment_id,
      SUM(b.amount) AS amount_used
  FROM fin_payment_credit b
  GROUP BY b.fin_payment_id_used
),
used_rows AS (
  SELECT
      'AC' AS doc_code,
      'Anticipo Cliente' AS doc_type,
      bp.name AS bpartner_name,
      bp.taxid,
      p.documentno AS invoice,
      p.documentno AS applied,
      c.paymentdate AS documentdate,
      c.paymentdate AS dateacct,
      p.referenceno AS poreference,
      to_char(p.description) AS description,
      NULL AS duedate,
      u.amount_used AS grandtotal,
      c_currency_convert(u.amount_used, p.c_currency_id, '100', c.paymentdate, NULL, p.ad_client_id, p.ad_org_id) AS grandtotalconverted,
      dt.name AS doctype,
      cc.name AS costcenter,
      cc.c_costcenter_id,
      p.isreceipt AS isclient,
      p.posted,
      p.c_bpartner_id,
      c.fin_payment_id,
      p.c_currency_id,
      p.ad_client_id,
      p.ad_org_id,
      to_char('') AS c_invoice_id,
      to_char('') AS em_sswh_withholdingref,
      to_number(0) AS em_sswh_totalwithholdingincome,
      to_number(0) AS em_sswh_totalwithholdingvat
  FROM gen g
  JOIN used u ON u.fin_payment_id = g.fin_payment_id
  JOIN fin_payment p ON p.fin_payment_id = g.fin_payment_id
  JOIN fin_payment c ON c.fin_payment_id = (
                          SELECT b.fin_payment_id
                          FROM fin_payment_credit b
                          WHERE b.fin_payment_id_used = g.fin_payment_id
                          ORDER BY b.fin_payment_credit_id
                          LIMIT 1
                        )
  LEFT JOIN c_bpartner bp ON bp.c_bpartner_id = p.c_bpartner_id
  LEFT JOIN c_doctype dt ON dt.c_doctype_id = p.c_doctype_id
  LEFT JOIN c_costcenter cc ON cc.c_costcenter_id = p.c_costcenter_id
  WHERE c.paymentdate <= $P{Dateto}
    AND ($P{Docstatus} IS NULL OR p.posted = $P{Docstatus})
    AND ($P{C_BPartner_ID} IS NULL OR p.c_bpartner_id = $P{C_BPartner_ID})
),
zro AS (
  SELECT DISTINCT
      arp.doctype AS doc_code,
      arp.doc_type,
      arp.bpartner_name,
      NULL AS taxid,
      arp.invoice,
      arp.applied,
      arp.documentdate,
      arp.dateacct,
      arp.poreference,
      arp.description,
      arp.duedate,
      arp.grandtotal,
      arp.grandtotalconverted,
      arp.doctype,
      arp.costcenter,
      arp.c_costcenter_id,
      arp.isclient,
      arp.posted,
      arp.c_bpartner_id,
      arp.fin_payment_id,
      arp.c_currency_id,
      arp.ad_client_id,
      arp.ad_org_id,
      arp.c_invoice_id,
      arp.em_sswh_withholdingref,
      arp.em_sswh_totalwithholdingincome,
      arp.em_sswh_totalwithholdingvat
  FROM sswh_acct_receivab_payab_zro_v arp
  WHERE arp.isclient = 'Y'
    AND arp.doc_type IN ('Anticipo Cliente')
    AND arp.dateacct <= $P{Dateto}
    AND ($P{Docstatus} IS NULL OR arp.posted = $P{Docstatus})
    AND ($P{C_BPartner_ID} IS NULL OR arp.c_bpartner_id = $P{C_BPartner_ID})
)
SELECT
    tercero,
    identificador,
    factura,
    SUM(GrandTotalConvert) AS valor,
    MIN(fecha_cobro) AS fecha_cobro,
    to_char($P{Dateto}::date, 'dd/MM/yyyy') AS fhasta,
    TO_CHAR(now(), 'dd/MM/yyyy HH24:MI:SS') AS "fecha_impresion"
FROM (
    SELECT
        bpartner_name AS tercero,
        taxid AS identificador,
        invoice AS factura,
        documentdate AS fecha_cobro,
        grandtotalconverted AS GrandTotalConvert
    FROM acsi

    UNION ALL

    SELECT
        bpartner_name AS tercero,
        taxid AS identificador,
        invoice AS factura,
        documentdate AS fecha_cobro,
        grandtotalconverted AS GrandTotalConvert
    FROM gen_rows

    UNION ALL

    SELECT
        bpartner_name AS tercero,
        taxid AS identificador,
        invoice AS factura,
        documentdate AS fecha_cobro,
        grandtotalconverted AS GrandTotalConvert
    FROM used_rows

    UNION ALL

    SELECT
        bpartner_name AS tercero,
        taxid AS identificador,
        invoice AS factura,
        documentdate AS fecha_cobro,
        grandtotalconverted AS GrandTotalConvert
    FROM zro
) xxx
GROUP BY tercero, identificador, factura
HAVING ROUND(SUM(GrandTotalConvert), 2) NOT BETWEEN -0.01 AND 0.01
ORDER BY 1, 2;]]>
	</queryString>
	<field name="tercero" class="java.lang.String"/>
	<field name="identificador" class="java.lang.String"/>
	<field name="factura" class="java.lang.String"/>
	<field name="valor" class="java.math.BigDecimal"/>
	<field name="fecha_cobro" class="java.sql.Timestamp"/>
	<field name="fhasta" class="java.lang.String"/>
	<field name="fecha_impresion" class="java.lang.String"/>
	<variable name="vtotal" class="java.math.BigDecimal" calculation="Sum">
		<variableExpression><![CDATA[$F{valor}]]></variableExpression>
	</variable>
