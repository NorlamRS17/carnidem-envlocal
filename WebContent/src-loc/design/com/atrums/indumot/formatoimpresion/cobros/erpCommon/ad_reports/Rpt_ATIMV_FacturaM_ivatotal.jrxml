<?xml version="1.0" encoding="UTF-8"?>
<jasperReport xmlns="http://jasperreports.sourceforge.net/jasperreports" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://jasperreports.sourceforge.net/jasperreports http://jasperreports.sourceforge.net/xsd/jasperreport.xsd" name="Rpt_ATIMV_FacturaM_ivatotal" pageWidth="596" pageHeight="100" columnWidth="596" leftMargin="0" rightMargin="0" topMargin="0" bottomMargin="0">
	<property name="ireport.zoom" value="1.5"/>
	<property name="ireport.x" value="0"/>
	<property name="ireport.y" value="0"/>
	<parameter name="DOCUMENT_ID" class="java.lang.String"/>
	<queryString>
		<![CDATA[select   t.rate || '%' as "TipoImpuesto",
        sum(ilt.taxbaseamt) as "SumBase"
  from c_invoiceline cl left join m_product p on (cl.m_product_id = p.m_product_id)
  left join c_invoicelinetax ilt on (cl.c_invoiceline_id=ilt.c_invoiceline_id)
  left join c_tax t on (ilt.c_tax_id=t.c_tax_id)
  where cl.c_invoice_id=$P{DOCUMENT_ID}
group by t.rate
union
select  t.rate || '%' as "TipoImpuesto",
        sum(ilt.taxamt) as "SumImp"
  from c_invoiceline cl left join m_product p on (cl.m_product_id = p.m_product_id)
  left join c_invoicelinetax ilt on (cl.c_invoiceline_id=ilt.c_invoiceline_id)
  left join c_tax t on (ilt.c_tax_id=t.c_tax_id)
  where cl.c_invoice_id=$P{DOCUMENT_ID}
group by t.rate]]>
	</queryString>
	<field name="TipoImpuesto" class="java.lang.String"/>
	<field name="SumBase" class="java.math.BigDecimal"/>
	<variable name="Ttotal" class="java.math.BigDecimal" calculation="Sum">
		<variableExpression><![CDATA[$F{SumBase}]]></variableExpression>
	</variable>
	<detail>
		<band height="17" splitType="Stretch">
			<textField>
				<reportElement x="367" y="0" width="100" height="16"/>
				<textElement textAlignment="Right" verticalAlignment="Middle">
					<font size="8"/>
				</textElement>
				<textFieldExpression class="java.lang.String"><![CDATA[$F{TipoImpuesto}]]></textFieldExpression>
			</textField>
			<textField>
				<reportElement x="496" y="0" width="100" height="16"/>
				<textElement textAlignment="Right" verticalAlignment="Middle">
					<font size="8"/>
				</textElement>
				<textFieldExpression class="java.math.BigDecimal"><![CDATA[$F{SumBase}]]></textFieldExpression>
			</textField>
		</band>
	</detail>
	<pageFooter>
		<band height="21">
			<textField>
				<reportElement x="496" y="0" width="100" height="20"/>
				<textElement textAlignment="Right" verticalAlignment="Middle">
					<font size="11" isBold="true"/>
				</textElement>
				<textFieldExpression class="java.math.BigDecimal"><![CDATA[$V{Ttotal}]]></textFieldExpression>
			</textField>
			<staticText>
				<reportElement x="367" y="0" width="100" height="20"/>
				<textElement textAlignment="Right">
					<font size="11" isBold="true"/>
				</textElement>
				<text><![CDATA[TOTAL]]></text>
			</staticText>
		</band>
	</pageFooter>
</jasperReport>
