<?xml version="1.0" encoding="UTF-8"?>
<jasperReport xmlns="http://jasperreports.sourceforge.net/jasperreports" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://jasperreports.sourceforge.net/jasperreports http://jasperreports.sourceforge.net/xsd/jasperreport.xsd" name="Rpt_atimv_guiaremision_subreportdetalles" pageWidth="595" pageHeight="842" columnWidth="595" leftMargin="0" rightMargin="0" topMargin="0" bottomMargin="0">
	<property name="ireport.zoom" value="1.1000000000000005"/>
	<property name="ireport.x" value="0"/>
	<property name="ireport.y" value="0"/>
	<parameter name="DOCUMENT_ID" class="java.lang.String"/>
	<queryString>
		<![CDATA[select
    tb_mpd.value as codigo,
    coalesce(tb_mpd.name,'') as descripcion,
    coalesce(sum(tb_minl.movementqty),0) as cantidad
from
    m_inoutline as tb_minl join
    m_product as tb_mpd on
    tb_minl.m_product_id = tb_mpd.m_product_id
where tb_minl.m_inout_id = $P{DOCUMENT_ID}
group by 1,2;]]>
	</queryString>
	<field name="codigo" class="java.lang.String"/>
	<field name="descripcion" class="java.lang.String"/>
	<field name="cantidad" class="java.math.BigDecimal"/>
	<background>
		<band splitType="Stretch"/>
	</background>
	<detail>
		<band height="21" splitType="Stretch">
			<textField>
				<reportElement x="1" y="0" width="113" height="20"/>
				<textElement>
					<font fontName="Arial" pdfFontName="Courier"/>
				</textElement>
				<textFieldExpression class="java.lang.String"><![CDATA[$F{codigo}]]></textFieldExpression>
			</textField>
			<textField>
				<reportElement x="114" y="0" width="299" height="20"/>
				<textElement>
					<font fontName="Arial" pdfFontName="Courier"/>
				</textElement>
				<textFieldExpression class="java.lang.String"><![CDATA[$F{descripcion}]]></textFieldExpression>
			</textField>
			<textField>
				<reportElement x="413" y="0" width="73" height="20"/>
				<textElement textAlignment="Right">
					<font fontName="Arial" pdfFontName="Courier"/>
				</textElement>
				<textFieldExpression class="java.math.BigDecimal"><![CDATA[$F{cantidad}]]></textFieldExpression>
			</textField>
		</band>
	</detail>
</jasperReport>
