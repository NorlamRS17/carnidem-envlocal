<?xml version="1.0" encoding="UTF-8"?>
<jasperReport xmlns="http://jasperreports.sourceforge.net/jasperreports" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://jasperreports.sourceforge.net/jasperreports http://jasperreports.sourceforge.net/xsd/jasperreport.xsd" name="Rpt_comprobante_compra" pageWidth="595" pageHeight="600" columnWidth="555" leftMargin="20" rightMargin="20" topMargin="20" bottomMargin="20">
	<property name="ireport.zoom" value="1.4641000000000006"/>
	<property name="ireport.x" value="37"/>
	<property name="ireport.y" value="164"/>
	<parameter name="DOCUMENT_ID" class="java.lang.String"/>
	<parameter name="BASE_DESIGN" class="java.lang.String" isForPrompting="false">
		<defaultValueExpression><![CDATA["C:/DesarrolloLuis/OpenbravoERPNuevo/modules/com.atrums.indumot.formatoimpresion/src"]]></defaultValueExpression>
	</parameter>
	<queryString>
		<![CDATA[select a.documentno, a.dateinvoiced, a.dateacct, a.name, a.name2, a.codigo, a.descripcion, sum(a.debe) as debe, sum(a.haber) as haber, a.retencion, a.importacion, a.creado
from (
select  i.em_co_nro_estab || '-' || i.em_co_punto_emision || '-' || i.documentno as documentno,
        i.dateinvoiced,
        i.dateacct,
        bp.name,
        bp.name2,
        coalesce(f.acctvalue,'-') as codigo, coalesce(f.acctdescription,'-') as descripcion, case when f.acctvalue = '2010301001' then 0 else coalesce(f.amtsourcedr, 0 ) end as debe,

        case when f.acctvalue = '2010301001' then coalesce(f.amtsourcecr-f.amtsourcedr, 0) else coalesce(f.amtsourcecr, 0) end as haber,

        coalesce(rc.documentno,'-') as retencion,
        coalesce((select documentno from atimi_importacion where atimi_importacion_id = i.em_atimi_importacion_id),'-') as importacion,
(select username from ad_user where ad_user_id = i.createdby) as creado
from c_invoice i
    left join co_retencion_compra rc on i.c_invoice_id = rc.c_invoice_id,
    c_bpartner bp, fact_acct f
where i.c_bpartner_id = bp.c_bpartner_id
and f.fact_acct_group_id IN (select fact_acct_group_id from fact_acct where record_id = $P{DOCUMENT_ID})
and i.c_invoice_id = $P{DOCUMENT_ID}
order by 8 desc  ) a
group by 1,2,3,4,5,6,7,10,11,12
order by 8 desc]]>
	</queryString>
	<field name="documentno" class="java.lang.String"/>
	<field name="dateinvoiced" class="java.sql.Timestamp"/>
	<field name="dateacct" class="java.sql.Timestamp"/>
	<field name="name" class="java.lang.String"/>
	<field name="name2" class="java.lang.String"/>
	<field name="retencion" class="java.lang.String"/>
	<field name="importacion" class="java.lang.String"/>
	<field name="codigo" class="java.lang.String"/>
	<field name="descripcion" class="java.lang.String"/>
	<field name="debe" class="java.math.BigDecimal"/>
	<field name="haber" class="java.math.BigDecimal"/>
	<field name="creado" class="java.lang.String"/>
	<variable name="total" class="java.math.BigDecimal" calculation="Sum">
		<variableExpression><![CDATA[$F{haber}]]></variableExpression>
	</variable>
