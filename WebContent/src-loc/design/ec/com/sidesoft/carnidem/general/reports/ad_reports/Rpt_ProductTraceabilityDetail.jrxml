<?xml version="1.0" encoding="UTF-8"?>
<jasperReport xmlns="http://jasperreports.sourceforge.net/jasperreports" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://jasperreports.sourceforge.net/jasperreports http://jasperreports.sourceforge.net/xsd/jasperreport.xsd" name="Rpt_UsefulLifeProduct" pageWidth="450" pageHeight="360" orientation="Landscape" whenNoDataType="BlankPage" columnWidth="450" leftMargin="0" rightMargin="0" topMargin="0" bottomMargin="0" isSummaryWithPageHeaderAndFooter="true" uuid="cfaf7223-c06e-4591-8e0f-b406a2336150">
	<property name="ireport.zoom" value="1.9965000000000006"/>
	<property name="ireport.x" value="0"/>
	<property name="ireport.y" value="0"/>
	<property name="net.sf.jasperreports.export.xls.detect.cell.type" value="true"/>
	<parameter name="DATEFORMAT" class="java.text.SimpleDateFormat" isForPrompting="false">
		<defaultValueExpression><![CDATA[new SimpleDateFormat("dd/MM/yyyy")]]></defaultValueExpression>
	</parameter>
	<parameter name="NUMBERFORMAT" class="java.text.DecimalFormat" isForPrompting="false">
		<defaultValueExpression><![CDATA[new DecimalFormat("###,##0.00;-###,##0.00", new DecimalFormatSymbols())]]></defaultValueExpression>
	</parameter>
	<parameter name="NUMBERDECIMAL" class="java.lang.Integer" isForPrompting="false">
		<defaultValueExpression><![CDATA[2]]></defaultValueExpression>
	</parameter>
	<parameter name="BASE_WEB" class="java.lang.String" isForPrompting="false"/>
	<parameter name="SOURCE_PATH" class="java.lang.String" isForPrompting="false"/>
	<parameter name="M_Product_Head_ID" class="java.lang.String">
		<defaultValueExpression><![CDATA[]]></defaultValueExpression>
	</parameter>
	<queryString>
		<![CDATA[SELECT
p.name as producto
,mat.description as lote
,l.value as bodega
,msd.qtyonhand as qty
FROM M_Storage_Detail msd
full JOIN m_product p ON p.m_product_id = msd.m_product_id
full JOIN m_locator l ON l.m_locator_id = msd.m_locator_id
full JOIN m_attributesetinstance mat ON mat.m_attributesetinstance_id = msd.m_attributesetinstance_id
WHERE p.m_product_id = $P{M_Product_Head_ID}
GROUP BY P.NAME,mat.description,l.value,msd.qtyonhand
HAVING sum(msd.qtyonhand) > 0]]>
	</queryString>
	<field name="producto" class="java.lang.String"/>
	<field name="lote" class="java.lang.String"/>
	<field name="bodega" class="java.lang.String"/>
	<field name="qty" class="java.math.BigDecimal"/>
	<variable name="REPORT_PAGE" class="java.lang.Integer" resetType="None" incrementType="Page">
		<variableExpression><![CDATA[$V{PAGE_NUMBER}]]></variableExpression>
	</variable>
