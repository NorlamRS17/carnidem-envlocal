	</parameter>
	<parameter name="SscgrProductId" class="java.lang.String">
		<defaultValueExpression><![CDATA[]]></defaultValueExpression>
	</parameter>
	<parameter name="SscgrDateFrom" class="java.util.Date">
		<defaultValueExpression><![CDATA[]]></defaultValueExpression>
	</parameter>
	<parameter name="SscgrDateTo" class="java.util.Date">
		<defaultValueExpression><![CDATA[]]></defaultValueExpression>
	</parameter>
	<parameter name="M_AttributeInstance_ID" class="java.lang.String">
		<defaultValueExpression><![CDATA[]]></defaultValueExpression>
	</parameter>
	<queryString>
		<![CDATA[SELECT
	ci.dateinvoiced::date as "Fecha Factura",
	masi.description as "Codigo de compra",
	mp.name as "Producto",
	mpc.name as "Categoria del Producto",
	cb.name as "Proveedor",
	ci.documentno as "Nº Documento",
	ci.poreference as "Factura Proveedor",
	cil.qtyinvoiced as "Cantidad Facturada",
	cu.name as "Unidad",
	cau.name as "Alternativa",
	case
		when COALESCE(ct.rate,0) = 0 then ROUND(0,(select StdPrecision from c_currency where c_currency_id = '100'))
		else ROUND(cil.priceActual*((COALESCE(ct.rate,0)+100)/100),(select StdPrecision from c_currency where c_currency_id = '100'))
	END AS "PrecioUIva",
	ROUND(cil.priceActual,(select StdPrecision from c_currency where c_currency_id = '100')) as "PrecioUSIva",
	case
		when COALESCE(ct.rate,0) = 0 then ROUND((cil.priceActual*((ct.rate+100)/100))*cil.qtyinvoiced,(select StdPrecision from c_currency where c_currency_id = '100'))
		else ROUND((cil.priceActual*((ct.rate+100)/100))*cil.qtyinvoiced,(select StdPrecision from c_currency where c_currency_id = '100'))
	END AS "Precio Total"
FROM c_invoice ci
LEFT JOIN c_order co on co.c_order_id = ci.c_order_id
LEFT JOIN c_bpartner cb on cb.c_bpartner_id = ci.c_bpartner_id
LEFT JOIN c_invoiceline cil on cil.c_invoice_id = ci.c_invoice_id
LEFT JOIN m_inoutline mil on mil.m_inoutline_id = cil.m_inoutline_id
LEFT JOIN m_inout mi on mi.m_inout_id = mil.m_inout_id
LEFT JOIN m_product mp on mp.m_product_id = cil.m_product_id
LEFT JOIN m_product_category mpc on mpc.m_product_category_id = mp.m_product_category_id
LEFT JOIN m_attributesetinstance masi on masi.m_attributesetinstance_id = mil.m_attributesetinstance_id
LEFT JOIN c_uom cu on cu.c_uom_id = cil.c_uom_id
--LEFT JOIN c_uom cau on cu.c_uom_id = cil.c_aum
LEFT JOIN c_uom cau ON cau.c_uom_id = cil.c_aum
LEFT JOIN c_tax ct on ct.c_tax_id = cil.c_tax_id
WHERE ci.docstatus = 'CO'
AND ci.poreference is not null
AND (mp.m_product_category_id = $P{SscgrProductCatId} or $P{SscgrProductCatId} is null)
AND (mp.m_product_id = $P{SscgrProductId} or $P{SscgrProductId} is null)
AND (ci.dateinvoiced::date >= $P{SscgrDateFrom}::date or coalesce(to_char($P{SscgrDateFrom}),'nd')='nd')
AND (ci.dateinvoiced::date <= $P{SscgrDateTo}::date or coalesce(to_char($P{SscgrDateTo}),'nd')='nd')
AND (masi.m_attributesetinstance_id = $P{M_AttributeInstance_ID} or $P{M_AttributeInstance_ID} is null)
AND ci.issotrx = 'N'
--AND ci.c_invoice_id = 'A38164EA1CD04D23A7EC7FC84E311854'
order by ci.dateinvoiced, ci.documentno asc]]>
	</queryString>
