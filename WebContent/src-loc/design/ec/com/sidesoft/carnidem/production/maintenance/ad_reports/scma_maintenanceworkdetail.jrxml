	<parameter name="Detailed" class="java.lang.String" isForPrompting="false"/>
	<parameter name="DOCUMENT_ID" class="java.lang.String"/>
	<queryString>
		<![CDATA[select
cb_sol.name as area_sub,
ms.name as nombre_sub
from MA_Maint_Part mmp
left join MA_Maint_Worker mmw on mmw.MA_Maint_Part_id=mmp.MA_Maint_Part_id
left join MA_Maint_Scheduled mms on mms.MA_Maint_Part_id=mmp.MA_Maint_Part_id
left join MA_Machine mm on mm.MA_Machine_id=mms.MA_Machine_id
left join c_bpartner cb on cb.c_bpartner_id=mms.EM_Scma_Acceptname
left join c_bpartner cb_resp on cb_resp.c_bpartner_id=mmw.c_bpartner_id
left join c_bpartner cb_sol on cb_sol.c_bpartner_id=mmw.EM_Scma_Applicant
left join ma_section ms on ms.ma_section_id=mmw.EM_Scma_Section_ID
where mmp.MA_Maint_Part_id=$P{DOCUMENT_ID}
group by cb_sol.name,ms.name]]>
	</queryString>
	<field name="area_sub" class="java.lang.String"/>
	<field name="nombre_sub" class="java.lang.String"/>
