	<parameter name="DOCUMENT_ID" class="java.lang.String">
		<defaultValueExpression><![CDATA[]]></defaultValueExpression>
	</parameter>
	<parameter name="ma_ccp_id" class="java.lang.String" isForPrompting="false">
		<defaultValueExpression><![CDATA[]]></defaultValueExpression>
	</parameter>
	<queryString>
		<![CDATA[SELECT
  MAX(CASE WHEN rn = 1 THEN no_toma END) AS toma1_header,
  MAX(CASE WHEN rn = 1 THEN valuetype END) AS toma1_type,
  MAX(CASE WHEN rn = 1 THEN v_string END) AS toma1_string,
  MAX(CASE WHEN rn = 1 THEN v_number END) AS toma1_number,
  MAX(CASE WHEN rn = 2 THEN no_toma END) AS toma2_header,
  MAX(CASE WHEN rn = 2 THEN valuetype END) AS toma2_type,
  MAX(CASE WHEN rn = 2 THEN v_string END) AS toma2_string,
  MAX(CASE WHEN rn = 2 THEN v_number END) AS toma2_number,
  MAX(CASE WHEN rn = 3 THEN no_toma END) AS toma3_header,
  MAX(CASE WHEN rn = 3 THEN valuetype END) AS toma3_type,
  MAX(CASE WHEN rn = 3 THEN v_string END) AS toma3_string,
  MAX(CASE WHEN rn = 3 THEN v_number END) AS toma3_number,
  MAX(CASE WHEN rn = 4 THEN no_toma END) AS toma4_header,
  MAX(CASE WHEN rn = 4 THEN valuetype END) AS toma4_type,
  MAX(CASE WHEN rn = 4 THEN v_string END) AS toma4_string,
  MAX(CASE WHEN rn = 4 THEN v_number END) AS toma4_number,
  COALESCE(SUM(v_number), 0) AS sum_values
FROM (
  SELECT
    v.valuetype,
    COALESCE(v_string, CASE WHEN v_char='N' THEN 'NO' ELSE 'SI' END) AS v_string,
    COALESCE(v_number, 0) AS v_number,
    COALESCE(cd.description, to_char(t.em_spquly_takenumber)) AS no_toma,
    ROW_NUMBER() OVER (ORDER BY v.seqno) AS rn
  FROM ma_measure_shift s
  JOIN ma_measure_group g
    ON g.ma_measure_shift_id = s.ma_measure_shift_id
  JOIN ma_measure_time t
    ON t.ma_measure_group_id = g.ma_measure_group_id
  JOIN ma_measure_values v
    ON v.ma_measure_time_id = t.ma_measure_time_id
  JOIN MA_CCP_Group msg
    ON msg.MA_CCP_Group_id = s.em_spquly_ccp_id
  LEFT JOIN crprod_dimension cd
    ON cd.MA_CCP_Group_id = msg.MA_CCP_Group_id
   AND cd.name = to_char(t.em_spquly_takenumber)
  LEFT JOIN ma_ccp mc
    ON mc.ma_ccp_id = v.ma_ccp_id
  WHERE s.ma_measure_shift_id = $P{DOCUMENT_ID}
  AND mc.ma_ccp_id = $P{ma_ccp_id}
) base]]>
	</queryString>
