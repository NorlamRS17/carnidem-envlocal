<?xml version="1.0" encoding="UTF-8"?>
<jasperReport xmlns="http://jasperreports.sourceforge.net/jasperreports" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://jasperreports.sourceforge.net/jasperreports http://jasperreports.sourceforge.net/xsd/jasperreport.xsd" name="Rpt_PackWaste" pageWidth="1000" pageHeight="842" columnWidth="960" leftMargin="20" rightMargin="20" topMargin="20" bottomMargin="20" uuid="457c92e4-9e5a-436b-9661-bedceeec3e3b">
	<property name="ireport.zoom" value="1.7715610000000082"/>
	<property name="ireport.x" value="0"/>
	<property name="ireport.y" value="0"/>
	<parameter name="DateFrom" class="java.util.Date"/>
	<parameter name="DateTo" class="java.util.Date"/>
	<parameter name="cr_m_product_id" class="java.lang.String"/>
	<parameter name="cr_m_attributesetinstance_id" class="java.lang.String"/>
	<parameter name="AD_User_ID" class="java.lang.String" isForPrompting="false"/>
	<queryString>
		<![CDATA[SELECT
			to_char(mt.movementdate,'dd/MM/yyyy') as fecha,
			mprod.documentno as num_documento,
			COALESCE(mp_terminado.value, mp.value) as codigo,
			COALESCE(mp_terminado.name, mp.name) as producto,
			-- Producto en proceso cocido: P- con mayor cantidad
			COALESCE(mpdl_materia_mayor.movementqty, 0) as producto_proceso_cocido,
		-- Producto terminado: si UOM es kilogramos, tomar cantidad directamente; si no, cantidad * peso
		CASE
			WHEN mpdl_terminado.c_uom_id = '72BA247D31F745F3AF11F74A5E2CCBEF' THEN COALESCE(mpdl_terminado.movementqty, 0)
			ELSE COALESCE(mpdl_terminado.movementqty * mp_terminado.weight, 0)
		END as producto_terminado,
			-- Recorte: valor del campo EM_Crprod_Cutout de la parte de fabricación
			COALESCE(mpp.em_crprod_cutout, 0) as recorte,
			-- % Recorte: recorte/producto en proceso cocido * 100
			CASE WHEN COALESCE(mpdl_materia_mayor.movementqty, 0) > 0
				THEN round(((COALESCE(mpp.em_crprod_cutout, 0)/mpdl_materia_mayor.movementqty)*100),2)
				ELSE 0
			END as porcentaje_recorte,
			-- Desperdicio: Rejectedquantity (cantidad rechazada)
			COALESCE(mpp.rejectedquantity, 0) as desperdicio,
			-- % Desperdicio: desperdicio/producto_proceso_cocido * 100
			CASE WHEN COALESCE(mpdl_materia_mayor.movementqty, 0) > 0
				THEN round(((COALESCE(mpp.rejectedquantity, 0)/mpdl_materia_mayor.movementqty)*100),2)
				ELSE 0
			END as porcentaje_desperdicio,
		-- Merma: producto_proceso_cocido - producto_terminado - recorte - desperdicio
		COALESCE(mpdl_materia_mayor.movementqty - 
			CASE
				WHEN mpdl_terminado.c_uom_id = '72BA247D31F745F3AF11F74A5E2CCBEF' THEN COALESCE(mpdl_terminado.movementqty, 0)
				ELSE COALESCE(mpdl_terminado.movementqty * mp_terminado.weight, 0)
			END - mpp.em_crprod_cutout - mpp.rejectedquantity, 0) as merma,
		-- % Merma: merma/producto_proceso_cocido * 100
		CASE WHEN COALESCE(mpdl_materia_mayor.movementqty, 0) > 0
			THEN round(((COALESCE(mpdl_materia_mayor.movementqty - 
				CASE
					WHEN mpdl_terminado.c_uom_id = '72BA247D31F745F3AF11F74A5E2CCBEF' THEN COALESCE(mpdl_terminado.movementqty, 0)
					ELSE COALESCE(mpdl_terminado.movementqty * mp_terminado.weight, 0)
				END - COALESCE(mpp.em_crprod_cutout, 0) - COALESCE(mpp.rejectedquantity, 0), 0)/mpdl_materia_mayor.movementqty)*100),2)
			ELSE 0
		END as porcentaje_merma,
			mt.ad_org_id as organizationid,
			now() as fechaimpresion,
			(SELECT au.name FROM ad_user au WHERE au.ad_user_id = $P{AD_User_ID}) as usuario
		FROM m_transaction mt
		LEFT JOIN m_product mp ON mp.m_product_id = mt.m_product_id
		-- Navegación SIMPLIFICADA: M_Transaction -> M_ProductionLine -> M_ProductionPlan -> M_Production
		LEFT JOIN m_productionline mpdl ON mpdl.m_productionline_id = mt.m_productionline_id
		LEFT JOIN m_productionplan mpp ON mpp.m_productionplan_id = mpdl.m_productionplan_id
		LEFT JOIN m_production mprod ON mprod.m_production_id = mpp.m_production_id
		-- P+ con mayor cantidad (producto terminado)
		LEFT JOIN (
			SELECT mpp2.m_productionplan_id, mpdl2.movementqty, mpdl2.m_product_id, mpdl2.c_uom_id
			FROM m_productionplan mpp2
			LEFT JOIN m_productionline mpdl2 ON mpdl2.m_productionplan_id = mpp2.m_productionplan_id AND mpdl2.productiontype = '+'
			WHERE mpdl2.movementqty = (
				SELECT MAX(mpdl3.movementqty)
				FROM m_productionline mpdl3
				WHERE mpdl3.m_productionplan_id = mpp2.m_productionplan_id AND mpdl3.productiontype = '+'
			)
		) mpdl_terminado ON mpdl_terminado.m_productionplan_id = mpp.m_productionplan_id
		LEFT JOIN m_product mp_terminado ON mp_terminado.m_product_id = mpdl_terminado.m_product_id
		-- P- con mayor cantidad (primero busca el que tenga em_crprod_productact = 'Y' en m_product, si no existe toma el de mayor cantidad)
		LEFT JOIN (
			SELECT mpp2.m_productionplan_id, mpdl2.movementqty
			FROM m_productionplan mpp2
			LEFT JOIN m_productionline mpdl2 ON mpdl2.m_productionplan_id = mpp2.m_productionplan_id AND mpdl2.productiontype = '-'
			LEFT JOIN m_product mp_materia ON mp_materia.m_product_id = mpdl2.m_product_id
			WHERE (
				-- Primero: si existe alguno con em_crprod_productact = 'Y', toma ese
				(EXISTS (SELECT 1 FROM m_productionline mpdl_act
				         LEFT JOIN m_product mp_act ON mp_act.m_product_id = mpdl_act.m_product_id
				         WHERE mpdl_act.m_productionplan_id = mpp2.m_productionplan_id
				         AND mpdl_act.productiontype = '-'
				         AND mp_act.em_crprod_productact = 'Y')
				 AND mp_materia.em_crprod_productact = 'Y')
				OR
				-- Si no existe ninguno activo, toma el de mayor cantidad
				(NOT EXISTS (SELECT 1 FROM m_productionline mpdl_act
				             LEFT JOIN m_product mp_act ON mp_act.m_product_id = mpdl_act.m_product_id
				             WHERE mpdl_act.m_productionplan_id = mpp2.m_productionplan_id
				             AND mpdl_act.productiontype = '-'
				             AND mp_act.em_crprod_productact = 'Y')
				 AND mpdl2.movementqty = (SELECT MAX(mpdl3.movementqty) FROM m_productionline mpdl3 WHERE mpdl3.m_productionplan_id = mpp2.m_productionplan_id AND mpdl3.productiontype = '-'))
			)
		) mpdl_materia_mayor ON mpdl_materia_mayor.m_productionplan_id = mpp.m_productionplan_id
		-- P+ con menor cantidad (si solo hay 1 P+, toma ese)
		LEFT JOIN (
			SELECT mpp2.m_productionplan_id, mpdl2.movementqty
			FROM m_productionplan mpp2
			LEFT JOIN m_productionline mpdl2 ON mpdl2.m_productionplan_id = mpp2.m_productionplan_id AND mpdl2.productiontype = '+'
			WHERE mpdl2.movementqty = (
				SELECT MIN(mpdl3.movementqty)
				FROM m_productionline mpdl3
				WHERE mpdl3.m_productionplan_id = mpp2.m_productionplan_id
					AND mpdl3.productiontype = '+'
			)
		) mpdl_terminado_menor ON mpdl_terminado_menor.m_productionplan_id = mpp.m_productionplan_id
		WHERE mt.m_product_id::text = $P{cr_m_product_id}
			AND DATE(mt.movementdate) >= DATE($P{DateFrom})
			AND DATE(mt.movementdate) <= DATE($P{DateTo})
			AND mt.m_productionline_id IS NOT NULL
			AND ($P{cr_m_attributesetinstance_id} IS NULL OR $P{cr_m_attributesetinstance_id} = '' OR mt.m_attributesetinstance_id::text = $P{cr_m_attributesetinstance_id})
		ORDER BY mt.movementdate, COALESCE(mp_terminado.value, mp.value)]]>
	</queryString>
	<field name="fecha" class="java.lang.String"/>
	<field name="num_documento" class="java.lang.String"/>
	<field name="codigo" class="java.lang.String"/>
	<field name="producto" class="java.lang.String"/>
	<field name="producto_proceso_cocido" class="java.math.BigDecimal"/>
	<field name="producto_terminado" class="java.math.BigDecimal"/>
	<field name="recorte" class="java.math.BigDecimal"/>
	<field name="porcentaje_recorte" class="java.math.BigDecimal"/>
	<field name="desperdicio" class="java.math.BigDecimal"/>
	<field name="porcentaje_desperdicio" class="java.math.BigDecimal"/>
	<field name="merma" class="java.math.BigDecimal"/>
	<field name="porcentaje_merma" class="java.math.BigDecimal"/>
	<field name="organizationid" class="java.lang.String"/>
	<field name="fechaimpresion" class="java.sql.Timestamp"/>
	<field name="usuario" class="java.lang.String"/>
	<variable name="total_producto_proceso_cocido" class="java.math.BigDecimal" calculation="Sum">
		<variableExpression><![CDATA[$F{producto_proceso_cocido}]]></variableExpression>
	</variable>
	<variable name="total_producto_terminado" class="java.math.BigDecimal" calculation="Sum">
		<variableExpression><![CDATA[$F{producto_terminado}]]></variableExpression>
	</variable>
	<variable name="total_recorte" class="java.math.BigDecimal" calculation="Sum">
		<variableExpression><![CDATA[$F{recorte}]]></variableExpression>
	</variable>
	<variable name="total_desperdicio" class="java.math.BigDecimal" calculation="Sum">
		<variableExpression><![CDATA[$F{desperdicio}]]></variableExpression>
	</variable>
	<variable name="total_merma" class="java.math.BigDecimal" calculation="Sum">
		<variableExpression><![CDATA[$F{merma}]]></variableExpression>
	</variable>
