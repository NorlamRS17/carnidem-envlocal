<?xml version="1.0" encoding="UTF-8"?>
<jasperReport xmlns="http://jasperreports.sourceforge.net/jasperreports" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://jasperreports.sourceforge.net/jasperreports http://jasperreports.sourceforge.net/xsd/jasperreport.xsd" name="Rpt_ImportsDetail" pageWidth="802" pageHeight="595" orientation="Landscape" columnWidth="802" leftMargin="0" rightMargin="0" topMargin="0" bottomMargin="0" uuid="5ade871c-9ec8-45c1-bbc4-9b04af22a436">
	<property name="ireport.zoom" value="2.5937424601000094"/>
	<property name="ireport.x" value="1205"/>
	<property name="ireport.y" value="0"/>
	<parameter name="DATE_TO" class="java.util.Date"/>
	<parameter name="REPORT_TYPE" class="java.lang.String" isForPrompting="false"/>
	<parameter name="AD_USER_ID" class="java.lang.String" isForPrompting="false"/>
	<parameter name="organizationid" class="java.lang.String" isForPrompting="false"/>
	<parameter name="C_ORDER_ID" class="java.lang.String"/>
	<queryString>
		<![CDATA[select

documento
, fecha_orden
,identificador
,importacion
,producto
,coalesce(cant_pedida,0) as cant_pedida
,coalesce(costo_origen,0) as costo_origen
,coalesce( base_alternativa,0) as base_alternativa
, coalesce(round(costo_importacion,2),0)  as costo_importacion
, coalesce(ice,0) as ice
,  coalesce(base_alternativa,0) + coalesce(round(costo_importacion,2),0) + coalesce(ice,0) as importe_total
from
(select
co.documentno as documento
, to_char(co.dateordered,'dd/MM/yyyy') as fecha_orden
, mp.value as identificador
,cc.value as importacion
,mp.name as producto
,col.qtyordered as cant_pedida
,col.PriceActual as costo_origen
,col.Taxbaseamt as base_alternativa
, tot_base_alt
, net_total
,case when col.Taxbaseamt>0 and tot_base_alt>0 then repp.linenetamt  * (col.Taxbaseamt/tot_base_alt) else 0 end as costo_importacion

,col.EM_Ssipice_Value_Ice as ice
,col.line
from c_order co
join c_orderline col on col.c_order_id = co.c_order_id
join m_product mp on mp.m_product_id = col.m_product_id
join c_bpartner cbp on cbp.c_bpartner_id = co.c_bpartner_id
join C_Campaign cc on cc.C_Campaign_ID = co.C_Campaign_ID
left join  (
select sum(Taxbaseamt) as tot_base_alt,c_order_id from c_orderline
group by c_order_id
) rep1 on rep1.c_order_id = co.c_order_id
left join ( select sum(amountnet) as net_total,c_order_id
from SSIP_Costimport
group by c_order_id
) rep2 on rep2.c_order_id = co.c_order_id
left join (

	select
	value
	,C_Campaign_id
	,sum(linenetamt) as linenetamt
	from
	(
		select
		cc.value
		,cc.C_Campaign_id
		,sum(cil.linenetamt * ( case when cd.docbasetype = 'APC' and cd.isreversal = 'Y' then -1 else 1 end)) as linenetamt
		from  C_Campaign cc
		join c_invoiceline cil on cc.C_Campaign_id = cil.em_ssip_campaign_id
		join c_invoice ci on ci.c_invoice_id = cil.c_invoice_id
		join c_doctype cd on cd.c_doctype_id = ci.c_doctype_id
		where cil.em_ssip_importtype ='Y'
		group by cc.value
		,cc.C_Campaign_id
		union all
		select
		cc.value
		,cc.C_Campaign_id
		,gjl.AmtSourceDr as linenetamt
		from C_Campaign cc
		left join GL_JournalLine gjl on cc.C_Campaign_id = gjl.C_Campaign_id
		where
		gjl.EM_Ssip_Importcosts ='Y'
	) compaing
	group by value
	,C_Campaign_id

) repp on repp.C_Campaign_ID = co.C_Campaign_ID
where
co.issotrx ='N'
and cc.isactive='Y'
and co.EM_Ssip_Importstatus='NL'
AND (cc.C_Campaign_ID = $P{C_ORDER_ID} OR   COALESCE(TO_CHAR($P{C_ORDER_ID}),'')='')
AND  (CO.DATEORDERED < $P{DATE_TO} or COALESCE(TO_CHAR($P{DATE_TO}),'')='' )
) rep1
order by 1,line asc]]>
	</queryString>
