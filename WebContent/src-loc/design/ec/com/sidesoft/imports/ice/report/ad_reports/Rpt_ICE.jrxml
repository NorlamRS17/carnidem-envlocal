	</variable>
	<variable name="ice" class="java.math.BigDecimal" calculation="Sum">
		<variableExpression><![CDATA[$F{valorice}]]></variableExpression>
	</variable>
	<variable name="icetotal" class="java.math.BigDecimal" calculation="Sum">
		<variableExpression><![CDATA[$F{totalice}]]></variableExpression>
	</variable>
