<?xml version="1.0" encoding="UTF-8"?>
<jasperReport xmlns="http://jasperreports.sourceforge.net/jasperreports" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://jasperreports.sourceforge.net/jasperreports http://jasperreports.sourceforge.net/xsd/jasperreport.xsd" name="Rpt_ICE" pageWidth="842" pageHeight="595" orientation="Landscape" whenNoDataType="BlankPage" columnWidth="814" leftMargin="14" rightMargin="14" topMargin="14" bottomMargin="14" uuid="cfaf7223-c06e-4591-8e0f-b406a2336150">
	<property name="ireport.zoom" value="1.239669421487604"/>
	<property name="ireport.x" value="0"/>
	<property name="ireport.y" value="0"/>
	<property name="net.sf.jasperreports.export.xls.detect.cell.type" value="true"/>
	<property name="net.sf.jasperreports.export.xls.sheet.names.all" value="Reporte de Stock Nacional"/>
	<parameter name="NUMBERFORMAT" class="java.text.DecimalFormat" isForPrompting="false">
		<defaultValueExpression><![CDATA[new DecimalFormat("###,##0.00;-###,##0.00", new DecimalFormatSymbols())]]></defaultValueExpression>
	</parameter>
	<parameter name="ad_org_id" class="java.lang.String"/>
	<parameter name="datefrom" class="java.util.Date"/>
	<parameter name="dateto" class="java.util.Date"/>
	<parameter name="AD_USER_ID" class="java.lang.String"/>
	<queryString>
		<![CDATA[SELECT
to_char(now(), 'dd/MM/yyyy HH24:MI:SS') AS fecha_actual

,(SELECT UPPER(name) FROM ad_user WHERE ad_user_id=$P{AD_USER_ID}) AS usuario
,(SELECT ad_org_id FROM ad_org WHERE ad_org_id=$P{ad_org_id}) AS organizationid
,c.name as importaciones,
p.name as producto,
p.value as identificador,
ol.qtyordered as cantidad,
coalesce(round(EM_Ssipice_Value_Ice/ol.qtyordered,2),0) as valorice,
coalesce(EM_Ssipice_Value_Ice,0) as totalice,

(SELECT coalesce(pp.pricestd,ol.PriceList)
FROM m_pricelist_version pv
LEFT JOIN m_productprice pp on pp.m_product_id = p.m_product_id AND pp.m_pricelist_version_id=pv.m_pricelist_version_id
WHERE pv.m_pricelist_id=bp.m_PriceList_ID order by validfrom desc LIMIT 1) as tarifa,
p.EM_Ssipice_Pvp_Sri as sri
FROM c_order o
JOIN c_orderline ol on ol.c_order_id=o.c_order_id
JOIN m_pricelist mp on mp.m_pricelist_id=o.m_pricelist_id
LEFT JOIN C_Campaign c on c.C_Campaign_ID=o.C_Campaign_ID
JOIN c_bpartner bp on bp.c_bpartner_id = o.c_bpartner_id
LEFT JOIN M_Product p on p.M_Product_ID=ol.M_Product_ID
WHERE issotrx='N' AND (EM_Ssipice_Value_Ice is not null OR p.EM_Ssipice_Tax_Ice='Y')
AND c.C_Campaign_ID in (SELECT em_ssip_campaign_id from c_invoice i
JOIN c_invoiceline l on l.c_invoice_id=i.c_invoice_id
JOIN M_Product pt on pt.M_Product_ID=l.M_Product_ID
WHERE i.issotrx='N' AND i.docstatus='CO' AND pt.EM_Ssipice_Tax_Ice='Y'
AND l.EM_Ssimacc_Dataimport ='Y'
AND em_ssip_campaign_id is not null
AND dateinvoiced::date BETWEEN  $P{datefrom}::date AND $P{dateto}::date )
ORDER BY importaciones]]>
	</queryString>
	<field name="fecha_actual" class="java.lang.String"/>
	<field name="usuario" class="java.lang.String"/>
	<field name="organizationid" class="java.lang.String"/>
	<field name="importaciones" class="java.lang.String"/>
	<field name="producto" class="java.lang.String"/>
	<field name="identificador" class="java.lang.String"/>
	<field name="cantidad" class="java.math.BigDecimal"/>
	<field name="valorice" class="java.math.BigDecimal"/>
	<field name="totalice" class="java.math.BigDecimal"/>
	<field name="tarifa" class="java.math.BigDecimal"/>
	<field name="sri" class="java.math.BigDecimal"/>
	<variable name="TOTAL_PAGINAS" class="java.lang.Integer">
