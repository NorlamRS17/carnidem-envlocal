<?xml version="1.0" encoding="UTF-8"?>
<jasperReport xmlns="http://jasperreports.sourceforge.net/jasperreports" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://jasperreports.sourceforge.net/jasperreports http://jasperreports.sourceforge.net/xsd/jasperreport.xsd" name="Rpt_ImportsDetail" pageWidth="2088" pageHeight="595" orientation="Landscape" columnWidth="2048" leftMargin="20" rightMargin="20" topMargin="20" bottomMargin="20" uuid="e4ad59bc-e1a3-40ab-98ff-be7a156b2fad">
	<property name="ireport.zoom" value="1.6105100000000054"/>
	<property name="ireport.x" value="1434"/>
	<property name="ireport.y" value="0"/>
	<parameter name="Datefrom" class="java.util.Date">
		<defaultValueExpression><![CDATA[]]></defaultValueExpression>
	</parameter>
	<parameter name="Dateto" class="java.util.Date">
		<defaultValueExpression><![CDATA[]]></defaultValueExpression>
	</parameter>
	<parameter name="Ad_Org_ID" class="java.lang.String">
		<defaultValueExpression><![CDATA[]]></defaultValueExpression>
	</parameter>
	<parameter name="C_BPartner_ID" class="java.lang.String">
		<defaultValueExpression><![CDATA[]]></defaultValueExpression>
	</parameter>
	<parameter name="C_Campaign_ID" class="java.lang.String">
		<defaultValueExpression><![CDATA[]]></defaultValueExpression>
	</parameter>
	<parameter name="M_Product_ID" class="java.lang.String">
		<defaultValueExpression><![CDATA[]]></defaultValueExpression>
	</parameter>
	<parameter name="Posted" class="java.lang.String">
		<defaultValueExpression><![CDATA[]]></defaultValueExpression>
	</parameter>
	<parameter name="Ad_User_Id" class="java.lang.String">
		<defaultValueExpression><![CDATA[]]></defaultValueExpression>
	</parameter>
	<queryString>
		<![CDATA[SELECT cc.name,co.documentno,bp.name as "tercero",co.dateordered,sum(ol.em_ssip_costorigin) as "costoorigen", sum(ol.em_ssip_realcost) as "costreal", CASE WHEN co.em_ssip_importstatus='NL' THEN 'NO LIQUIDADO'
WHEN co.em_ssip_importstatus='PL' THEN 'PRE LIQUIDADO' WHEN co.em_ssip_importstatus='LL' THEN 'LIQUIDADO' END AS em_ssip_importstatus,
sq.docfactura,sq.terfactura,sq.dateinvoiced,sq.totallines,sq.iva,sq.grandtotal,mi.documentno as "docalbaran",mi.movementdate, sqq.documentno as "docum", COALESCE(sqq.debe,0) AS "debe", COALESCE(sqq.haber,0) as "haber",
(select
coalesce(cbu.name,adu.name) as usuario
from ad_user adu
left join c_bpartner cbu on cbu.c_bpartner_id = adu.c_bpartner_id
where adu.ad_user_id = $P{Ad_User_Id}) as "usuario",
now() as "fechaimpresion",
co.ad_org_id
FROM c_campaign cc
LEFT JOIN c_order co ON cc.c_campaign_id = co.c_campaign_id and co.em_ssip_isimports ='Y'
LEFT JOIN c_bpartner bp ON co.c_bpartner_id = bp.c_bpartner_id
LEFT JOIN c_orderline ol ON co.c_order_id = ol.c_order_id
LEFT JOIN m_inout mi ON mi.c_order_id = co.c_order_id
LEFT JOIN
(SELECT
ci.documentno as "docfactura",bpa.name as "terfactura",ci.dateinvoiced,
CASE WHEN (ci.grandtotal-ci.totallines <0) THEN ci.grandtotal ELSE ci.totallines END AS totallines,
CASE WHEN (ci.grandtotal-ci.totallines <0) THEN 0 ELSE ci.grandtotal-ci.totallines END AS iva,
ci.grandtotal,
ci.c_campaign_id, il.em_ssip_campaign_id
FROM c_invoice ci
LEFT JOIN c_invoiceline il ON il.c_invoice_id = ci.c_invoice_id
LEFT JOIN c_bpartner bpa ON ci.c_bpartner_id = bpa.c_bpartner_id
WHERE ci.issotrx='N' AND ci.docstatus='CO'
	AND (il.em_ssip_importtype ='Y' or ci.c_campaign_id IS NOT NULL)
AND (ci.posted = $P{Posted} OR $P{Posted} IS NULL)
GROUP BY ci.documentno,bpa.name,ci.dateinvoiced,ci.totallines,ci.grandtotal,
ci.c_campaign_id, il.em_ssip_campaign_id
order by 1
) sq ON cc.c_campaign_id = sq.em_ssip_campaign_id or cc.c_campaign_id = sq.c_campaign_id
LEFT JOIN
(SELECT  gb.gl_journalbatch_id, gb.documentno, gl.c_campaign_id, sum(amtsourcedr) as debe, sum(amtsourcecr) as haber
FROM gl_journalbatch gb
INNER JOIN gl_journal gj ON gb.gl_journalbatch_id = gj.gl_journalbatch_id
INNER JOIN gl_journalline gl ON gj.gl_journal_id = gl.gl_journal_id
WHERE  gl.c_campaign_id IS NOT NULL AND gl.EM_Ssip_Importcosts = 'Y' AND gj.posted='Y' and gj.processed='Y'
GROUP BY gb.gl_journalbatch_id, gb.documentno, gl.c_campaign_id
) sqq ON sqq.c_campaign_id = cc.c_campaign_id
WHERE co.issotrx='N' AND co.docstatus='CO'
AND co.dateordered BETWEEN $P{Datefrom} AND $P{Dateto}
AND (co.ad_org_id = $P{Ad_Org_ID} OR $P{Ad_Org_ID} IS NULL)
AND (co.c_bpartner_id = $P{C_BPartner_ID} OR $P{C_BPartner_ID} IS NULL)
AND (cc.c_campaign_id = $P{C_Campaign_ID} OR $P{C_Campaign_ID} IS NULL)
AND (ol.m_product_id = $P{M_Product_ID} OR $P{M_Product_ID} IS NULL)

GROUP BY cc.name,co.documentno,bp.name,co.dateordered,co.em_ssip_importstatus,
sq.docfactura,sq.terfactura,sq.dateinvoiced,sq.totallines,sq.iva,sq.grandtotal,mi.documentno,mi.movementdate,co.ad_org_id,sqq.documentno, sqq.debe, sqq.haber
order by co.dateordered,cc.name]]>
	</queryString>
