<?xml version="1.0" encoding="UTF-8"?>
<jasperReport xmlns="http://jasperreports.sourceforge.net/jasperreports" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://jasperreports.sourceforge.net/jasperreports http://jasperreports.sourceforge.net/xsd/jasperreport.xsd" name="Pago de quincena" pageWidth="792" pageHeight="612" orientation="Landscape" columnWidth="752" leftMargin="20" rightMargin="20" topMargin="20" bottomMargin="20" uuid="d1ff138d-947f-4d0e-a277-5dc727311a7f">
	<property name="ireport.zoom" value="1.2100000000000002"/>
	<property name="ireport.x" value="0"/>
	<property name="ireport.y" value="0"/>
	<property name="net.sf.jasperreports.export.xls.detect.cell.type" value="true"/>
	<parameter name="NUMBERFORMAT" class="java.text.DecimalFormat" isForPrompting="false">
		<defaultValueExpression><![CDATA[new DecimalFormat("###,##0.00;-###,##0.00", new DecimalFormatSymbols())]]></defaultValueExpression>
	</parameter>
	<parameter name="DATEFORMAT" class="java.text.SimpleDateFormat" isForPrompting="false">
		<defaultValueExpression><![CDATA[new SimpleDateFormat("dd/MM/yyyy")]]></defaultValueExpression>
	</parameter>
	<parameter name="EM_Sspr_Costcenter_ID" class="java.lang.String">
		<defaultValueExpression><![CDATA[]]></defaultValueExpression>
	</parameter>
	<parameter name="c_year_id" class="java.lang.String">
		<defaultValueExpression><![CDATA[]]></defaultValueExpression>
	</parameter>
	<queryString>
		<![CDATA[select
	cbp.taxid as cedula,
	cbank.AccountNo as cuenta,
	cbp.name as nombres,
	cant.name as canton,
	scon.ad_org_id,
	ROUND(ut.totalprofits,2) as utilidad,
	cast(substring(per.name, 5, 6)as integer) + 2000 as anio_quin,
	case
		when substring(per.name, 1, 3)='Ene' then 'Enero'
		when substring(per.name, 1, 3)='Feb' then 'Febrero'
		when substring(per.name, 1, 3)='Mar' then 'Marzo'
		when substring(per.name, 1, 3)='Abr' then 'Abril'
		when substring(per.name, 1, 3)='May' then 'Mayo'
		when substring(per.name, 1, 3)='Jun' then 'Junio'
		when substring(per.name, 1, 3)='Jul' then 'Julio'
		when substring(per.name, 1, 3)='Ago' then 'Agosto'
		when substring(per.name, 1, 3)='Sep' then 'Septiembre'
		when substring(per.name, 1, 3)='Oct' then 'Octubre'
		when substring(per.name, 1, 3)='Nov' then 'Noviembre'
		when substring(per.name, 1, 3)='Dic' then 'Diciembre'
	end mes_quin,

	cast(extract(day from current_Date) as integer) as dia,
	extract(month from current_Date) as mes,
	case
		when extract(month from current_Date)=cast('1' as DOUBLE PRECISION) then 'Enero'
		when extract(month from current_Date)=cast('2' as DOUBLE PRECISION) then 'Febrero'
		when extract(month from current_Date)=cast('3' as DOUBLE PRECISION) then 'Marzo'
		when extract(month from current_Date)=cast('4' as DOUBLE PRECISION) then 'Abril'
		when extract(month from current_Date)=cast('5' as DOUBLE PRECISION) then 'Mayo'
		when extract(month from current_Date)=cast('6' as DOUBLE PRECISION) then 'Junio'
		when extract(month from current_Date)=cast('7' as DOUBLE PRECISION) then 'Julio'
		when extract(month from current_Date)=cast('8' as DOUBLE PRECISION) then 'Agosto'
		when extract(month from current_Date)=cast('9' as DOUBLE PRECISION) then 'Septiembre'
		when extract(month from current_Date)=cast('10' as DOUBLE PRECISION) then 'Octubre'
		when extract(month from current_Date)=cast('11' as DOUBLE PRECISION) then 'Noviembre'
		when extract(month from current_Date)=cast('12' as DOUBLE PRECISION) then 'Diciembre'
	end name_mes,
	cast(extract(year from current_Date) as integer) as anio



from sspr_configurationutility scon
	left join c_year cy on cy.c_year_id=scon.c_year_id --ejercicio(anio)

	left join sspr_utilities ut on ut.c_year_id=scon.c_year_id

	left join c_bpartner cbp on cbp.c_bpartner_id=ut.c_bpartner_id

	left join AD_OrgInfo org_inf on org_inf.ad_org_id = cbp.ad_org_id
	left join secpm_canton cant on cant.secpm_canton_id = org_inf.em_sorgi_canton_id

	left join C_BP_BankAccount cbank on cbank.c_bpartner_id=cbp.c_bpartner_id
	left join ssfi_banktransfer bk on bk.ssfi_banktransfer_id=cbank.em_ssfi_banktransfer_id
	left join c_costcenter cc on cc.c_costcenter_id=cbp.EM_Sspr_Costcenter_ID
	left join C_Period per on per.C_Period_ID = scon.C_Period_ID


where cy.c_year_id=$P{c_year_id}
	and bk.code='203'
	and cbp.isemployee='Y'
	and (cbp.EM_Sspr_Costcenter_ID = $P{EM_Sspr_Costcenter_ID} or $P{EM_Sspr_Costcenter_ID} is null)
	and cbp.EM_Sspr_Costcenter_ID is not null
	--and cbp.EM_Sspr_Costcenter_ID='A1C61B9842914EE9B3FB28021BD5C48E' --Departamento de administracion
order by cbp.name asc]]>
	</queryString>
	<field name="cedula" class="java.lang.String"/>
	<field name="cuenta" class="java.lang.String"/>
	<field name="nombres" class="java.lang.String"/>
	<field name="canton" class="java.lang.String"/>
	<field name="ad_org_id" class="java.lang.String"/>
	<field name="utilidad" class="java.math.BigDecimal"/>
	<field name="anio_quin" class="java.lang.Integer"/>
	<field name="mes_quin" class="java.lang.String"/>
	<field name="dia" class="java.lang.Integer"/>
	<field name="mes" class="java.lang.Double"/>
	<field name="name_mes" class="java.lang.String"/>
	<field name="anio" class="java.lang.Integer"/>
