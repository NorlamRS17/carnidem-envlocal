<?xml version="1.0" encoding="UTF-8"?>
<jasperReport xmlns="http://jasperreports.sourceforge.net/jasperreports" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://jasperreports.sourceforge.net/jasperreports http://jasperreports.sourceforge.net/xsd/jasperreport.xsd" name="c_purchase_by_provider" pageWidth="1692" pageHeight="878" orientation="Landscape" columnWidth="1652" leftMargin="20" rightMargin="20" topMargin="20" bottomMargin="20" uuid="8a573311-42da-4314-b2fd-ae80fe72eef0">
	<property name="ireport.zoom" value="1.4641000000000095"/>
	<property name="ireport.x" value="1654"/>
	<property name="ireport.y" value="0"/>
	<property name="ireport.scriptlethandling" value="0"/>
	<property name="ireport.encoding" value="UTF-8"/>
	<import value="net.sf.jasperreports.engine.*"/>
	<import value="java.util.*"/>
	<import value="net.sf.jasperreports.engine.data.*"/>
	<style name="Detail_Header" mode="Opaque" forecolor="#FFFFFF" backcolor="#5D5D5D" vAlign="Middle" fontName="Bitstream Vera Sans" fontSize="10" isBold="true"/>
	<parameter name="C_BPartner_ID" class="java.lang.String"/>
	<parameter name="DateFrom" class="java.util.Date"/>
	<parameter name="DateTo" class="java.util.Date"/>
	<parameter name="NUMBERFORMAT" class="java.text.DecimalFormat" isForPrompting="false"/>
	<parameter name="USER_CLIENT" class="java.lang.String" isForPrompting="false"/>
	<parameter name="USER_ORG" class="java.lang.String" isForPrompting="false"/>
	<parameter name="AD_LANGUAGE" class="java.lang.String" isForPrompting="false">
		<defaultValueExpression><![CDATA["en_US"]]></defaultValueExpression>
	</parameter>
	<parameter name="DocStatus" class="java.lang.String"/>
	<parameter name="C_DocTypeTarget_ID" class="java.lang.String"/>
	<parameter name="AD_USER_ID" class="java.lang.String">
		<defaultValueExpression><![CDATA[]]></defaultValueExpression>
	</parameter>
	<queryString>
		<![CDATA[select inv.ad_org_id as "organizationid", org.name AS "name_org", inv.ad_client_id as "client_org",
inv.dateinvoiced as "date",
(inv.dateinvoiced+(pay.fixmonthoffset*30)+pay.netdays) as "datedue",
coalesce(to_char(dtt.name), to_char(dt.name)) as "document_type",
(select name from ad_ref_list_v
where ad_reference_id = '131' and value = inv.docstatus and ad_language in ($P{AD_LANGUAGE}))  as "status",
inv.poreference as "poreference",
fp.name as "payment_method",
coalesce(TO_CHAR(payt.name),TO_CHAR(pay.name)) as "payment_term",
costo.name as "costcenter",
us1.name as "dimension1",
us2.name as "dimension2",
pa.name as "provider",inv.documentno as "documentno", sum(it.taxbaseamt) as "subtotal", sum(it.taxamt) as "vat",
avg(inv.grandtotal) as "total", avg(inv.em_sswh_totalwithholdingincome) as "withholdingincome",
avg(inv.em_sswh_totalwithholdingvat) as "withholdingvat",us.name as "user",
now() as "printdate", (select cb.name from ad_user au inner join c_bpartner cb on cb.c_bpartner_id = au.c_bpartner_id and au.ad_user_id= $P{AD_USER_ID}) as "username"
from c_invoice inv left join c_bpartner pa on inv.c_bpartner_id = pa.c_bpartner_id
left join c_invoicetax it on inv.c_invoice_id = it.c_invoice_id
left join c_doctype dt on inv.c_doctype_id = dt.c_doctype_id
left join c_doctype_trl dtt on dt.c_doctype_id = dtt.c_doctype_id and dtt.ad_language in ($P{AD_LANGUAGE})
left join c_paymentterm pay on inv.c_paymentterm_id = pay.c_paymentterm_id
left join c_paymentterm_trl payt on pay.c_paymentterm_id = payt.c_paymentterm_id and payt.ad_language in ($P{AD_LANGUAGE})
left join fin_paymentmethod fp on inv.fin_paymentmethod_id = fp.fin_paymentmethod_id
left join c_costcenter costo on inv.c_costcenter_id = costo.c_costcenter_id
left join user1 us1 on inv.user1_id = us1.user1_id
left join user2 us2 on inv.user2_id = us2.user2_id
left join ad_user us on inv.createdby = us.ad_user_id
left join ad_org org on inv.ad_org_id = org.ad_org_id
where inv.issotrx='N' and it.c_tax_id in (select c_tax_id from c_invoiceline where c_invoice_id  = inv.c_invoice_id)
and (inv.c_bpartner_id = $P{C_BPartner_ID} or $P{C_BPartner_ID} is null)
and inv.dateinvoiced between $P{DateFrom} and $P{DateTo}
and (inv.C_doctypetarget_id = $P{C_DocTypeTarget_ID} or $P{C_DocTypeTarget_ID} is null)
and (inv.docstatus= $P{DocStatus} or $P{DocStatus} is null)
group by inv.ad_org_id, org.name, inv.ad_client_id, inv.dateinvoiced, pay.fixmonthoffset, pay.netdays, dtt.name, dt.name, inv.docstatus, inv.poreference, fp.name, payt.name, pay.name, costo.name, us1.name, us2.name, pa.name, inv.documentno, us.name
order by inv.dateinvoiced]]>
	</queryString>
