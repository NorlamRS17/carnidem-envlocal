	<parameter name="DATEFROM" class="java.util.Date"/>
	<parameter name="DATETO" class="java.util.Date"/>
	<parameter name="ACCOUNTFROM" class="java.lang.String"/>
	<parameter name="ACCOUNTTO" class="java.lang.String"/>
	<parameter name="PARTNERID" class="java.lang.String"/>
	<parameter name="AD_USER_ID" class="java.lang.String"/>
	<queryString>
		<![CDATA[SELECT
	COALESCE((SELECT UPPER(name) FROM c_elementvalue WHERE c_elementvalue_id=$P{ACCOUNTFROM}),'') AS cuenta_desde,
	COALESCE((SELECT UPPER(name) FROM c_elementvalue WHERE c_elementvalue_id=$P{ACCOUNTTO}),'') AS cuenta_hasta,
	(SELECT UPPER(name) FROM ad_user WHERE ad_user_id=$P{AD_USER_ID}) AS usuario
	,to_char(NOW(), 'DD-MM-YYYY HH24:MI:SS') AS fecha_actual
	,value, name, dateacct,
              SUM(AMTACCTDR) AS amtacctdr, SUM(AMTACCTCR) AS amtacctcr, (SUM(AMTACCTDR)-SUM(AMTACCTCR)) AS total,
              FACT_ACCT_GROUP_ID, id,
              MIN(DESCRIPTION) AS description,
              totalacctdr, totalacctcr
	   , (totalacctdr-totalacctcr) AS totalacctsub,
              0 AS previousdebit, 0 AS previouscredit, 0 AS previoustotal,
              0 AS finaldebit, 0 AS finalcredit, 0 AS finaltotal,
              TO_CHAR(DATEACCT,'J') AS dateacctnumber,
                AD_ORG_ID,
	    NAMEORG
	      ,bpname, pdname, PJNAME
	,(SELECT UPPER(spd.name) FROM c_doctype AS dt LEFT JOIN scsdc_signaturesperdoc AS spd ON (dt.c_doctype_id=spd.c_doctype_id AND spd.line = 10) WHERE dt.name='LIBRO MAYOR DETALLADO') AS elaborado_por
	,(SELECT UPPER(spd.name) FROM c_doctype AS dt LEFT JOIN scsdc_signaturesperdoc AS spd ON (dt.c_doctype_id=spd.c_doctype_id AND spd.line = 40) WHERE dt.name='LIBRO MAYOR DETALLADO') AS autorizado_por
	,(SELECT UPPER(spd.name) FROM c_doctype AS dt LEFT JOIN scsdc_signaturesperdoc AS spd ON (dt.c_doctype_id=spd.c_doctype_id AND spd.line = 20) WHERE dt.name='LIBRO MAYOR DETALLADO') AS revisado_por
          ,(SELECT UPPER(spd.name) FROM c_doctype AS dt LEFT JOIN scsdc_signaturesperdoc AS spd ON (dt.c_doctype_id=spd.c_doctype_id AND spd.line = 30) WHERE dt.name='LIBRO MAYOR DETALLADO') AS aprobado_por
	      ,trans_documentno, trans_description
          FROM
            (SELECT FACT_ACCT.ACCTVALUE AS VALUE, FACT_ACCT.ACCTDESCRIPTION AS NAME,
                DATEACCT, AMTACCTDR, AMTACCTCR,
                FACT_ACCT_GROUP_ID, FACT_ACCT.ACCOUNT_ID AS ID, FACT_ACCT.DESCRIPTION,
                CASE WHEN AMTACCTDR <> 0 THEN 'Y' ELSE 'N' END AS ISDEBIT,
                FACT_ACCT.AD_ORG_ID,
	      UPPER(AD_ORG.NAME) AS NAMEORG,
	      COALESCE(totalacctdr, 0) AS totalacctdr, COALESCE(totalacctcr,0) AS totalacctcr,
	      C_BPARTNER.name AS bpname,
	      M_PRODUCT.name AS pdname,
	      C_PROJECT.name AS PJNAME,
 	      FACT_ACCT.ad_table_id,
	      FACT_ACCT.record_id,
	      (ssaglrd_factacct_docn((
		SELECT t.tablename
		FROM ad_table AS t
		WHERE t.ad_table_id=FACT_ACCT.ad_table_id), FACT_ACCT.record_id,'es_ES')) AS trans_documentno,
	      (ssaglrd_factacct_des((
		SELECT t.tablename
		FROM ad_table AS t
		WHERE t.ad_table_id=FACT_ACCT.ad_table_id), FACT_ACCT.record_id,'es_ES')) AS trans_description
           FROM FACT_ACCT
              LEFT JOIN C_BPARTNER ON FACT_ACCT.C_BPARTNER_ID = C_BPARTNER.C_BPARTNER_ID
              LEFT JOIN M_PRODUCT ON FACT_ACCT.M_PRODUCT_ID = M_PRODUCT.M_PRODUCT_ID
              LEFT JOIN C_PROJECT ON FACT_ACCT.C_PROJECT_ID = C_PROJECT.C_PROJECT_ID
              LEFT JOIN(
                  select account_id, record_id2, sum(amtacctdr-amtacctcr) as sum
                  from fact_acct f1
                  where 5=5
                  group by account_id, record_id2
                ) f2 ON fact_acct.account_id = f2.account_id and fact_acct.record_id2 = f2.record_id2
	   LEFT JOIN AD_ORG ON FACT_ACCT.AD_ORG_ID=AD_ORG.AD_ORG_ID
  	   LEFT JOIN (
  		SELECT account_id, SUM(AMTACCTDR) AS totalacctdr, SUM(AMTACCTCR) AS totalacctcr
		FROM FACT_ACCT
		WHERE DATEACCT < $P{DATEFROM}
		GROUP BY ACCOUNT_ID, ACCTVALUE
   	 ) s ON s.account_id=FACT_ACCT.ACCOUNT_ID

            WHERE  3=3 AND dateacct>=$P{DATEFROM} AND dateacct<=$P{DATETO} AND FACT_ACCT.account_id IN (
	      SELECT c_elementvalue_id
                FROM C_ELEMENTVALUE
                WHERE (value >= (  select value from c_elementvalue where c_elementvalue_id = $P{ACCOUNTFROM}) OR $P{ACCOUNTFROM} IS NULL) AND (value <= (  select value from c_elementvalue where c_elementvalue_id = $P{ACCOUNTTO})  OR $P{ACCOUNTTO} IS NULL))
	      AND (FACT_ACCT.C_BPARTNER_ID=$P{PARTNERID} OR $P{PARTNERID} IS NULL)
	  ) D
            WHERE 6=6
            GROUP BY VALUE, NAME, ID, DATEACCT, FACT_ACCT_GROUP_ID, ISDEBIT, AD_ORG_ID, NAMEORG, totalacctdr, totalacctcr, bpname, pdname, PJNAME
            , trans_documentno, trans_description
            , ad_table_id, record_id
            HAVING SUM(AMTACCTDR) - SUM(AMTACCTCR) <> 0
            ORDER  BY VALUE, NAME, ID, DATEACCT,  FACT_ACCT_GROUP_ID, ISDEBIT]]>
	</queryString>
