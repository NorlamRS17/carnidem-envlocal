		<defaultValueExpression><![CDATA[new SimpleDateFormat("dd/MM/yyyy")]]></defaultValueExpression>
	</parameter>
	<parameter name="NUMBERFORMAT" class="java.text.DecimalFormat" isForPrompting="false">
		<defaultValueExpression><![CDATA[new DecimalFormat("###,##0.00;-###,##0.00", new DecimalFormatSymbols())]]></defaultValueExpression>
	</parameter>
	<parameter name="NUMBERDECIMAL" class="java.lang.Integer" isForPrompting="false">
		<defaultValueExpression><![CDATA[2]]></defaultValueExpression>
	</parameter>
	<parameter name="SUBREPORT_DIR" class="java.lang.String" isForPrompting="false">
		<defaultValueExpression><![CDATA["/opt/reportFiles/magic_cross/"]]></defaultValueExpression>
	</parameter>
	<parameter name="BASE_DESIGN" class="java.lang.String">
		<parameterDescription><![CDATA[]]></parameterDescription>
		<defaultValueExpression><![CDATA["/opt/openbravo/carnidem/modules/ec.com.sidesoft.ldm.report/src/"]]></defaultValueExpression>
	</parameter>
	<parameter name="SOURCE_PATH" class="java.lang.String" isForPrompting="false"/>
	<parameter name="DOCUMENT_ID" class="java.lang.String"/>
	<parameter name="USERNAME" class="java.lang.String"/>
	<queryString>
		<![CDATA[select
    (SELECT ad_org_id FROM ad_org WHERE AD_Orgtype_ID = '1' LIMIT 1) AS ad_org_id,
    rows_report,
    fecha_impresion,
    value1,
    name1,
    unit1,
    value2,
    name2,
    unit2,
    BOMQty,
    Price,
    COALESCE(BOMQty, 0) * COALESCE(Price, 0) AS TotalCost
from (
    select
        generate_series(1, 1) AS rows_report,
        TO_CHAR(now(), 'dd/MM/yyyy HH24:MI:SS') fecha_impresion,
        mp.value as value1,
        mp.name as name1,
        unittrl.name as unit1,
        mp1.value as value2,
        mp1.name as name2,
        unittrl1.name as unit2,
        CASE
            WHEN mp1.ProductType = 'S' THEN mpb.BOMQty
            ELSE COALESCE(mpb.BOMQty,0)
        END AS BOMQty,
        CASE
            WHEN mp1.ProductType = 'S' THEN mpb.Bomprice
            ELSE COALESCE(mpc.Price, 0)
        END AS Price
    from m_product mp
    left join C_UOM unit on mp.C_UOM_ID = unit.C_UOM_ID
    left join C_UOM_Trl unittrl on unit.C_UOM_ID = unittrl.C_UOM_ID
    left join M_Product_BOM mpb on  mpb.m_product_id = mp.m_product_id
    left join m_product mp1 on mpb.m_productbom_id = mp1.m_product_id
    left join C_UOM unit1 on mp1.C_UOM_ID = unit1.C_UOM_ID
    left join C_UOM_Trl unittrl1 on unit1.C_UOM_ID = unittrl1.C_UOM_ID
    LEFT JOIN (
        SELECT m_product_id, MAX(created) AS MaxDate
        FROM M_Costing
        GROUP BY m_product_id
    ) last_cost ON mp1.m_product_id = last_cost.m_product_id
    LEFT JOIN M_Costing mpc
        ON mp1.m_product_id = mpc.m_product_id
       AND mpc.created = last_cost.MaxDate
       AND mpc.isactive = 'Y'
    WHERE mp.IsBOM = 'Y'
      AND mp.m_product_ID = $P{DOCUMENT_ID}
) as x;]]>
	</queryString>
