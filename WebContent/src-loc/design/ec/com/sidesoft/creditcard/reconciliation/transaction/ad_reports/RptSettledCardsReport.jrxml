	<import value="java.util.*"/>
	<import value="net.sf.jasperreports.engine.data.*"/>
	<parameter name="NUMBERFORMAT" class="java.text.DecimalFormat" isForPrompting="false">
		<defaultValueExpression><![CDATA[new DecimalFormat("###,##0.00;-###,##0.00", new DecimalFormatSymbols())]]></defaultValueExpression>
	</parameter>
	<parameter name="DATEFORMAT" class="java.text.SimpleDateFormat" isForPrompting="false">
		<defaultValueExpression><![CDATA[new SimpleDateFormat("dd/MM/yyyy")]]></defaultValueExpression>
	</parameter>
	<parameter name="Org_ID" class="java.lang.String" isForPrompting="false">
		<defaultValueExpression><![CDATA[OBContext.getOBContext().getCurrentOrganization().getId()]]></defaultValueExpression>
	</parameter>
	<parameter name="User_ID" class="java.lang.String" isForPrompting="false">
		<defaultValueExpression><![CDATA[OBContext.getOBContext().getUser().getId()]]></defaultValueExpression>
	</parameter>
	<parameter name="DATE" class="java.util.Date">
		<defaultValueExpression><![CDATA[]]></defaultValueExpression>
	</parameter>
	<queryString>
		<![CDATA[SELECT
    to_char(now(),'dd/MM/yyyy') as "fecha_movimiento",
    (select $P{DATE} from dual) as fecha,
    (select name from ad_org where ad_org_id = $P{Org_ID} ) as organization,
    (select name from ad_user where ad_user_id = $P{User_ID} ) as usuario,
    pcr.Date_Payment,
    pcr.Documentno,
    MAX(pcrl.lot) AS lote,
    MAX(pcrl.recap) AS recap,
    SUM(CASE WHEN pcrl.Type = 'B' THEN pcrl.deposit_amount ELSE 0 END) AS acreditvalue,
    SUM(CASE WHEN pcrl.Type = 'C' THEN pcrl.deposit_amount ELSE 0 END) AS commision,
    SUM(CASE WHEN pcrl.Type = 'IW' THEN pcrl.deposit_amount ELSE 0 END) AS retrent,
    SUM(CASE WHEN pcrl.Type = 'VW' THEN pcrl.deposit_amount ELSE 0 END) AS retiva,
    SUM(CASE WHEN pcrl.Type = 'IVA' THEN pcrl.deposit_amount ELSE 0 END) AS iva,
    max(em_sccrt_liquidated) as liquidado
FROM
    Ssccr_Pos_Card_Rec pcr
LEFT JOIN
    Ssccr_Pos_Card_Rec_Line pcrl ON pcrl.Ssccr_Pos_Card_Rec_id = pcr.Ssccr_Pos_Card_Rec_id
WHERE
    pcrl.Ssccr_Pos_Card_Rec_id = pcr.Ssccr_Pos_Card_Rec_id
    and (TRUNC(pcr.Date_Payment::date) = $P{DATE} or TRUNC($P{DATE}::date) is null)
GROUP BY
    pcr.Documentno, pcr.Date_Payment
ORDER by
    pcr.Date_Payment;]]>
	</queryString>
