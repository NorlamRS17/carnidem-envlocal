<?xml version="1.0" encoding="UTF-8"?>
<jasperReport xmlns="http://jasperreports.sourceforge.net/jasperreports" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://jasperreports.sourceforge.net/jasperreports http://jasperreports.sourceforge.net/xsd/jasperreport.xsd" name="ReportIncomeStatementCostCenter_Balance" columnCount="200" printOrder="Horizontal" pageWidth="17600" pageHeight="16" columnWidth="88" leftMargin="0" rightMargin="0" topMargin="0" bottomMargin="0" whenResourceMissingType="Error" uuid="692b39a1-c18d-4482-abc6-33842b7e7ea6">
	<property name="ireport.zoom" value="1.5"/>
	<property name="ireport.x" value="0"/>
	<property name="ireport.y" value="0"/>
	<property name="net.sf.jasperreports.export.pdf.size.page.to.content" value="true"/>
	<parameter name="ad_org_id" class="java.lang.String">
		<defaultValueExpression><![CDATA[]]></defaultValueExpression>
	</parameter>
	<parameter name="AD_USER_ID" class="java.lang.String">
		<defaultValueExpression><![CDATA[]]></defaultValueExpression>
	</parameter>
	<parameter name="C_Costcenter_ID" class="java.lang.String">
		<defaultValueExpression><![CDATA[]]></defaultValueExpression>
	</parameter>
	<parameter name="datefrom" class="java.util.Date">
		<defaultValueExpression><![CDATA[]]></defaultValueExpression>
	</parameter>
	<parameter name="dateto" class="java.util.Date">
		<defaultValueExpression><![CDATA[]]></defaultValueExpression>
	</parameter>
	<parameter name="nivel" class="java.lang.String">
		<defaultValueExpression><![CDATA[]]></defaultValueExpression>
	</parameter>
	<parameter name="sfcbr_accountlevel" class="java.lang.String">
		<defaultValueExpression><![CDATA[]]></defaultValueExpression>
	</parameter>
	<parameter name="sfcbr_showzeroaccount" class="java.lang.String">
		<defaultValueExpression><![CDATA[]]></defaultValueExpression>
	</parameter>
	<parameter name="User1_ID" class="java.lang.String">
		<defaultValueExpression><![CDATA[]]></defaultValueExpression>
	</parameter>
	<parameter name="BASE_DESIGN" class="java.lang.String">
		<defaultValueExpression><![CDATA[]]></defaultValueExpression>
	</parameter>
	<parameter name="account_name" class="java.lang.String">
		<defaultValueExpression><![CDATA[]]></defaultValueExpression>
	</parameter>
	<queryString>
		<![CDATA[SELECT SUM(sq.amount) AS amount, REPLACE(sq.Costcenter,'X-','') AS Costcenter FROM ((SELECT COALESCE(SUM(fa.AmtAcctDr)-SUM(fa.AmtAcctCr),0.00) AS amount ,
											(CASE WHEN COALESCE(cos.name,'NA') = 'NA' THEN CONCAT('X-',COALESCE(cos.name,'NA')) ELSE COALESCE(cos.name,'NA') END) AS Costcenter
											FROM fact_acct fa
	LEFT JOIN c_elementvalue ev ON fa.account_id = ev.c_elementvalue_id
	LEFT JOIN sfcbr_tree_acounting_v ta ON ta.id = fa.account_id
	LEFT JOIN c_costcenter cos ON fa.c_costcenter_id = cos.c_costcenter_id
WHERE ta.p1 = $P{account_name}
AND fa.dateacct BETWEEN $P{datefrom} AND $P{dateto}
AND fa.factaccttype <> 'R'
AND fa.factaccttype <> 'C'
AND fa.factaccttype = 'N'
AND fa.isactive = 'Y'
AND (cos.c_costcenter_id IS NULL OR cos.c_costcenter_id = (CASE WHEN $P{C_Costcenter_ID} IS NULL THEN cos.c_costcenter_id ELSE $P{C_Costcenter_ID} END))
AND fa.ad_org_id = (CASE WHEN $P{ad_org_id} = '0' THEN fa.ad_org_id ELSE $P{ad_org_id} END )
AND (CASE WHEN ($P{C_Costcenter_ID} IS NOT NULL AND cos.c_costcenter_id IS NULL) THEN FALSE ELSE TRUE END)
GROUP BY cos.name,ta.p6,ta.P5,ta.p4,ta.p3,ta.p2,ta.p1,ev.accounttype
ORDER BY ta.p6,ta.P5,ta.p4,ta.p3,ta.p2,ta.p1)
union all
(
SELECT 0.00 AS amount,
       (CASE WHEN COALESCE(ub2.name,'NA') = 'NA' THEN CONCAT('X-',COALESCE(ub2.name,'NA')) ELSE COALESCE(ub2.name,'NA') END) AS Costcenter
FROM (
            SELECT DISTINCT cos.name, cos.c_costcenter_id
            FROM fact_acct fa
            LEFT JOIN c_costcenter cos ON fa.c_costcenter_id = cos.c_costcenter_id
	WHERE (cos.c_costcenter_id IS NULL OR cos.c_costcenter_id =(CASE WHEN $P{C_Costcenter_ID} IS NULL THEN cos.c_costcenter_id ELSE $P{C_Costcenter_ID} END ))
AND (CASE WHEN ($P{C_Costcenter_ID} IS NOT NULL AND cos.c_costcenter_id IS NULL) THEN FALSE ELSE TRUE END)
          ) ub2)) as sq
GROUP BY sq.Costcenter
ORDER BY sq.Costcenter]]>
	</queryString>
	<field name="amount" class="java.math.BigDecimal"/>
	<field name="costcenter" class="java.lang.String"/>
	<variable name="total" class="java.math.BigDecimal" resetType="Column" calculation="Sum">
		<variableExpression><![CDATA[$F{amount}]]></variableExpression>
	</variable>
	<background>
		<band splitType="Stretch"/>
	</background>
	<detail>
		<band height="16" splitType="Stretch">
			<textField pattern="#,##0.00;-#,##0.00">
				<reportElement positionType="Float" stretchType="RelativeToTallestObject" mode="Transparent" x="0" y="0" width="88" height="16" isPrintWhenDetailOverflows="true" uuid="70eb35b8-6ba8-4028-8f28-837f3017aa1b"/>
				<textElement textAlignment="Right" verticalAlignment="Middle">
					<font size="9"/>
				</textElement>
				<textFieldExpression><![CDATA[$F{amount}]]></textFieldExpression>
			</textField>
		</band>
	</detail>
	<pageFooter>
		<band/>
	</pageFooter>
</jasperReport>
