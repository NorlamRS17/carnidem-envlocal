<?xml version="1.0" encoding="UTF-8"?>
<jasperReport xmlns="http://jasperreports.sourceforge.net/jasperreports" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://jasperreports.sourceforge.net/jasperreports http://jasperreports.sourceforge.net/xsd/jasperreport.xsd" name="Rpt_Work_Requirement_By_Area" pageWidth="842" pageHeight="595" orientation="Landscape" columnWidth="802" leftMargin="20" rightMargin="20" topMargin="20" bottomMargin="20" uuid="416a4865-ee9a-4e71-a9bb-a69cfce605b0">
	<property name="ireport.zoom" value="0.8264462809917391"/>
	<property name="ireport.x" value="56"/>
	<property name="ireport.y" value="0"/>
	<parameter name="AD_USER_ID" class="java.lang.String" isForPrompting="false">
		<defaultValueExpression><![CDATA["100"]]></defaultValueExpression>
	</parameter>
	<parameter name="StartDate" class="java.util.Date">
		<defaultValueExpression><![CDATA[]]></defaultValueExpression>
	</parameter>
	<parameter name="EndDate" class="java.util.Date">
		<defaultValueExpression><![CDATA[]]></defaultValueExpression>
	</parameter>
	<parameter name="Ma_Section_ID" class="java.lang.String">
		<defaultValueExpression><![CDATA[]]></defaultValueExpression>
	</parameter>
	<queryString>
		<![CDATA[SELECT
wr.startdate AS "desde",
wr.enddate AS "hasta",
pd.name AS "producto",
now() AS "fechaimpresion",
sc.name AS "area",
pd2.name AS "ingredientes",
'' AS "lotemp",
coalesce(wp2.MovementQty,0) AS "cantidadreceta",
coalesce(wr.Secondaryqty,0) AS "cantidadsolicitada",
coalesce(wr.Secondaryqty,0)  * coalesce(wp2.MovementQty,0) AS "cantidadparada",
COALESCE(tr.uomsymbol,uo.uomsymbol) AS "unidad",
sc.description AS "descripcion",
(select ao.name from ad_org ao where ao.ad_orgtype_id='1') AS "organizacion",
(select ad_org_id from ad_org ao where ao.ad_orgtype_id='1') AS "ad_org_id",
(select
coalesce(cbu.name,adu.name) as usuario
from ad_user adu
left join c_bpartner cbu on cbu.c_bpartner_id = adu.c_bpartner_id
where adu.ad_user_id = $P{AD_USER_ID}) as "usuario",
to_date(wr.startdate,'dd/mm/yyyy')as "dat"
FROM MA_WorkRequirement wr
LEFT JOIN ma_processplan pp ON wr.ma_processplan_id = pp.ma_processplan_id
--ÁREA
LEFT JOIN MA_WRPhase ph ON wr.MA_WorkRequirement_id = ph.MA_WorkRequirement_id
LEFT JOIN ma_process pr ON ph.ma_process_id = pr.ma_process_id
LEFT JOIN ma_workstation ws ON pr.ma_workstation_id  = ws.ma_workstation_id
LEFT JOIN ma_section sc ON ws.ma_section_id = sc.ma_section_id
--PRODUCTO

LEFT JOIN MA_WRPhaseProduct wp ON ph.MA_WRPhase_id = wp.MA_WRPhase_id AND wp.productiontype='+'
LEFT JOIN m_product pd ON wp.m_product_id = pd.m_product_id

--INGREDIENTES
LEFT JOIN MA_WRPhaseProduct wp2 ON ph.MA_WRPhase_id = wp2.MA_WRPhase_id AND wp2.productiontype='-'
LEFT JOIN m_product pd2 ON wp2.m_product_id =  pd2.m_product_id
LEFT JOIN c_uom uo ON pd2.c_uom_id = uo.c_uom_id
LEFT JOIN c_uom_trl tr ON uo.c_uom_id =tr.c_uom_id AND UPPER(tr.ad_language)='ES_ES'

WHERE (sc.ma_section_id = $P{Ma_Section_ID} OR $P{Ma_Section_ID} IS NULL)
AND wr.startdate >= $P{StartDate}
AND wr.enddate <= $P{EndDate}
AND wr.closed='Y'
ORDER BY sc.name,pd.name,pd2.name ASC]]>
	</queryString>
