	<parameter name="document_id" class="java.lang.String"/>
	<parameter name="BASE_DESIGN" class="java.lang.String" isForPrompting="false">
		<defaultValueExpression><![CDATA["/opt/EntornosOP/webapps/indumot/src-loc/design"]]></defaultValueExpression>
	</parameter>
	<queryString>
		<![CDATA[SELECT
ROW_NUMBER () OVER (ORDER BY ma_weemployee_id) as row,
b.name2
FROM ma_weemployee e
LEFT JOIN c_bpartner b on b.c_bpartner_id=e.c_bpartner_id
WHERE
e.m_production_id=$P{document_id}]]>
	</queryString>
	<field name="row" class="java.lang.Long"/>
	<field name="name2" class="java.lang.String"/>
	<variable name="REPORT_PAGE" class="java.lang.Integer" resetType="None" incrementType="Page">
		<variableExpression><![CDATA[$V{PAGE_NUMBER}]]></variableExpression>
	</variable>
	<variable name="row" class="java.math.BigDecimal" calculation="Sum"/>
