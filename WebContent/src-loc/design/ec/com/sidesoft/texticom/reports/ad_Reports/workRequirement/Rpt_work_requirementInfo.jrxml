<?xml version="1.0" encoding="UTF-8"?>
<jasperReport xmlns="http://jasperreports.sourceforge.net/jasperreports" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://jasperreports.sourceforge.net/jasperreports http://jasperreports.sourceforge.net/xsd/jasperreport.xsd" name="Rpt_work_requirement" pageWidth="535" pageHeight="842" whenNoDataType="BlankPage" columnWidth="535" leftMargin="0" rightMargin="0" topMargin="0" bottomMargin="0" isIgnorePagination="true" uuid="0a9e7a3a-4591-40f3-950f-4bb40099ac9f">
	<property name="ireport.zoom" value="2.0"/>
	<property name="ireport.x" value="0"/>
	<property name="ireport.y" value="0"/>
	<property name="ireport.scriptlethandling" value="0"/>
	<property name="net.sf.jasperreports.export.xls.detect.cell.type" value="true"/>
	<property name="net.sf.jasperreports.export.xls.sheet.names.all" value="Orden de Fabricación"/>
	<property name="ireport.encoding" value="UTF-8"/>
	<import value="net.sf.jasperreports.engine.*"/>
	<import value="java.util.*"/>
	<import value="net.sf.jasperreports.engine.data.*"/>
	<parameter name="document_id" class="java.lang.String"/>
	<queryString>
		<![CDATA[SELECT
ROW_NUMBER () OVER (ORDER BY mp.ma_processplan_id) as row,
w.ad_org_id,
w.documentno,
mp.value as code,
mp.name as product,
pr.name as area,
to_char(w.launchdate,'dd/MM/yyyy') as launchdate,
to_char(w.startdate,'dd/MM/yyyy') as startdate,
to_char(w.enddate,'dd/MM/yyyy') as enddate,
w.quantity,
w.estimatedtime,
p.value as code_p,
p.name as name_p,
u.x12de355 as unit,
ml.movementqty as qty,
m.documentno as m_documentno,
mt.description as lote
FROM ma_workrequirement w
LEFT JOIN ma_processplan mp on mp.ma_processplan_id=w.ma_processplan_id
LEFT JOIN ma_wrphase mw on mw.ma_workrequirement_id=w.ma_workrequirement_id
LEFT JOIN ma_process pr on pr.ma_process_id=mw.ma_process_id
LEFT JOIN ma_wrphaseproduct wp on wp.ma_wrphase_id=mw.ma_wrphase_id
LEFT JOIN m_product p on p.m_product_id=wp.m_product_id
LEFT JOIN c_uom u on u.c_uom_id=wp.c_uom_id
LEFT JOIN m_movement m on m.m_movement_id=w.em_ssprodp_movement_id
LEFT JOIN m_movementline ml on ml.m_movement_id=m.m_movement_id
LEFT JOIN m_attributesetinstance mt on mt.m_attributesetinstance_id=ml.m_attributesetinstance_id
WHERE
w.ma_workrequirement_id=$P{document_id}
AND wp.Productiontype='-' limit 1]]>
	</queryString>
