	</parameter>
	<parameter name="SUBREPORT_DIR" class="java.lang.String" isForPrompting="false">
		<defaultValueExpression><![CDATA[$P{BASE_DESIGN} != null && $P{BASE_DESIGN}.trim().length() > 0 ? $P{BASE_DESIGN} + "/ec/com/sidesoft/production/ad_reports/reports/" : ""]]></defaultValueExpression>
	</parameter>
	<queryString>
		<![CDATA[SELECT
wr.startdate AS "desde",
wr.enddate AS "hasta",
wr.documentno AS "workrequirement",
COALESCE(mpd.documentno,'') AS "productionplan",
mpd.m_production_id::text AS "m_production_id",
now() AS "fechaimpresion",
sc.name AS "area",
pd2.value AS "productvalue",
pd2.name AS "ingredientes",
COALESCE(mas.description, mas.lot, '') AS "lotemp",
CASE WHEN wp2.ma_wrphaseproduct_id IS NOT NULL THEN wp2.MovementQty ELSE NULL END AS "cantidadreceta",
CASE WHEN wp2.ma_wrphaseproduct_id IS NOT NULL THEN coalesce(wr.Secondaryqty,0) ELSE NULL END AS "cantidadsolicitada",
CASE WHEN wp2.ma_wrphaseproduct_id IS NOT NULL THEN coalesce(wr.Secondaryqty,0) * wp2.MovementQty ELSE NULL END AS "cantidadparada",
CASE WHEN wp2.ma_wrphaseproduct_id IS NOT NULL THEN
    wp2.MovementQty * COALESCE(
        (SELECT mpl2.movementqty
         FROM m_productionline mpl2
         WHERE mpl2.m_productionplan_id = mpp.m_productionplan_id
           AND mpl2.productiontype = '+'
         LIMIT 1), 0)
ELSE NULL END AS "consumototalTeorico",
coalesce(mpl.movementqty, 0) AS "cantidadreal",
CASE WHEN wp2.ma_wrphaseproduct_id IS NOT NULL THEN (coalesce(wr.Secondaryqty,0) * wp2.MovementQty) - coalesce(mpl.movementqty, 0) ELSE NULL END AS "diferencia",
COALESCE(tr.uomsymbol,uo.uomsymbol) AS "unidad",
COALESCE(ws.name,'') AS "puesto_trabajo",
sc.description AS "descripcion",
(select ao.name from ad_org ao where ao.ad_orgtype_id='1') AS "organizacion",
(select ad_org_id from ad_org ao where ao.ad_orgtype_id='1') AS "ad_org_id",
(select
coalesce(cbu.name,adu.name) as usuario
from ad_user adu
left join c_bpartner cbu on cbu.c_bpartner_id = adu.c_bpartner_id
where adu.ad_user_id = $P{AD_USER_ID}) as "usuario",
to_date(wr.startdate,'dd/mm/yyyy')as "dat",
CASE WHEN $P{M_Product_ID} IS NULL OR trim(coalesce($P{M_Product_ID},'')) = '' THEN '' WHEN pd2.m_product_id::text = $P{M_Product_ID} THEN pd2.name ELSE (SELECT name FROM m_product WHERE m_product_id::text = $P{M_Product_ID} LIMIT 1) END AS "producto_titulo",
CASE WHEN $P{M_Product_ID} IS NULL OR trim(coalesce($P{M_Product_ID},'')) = '' THEN '' WHEN pd2.m_product_id::text = $P{M_Product_ID} THEN COALESCE(mas.description, mas.lot, '') ELSE (SELECT COALESCE(mas_f.description, mas_f.lot, '') FROM m_productionline mpl_f LEFT JOIN m_attributesetinstance mas_f ON mas_f.m_attributesetinstance_id = mpl_f.m_attributesetinstance_id WHERE mpl_f.m_productionplan_id = mpp.m_productionplan_id AND mpl_f.productiontype = '+' AND mpl_f.m_product_id::text = $P{M_Product_ID} LIMIT 1) END AS "lote_titulo"
FROM m_productionline mpl
INNER JOIN m_productionplan mpp ON mpl.m_productionplan_id = mpp.m_productionplan_id AND mpl.productiontype = '-'
INNER JOIN m_production mpd ON mpp.m_production_id = mpd.m_production_id
INNER JOIN ma_wrphase ph ON mpp.ma_wrphase_id = ph.ma_wrphase_id
INNER JOIN ma_workrequirement wr ON ph.ma_workrequirement_id = wr.ma_workrequirement_id
LEFT JOIN ma_process pr ON ph.ma_process_id = pr.ma_process_id
LEFT JOIN ma_workstation ws ON pr.ma_workstation_id = ws.ma_workstation_id
LEFT JOIN ma_section sc ON ws.ma_section_id = sc.ma_section_id
LEFT JOIN ma_wrphaseproduct wp2 ON ph.ma_wrphase_id = wp2.ma_wrphase_id AND wp2.productiontype = '-' AND wp2.m_product_id = mpl.m_product_id
LEFT JOIN m_product pd2 ON mpl.m_product_id = pd2.m_product_id
LEFT JOIN m_attributesetinstance mas ON mpl.m_attributesetinstance_id = mas.m_attributesetinstance_id
LEFT JOIN c_uom uo ON pd2.c_uom_id = uo.c_uom_id
LEFT JOIN c_uom_trl tr ON uo.c_uom_id = tr.c_uom_id AND UPPER(tr.ad_language)='ES_ES'

WHERE (sc.ma_section_id = $P{Ma_Section_ID} OR $P{Ma_Section_ID} IS NULL)
AND ($P{MA_WorkRequirement_ID} IS NULL OR trim(coalesce($P{MA_WorkRequirement_ID},'')) = '' OR wr.ma_workrequirement_id::text = $P{MA_WorkRequirement_ID})
AND wr.startdate >= $P{StartDate}
AND wr.enddate <= $P{EndDate}
AND wr.closed='Y'
AND ($P{M_Product_ID} IS NULL OR trim(coalesce($P{M_Product_ID},'')) = '' OR EXISTS (SELECT 1 FROM m_productionline mpl_f WHERE mpl_f.m_productionplan_id = mpp.m_productionplan_id AND mpl_f.m_product_id::text = $P{M_Product_ID}))
ORDER BY sc.name, mpd.documentno, pd2.name ASC]]>
	</queryString>
