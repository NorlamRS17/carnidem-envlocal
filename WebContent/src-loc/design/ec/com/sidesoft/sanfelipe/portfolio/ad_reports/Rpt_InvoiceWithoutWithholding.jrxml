	<property name="net.sf.jasperreports.export.xls.sheet.names.all" value="Facturas sin Retencion"/>
	<import value="org.openbravo.dal.core.OBContext"/>
	<parameter name="DATEFORMAT" class="java.text.SimpleDateFormat" isForPrompting="false">
		<defaultValueExpression><![CDATA[new SimpleDateFormat("dd/MM/yyyy")]]></defaultValueExpression>
	</parameter>
	<parameter name="NUMBERFORMAT" class="java.text.DecimalFormat" isForPrompting="false">
		<defaultValueExpression><![CDATA[new DecimalFormat("###,##0.00;-###,##0.00", new DecimalFormatSymbols())]]></defaultValueExpression>
	</parameter>
	<parameter name="NUMBERDECIMAL" class="java.lang.Integer" isForPrompting="false">
		<defaultValueExpression><![CDATA[2]]></defaultValueExpression>
	</parameter>
	<parameter name="BASE_WEB" class="java.lang.String" isForPrompting="false"/>
	<parameter name="SOURCE_PATH" class="java.lang.String" isForPrompting="false"/>
	<parameter name="Identification" class="java.lang.String">
		<defaultValueExpression><![CDATA[]]></defaultValueExpression>
	</parameter>
	<parameter name="C_Bpartner_ID" class="java.lang.String">
		<defaultValueExpression><![CDATA[]]></defaultValueExpression>
	</parameter>
	<parameter name="DateTo" class="java.util.Date">
		<defaultValueExpression><![CDATA[]]></defaultValueExpression>
	</parameter>
	<parameter name="Org_ID" class="java.lang.String" isForPrompting="false">
		<defaultValueExpression><![CDATA[OBContext.getOBContext().getCurrentOrganization().getId()]]></defaultValueExpression>
	</parameter>
	<parameter name="User_ID" class="java.lang.String" isForPrompting="false">
		<defaultValueExpression><![CDATA[OBContext.getOBContext().getUser().getId()]]></defaultValueExpression>
	</parameter>
	<parameter name="UserName" class="java.lang.String" isForPrompting="false">
		<defaultValueExpression><![CDATA[OBContext.getOBContext().getUser().getUsername()]]></defaultValueExpression>
	</parameter>
	<queryString>
		<![CDATA[SELECT TO_CHAR(NOW(),'dd/mm/yyyy HH24:MI:SS') as fecha_impresion
,c.dateinvoiced
,bp.taxid
,c.documentno
,c.grandtotal
,COALESCE(bp.name,'') as nombre
,COALESCE(bpu.name,u.username) as responsable
,o.name as orgname
,c.outstandingamt
,c.ad_org_id
,op.name as org_parent
FROM c_invoice c
JOIN c_bpartner bp ON bp.c_bpartner_id=c.c_bpartner_id
JOIN c_doctype d ON d.c_doctype_id=c.c_doctype_id
LEFT JOIN ad_user u ON u.ad_user_id=c.salesrep_id
JOIN ad_org o ON o.ad_org_id=c.ad_org_id
LEFT JOIN (SELECT org.name
FROM ad_org_tree ot
JOIN ad_org org ON org.ad_org_id=ot.ad_org_id
WHERE levelno=2 AND ad_parent_org_id='0'
AND org.ad_orgtype_id = '1') op ON 1=1
LEFT JOIN c_bpartner bpu ON bpu.c_bpartner_id=u.c_bpartner_id
WHERE COALESCE(bp.em_ssfpf_iswithholding_agent,'N')='Y'
AND c.issotrx='Y'
AND d.EM_Eei_Is_Edoc='Y'
AND d.EM_Sswh_Implementautoriza='Y'
AND d.EM_Eei_Edoc_Type='01'
AND d.DocBaseType='ARI'
AND c.dateinvoiced <= $P{DateTo}
AND c.outstandingamt>0
AND (bp.taxid=$P{Identification} OR $P{Identification} IS NULL)
AND (bp.c_bpartner_id=$P{C_Bpartner_ID} OR $P{C_Bpartner_ID} IS NULL)
AND NOT EXISTS (SELECT 1
                      FROM ssws_withholdingsale
                      WHERE ssws_withholdingsale.c_invoice_id=c.c_invoice_id)
ORDER BY c.dateinvoiced DESC,c.documentno]]>
	</queryString>
	<field name="fecha_impresion" class="java.lang.String"/>
	<field name="dateinvoiced" class="java.sql.Timestamp"/>
	<field name="taxid" class="java.lang.String"/>
	<field name="documentno" class="java.lang.String"/>
	<field name="grandtotal" class="java.math.BigDecimal"/>
	<field name="nombre" class="java.lang.String"/>
	<field name="responsable" class="java.lang.String"/>
	<field name="orgname" class="java.lang.String"/>
	<field name="outstandingamt" class="java.math.BigDecimal"/>
