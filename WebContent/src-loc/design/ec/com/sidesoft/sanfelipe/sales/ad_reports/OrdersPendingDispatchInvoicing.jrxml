<?xml version="1.0" encoding="UTF-8"?>
<jasperReport xmlns="http://jasperreports.sourceforge.net/jasperreports" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://jasperreports.sourceforge.net/jasperreports http://jasperreports.sourceforge.net/xsd/jasperreport.xsd" name="PartialSalesInvoicesWithoutDispatch" pageWidth="1700" pageHeight="1000" orientation="Landscape" whenNoDataType="BlankPage" columnWidth="1660" leftMargin="20" rightMargin="20" topMargin="20" bottomMargin="20" isSummaryWithPageHeaderAndFooter="true" uuid="f0bd3c03-16ff-483f-a5db-e8931d2b18e7">
	<property name="ireport.zoom" value="2.0"/>
	<property name="ireport.x" value="979"/>
	<property name="ireport.y" value="55"/>
	<parameter name="Datefrom" class="java.util.Date"/>
	<parameter name="Dateto" class="java.util.Date"/>
	<parameter name="AD_USER_ID" class="java.lang.String">
		<defaultValueExpression><![CDATA[]]></defaultValueExpression>
	</parameter>
	<parameter name="AD_ORG_ID" class="java.lang.String"/>
	<parameter name="M_PRODUCT_ID" class="java.lang.String"/>
	<parameter name="ONLY_BILLED" class="java.lang.String"/>
	<parameter name="ONLY_ORDER" class="java.lang.String">
		<defaultValueExpression><![CDATA[]]></defaultValueExpression>
	</parameter>
	<queryString>
		<![CDATA[SELECT
 org.ad_org_id organizationid
 , org.name organization
 , TO_CHAR(NOW(),'dd/MM/yyyy HH24:MI:SS') printing_date
 , pu.name printing_user
 , o.documentno o_documentno
 , pr.value pr_value
 , pr.name pr_name
 , CASE WHEN o.docstatus = 'CL' THEN
     ol.em_ssfps_qtyordered
     ELSE (CASE WHEN ol.em_ssfps_qtyordered != NULL THEN ol.em_ssfps_qtyordered ELSE ol.qtyordered END)
   END AS qtyordered
 , u.uomsymbol
 , o.dateordered
 , io.documentno io_documentno
 , io.movementdate
, CASE WHEN o.docstatus='CL' THEN
     ol.em_ssfps_qtydelivered
     ELSE COALESCE(iol.movementqty,0)
   END AS movementqty
, (CASE WHEN o.docstatus='CL' THEN
     ol.em_ssfps_qtyordered - ol.em_ssfps_qtydelivered
     ELSE ol.qtyordered - ol.QtyDelivered END
   ) AS QtyNotDelivered
 , i.documentno i_documentno
 , i.dateinvoiced
 , CASE WHEN o.docstatus='CL' THEN
     ol.em_ssfps_qtyinvoiced
     ELSE COALESCE(il.qtyinvoiced,0)
   END AS qtyinvoiced
 , CASE WHEN o.docstatus='CL' THEN
      ol.em_ssfps_qtyordered - ol.em_ssfps_qtyinvoiced
      ELSE ol.qtyordered - ol.QtyInvoiced
   END AS QtyNotInvoiced
, CASE WHEN COALESCE(o.docstatus, '') = 'CL' THEN  COALESCE(
    rcl.name
 , '' )  ELSE '' END as motivo_cierre
FROM sinvmin_square_bill sb
 LEFT JOIN c_orderline ol ON ol.c_orderline_id = sb.c_orderline_id
 LEFT JOIN c_order o ON o.c_order_id = ol.c_order_id
 LEFT JOIN c_invoiceline il ON il.c_invoiceline_id = sb.c_invoiceline_id
 LEFT JOIN c_invoice i ON i.c_invoice_id = il.c_invoice_id
 LEFT JOIN m_inoutline iol ON iol.m_inoutline_id = sb.m_inoutline_id
 LEFT JOIN m_inout io ON io.m_inout_id = iol.m_inout_id
 LEFT JOIN SSFPS_reasons_clousure rcl on rcl.SSFPS_reasons_clousure_id = o.EM_SSFPS_reasons_clousure_id
 JOIN m_product pr ON pr.m_product_id = COALESCE(ol.m_product_id,il.m_product_id)
 JOIN ad_org org ON org.ad_org_id = COALESCE(o.ad_org_id,i.ad_org_id)
 JOIN ad_user pu ON pu.ad_user_id = $P{AD_USER_ID}
 JOIN c_uom u ON u.c_uom_id = pr.c_uom_id
 LEFT JOIN (
  SELECT c_invoiceline_id, SUM(ABS(qty)) qty
  FROM sinvmin_square_bill
  WHERE ad_table_id = '319'
  GROUP BY c_invoiceline_id
 ) abiol ON abiol.c_invoiceline_id = il.c_invoiceline_id
WHERE
 (org.ad_org_id = $P{AD_ORG_ID} OR $P{AD_ORG_ID} = '0' OR $P{AD_ORG_ID} IS NULL)
 AND (pr.m_product_id = $P{M_PRODUCT_ID} OR $P{M_PRODUCT_ID} IS NULL)
 AND CASE WHEN ol.c_orderline_id IS NOT NULL AND o.docstatus = 'CO' THEN (ol.QtyDelivered != ol.qtyordered OR ol.QtyInvoiced != ol.qtyordered) ELSE TRUE END
 AND CASE WHEN ol.c_orderline_id IS NOT NULL AND o.docstatus = 'CO' AND ol.QtyDelivered + ol.QtyInvoiced > 0 THEN sb.c_invoiceline_id IS NOT NULL OR sb.m_inoutline_id IS NOT NULL ELSE TRUE END
 AND CASE WHEN ol.c_orderline_id IS NOT NULL AND $P{ONLY_BILLED} = 'Y' THEN ol.QtyDelivered = 0 AND ol.QtyInvoiced > 0 ELSE TRUE END
 AND CASE WHEN ol.c_orderline_id IS NULL AND $P{ONLY_BILLED} = 'Y' THEN abiol.c_invoiceline_id IS NULL ELSE TRUE END
 AND CASE WHEN ol.c_orderline_id IS NULL AND $P{ONLY_ORDER} = 'Y' THEN o.isdelivered ='N'   AND abiol.c_invoiceline_id IS NULL ELSE TRUE END
 AND (to_date(to_char(coalesce(o.dateordered,i.dateinvoiced,io.movementdate),'dd/MM/yyyy')) between  $P{Datefrom} and $P{Dateto})
 AND o.docstatus IN ('CL','CO')
 AND sb.ad_table_id = '259'
ORDER BY o.documentno, sb.created]]>
	</queryString>
	<field name="organizationid" class="java.lang.String"/>
	<field name="organization" class="java.lang.String"/>
	<field name="printing_date" class="java.lang.String"/>
	<field name="printing_user" class="java.lang.String"/>
	<field name="o_documentno" class="java.lang.String"/>
	<field name="pr_value" class="java.lang.String"/>
	<field name="pr_name" class="java.lang.String"/>
	<field name="qtyordered" class="java.math.BigDecimal"/>
	<field name="uomsymbol" class="java.lang.String"/>
	<field name="dateordered" class="java.sql.Timestamp"/>
	<field name="io_documentno" class="java.lang.String"/>
	<field name="movementdate" class="java.sql.Timestamp"/>
	<field name="movementqty" class="java.math.BigDecimal"/>
	<field name="qtynotdelivered" class="java.math.BigDecimal"/>
	<field name="i_documentno" class="java.lang.String"/>
	<field name="dateinvoiced" class="java.sql.Timestamp"/>
	<field name="qtyinvoiced" class="java.math.BigDecimal"/>
	<field name="qtynotinvoiced" class="java.math.BigDecimal"/>
	<field name="motivo_cierre" class="java.lang.String"/>
