		<defaultValueExpression><![CDATA[]]></defaultValueExpression>
	</parameter>
	<parameter name="DateFrom" class="java.util.Date">
		<defaultValueExpression><![CDATA[]]></defaultValueExpression>
	</parameter>
	<parameter name="DateTo" class="java.util.Date">
		<defaultValueExpression><![CDATA[]]></defaultValueExpression>
	</parameter>
	<parameter name="M_Warehouse_ID" class="java.lang.String">
		<defaultValueExpression><![CDATA[]]></defaultValueExpression>
	</parameter>
	<parameter name="C_Bpartner_ID" class="java.lang.String">
		<defaultValueExpression><![CDATA[]]></defaultValueExpression>
	</parameter>
	<parameter name="Lote" class="java.lang.String">
		<defaultValueExpression><![CDATA[]]></defaultValueExpression>
	</parameter>
	<queryString>
		<![CDATA[SELECT
p.name as producto
,mat.description as lote
,l.value as bodega
,msd.qtyonhand as qty
FROM M_Storage_Detail msd
full JOIN m_product p ON p.m_product_id = msd.m_product_id
full JOIN m_locator l ON l.m_locator_id = msd.m_locator_id
full JOIN m_attributesetinstance mat ON mat.m_attributesetinstance_id = msd.m_attributesetinstance_id
WHERE p.m_product_id = $P{M_Product_Head_ID}
AND (l.m_warehouse_id = $P{M_Warehouse_ID} OR $P{M_Warehouse_ID} IS NULL)
GROUP BY P.NAME,mat.description,l.value,msd.qtyonhand
HAVING sum(msd.qtyonhand) > 0]]>
	</queryString>
	<field name="producto" class="java.lang.String"/>
	<field name="lote" class="java.lang.String"/>
	<field name="bodega" class="java.lang.String"/>
	<field name="qty" class="java.math.BigDecimal"/>
