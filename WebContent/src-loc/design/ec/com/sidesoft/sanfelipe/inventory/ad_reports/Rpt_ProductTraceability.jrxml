	<parameter name="SOURCE_PATH" class="java.lang.String" isForPrompting="false"/>
	<parameter name="BASE_DESIGN" class="java.lang.String" isForPrompting="false">
		<defaultValueExpression><![CDATA["/opt/openbravo/sanfelipe/modules/ec.com.sidesoft.sanfelipe.inventory/src/"]]></defaultValueExpression>
	</parameter>
	<parameter name="M_Product_ID" class="java.lang.String">
		<defaultValueExpression><![CDATA[]]></defaultValueExpression>
	</parameter>
	<parameter name="DateTo" class="java.util.Date">
		<defaultValueExpression><![CDATA[]]></defaultValueExpression>
	</parameter>
	<parameter name="DateFrom" class="java.util.Date">
		<defaultValueExpression><![CDATA[]]></defaultValueExpression>
	</parameter>
	<parameter name="M_Warehouse_ID" class="java.lang.String" isForPrompting="false">
		<defaultValueExpression><![CDATA[]]></defaultValueExpression>
	</parameter>
	<parameter name="C_Bpartner_ID" class="java.lang.String" isForPrompting="false">
		<defaultValueExpression><![CDATA[]]></defaultValueExpression>
	</parameter>
	<parameter name="Lote" class="java.lang.String" isForPrompting="false">
		<defaultValueExpression><![CDATA[]]></defaultValueExpression>
	</parameter>
	<queryString>
		<![CDATA[SELECT p.m_product_id,mt.m_transaction_id
,p.ad_org_id
,TO_CHAR(NOW(),'dd/mm/yyyy HH24:MI:SS') as fecha_impresion
,p.value as code
,p.name as producto
,c.name as categoty
,uom.name as unit
,mat.description as lote
,mt.movementdate as datetrx
,mt.movementqty as movementqtyf
,CASE
WHEN mt.movementtype='I+' THEN 'AJUSTE'
WHEN mt.movementtype IN ('M+','M-') THEN 'TRANSFERENCIA'
WHEN mt.movementtype = 'C-' AND CDTYP.IsReturn='Y' then 'DEVOLUCION VENTA'
WHEN mt.movementtype = 'C-' AND CDTYP.IsReturn='N' then 'VENTA'
WHEN mt.movementtype = 'P+' then 'PRODUCCION'
--ELSE 'PRODUCCION' END as typetrx
ELSE '' END as typetrx

,COALESCE(it.documentno,m.documentno,iv.documentno,mprod.documentno) as documentnotxr
,bp.name as customer
,US1.NAME as bp_category
,COALESCE(l.value,'-')||';'||COALESCE(lt.value,'-') as locations
FROM m_transaction mt
JOIN m_product p ON p.m_product_id = mt.m_product_id
JOIN m_product_category c ON c.m_product_category_id = p.m_product_category_id
JOIN c_uom_trl uom ON uom.c_uom_id = p.c_uom_id AND uom.ad_language = 'es_ES'
JOIN m_attributesetinstance mat ON mat.m_attributesetinstance_id = mt.m_attributesetinstance_id
JOIN m_locator lh ON lh.m_locator_id = mt.m_locator_id


LEFT JOIN m_inventoryline itl ON itl.m_inventoryline_id = mt.m_inventoryline_id
LEFT JOIN m_inventory it ON it.m_inventory_id = itl.m_inventory_id

LEFT JOIN m_movementline mv ON mv.m_movementline_id = mt.m_movementline_id
LEFT JOIN m_movement m ON m.m_movement_id = mv.m_movement_id
LEFT JOIN m_locator l ON l.m_locator_id = mv.m_locator_id
LEFT JOIN m_locator lt ON lt.m_locator_id = mv.m_locatorto_id

LEFT JOIN m_inoutline il ON il.m_inoutline_id = mt.m_inoutline_id
LEFT JOIN m_inout iv ON iv.m_inout_id = il.m_inout_id
LEFT JOIN c_bpartner bp ON bp.c_bpartner_id=iv.c_bpartner_id
LEFT JOIN c_bp_group bpg ON bpg.c_bp_group_id=bp.c_bp_group_id
LEFT JOIN USER1 US1 ON US1.user1_id=BP.EM_Ssfc_User1_ID
LEFT JOIN C_DOCTYPE CDTYP ON CDTYP.C_DOCTYPE_ID=IV.C_DOCTYPE_ID

LEFT JOIN M_PRODUCTIONline mpl ON mpl.m_productionline_ID = mt.m_productionline_ID
LEFT join M_PRODUCTIONPLAN mpp on mpp.M_PRODUCTIONPLAN_ID = mpl.M_PRODUCTIONPLAN_ID
LEFT join m_production mprod on mprod.m_production_id=mpp.m_production_id
WHERE (p.m_product_id = $P{M_Product_ID} OR $P{M_Product_ID} IS NULL)
AND mt.movementdate between $P{DateFrom} AND $P{DateTo}
AND (lh.m_warehouse_id = $P{M_Warehouse_ID} OR $P{M_Warehouse_ID} IS NULL)
AND (bp.c_bpartner_id = $P{C_Bpartner_ID} OR $P{C_Bpartner_ID} IS NULL)
AND (TRIM(mat.description) = $P{Lote} OR $P{Lote} IS NULL)
GROUP BY p.m_product_id,c.name,uom.name,mat.description,datetrx,movementqtyf, itl.m_inventoryline_id ,  mt.m_movementline_id  , mt.m_inoutline_id,typetrx,documentnotxr,bp_category,customer,locations,mt.m_transaction_id
ORDER BY p.value,datetrx]]>
	</queryString>
