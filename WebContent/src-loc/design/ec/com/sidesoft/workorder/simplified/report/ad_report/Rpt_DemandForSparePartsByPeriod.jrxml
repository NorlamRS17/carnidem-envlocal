	<parameter name="DOCUMENT_ID" class="java.lang.String"/>
	<parameter name="NUMBERFORMAT" class="java.text.DecimalFormat" isForPrompting="false">
		<defaultValueExpression><![CDATA[new DecimalFormat("###,##0.00;-###,##0.00", new DecimalFormatSymbols())]]></defaultValueExpression>
	</parameter>
	<parameter name="NUMBERDECIMAL" class="java.lang.Integer">
		<defaultValueExpression><![CDATA[2]]></defaultValueExpression>
	</parameter>
	<parameter name="AD_USER_ID" class="java.lang.String">
		<defaultValueExpression><![CDATA[]]></defaultValueExpression>
	</parameter>
	<parameter name="start_date" class="java.util.Date">
		<defaultValueExpression><![CDATA[]]></defaultValueExpression>
	</parameter>
	<parameter name="end_date" class="java.util.Date">
		<defaultValueExpression><![CDATA[]]></defaultValueExpression>
	</parameter>
	<parameter name="m_product_category_id" class="java.lang.String">
		<defaultValueExpression><![CDATA[]]></defaultValueExpression>
	</parameter>
	<parameter name="slps_product_category_id" class="java.lang.String">
		<defaultValueExpression><![CDATA[]]></defaultValueExpression>
	</parameter>
	<parameter name="m_product_id" class="java.lang.String">
		<defaultValueExpression><![CDATA[]]></defaultValueExpression>
	</parameter>
	<parameter name="ad_org_id" class="java.lang.String">
		<defaultValueExpression><![CDATA[]]></defaultValueExpression>
	</parameter>
	<queryString>
		<![CDATA[Select *
From (
	Select x.ad_org_id
		, x.organization
		, x.item
		, x.nombre
		, x.sub_category
		, SUM(x.cantidad) as "cantidad"
	From (Select o.ad_org_id
			, o.name as "organization"
			, p.value as "item"
			, p.name as "nombre"
			, pc.name as "sub_category"
			, pvl.em_sswos_transfer as "cantidad"
		  From atindpo_postventa pv
			Join ad_org o on o.ad_org_id = pv.ad_org_id
			Join atindpo_postventalinea pvl on pvl.atindpo_postventa_id = pv.atindpo_postventa_id
			Join sswos_transfer st on st.atindpo_postventalinea_id = pvl.atindpo_postventalinea_id and st.isactive= 'Y'
			Join m_product p on p.m_product_id = pvl.m_product_id and p.producttype = 'I'
			Join slps_product_category pc on pc.slps_product_category_id = p.em_slps_product_category_id
		  Where TO_DATE(st.date_transfer, 'DD-MM-YYYY') Between $P{start_date} and $P{end_date}
			And (p.m_product_category_id = $P{m_product_category_id} or $P{m_product_category_id} is null)
			And (p.em_slps_product_category_id = $P{slps_product_category_id} or $P{slps_product_category_id} is null)
			And (o.ad_org_id = $P{ad_org_id} or $P{ad_org_id} is null)
			And (p.m_product_id = $P{m_product_id} or $P{m_product_id} is null)

		Union all

			Select o.ad_org_id
				, o.name as "organization"
				, p.value as "item"
				, p.name as "nombre"
				, pc.name as "sub_category"
				, col.qtyordered as "cantidad"
			From c_order co
			 Join ad_org o on o.ad_org_id = co.ad_org_id
			 Join c_orderline col on col.c_order_id = co.c_order_id
			 Join m_product p on p.m_product_id = col.m_product_id and p.producttype = 'I'
			 Join slps_product_category pc on pc.slps_product_category_id = p.em_slps_product_category_id
			Where co.issotrx = 'Y'
				And co.docstatus = 'CO'
				And Not EXISTS (
					Select 1
					From sswos_so_transfer sst
					Where sst.c_doctype_id_order = co.c_doctype_id
				) And TO_DATE(co.dateordered, 'DD-MM-YYYY') Between $P{start_date} and $P{end_date}
				And (p.m_product_category_id = $P{m_product_category_id} or $P{m_product_category_id} is null)
				And (p.em_slps_product_category_id = $P{slps_product_category_id} or $P{slps_product_category_id} is null)
				And (o.ad_org_id = $P{ad_org_id} or $P{ad_org_id} is null)
				And (p.m_product_id = $P{m_product_id} or $P{m_product_id} is null)
	) x
	Group By x.ad_org_id, x.organization, x.item, x.nombre, x.sub_category
) z
,(Select
--Los CLOALESCE no son necesarios, se los pone por tema de prueba
	 sescr_get_label_trl('Label_Rpt_DemForSpPart_title','M','es_ES') as "label_titulo"
	, sescr_get_label_trl('Label_Rpt_DemForSpPart_StartDate','M','es_ES') as "label_FechaDesde"
	, sescr_get_label_trl('Label_Rpt_DemForSpPart_EndDate','M','es_ES') as "label_FechaHasta"
	, sescr_get_label_trl('DAC83B2BA21044CF99E616B3AFD4F31F','F','es_ES') as "label_Organizacion"
  	, sescr_get_label_trl('Label_Rpt_DemForSpPart_Item','M','es_ES') as "label_Item"
  	, sescr_get_label_trl('Label_Rpt_DemForSpPart_Name','M','es_ES') as "label_Nombre"
  	, sescr_get_label_trl('Label_Rpt_DemForSpPart_Quantity','M','es_ES') as "label_Cantidad"
  	, sescr_get_label_trl('Label_Rpt_DemForSpPart_SubCategory','M','es_ES') as "label_SubCategory"
  	, sescr_get_label_trl('Label_Rpt_DemForSpPart_Total','M','es_ES') as "label_Total"
From Dual) labels
,(Select
	to_char('Auditoria: ') || (select coalesce(to_char(cbp.name), to_char(au.name)) from ad_user au left join c_bpartner cbp on cbp.c_bpartner_id = au.c_bpartner_id where au.ad_user_id = $P{AD_USER_ID}) ||to_char('Fecha de impresión: ') || to_char(now(),'DD/MM/YYYY HH24:MI:SS') as "auditorita"
From dual ) audit
Order BY z.sub_category, z.organization, z.item, z.nombre]]>
	</queryString>
