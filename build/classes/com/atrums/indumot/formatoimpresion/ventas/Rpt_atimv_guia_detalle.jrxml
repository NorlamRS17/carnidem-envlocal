<?xml version="1.0" encoding="UTF-8"?>
<jasperReport xmlns="http://jasperreports.sourceforge.net/jasperreports" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://jasperreports.sourceforge.net/jasperreports http://jasperreports.sourceforge.net/xsd/jasperreport.xsd" name="Rpt_atimv_guia_detalle" pageWidth="595" pageHeight="842" columnWidth="575" leftMargin="20" rightMargin="0" topMargin="20" bottomMargin="20">
	<property name="ireport.zoom" value="1.5"/>
	<property name="ireport.x" value="93"/>
	<property name="ireport.y" value="0"/>
	<parameter name="DOCUMENT_ID" class="java.lang.String"/>
	<parameter name="BASE_DESIGN" class="java.lang.String" isForPrompting="false">
		<defaultValueExpression><![CDATA["C:/DesarrolloLuis/OpenbravoERPNuevo/modules/com.atrums.indumot.formatoimpresion/src"]]></defaultValueExpression>
	</parameter>
	<queryString>
		<![CDATA[select  p.value as codigo,
        p.name as producto,
        asi.description as detalles,
        gui.documentno as documento,
        bpar.name as nombre
from m_inoutline io, m_product p, m_attributesetinstance asi, m_inout gui, c_bpartner bpar
where io.m_product_id = p.m_product_id
and io.m_attributesetinstance_id = asi.m_attributesetinstance_id
and io.m_inout_id=gui.m_inout_id
and gui.c_bpartner_id=bpar.c_bpartner_id
and io.m_inout_id = $P{DOCUMENT_ID}]]>
	</queryString>
	<field name="codigo" class="java.lang.String"/>
	<field name="producto" class="java.lang.String"/>
	<field name="detalles" class="java.lang.String"/>
	<field name="documento" class="java.lang.String"/>
	<field name="nombre" class="java.lang.String"/>
	<background>
		<band splitType="Stretch"/>
	</background>
	<title>
		<band height="50"/>
	</title>
	<pageHeader>
		<band height="50"/>
	</pageHeader>
	<columnHeader>
		<band height="63" splitType="Stretch">
			<staticText>
				<reportElement x="0" y="30" width="89" height="20"/>
				<textElement verticalAlignment="Middle">
					<font fontName="Courier New" size="12" isBold="true"/>
				</textElement>
				<text><![CDATA[Código]]></text>
			</staticText>
			<staticText>
				<reportElement x="89" y="30" width="201" height="20"/>
				<textElement verticalAlignment="Middle">
					<font fontName="Courier New" size="12" isBold="true"/>
				</textElement>
				<text><![CDATA[Descripción]]></text>
			</staticText>
			<staticText>
				<reportElement x="290" y="30" width="285" height="20"/>
				<textElement verticalAlignment="Middle">
					<font fontName="Courier New" size="12" isBold="true"/>
				</textElement>
				<text><![CDATA[Detalle (Serie / Motor Chasis RAMV)]]></text>
			</staticText>
			<staticText>
				<reportElement x="1" y="2" width="88" height="20"/>
				<textElement>
					<font size="10"/>
				</textElement>
				<text><![CDATA[Cliente:]]></text>
			</staticText>
			<staticText>
				<reportElement x="359" y="2" width="92" height="20"/>
				<textElement>
					<font size="10"/>
				</textElement>
				<text><![CDATA[# Guia Despacho]]></text>
			</staticText>
			<textField>
				<reportElement x="89" y="0" width="270" height="20"/>
				<textElement>
					<font size="12"/>
				</textElement>
				<textFieldExpression class="java.lang.String"><![CDATA[$F{nombre}]]></textFieldExpression>
			</textField>
			<textField>
				<reportElement x="451" y="2" width="90" height="20"/>
				<textElement textAlignment="Right">
					<font size="12"/>
				</textElement>
				<textFieldExpression class="java.lang.String"><![CDATA[$F{documento}]]></textFieldExpression>
			</textField>
		</band>
	</columnHeader>
	<detail>
		<band height="15" splitType="Stretch">
			<textField>
				<reportElement x="0" y="0" width="89" height="15"/>
				<textElement verticalAlignment="Middle">
					<font fontName="Courier New" size="9" pdfFontName="Courier"/>
				</textElement>
				<textFieldExpression class="java.lang.String"><![CDATA[$F{codigo}]]></textFieldExpression>
			</textField>
			<textField>
				<reportElement x="89" y="0" width="201" height="15"/>
				<textElement verticalAlignment="Middle">
					<font fontName="Courier New" size="9" pdfFontName="Courier"/>
				</textElement>
				<textFieldExpression class="java.lang.String"><![CDATA[$F{producto}]]></textFieldExpression>
			</textField>
			<textField>
				<reportElement x="290" y="0" width="285" height="15"/>
				<textElement verticalAlignment="Middle">
					<font fontName="Courier New" size="9" pdfFontName="Courier"/>
				</textElement>
				<textFieldExpression class="java.lang.String"><![CDATA[$F{detalles}]]></textFieldExpression>
			</textField>
		</band>
	</detail>
</jasperReport>
