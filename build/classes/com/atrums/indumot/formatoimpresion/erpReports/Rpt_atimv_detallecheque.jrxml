<?xml version="1.0" encoding="UTF-8"?>
<jasperReport xmlns="http://jasperreports.sourceforge.net/jasperreports" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://jasperreports.sourceforge.net/jasperreports http://jasperreports.sourceforge.net/xsd/jasperreport.xsd" name="Rpt_atimv_detallecheque" pageWidth="583" pageHeight="400" columnWidth="555" leftMargin="14" rightMargin="14" topMargin="14" bottomMargin="14">
	<property name="ireport.zoom" value="1.7715610000000015"/>
	<property name="ireport.x" value="0"/>
	<property name="ireport.y" value="0"/>
	<style name="GroupHeader_DarkGray" mode="Opaque" forecolor="#FFFFFF" backcolor="#555555" vAlign="Middle" fontName="Bitstream Vera Sans" fontSize="18" isBold="true">
		<box leftPadding="5"/>
	</style>
	<style name="Gray" mode="Opaque" forecolor="#000000" backcolor="#CCCCCC"/>
	<parameter name="DOCUMENT_ID" class="java.lang.String"/>
	<queryString>
		<![CDATA[SELECT
     case when psd.fin_payment_schedule_order is not null and psd.fin_payment_schedule_invoice is null then 'O'
          when psd.fin_payment_schedule_invoice is not null and psd.fin_payment_schedule_order is null then 'I'
          when psd.fin_payment_schedule_invoice is not null and psd.fin_payment_schedule_order is not null then 'I'
          when pd.c_glitem_id is not null then 'GL'
          when psd.fin_payment_schedule_invoice is null and psd.fin_payment_schedule_order is null and p.referenceno= 'RP'
          then 'RP'
          else 'U'
          end as LINE_DOCUMENTTYPE,
     coalesce(to_char(inv.documentno), to_char('')) as LINE_DOCUMENTNO,
     coalesce(psd.amount, pd.amount)-coalesce(p.used_credit,0) as AMOUNT,
     p.description as RAZON,
     c_validcombination.combination as CUENTA_PAGO,
     (select name from c_elementvalue where c_elementvalue_id = c_validcombination.account_id) as CUENTA_PAGO_NOMBRE,
     CASE WHEN pd.c_glitem_id is not null THEN
               (select combination from c_validcombination vc1, c_glitem_acct gl1
                  where gl1.glitem_credit_acct = vc1.c_validcombination_id
                  and pd.c_glitem_id = gl1.c_glitem_id)
    when p.generated_credit > 0 then
        BENEFICIARIO2.combination
    else
                   BENEFICIARIO1.combination
     END as CUENTA_BENEFICIARIO,
     CASE WHEN pd.c_glitem_id is not null THEN
              (select ev.description from c_validcombination vc1, c_glitem_acct gl1, c_elementvalue ev
                where gl1.glitem_credit_acct = vc1.c_validcombination_id
                  and vc1.account_id = ev.c_elementvalue_id
                  and pd.c_glitem_id = gl1.c_glitem_id)
           when p.generated_credit > 0 then
            (select name from c_elementvalue where c_elementvalue_id = BENEFICIARIO2.account_id)
            else
                  (select name from c_elementvalue where c_elementvalue_id = BENEFICIARIO1.account_id)
     END as CUENTA_BENEFICIARIO_NOMBRE
    FROM fin_payment p join fin_payment_detail pd on (p.fin_payment_id=pd.fin_payment_id)
        join fin_payment_scheduledetail psd on (pd.fin_payment_detail_id=psd.fin_payment_detail_id)
        left outer join fin_payment_schedule ps on (psd.fin_payment_schedule_invoice=ps.fin_payment_schedule_id)
        left outer join c_invoice inv on (ps.c_invoice_id = inv.c_invoice_id)
        left outer join c_glitem gl on (pd.c_glitem_id = gl.c_glitem_id)
        join fin_financial_account finact on (finact.fin_financial_account_id=p.fin_financial_account_id)
    	join c_validcombination on
                    (c_validcombination_id = (select fin_withdrawal_acct from  fin_financial_account_acct
                                                    where fin_financial_account_id=finact.fin_financial_account_id
                                                    limit 1))
    	LEFT JOIN c_validcombination BENEFICIARIO1 on
                BENEFICIARIO1.c_validcombination_id = (select v_liability_acct from c_bp_vendor_acct
                                                    where c_bpartner_id=p.c_bpartner_id
                                                    limit 1)
       LEFT JOIN c_validcombination BENEFICIARIO2 on
                BENEFICIARIO2.c_validcombination_id = (select v_prepayment_acct from c_bp_vendor_acct
                                                    where c_bpartner_id=p.c_bpartner_id
                                                    limit 1)
   WHERE  p.fin_payment_id=$P{DOCUMENT_ID}]]>
	</queryString>
	<field name="line_documenttype" class="java.lang.String"/>
	<field name="line_documentno" class="java.lang.String"/>
	<field name="AMOUNT" class="java.math.BigDecimal"/>
	<field name="RAZON" class="java.lang.String"/>
	<field name="CUENTA_PAGO" class="java.lang.String"/>
	<field name="CUENTA_PAGO_NOMBRE" class="java.lang.String"/>
	<field name="CUENTA_BENEFICIARIO" class="java.lang.String"/>
	<field name="CUENTA_BENEFICIARIO_NOMBRE" class="java.lang.String"/>
	<variable name="SUM_LINEAMNT" class="java.math.BigDecimal" calculation="Sum">
		<variableExpression><![CDATA[$F{AMOUNT}]]></variableExpression>
	</variable>
	<background>
		<band/>
	</background>
	<title>
		<band/>
	</title>
	<pageHeader>
		<band/>
	</pageHeader>
	<detail>
		<band height="12" splitType="Stretch">
			<textField>
				<reportElement x="0" y="0" width="100" height="12"/>
				<textElement>
					<font fontName="Courier New" size="10"/>
				</textElement>
				<textFieldExpression class="java.lang.String"><![CDATA[$F{CUENTA_BENEFICIARIO}]]></textFieldExpression>
			</textField>
			<textField>
				<reportElement x="127" y="0" width="181" height="12"/>
				<textElement>
					<font fontName="Courier New" size="10"/>
				</textElement>
				<textFieldExpression class="java.lang.String"><![CDATA[$F{CUENTA_BENEFICIARIO_NOMBRE}]]></textFieldExpression>
			</textField>
			<textField pattern="###0.00;-###0.00">
				<reportElement x="359" y="0" width="100" height="12"/>
				<textElement>
					<font fontName="Courier New" size="10"/>
				</textElement>
				<textFieldExpression class="java.math.BigDecimal"><![CDATA[$F{AMOUNT}]]></textFieldExpression>
			</textField>
		</band>
	</detail>
	<columnFooter>
		<band height="13" splitType="Stretch">
			<textField>
				<reportElement x="127" y="0" width="181" height="12"/>
				<textElement>
					<font fontName="Courier New" size="10"/>
				</textElement>
				<textFieldExpression class="java.lang.String"><![CDATA[$F{CUENTA_PAGO_NOMBRE}]]></textFieldExpression>
			</textField>
			<textField pattern="###0.00;-###0.00">
				<reportElement x="438" y="0" width="100" height="12"/>
				<textElement>
					<font fontName="Courier New" size="10"/>
				</textElement>
				<textFieldExpression class="java.math.BigDecimal"><![CDATA[$V{SUM_LINEAMNT}]]></textFieldExpression>
			</textField>
			<textField>
				<reportElement x="0" y="0" width="100" height="12"/>
				<textElement>
					<font fontName="Courier New" size="10"/>
				</textElement>
				<textFieldExpression class="java.lang.String"><![CDATA[$F{CUENTA_PAGO}]]></textFieldExpression>
			</textField>
		</band>
	</columnFooter>
	<pageFooter>
		<band splitType="Stretch"/>
	</pageFooter>
</jasperReport>
