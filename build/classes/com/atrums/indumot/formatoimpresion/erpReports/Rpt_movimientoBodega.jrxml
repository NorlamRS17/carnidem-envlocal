<?xml version="1.0" encoding="UTF-8"?>
<jasperReport xmlns="http://jasperreports.sourceforge.net/jasperreports" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://jasperreports.sourceforge.net/jasperreports http://jasperreports.sourceforge.net/xsd/jasperreport.xsd" name="Rpt_movimientoBodega" pageWidth="595" pageHeight="842" columnWidth="555" leftMargin="20" rightMargin="20" topMargin="20" bottomMargin="20">
	<property name="ireport.zoom" value="2.0"/>
	<property name="ireport.x" value="0"/>
	<property name="ireport.y" value="0"/>
	<parameter name="m_movement_id" class="java.lang.String">
		<defaultValueExpression><![CDATA[]]></defaultValueExpression>
	</parameter>
	<parameter name="DOCUMENT_ID" class="java.lang.String" isForPrompting="false">
		<defaultValueExpression><![CDATA["'1000069'"]]></defaultValueExpression>
	</parameter>
	<queryString>
		<![CDATA[select mv.m_movement_id as codigomov,mv.movementdate::date as fecha,mv.documentno as orden,
       (select value from m_locator
         where m_locator_id =mvl.m_locator_id ) as coddesde,
       (select war.name from m_locator loc,m_warehouse war
         where loc.m_locator_id = mvl.m_locator_id
           and loc.m_warehouse_id = war.m_warehouse_id) as desde,
       (select value from m_locator
         where m_locator_id =mvl.em_atimb_bodega_dest_id ) as codsolicitante,
       (select war.name from m_locator loc,m_warehouse war
         where loc.m_locator_id = mvl.em_atimb_bodega_dest_id
           and loc.m_warehouse_id = war.m_warehouse_id) as solicitante,
        mvl.movementqty as cantidad,
        coalesce(mv.description,'') as descripcion,
       (select name from c_uom where c_uom_id = mvl.c_uom_id) as um,
       (select value from m_product where m_product_id = mvl.m_product_id) as codigoproducto,
        (select coalesce(description,'') from m_movementline where m_movementline_id = mvl.m_movementline_id)  || ' ' || (select name from m_product where m_product_id = mvl.m_product_id) as descripcionProducto,
(select name from m_product where m_product_id = mvl.m_product_id) as marca,
(select description from m_attributesetinstance where m_attributesetinstance_id = mvl.m_attributesetinstance_id) as atributo
from m_movementline mvl, m_movement mv
where mv.m_movement_id IN ($P{DOCUMENT_ID})
  and mvl.m_movement_id = mv.m_movement_id]]>
	</queryString>
	<field name="codigomov" class="java.lang.String"/>
	<field name="fecha" class="java.sql.Date"/>
	<field name="orden" class="java.lang.String"/>
	<field name="coddesde" class="java.lang.String"/>
	<field name="desde" class="java.lang.String"/>
	<field name="codsolicitante" class="java.lang.String"/>
	<field name="solicitante" class="java.lang.String"/>
	<field name="cantidad" class="java.math.BigDecimal"/>
	<field name="descripcion" class="java.lang.String"/>
	<field name="um" class="java.lang.String"/>
	<field name="codigoproducto" class="java.lang.String"/>
	<field name="descripcionproducto" class="java.lang.String"/>
	<field name="marca" class="java.lang.String"/>
	<field name="atributo" class="java.lang.String"/>
	<background>
		<band splitType="Stretch"/>
	</background>
	<pageHeader>
		<band height="203" splitType="Stretch">
			<textField>
				<reportElement x="66" y="104" width="100" height="20"/>
				<textElement>
					<font size="9"/>
				</textElement>
				<textFieldExpression class="java.util.Date"><![CDATA[$F{fecha}]]></textFieldExpression>
			</textField>
			<textField>
				<reportElement x="66" y="124" width="100" height="20"/>
				<textElement>
					<font size="9"/>
				</textElement>
				<textFieldExpression class="java.lang.String"><![CDATA[$F{orden}]]></textFieldExpression>
			</textField>
			<textField>
				<reportElement x="66" y="144" width="100" height="20"/>
				<textElement>
					<font size="9"/>
				</textElement>
				<textFieldExpression class="java.lang.String"><![CDATA[$F{solicitante}]]></textFieldExpression>
			</textField>
			<textField isBlankWhenNull="true">
				<reportElement x="303" y="124" width="252" height="20"/>
				<textElement>
					<font size="9"/>
				</textElement>
				<textFieldExpression class="java.lang.String"><![CDATA[$F{coddesde} +" "+$F{desde}]]></textFieldExpression>
			</textField>
			<textField isBlankWhenNull="true">
				<reportElement x="303" y="144" width="252" height="20"/>
				<textElement>
					<font size="9"/>
				</textElement>
				<textFieldExpression class="java.lang.String"><![CDATA[$F{codsolicitante} +" "+$F{solicitante}]]></textFieldExpression>
			</textField>
			<textField isBlankWhenNull="true">
				<reportElement x="303" y="104" width="133" height="20"/>
				<textElement verticalAlignment="Middle">
					<font size="9"/>
				</textElement>
				<textFieldExpression class="java.lang.String"><![CDATA[$F{descripcion}]]></textFieldExpression>
			</textField>
		</band>
	</pageHeader>
	<detail>
		<band height="31" splitType="Stretch">
			<textField>
				<reportElement x="436" y="0" width="77" height="16"/>
				<textElement textAlignment="Center" verticalAlignment="Top">
					<font size="9"/>
				</textElement>
				<textFieldExpression class="java.math.BigDecimal"><![CDATA[$F{cantidad}]]></textFieldExpression>
			</textField>
			<textField>
				<reportElement x="400" y="0" width="23" height="16"/>
				<textElement verticalAlignment="Top">
					<font size="9"/>
				</textElement>
				<textFieldExpression class="java.lang.String"><![CDATA[$F{um}]]></textFieldExpression>
			</textField>
			<textField>
				<reportElement x="-7" y="0" width="97" height="16"/>
				<textElement verticalAlignment="Top">
					<font size="9"/>
				</textElement>
				<textFieldExpression class="java.lang.String"><![CDATA[$F{codigoproducto}]]></textFieldExpression>
			</textField>
			<textField isBlankWhenNull="true">
				<reportElement x="90" y="0" width="285" height="16"/>
				<textElement verticalAlignment="Top">
					<font size="9"/>
				</textElement>
				<textFieldExpression class="java.lang.String"><![CDATA[$F{marca}]]></textFieldExpression>
			</textField>
			<textField isBlankWhenNull="true">
				<reportElement x="65" y="15" width="310" height="16"/>
				<textElement verticalAlignment="Top">
					<font size="9"/>
				</textElement>
				<textFieldExpression class="java.lang.String"><![CDATA[$F{atributo}]]></textFieldExpression>
			</textField>
		</band>
	</detail>
</jasperReport>
