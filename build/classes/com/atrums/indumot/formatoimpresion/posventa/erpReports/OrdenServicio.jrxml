<?xml version="1.0" encoding="UTF-8"?>
<jasperReport xmlns="http://jasperreports.sourceforge.net/jasperreports" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://jasperreports.sourceforge.net/jasperreports http://jasperreports.sourceforge.net/xsd/jasperreport.xsd" name="OrdenServicio" pageWidth="595" pageHeight="842" columnWidth="555" leftMargin="20" rightMargin="20" topMargin="20" bottomMargin="20" uuid="78acbcd6-a4cb-4659-b415-18a133e1b728">
	<property name="ireport.zoom" value="1.5"/>
	<property name="ireport.x" value="101"/>
	<property name="ireport.y" value="0"/>
	<parameter name="BASE_DESIGN" class="java.lang.String" isForPrompting="false">
		<defaultValueExpression><![CDATA["C:/DesarrolloSS/OpenBravo/Indumot/OpenbravoERP/modules/com.atrums.indumot.formatoimpresion/src"]]></defaultValueExpression>
	</parameter>
	<parameter name="DOCUMENT_ID" class="java.lang.String"/>
	<queryString>
		<![CDATA[SELECT
	atpv.atindpo_postventa_id
	,atpv.ad_client_id
	,o.name organizacion
	--datos del documento
	,atpv.documentno
	,atpv.docstatus
	,COALESCE(fp.name,'') formaPago
	,TO_CHAR(atpv.fecha,'dd/mm/yyyy') fecha
	,atpv.hora
	,COALESCE(atpv.lstiposervicio,'') lstiposervicio
	--datos  del vehículo
	,COALESCE(atpv.lstipovehiculo,'') lstipovehiculo
	,COALESCE(atpv.marca,'') marca
	,COALESCE(atpv.modelo,'')||'  '||atpv.anio modeloAnio
	,COALESCE(atpv.numeromotor,'') numeromotor
	,COALESCE(atpv.numerochasis,'') numerochasis
	,COALESCE(atpv.placa,'') placa
	,COALESCE(atpv.lscolor,'') lscolor
	,atpv.kmhoras
	,atpv.fechaventa
	,lv.name local_venta
	--datos del cliente
	,COALESCE(cb.name,'') nombre_apellidoCliente
	,bl.name direccion_cliente
	,COALESCE(atpv.telefono,'') Telefono_cliente
	--,(SELECT coalesce(bl.phone,' ') FROM c_bpartner_location bl
	--               WHERE bl.c_bpartner_location_id=atpv.c_bpartner_location_id
	--                 AND bl.ad_client_id =atpv.ad_client_id ) Telefono_cliente
	,COALESCE(atpv.celular,'') celular
	--,(SELECT coalesce(bl.phone2,' ') FROM c_bpartner_location bl
	--               WHERE bl.c_bpartner_location_id=atpv.c_bpartner_location_id
	--                 AND bl.ad_client_id =atpv.ad_client_id ) celular
	,COALESCE(cl.city,' ') ciudad_cliente
	--RUC/CC:
	,COALESCE(cb.value,'') RUC
	,COALESCE(au.email,'') email
	,COALESCE(descripcioncliente,'') descripcioncliente
	--datos mecánico responsable
	,COALESCE(cbe.name,'') nombre_apellidoMeca
	,COALESCE(atpv.observacion,'') observacion
FROM atindpo_postventa atpv
	JOIN ad_org o ON o.ad_org_id = atpv.ad_org_id
	LEFT JOIN fin_paymentmethod fp ON fp.fin_paymentmethod_id = atpv.fin_paymentmethod_id
	LEFT JOIN ad_org lv ON lv.ad_org_id = atpv.ad_org_venta_id AND lv.ad_client_id =atpv.ad_client_id
	LEFT JOIN c_bpartner cb ON cb.c_bpartner_id = atpv.c_bpartner_id AND cb.ad_client_id = atpv.ad_client_id
	LEFT JOIN c_bpartner_location bl ON bl.c_bpartner_location_id = atpv.c_bpartner_location_id AND bl.ad_client_id = atpv.ad_client_id
	LEFT JOIN c_location cl ON cl.c_location_id = bl.c_location_id
	LEFT JOIN ad_user au ON au.c_bpartner_id = atpv.c_bpartner_id AND au.ad_client_id = atpv.ad_client_id AND au.ad_org_id = atpv.ad_org_id
  		--AND au.created = (SELECT MAX(au1.created) FROM ad_user au1 WHERE au.c_bpartner_id = atpv.c_bpartner_id AND au.ad_client_id =atpv.ad_client_id AND au.ad_org_id = atpv.ad_org_id)
	LEFT JOIN c_bpartner cbe ON cbe.c_bpartner_id = atpv.c_bpartner_emp_id AND cbe.ad_client_id = atpv.ad_client_id
WHERE atpv.atindpo_postventa_id = $P{DOCUMENT_ID};]]>
	</queryString>
