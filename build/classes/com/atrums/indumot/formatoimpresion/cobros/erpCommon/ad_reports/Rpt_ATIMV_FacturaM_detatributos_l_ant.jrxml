<?xml version="1.0" encoding="UTF-8"?>
<jasperReport xmlns="http://jasperreports.sourceforge.net/jasperreports" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://jasperreports.sourceforge.net/jasperreports http://jasperreports.sourceforge.net/xsd/jasperreport.xsd" name="Rpt_ATIMV_FacturaM_detatributos" pageWidth="681" pageHeight="180" orientation="Landscape" columnWidth="681" leftMargin="0" rightMargin="0" topMargin="0" bottomMargin="0">
	<property name="ireport.zoom" value="1.5000000000000024"/>
	<property name="ireport.x" value="111"/>
	<property name="ireport.y" value="0"/>
	<parameter name="DOCUMENT_ID" class="java.lang.String"/>
	<parameter name="BASE_DESIGN" class="java.lang.String" isForPrompting="false">
		<defaultValueExpression><![CDATA["C:/Desarrollo/OpenbravoERPIndumoto/modules/com.atrums.indumot.formatoimpresion/src"]]></defaultValueExpression>
	</parameter>
	<queryString>
		<![CDATA[select p.name as producto,
        p.m_product_id,
        p.value as codigo,
        coalesce(p.em_atimv_anio,'') as anio,
        coalesce(p.em_atimv_color,'') as color,
        coalesce(p.em_atimv_modelo,'') as modelo,
        coalesce(p.em_atimv_subclase,'') as subclase,
        coalesce(p.em_atimv_cilindraje,'') as cilindraje,
        coalesce(p.em_atimv_origen,'') as paisorigen,
        coalesce(p.em_atimdm_capacidad,0) as capacidad,
        coalesce(p.em_atimv_clase,'') as clase,
        coalesce(p.weight,0) as tonelaje,
        'GASOLINA' as combustible,
        p.em_atimdm_isatrib as atributo,
        cl.qtyinvoiced as cantidad,
        cl.pricelist   as precio_poe,
        cl.priceactual - (select coalesce(em_atvef_financiamiento,0) from c_orderline where c_order_id =
                         (select c_order_id from c_invoice where c_invoice_id = cl.c_invoice_id))
                       + (select case when discount > 0 then round(pricelist*(coalesce(discount,0)/100),2) else 0 end from c_orderline where c_order_id =
                         (select c_order_id from c_invoice where c_invoice_id = cl.c_invoice_id)) as precio_financiado,
        cl.priceactual - (select coalesce(em_atvef_financiamiento,0) from c_orderline where c_order_id =
                         (select c_order_id from c_invoice where c_invoice_id = cl.c_invoice_id))
                       + (select case when discount > 0 then round(pricelist*(coalesce(discount,0)/100),2) else 0 end from c_orderline where c_order_id =
                         (select c_order_id from c_invoice where c_invoice_id = cl.c_invoice_id)) as base,
        ilt.taxamt as impuesto,
        t.rate as tipo_impuesto,
        (select mai.value as valoratt
            from m_attributesetinstance ai
            left join m_attributeset ms on(ms.m_attributeset_id=ai.m_attributeset_id)
            left join m_attributeinstance mai on(mai.m_attributesetinstance_id=ai.m_attributesetinstance_id)
            left join m_attribute ma on(ma.m_attribute_id=mai.m_attribute_id)
          where ai.m_attributesetinstance_id=cl.m_attributesetinstance_id
          and ma.name='RAMV') as ramv,
        (select mai.value as valoratt
            from m_attributesetinstance ai
            left join m_attributeset ms on(ms.m_attributeset_id=ai.m_attributeset_id)
            left join m_attributeinstance mai on(mai.m_attributesetinstance_id=ai.m_attributesetinstance_id)
            left join m_attribute ma on(ma.m_attribute_id=mai.m_attribute_id)
          where ai.m_attributesetinstance_id=cl.m_attributesetinstance_id
          and ma.name='NUMERO DE MOTOR') as motor,
        (select mai.value as valoratt
            from m_attributesetinstance ai
            left join m_attributeset ms on(ms.m_attributeset_id=ai.m_attributeset_id)
            left join m_attributeinstance mai on(mai.m_attributesetinstance_id=ai.m_attributesetinstance_id)
            left join m_attribute ma on(ma.m_attribute_id=mai.m_attribute_id)
          where ai.m_attributesetinstance_id=cl.m_attributesetinstance_id
          and ma.name='NÚMERO DE CHASIS') as chasis
  from c_invoiceline cl left join m_product p on (cl.m_product_id = p.m_product_id)
  left join m_inoutline mi on (mi.m_inoutline_id=cl.m_inoutline_id)
  left join c_orderline col on (col.m_inoutline_id=mi.m_inoutline_id)
  left join c_invoicelinetax ilt on (cl.c_invoiceline_id=ilt.c_invoiceline_id)
  left join c_tax t on (ilt.c_tax_id=t.c_tax_id)
  where cl.c_invoice_id=$P{DOCUMENT_ID}]]>
	</queryString>
