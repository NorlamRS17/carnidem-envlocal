<?xml version="1.0" encoding="UTF-8"?>
<jasperReport xmlns="http://jasperreports.sourceforge.net/jasperreports" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://jasperreports.sourceforge.net/jasperreports http://jasperreports.sourceforge.net/xsd/jasperreport.xsd" name="Rpt_ATIMV_FacturaM_mayoreo" printOrder="Horizontal" pageWidth="842" pageHeight="595" orientation="Landscape" columnWidth="832" leftMargin="5" rightMargin="5" topMargin="56" bottomMargin="56">
	<property name="ireport.zoom" value="1.0245201830476058"/>
	<property name="ireport.x" value="36"/>
	<property name="ireport.y" value="232"/>
	<parameter name="DOCUMENT_ID" class="java.lang.String"/>
	<parameter name="BASE_DESIGN" class="java.lang.String" isForPrompting="false">
		<defaultValueExpression><![CDATA["C:/Desarrollo/OpenbravoERPIndumoto/modules/com.atrums.indumot.formatoimpresion/src"]]></defaultValueExpression>
	</parameter>
	<queryString>
		<![CDATA[select  p.name,
lo.address1 || ' - '  || (select coalesce(name,'') from c_city where c_city_id = lo.c_city_id) || ' - ' ||
        (select coalesce(name,'') from c_region where c_region_id = lo.c_region_id) || ' - ' ||
          coalesce(l.phone,'') as "DIRECCION",
	p.name2,
	coalesce(l.phone,'') as telefono,
        coalesce(p.taxid,'') AS "RUC/CI",
        p.value as "COD.CLIENTE",
        coalesce((select username  from ad_user where ad_user_id = i.salesrep_id),'')as "COD.VENDEDOR",
        i.dateinvoiced as "FECHA_EMISION",
        i.documentno as "NUM.DOC",
        (select name from c_paymentterm where c_paymentterm_id = i.c_paymentterm_id) as "FORMA_PAGO",
i.totallines,
        (select sum(it.taxamt) from c_invoicetax it where it.c_invoice_id = i.c_invoice_id) as imp,

        CASE when (select m_attributesetinstance_id from c_invoiceline where c_invoice_id = i.c_invoice_id limit 1)
        is null then 0
        when i.grandtotal-(select o.em_atvef_entrada from c_orderline o where o.c_order_id = i.c_order_id limit 1) < 0
        then 0
        when (select netdays from c_paymentterm where c_paymentterm_id = i.c_paymentterm_id) = 0 then 0
        else i.grandtotal-(select o.em_atvef_entrada from c_orderline o where o.c_order_id = i.c_order_id limit 1) end as finan,

        (select
case when sum(priceactual) < 0 then round(sum(priceactual),2) else 0 end
from c_invoiceline where priceactual<0 and c_invoice_id = $P{DOCUMENT_ID}) as descuento,
i.totallines as subtotal,
        i.grandtotal,
atimv_vencimiento_factura($P{DOCUMENT_ID}) as paymentterm,
        (select m_attributesetinstance_id from c_invoiceline where c_invoice_id = i.c_invoice_id limit 1) as "ATRIBUTOS"
from c_invoice as i left join c_bpartner p on(i.c_bpartner_id=p.c_bpartner_id) left join c_bpartner_location as l on(l.c_bpartner_location_id=i.c_bpartner_location_id), c_location lo
where i.c_invoice_id = $P{DOCUMENT_ID}
and i.docstatus = 'CO'
and lo.c_location_id = l.c_location_id]]>
	</queryString>
