<?xml version="1.0" encoding="UTF-8"?>
<jasperReport xmlns="http://jasperreports.sourceforge.net/jasperreports" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://jasperreports.sourceforge.net/jasperreports http://jasperreports.sourceforge.net/xsd/jasperreport.xsd" name="Rpt_ATIMV_FacturaM_subreport" pageWidth="635" pageHeight="400" orientation="Landscape" columnWidth="635" leftMargin="0" rightMargin="0" topMargin="0" bottomMargin="0">
	<property name="ireport.zoom" value="1.4641000000000013"/>
	<property name="ireport.x" value="121"/>
	<property name="ireport.y" value="0"/>
	<parameter name="DOCUMENT_ID" class="java.lang.String"/>
	<queryString>
		<![CDATA[select p.name as producto,
        p.value as codigo,
       sum(cl.qtyinvoiced) as cantidad,
       cl.pricelist   as precio,
       cl.pricelist as precio_actual,
       cl.pricelist*sum(cl.qtyinvoiced) as total
  from c_invoiceline cl, m_product p
 where cl.m_product_id = p.m_product_id
   and cl.c_invoice_id = $P{DOCUMENT_ID}
group by 1,2,4,5]]>
	</queryString>
	<field name="producto" class="java.lang.String"/>
	<field name="codigo" class="java.lang.String"/>
	<field name="cantidad" class="java.math.BigDecimal"/>
	<field name="precio" class="java.math.BigDecimal"/>
	<field name="precio_actual" class="java.math.BigDecimal"/>
	<field name="total" class="java.math.BigDecimal"/>
	<background>
		<band splitType="Stretch"/>
	</background>
	<detail>
		<band height="20" splitType="Stretch">
			<textField>
				<reportElement x="102" y="0" width="286" height="20"/>
				<textElement verticalAlignment="Middle">
					<font fontName="Courier New" size="11" pdfFontName="Courier" isPdfEmbedded="false"/>
				</textElement>
				<textFieldExpression class="java.lang.String"><![CDATA[$F{producto}]]></textFieldExpression>
			</textField>
			<textField>
				<reportElement x="0" y="0" width="102" height="20"/>
				<textElement textAlignment="Center" verticalAlignment="Middle">
					<font fontName="Courier New" size="11" pdfFontName="Courier" isPdfEmbedded="false"/>
				</textElement>
				<textFieldExpression class="java.lang.String"><![CDATA[$F{codigo}]]></textFieldExpression>
			</textField>
			<textField>
				<reportElement x="424" y="0" width="68" height="20"/>
				<textElement textAlignment="Right" verticalAlignment="Middle">
					<font fontName="Courier New" size="11" pdfFontName="Courier" isPdfEmbedded="false"/>
				</textElement>
				<textFieldExpression class="java.math.BigDecimal"><![CDATA[$F{cantidad}]]></textFieldExpression>
			</textField>
			<textField>
				<reportElement x="563" y="0" width="72" height="20"/>
				<textElement textAlignment="Right" verticalAlignment="Middle">
					<font fontName="Courier New" size="11" pdfFontName="Courier" isPdfEmbedded="false"/>
				</textElement>
				<textFieldExpression class="java.math.BigDecimal"><![CDATA[$F{total}]]></textFieldExpression>
			</textField>
			<textField pattern="###0.00">
				<reportElement x="492" y="0" width="71" height="20"/>
				<textElement textAlignment="Right" verticalAlignment="Middle">
					<font fontName="Courier New" size="11" pdfFontName="Courier" isPdfEmbedded="false"/>
				</textElement>
				<textFieldExpression class="java.math.BigDecimal"><![CDATA[$F{precio_actual}]]></textFieldExpression>
			</textField>
		</band>
	</detail>
</jasperReport>
