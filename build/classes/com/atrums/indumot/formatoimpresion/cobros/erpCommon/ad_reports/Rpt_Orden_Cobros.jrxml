<?xml version="1.0" encoding="UTF-8"?>
<jasperReport xmlns="http://jasperreports.sourceforge.net/jasperreports" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://jasperreports.sourceforge.net/jasperreports http://jasperreports.sourceforge.net/xsd/jasperreport.xsd" name="Rpt_Orden_Cobros" pageWidth="501" pageHeight="394" columnWidth="417" leftMargin="42" rightMargin="42" topMargin="42" bottomMargin="42">
	<property name="ireport.zoom" value="2.0"/>
	<property name="ireport.x" value="0"/>
	<property name="ireport.y" value="191"/>
	<parameter name="BASE_DESIGN" class="java.lang.String" isForPrompting="false">
		<defaultValueExpression><![CDATA["C:/Desarrollo/OpenbravoERPIndumoto/modules/com.atrums.indumot.formatoimpresion/src"]]></defaultValueExpression>
	</parameter>
	<parameter name="DOCUMENT_ID" class="java.lang.String"/>
	<queryString>
		<![CDATA[select cp.name as nombre, cp.value as codigo_emp ,
cl.name as direccion, fp.paymentdate as fecha_cobro , fp.documentno as num_documento,
fp.amount as monto, fpm.name as metodo_pago
from fin_payment fp
left join fin_paymentmethod fpm on(fp.fin_paymentmethod_id=fpm.fin_paymentmethod_id)
left join c_bpartner cp on(fp.c_bpartner_id=cp.c_bpartner_id)
left join c_bpartner_location cl on (cp.c_bpartner_id=cl.c_bpartner_id)
where fp.fin_payment_id=$P{DOCUMENT_ID}]]>
	</queryString>
	<field name="nombre" class="java.lang.String"/>
	<field name="codigo_emp" class="java.lang.String"/>
	<field name="direccion" class="java.lang.String"/>
	<field name="fecha_cobro" class="java.sql.Timestamp"/>
	<field name="num_documento" class="java.lang.String"/>
	<field name="monto" class="java.math.BigDecimal"/>
	<field name="metodo_pago" class="java.lang.String"/>
	<background>
		<band splitType="Stretch"/>
	</background>
	<pageHeader>
		<band height="113" splitType="Stretch">
			<textField isBlankWhenNull="true">
				<reportElement x="20" y="63" width="100" height="14"/>
				<textElement verticalAlignment="Middle">
					<font size="9"/>
				</textElement>
				<textFieldExpression class="java.lang.String"><![CDATA[$F{direccion}]]></textFieldExpression>
			</textField>
			<textField isBlankWhenNull="true">
				<reportElement x="170" y="22" width="76" height="14"/>
				<textElement verticalAlignment="Middle">
					<font size="8"/>
				</textElement>
				<textFieldExpression class="java.lang.String"><![CDATA[$F{codigo_emp}]]></textFieldExpression>
			</textField>
			<textField>
				<reportElement x="320" y="63" width="74" height="14"/>
				<textElement textAlignment="Right" verticalAlignment="Middle">
					<font size="8"/>
				</textElement>
				<textFieldExpression class="java.lang.String"><![CDATA[$F{num_documento}]]></textFieldExpression>
			</textField>
			<textField pattern="dd/MM/yyyy">
				<reportElement x="219" y="63" width="76" height="14"/>
				<textElement verticalAlignment="Middle">
					<font size="8"/>
				</textElement>
				<textFieldExpression class="java.sql.Timestamp"><![CDATA[$F{fecha_cobro}]]></textFieldExpression>
			</textField>
			<textField>
				<reportElement x="20" y="22" width="140" height="14"/>
				<textElement verticalAlignment="Middle">
					<font size="9"/>
				</textElement>
				<textFieldExpression class="java.lang.String"><![CDATA[$F{nombre}]]></textFieldExpression>
			</textField>
		</band>
	</pageHeader>
	<detail>
		<band height="125" splitType="Stretch">
			<subreport>
				<reportElement x="0" y="0" width="417" height="104"/>
				<subreportParameter name="DOCUMENT_ID">
					<subreportParameterExpression><![CDATA[$P{DOCUMENT_ID}]]></subreportParameterExpression>
				</subreportParameter>
				<connectionExpression><![CDATA[$P{REPORT_CONNECTION}]]></connectionExpression>
				<subreportExpression class="java.lang.String"><![CDATA[$P{BASE_DESIGN} + "/com/atrums/indumot/formatoimpresion/cobros/erpCommon/ad_reports/Rpt_Orden_Cobros_lineas.jasper"]]></subreportExpression>
			</subreport>
		</band>
	</detail>
	<columnFooter>
		<band height="50">
			<textField>
				<reportElement x="246" y="13" width="85" height="18"/>
				<textElement>
					<font size="8" isBold="true"/>
				</textElement>
				<textFieldExpression class="java.lang.String"><![CDATA[$F{metodo_pago}]]></textFieldExpression>
			</textField>
			<textField>
				<reportElement x="342" y="13" width="69" height="18"/>
				<textElement textAlignment="Right">
					<font size="8" isBold="true"/>
				</textElement>
				<textFieldExpression class="java.math.BigDecimal"><![CDATA[$F{monto}]]></textFieldExpression>
			</textField>
		</band>
	</columnFooter>
</jasperReport>
