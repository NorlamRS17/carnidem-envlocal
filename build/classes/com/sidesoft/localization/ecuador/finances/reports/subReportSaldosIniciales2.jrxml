<?xml version="1.0" encoding="UTF-8"?>
<jasperReport xmlns="http://jasperreports.sourceforge.net/jasperreports" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://jasperreports.sourceforge.net/jasperreports http://jasperreports.sourceforge.net/xsd/jasperreport.xsd" name="subReportSaldosIniciales" pageWidth="176" pageHeight="20" columnWidth="176" leftMargin="0" rightMargin="0" topMargin="0" bottomMargin="0" uuid="2ed8cf7d-83c1-4764-ae4f-2ebb606687d4">
	<property name="ireport.zoom" value="4.594972986357222"/>
	<property name="ireport.x" value="0"/>
	<property name="ireport.y" value="0"/>
	<property name="net.sf.jasperreports.export.xls.detect.cell.type" value="true"/>
	<parameter name="DateFrom" class="java.util.Date">
		<defaultValueExpression><![CDATA[new Date()]]></defaultValueExpression>
	</parameter>
	<parameter name="M_Product_ID" class="java.lang.String">
		<defaultValueExpression><![CDATA[""]]></defaultValueExpression>
	</parameter>
	<parameter name="SaldoInicial" class="java.lang.String"/>
	<parameter name="saldo" class="java.math.BigDecimal">
		<defaultValueExpression><![CDATA[new BigDecimal("0")]]></defaultValueExpression>
	</parameter>
	<queryString>
		<![CDATA[select coalesce(sum(mt.movementqty), 0) as sumasaldoi , coalesce (sum (mt.transactioncost), 0) as costot
     from m_transaction mt
     where mt.m_product_id = $P{M_Product_ID}
       and mt.movementdate < $P{DateFrom};]]>
	</queryString>
	<field name="sumasaldoi" class="java.math.BigDecimal"/>
	<field name="costot" class="java.math.BigDecimal"/>
	<variable name="producto_COUNT" class="java.math.BigDecimal">
		<variableExpression><![CDATA[$F{sumasaldoi}]]></variableExpression>
		<initialValueExpression><![CDATA[new BigDecimal("0")]]></initialValueExpression>
	</variable>
	<detail>
		<band height="20" splitType="Stretch">
			<textField>
				<reportElement x="0" y="0" width="56" height="20" uuid="515e6ebf-6771-48f9-aa26-6a58b730e99f"/>
				<textElement textAlignment="Right" verticalAlignment="Middle">
					<font size="8"/>
				</textElement>
				<textFieldExpression><![CDATA[$F{sumasaldoi}.add($P{saldo} != null? $P{saldo} : new BigDecimal("0"))]]></textFieldExpression>
			</textField>
			<textField>
				<reportElement x="114" y="0" width="62" height="20" uuid="fb690439-8a73-4f7c-b7e8-c13e7e882196"/>
				<textElement textAlignment="Right" verticalAlignment="Middle">
					<font size="8"/>
				</textElement>
				<textFieldExpression><![CDATA[$F{costot}]]></textFieldExpression>
			</textField>
			<textField>
				<reportElement x="56" y="0" width="58" height="20" uuid="70eafd2b-20b4-438b-bf14-bd7da157f214"/>
				<textElement textAlignment="Right" verticalAlignment="Middle">
					<font size="8"/>
				</textElement>
				<textFieldExpression><![CDATA[($P{saldo}.add($F{sumasaldoi}) != null && $P{saldo}.add($F{sumasaldoi}).compareTo(BigDecimal.ZERO) != 0)
    ? $F{costot}.divide($P{saldo}.add($F{sumasaldoi}), RoundingMode.HALF_UP)
    : BigDecimal.ZERO]]></textFieldExpression>
			</textField>
		</band>
	</detail>
</jasperReport>
