<?xml version="1.0" encoding="UTF-8"?>
<jasperReport xmlns="http://jasperreports.sourceforge.net/jasperreports" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://jasperreports.sourceforge.net/jasperreports http://jasperreports.sourceforge.net/xsd/jasperreport.xsd" name="Report_Kardex" pageWidth="1408" pageHeight="1161" orientation="Landscape" columnWidth="1348" leftMargin="30" rightMargin="30" topMargin="20" bottomMargin="20" uuid="0e70cd13-a13a-4c0a-a772-b808da84cb16">
	<property name="ireport.scriptlethandling" value="0"/>
	<property name="ireport.encoding" value="UTF-8"/>
	<property name="ireport.zoom" value="0.9090909090909097"/>
	<property name="ireport.x" value="18"/>
	<property name="ireport.y" value="0"/>
	<import value="net.sf.jasperreports.engine.*"/>
	<import value="java.util.*"/>
	<import value="net.sf.jasperreports.engine.data.*"/>
	<parameter name="DateFrom" class="java.util.Date"/>
	<parameter name="DateTo" class="java.util.Date"/>
	<parameter name="M_Product_ID" class="java.lang.String"/>
	<parameter name="M_Product_to_ID" class="java.lang.String">
		<defaultValueExpression><![CDATA[]]></defaultValueExpression>
	</parameter>
	<parameter name="m_locator_id" class="java.lang.String">
		<defaultValueExpression><![CDATA[]]></defaultValueExpression>
	</parameter>
	<queryString>
		<![CDATA[select *
from (

select
$P{DateFrom}  as fecha,
'I+' as tipomovimiento,
sum(t.movementqty) as cantidad,
'Saldo Inicial' as documentono,
$P{DateFrom} || ' Inventario Inicial' as documentoinv,
'' as documentnom,
'' as documentop,
 W.NAME as Bodega,
'' as descripcion1,
'' as descripcion2,
'' as descripcion3,
'' as descripcion4,
'' as descripcion5,
slps_get_product_cost(t.m_product_id, '01-01-2013', 'AVA') as costo,
sum(t.movementqty) * slps_get_product_cost(t.m_product_id, '01-01-2013', 'AVA') as costoxcantidad,
'SALDO INCIAL' as nombretransacciones,
sum(t.movementqty) as qtyin,
slps_get_product_cost(t.m_product_id, '01-01-2013', 'AVA') as costin,
0 as qtyout, 0 as costout,
'' as noorden,
'' as tercero,
'' as id_tercero,
'' as nofactura,
'' as unidad,
p.value AS PRODUCTO,P.NAME  AS PRODUCTO_NOMBRE,
'' as organizacion,
now() AS fecha_impresion,
'' as tipo,
slps_get_product_cost(t.m_product_id, $P{DateFrom}, 'AVA')  as unitcost,
slps_get_product_cost(t.m_product_id,$P{DateFrom} , 'AVA') *sum(t.movementqty) as totalcost
from m_transaction t
left join m_product p on p.m_product_id=t.m_product_id
left join m_locator r on t.m_locator_id=r.m_locator_id
left join m_warehouse w on r.m_warehouse_id=w.m_warehouse_id
left join ad_org f on t.ad_org_id = f.ad_org_id
where p.value between (select value from m_product where m_product_id =  $P{M_Product_ID}) and (select value from m_product where m_product_id = $P{M_Product_to_ID})
and to_date(t.movementdate) < $P{DateFrom}
and t.ad_org_id <>'0'
and (r.m_locator_id = $P{m_locator_id} or $P{m_locator_id} is null)
group by p.value,P.NAME, t.m_product_id, w.name

union all

select
t.movementdate as fecha,
CASE WHEN t.movementtype='I+' OR t.movementtype='C+' OR (t.movementtype='C-' AND  t.movementqty>0)OR t.movementtype='M+' OR t.movementtype='P+' OR t.movementtype='V+' OR t.movementtype='D+' OR t.movementtype='W+' THEN 'ENTRADA'
     WHEN t.movementtype='I-' OR (t.movementtype='C-' AND  t.movementqty<0) OR t.movementtype='M-' OR t.movementtype='P-' OR t.movementtype='V-' OR t.movementtype='D-' OR t.movementtype='W-' THEN 'SALIDA'
end  as tipomovimiento,
t.movementqty  as Cantidad ,
CASE WHEN t.movementtype='I+' OR t.movementtype='I-' THEN y.DOCUMENTNO
WHEN t.movementtype='C+' OR t.movementtype='V-' OR t.movementtype='D+' OR t.movementtype='D+' THEN o.DOCUMENTNO
 WHEN t.movementtype='C-'  OR t.movementtype='V+' THEN coalesce(o.DOCUMENTNO,'')|| coalesce('/' || O.POREFERENCE,'')
 WHEN t.movementtype='M-' OR t.movementtype='M+' THEN m.DOCUMENTNO
 WHEN t.movementtype='P-' OR t.movementtype='P+' THEN c.DOCUMENTNO
 END
as DocumentoNO,
y.name as documentoINV,
m.documentno as documentoM,
c.documentno as documentoP,

case when  t.movementtype='M-' THEN (select name from m_warehouse where m_warehouse_id =(SELECT m_warehouse_id FROM m_locator WHERE m_locator_id=(SELECT m_locator_id FROM m_movementline WHERE m_movementline_id=  t.m_movementline_id) ))
     when  t.movementtype='M+' THEN (select name from m_warehouse where m_warehouse_id =(SELECT m_warehouse_id FROM m_locator WHERE m_locator_id=(SELECT m_locatorto_id FROM m_movementline WHERE m_movementline_id=  t.m_movementline_id) ))
ELSE W.NAME end as Bodega,

CASE WHEN t.movementtype='I+' THEN y.description
     WHEN t.movementtype='I-' THEN y.description
     WHEN t.movementtype='C-' THEN o.description
     WHEN t.movementtype='C+' THEN o.description
     WHEN t.movementtype='M-' THEN 'MOVIMIENTO DESDE -'
     WHEN t.movementtype='M+' THEN 'MOVIMIENTO HASTA +'
     WHEN t.movementtype='P-' THEN 'PRODUCCION -'
     WHEN t.movementtype='P+' THEN 'PRODUCCION +'
     WHEN t.movementtype='V-' THEN o.description
     WHEN t.movementtype='V+' THEN o.description
     WHEN t.movementtype='D-' THEN 'CONSUMO INTERNO -'
     WHEN t.movementtype='D+' THEN 'INTERNAL CONSUMPTION +'
     WHEN t.movementtype='W-' THEN 'WORK ORDER -'
     WHEN t.movementtype='W+' THEN 'WORK ORDER +'
END as Descripcion1,

' DESDE: ' || (SELECT VALUE FROM M_LOCATOR WHERE M_LOCATOR_ID =(SELECT M_LOCATOR_ID FROM M_MOVEMENTLINE WHERE M_MOVEMENTLINE_ID = t.M_MOVEMENTLINE_ID)) || ' HASTA: ' || (SELECT VALUE FROM M_LOCATOR WHERE M_LOCATOR_ID =(SELECT M_LOCATORTO_ID FROM M_MOVEMENTLINE WHERE M_MOVEMENTLINE_ID = t.M_MOVEMENTLINE_ID)) as Descripcion2,
o.description as Descripcion3,
y.description as Descripcion4,
e.description as Descripcion5,
slps_get_product_cost(t.m_product_id, t.movementdate, 'AVA') as costo,
(slps_get_product_cost(t.m_product_id, t.movementdate, 'AVA')*t.movementqty) as costoxcantidad,
CASE WHEN t.movementtype='I+' THEN 'ING AJUSTE +'
     WHEN t.movementtype='I-' THEN 'SAL AJUSTE -'
     WHEN t.movementtype='C-' THEN 'VENTA -'
     WHEN t.movementtype='C+' THEN 'DEVOLUCION VENTA +'
     WHEN t.movementtype='M-' THEN 'TRANSF -'
     WHEN t.movementtype='M+' THEN 'TRANSF +'
     WHEN t.movementtype='P-' THEN 'PRODUCCION LDM-'
     WHEN t.movementtype='P+' THEN 'PRODUCCION LDM+'
     WHEN t.movementtype='V-' THEN 'DEVOLUCION COMPRA -'
     WHEN t.movementtype='V+' THEN 'COMPRA +'
     WHEN t.movementtype='D-' THEN 'CONSUMO INTERNO -'
     WHEN t.movementtype='D+' THEN 'CONSUMO INTERNO +'
     WHEN t.movementtype='W-' THEN 'WORK ORDER -'
     WHEN t.movementtype='W+' THEN 'WORK ORDER +'
END as nombretransacciones,
CASE WHEN t.movementqty>0 THEN t.movementqty
     WHEN t.movementqty>0 THEN t.movementqty
     WHEN t.movementqty>0 THEN t.movementqty
     WHEN t.movementqty>0 THEN t.movementqty
     WHEN t.movementqty>0 THEN t.movementqty
     WHEN t.movementqty>0 THEN t.movementqty
     WHEN t.movementqty>0 THEN t.movementqty
     ELSE 0
END as qtyin,
CASE WHEN t.movementqty>0 THEN (slps_get_product_cost(t.m_product_id, t.movementdate, 'AVA')*t.movementqty)
     WHEN t.movementqty>0 THEN (slps_get_product_cost(t.m_product_id, t.movementdate, 'AVA')*t.movementqty)
     WHEN t.movementqty>0 THEN (slps_get_product_cost(t.m_product_id, t.movementdate, 'AVA')*t.movementqty)
     WHEN t.movementqty>0 THEN (slps_get_product_cost(t.m_product_id, t.movementdate, 'AVA')*t.movementqty)
     WHEN t.movementqty>0 THEN (slps_get_product_cost(t.m_product_id, t.movementdate, 'AVA')*t.movementqty)
     WHEN t.movementqty>0 THEN (slps_get_product_cost(t.m_product_id, t.movementdate, 'AVA')*t.movementqty)
     WHEN t.movementqty>0 THEN (slps_get_product_cost(t.m_product_id, t.movementdate, 'AVA')*t.movementqty)
     ELSE 0
END as costin,
CASE
     WHEN t.movementqty<0 THEN abs(t.movementqty)
     WHEN t.movementqty<0 THEN abs(t.movementqty)
     WHEN t.movementqty<0 THEN abs(t.movementqty)
     WHEN t.movementqty<0 THEN abs(t.movementqty)
     WHEN t.movementqty<0 THEN abs(t.movementqty)
     WHEN t.movementqty<0 THEN abs(t.movementqty)
     WHEN t.movementqty<0 THEN abs(t.movementqty)
     ELSE 0
END as qtyout,
CASE
     WHEN t.movementqty<0 THEN (slps_get_product_cost(t.m_product_id, t.movementdate, 'AVA')*t.movementqty)
     WHEN t.movementqty<0 THEN (slps_get_product_cost(t.m_product_id, t.movementdate, 'AVA')*t.movementqty)
     WHEN t.movementqty<0 THEN (slps_get_product_cost(t.m_product_id, t.movementdate, 'AVA')*t.movementqty)
     WHEN t.movementqty<0 THEN (slps_get_product_cost(t.m_product_id, t.movementdate, 'AVA')*t.movementqty)
     WHEN t.movementqty<0 THEN (slps_get_product_cost(t.m_product_id, t.movementdate, 'AVA')*t.movementqty)
     WHEN t.movementqty<0 THEN (slps_get_product_cost(t.m_product_id, t.movementdate, 'AVA')*t.movementqty)
     WHEN t.movementqty<0 THEN (slps_get_product_cost(t.m_product_id, t.movementdate, 'AVA')*t.movementqty)
     ELSE 0
END as costout
,'Orden:  '||(select c_order.poreference from c_order where c_order.c_order_id=o.c_order_id) as noorden
,(select c_bpartner.name from c_bpartner where c_bpartner.c_bpartner_id=o.c_bpartner_id) as tercero
,(select c_bpartner.value from c_bpartner where c_bpartner.c_bpartner_id=o.c_bpartner_id) as id_tercero
,'Factura:  '||(select c_invoice.poreference from c_invoice where c_invoice.c_invoice_id=o.c_invoice_id) as Nofactura
,(select name from c_uom where c_uom_id = p.c_uom_id) as unidad
,P.VALUE AS PRODUCTO,P.NAME  AS PRODUCTO_NOMBRE,
f.value as organizacion,
now() AS fecha_impresion,
t.movementtype as tipo,
case when t.movementqty < 0 Then (tc.cost/t.movementqty)*-1
        else tc.cost/t.movementqty end as unitcost,
case when t.movementqty < 0 Then (case when t.movementqty < 0 Then (tc.cost/t.movementqty)*-1
       			 else tc.cost/t.movementqty end * t.movementqty) * -1
else case when t.movementqty < 0 Then (tc.cost/t.movementqty)*-1
       			 else tc.cost/t.movementqty end * t.movementqty end as totalcost
from m_transaction t
left join m_product p on t.m_product_id=p.m_product_id
left join m_inoutline i on t.m_inoutline_id=i.m_inoutline_id
left join m_inout o on i.m_inout_id=o.m_inout_id
left join m_inventoryline l on t.m_inventoryline_id=l.m_inventoryline_id
left join m_inventory y on l.m_inventory_id=y.m_inventory_id
left join m_movementline e on t.m_movementline_id=e.m_movementline_id
left join m_movement m on e.m_movement_id=m.m_movement_id
left join m_productionline a on t.m_productionline_id=a.m_productionline_id
left join m_productionplan b on a.m_productionplan_id=b.m_productionplan_id
left join m_production c on b.m_production_id=c.m_production_id
left join m_locator r on t.m_locator_id=r.m_locator_id
left join m_warehouse w on r.m_warehouse_id=w.m_warehouse_id
--LEFT JOIN c_invoice inv  on O.C_ORDER_ID = inv.C_ORDER_ID
--LEFT JOIN C_DOCTYPE CD ON CD.C_DOCTYPE_ID = INV.C_DOCTYPE_ID
left join ad_org f on t.ad_org_id = f.ad_org_id
left join m_transaction_cost tc on tc.m_transaction_id = t.m_transaction_id
where t.ad_org_id <>'0'
and (r.m_locator_id = $P{m_locator_id} or $P{m_locator_id} is null)
and (t.movementdate::date between $P{DateFrom} and  $P{DateTo})
and p.value between (select value from m_product where m_product_id = $P{M_Product_ID}) and (select value from m_product where m_product_id = $P{M_Product_to_ID} )

order by 8,PRODUCTO,fecha,tipomovimiento) kardex

order by producto_nombre, bodega, fecha, tipomovimiento]]>
	</queryString>
	<field name="fecha" class="java.sql.Timestamp"/>
	<field name="tipomovimiento" class="java.lang.String"/>
	<field name="cantidad" class="java.math.BigDecimal"/>
	<field name="documentono" class="java.lang.String"/>
	<field name="documentoinv" class="java.lang.String"/>
	<field name="documentnom" class="java.lang.String"/>
	<field name="documentop" class="java.lang.String"/>
	<field name="bodega" class="java.lang.String"/>
	<field name="descripcion1" class="java.lang.String"/>
	<field name="descripcion2" class="java.lang.String"/>
	<field name="descripcion3" class="java.lang.String"/>
	<field name="descripcion4" class="java.lang.String"/>
	<field name="descripcion5" class="java.lang.String"/>
	<field name="costo" class="java.math.BigDecimal"/>
	<field name="costoxcantidad" class="java.math.BigDecimal"/>
	<field name="nombretransacciones" class="java.lang.String"/>
	<field name="qtyin" class="java.math.BigDecimal"/>
	<field name="costin" class="java.math.BigDecimal"/>
	<field name="qtyout" class="java.math.BigDecimal"/>
	<field name="costout" class="java.math.BigDecimal"/>
	<field name="noorden" class="java.lang.String"/>
	<field name="tercero" class="java.lang.String"/>
	<field name="id_tercero" class="java.lang.String"/>
	<field name="nofactura" class="java.lang.String"/>
	<field name="unidad" class="java.lang.String"/>
	<field name="producto" class="java.lang.String"/>
	<field name="producto_nombre" class="java.lang.String"/>
	<field name="organizacion" class="java.lang.String"/>
	<field name="fecha_impresion" class="java.sql.Timestamp"/>
	<field name="tipo" class="java.lang.String"/>
	<field name="unitcost" class="java.math.BigDecimal"/>
	<field name="totalcost" class="java.math.BigDecimal"/>
	<variable name="sumbodega" class="java.math.BigDecimal" resetType="Group" resetGroup="bodega" calculation="Sum">
		<variableExpression><![CDATA[$F{cantidad}]]></variableExpression>
	</variable>
	<variable name="sumproducto" class="java.math.BigDecimal" resetType="Group" resetGroup="Producto" incrementType="Group" incrementGroup="bodega" calculation="Sum">
		<variableExpression><![CDATA[$V{sumbodega}]]></variableExpression>
	</variable>
	<variable name="sumtotal" class="java.math.BigDecimal" incrementType="Group" incrementGroup="Producto" calculation="Sum">
		<variableExpression><![CDATA[$V{sumproducto}]]></variableExpression>
	</variable>
	<variable name="sumqtyin" class="java.math.BigDecimal" resetType="Group" resetGroup="bodega" calculation="Sum">
		<variableExpression><![CDATA[$F{qtyin}]]></variableExpression>
	</variable>
	<variable name="sumqtyout" class="java.math.BigDecimal" resetType="Group" resetGroup="bodega" calculation="Sum">
		<variableExpression><![CDATA[$F{qtyout}]]></variableExpression>
	</variable>
	<variable name="sumproin" class="java.math.BigDecimal" resetType="Group" resetGroup="Producto" incrementType="Group" incrementGroup="bodega" calculation="Sum">
		<variableExpression><![CDATA[$V{sumqtyin}]]></variableExpression>
	</variable>
	<variable name="sumproout" class="java.math.BigDecimal" resetType="Group" resetGroup="Producto" incrementType="Group" incrementGroup="bodega" calculation="Sum">
		<variableExpression><![CDATA[$V{sumqtyout}]]></variableExpression>
	</variable>
	<variable name="sumcostunit" class="java.math.BigDecimal" resetType="Group" resetGroup="bodega" calculation="Sum">
		<variableExpression><![CDATA[$F{unitcost}]]></variableExpression>
	</variable>
	<variable name="sumcosttotal" class="java.math.BigDecimal" resetType="Group" resetGroup="bodega" calculation="Sum">
		<variableExpression><![CDATA[$V{totalcost}]]></variableExpression>
	</variable>
	<variable name="sumprocost" class="java.math.BigDecimal" resetType="Group" resetGroup="Producto" incrementType="Group" incrementGroup="bodega" calculation="Sum">
		<variableExpression><![CDATA[$V{sumcostunit}]]></variableExpression>
	</variable>
	<variable name="sumprocosttotal" class="java.math.BigDecimal" resetType="Group" resetGroup="Producto" incrementType="Group" incrementGroup="bodega" calculation="Sum">
		<variableExpression><![CDATA[$V{sumcosttotal}]]></variableExpression>
	</variable>
	<variable name="sumtotaltotal" class="java.math.BigDecimal" incrementType="Group" incrementGroup="Producto" calculation="Sum">
		<variableExpression><![CDATA[$V{sumprocosttotal}]]></variableExpression>
	</variable>
	<variable name="totalcost" class="java.math.BigDecimal" resetType="None">
		<variableExpression><![CDATA[$F{cantidad}.multiply($F{unitcost})]]></variableExpression>
	</variable>
	<variable name="v_costoUnit" class="java.lang.Double" resetType="Group" resetGroup="bodega">
		<variableExpression><![CDATA[($V{sumcosttotal}.doubleValue()!=Double.valueOf("0") && $V{sumbodega}.doubleValue()!=Double.valueOf("0"))? ($V{sumcosttotal}.doubleValue()/$V{sumbodega}.doubleValue()): Double.valueOf("0")]]></variableExpression>
	</variable>
	<variable name="v_TotalCostoUnit" class="java.lang.Double" resetType="Group" resetGroup="Producto">
		<variableExpression><![CDATA[($V{sumproducto}.doubleValue()!=Double.valueOf("0") && $V{sumprocosttotal}.doubleValue()!=Double.valueOf("0"))? ($V{sumprocosttotal}.doubleValue()/$V{sumproducto}.doubleValue()): Double.valueOf("0")]]></variableExpression>
	</variable>
	<group name="Producto">
		<groupExpression><![CDATA[$F{producto_nombre}]]></groupExpression>
