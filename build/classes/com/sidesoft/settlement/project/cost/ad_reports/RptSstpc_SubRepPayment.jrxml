<?xml version="1.0" encoding="UTF-8"?>
<jasperReport xmlns="http://jasperreports.sourceforge.net/jasperreports" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://jasperreports.sourceforge.net/jasperreports http://jasperreports.sourceforge.net/xsd/jasperreport.xsd" name="RptSstpc_SubRepPayment" pageWidth="306" pageHeight="283" whenNoDataType="NoDataSection" columnWidth="306" leftMargin="0" rightMargin="0" topMargin="0" bottomMargin="0">
	<property name="ireport.zoom" value="1.4641000000000006"/>
	<property name="ireport.x" value="0"/>
	<property name="ireport.y" value="0"/>
	<parameter name="PROJECT_ID" class="java.lang.String"/>
	<queryString>
		<![CDATA[select
sp.paymentdocumentno as "pago"
,fpdv.paymentdate as "fecha_pago"
, coalesce(sp.amount,0) + coalesce(sp.isadvanced,0) as "valor"
,(select sum(coalesce(sp.amount,0) + coalesce(sp.isadvanced,0)) from sstpc_payment sp
left join fin_payment_detail_v fpdv on fpdv.fin_payment_detail_v_id = sp.fin_payment_scheduledetail_id
where sp.sstpc_liquidation_projects_id = $P{PROJECT_ID}) as total
from sstpc_payment sp
left join fin_payment_detail_v fpdv on fpdv.fin_payment_detail_v_id = sp.fin_payment_scheduledetail_id
where sp.sstpc_liquidation_projects_id = $P{PROJECT_ID}]]>
	</queryString>
	<field name="pago" class="java.lang.String"/>
	<field name="fecha_pago" class="java.sql.Timestamp"/>
	<field name="valor" class="java.math.BigDecimal"/>
	<field name="total" class="java.math.BigDecimal"/>
	<variable name="v_TotalPayment" class="java.math.BigDecimal" calculation="Sum">
		<variableExpression><![CDATA[$F{valor}]]></variableExpression>
	</variable>
