	<parameter name="PROJECT_ID" class="java.lang.String"/>
	<queryString>
		<![CDATA[select
srr.documentno as  "factura"
,srr.dateinvoiced as "fecha"
,srr.amount as "valor"
,(select sum(srr.amount) from sstpc_related_costs srr
where srr.sstpc_liquidation_projects_id = $P{PROJECT_ID}) as total
from sstpc_related_costs srr
where srr.sstpc_liquidation_projects_id = $P{PROJECT_ID}]]>
	</queryString>
