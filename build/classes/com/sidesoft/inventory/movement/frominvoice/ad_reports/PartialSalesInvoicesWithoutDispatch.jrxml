<?xml version="1.0" encoding="UTF-8"?>
<jasperReport xmlns="http://jasperreports.sourceforge.net/jasperreports" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://jasperreports.sourceforge.net/jasperreports http://jasperreports.sourceforge.net/xsd/jasperreport.xsd" name="PartialSalesInvoicesWithoutDispatch" pageWidth="2016" pageHeight="780" orientation="Landscape" columnWidth="1976" leftMargin="20" rightMargin="20" topMargin="20" bottomMargin="20" uuid="f0bd3c03-16ff-483f-a5db-e8931d2b18e7">
	<property name="ireport.zoom" value="1.4641000000000715"/>
	<property name="ireport.x" value="0"/>
	<property name="ireport.y" value="0"/>
	<parameter name="AD_USER_ID" class="java.lang.String">
		<defaultValueExpression><![CDATA[]]></defaultValueExpression>
	</parameter>
	<parameter name="AD_ORG_ID" class="java.lang.String"/>
	<parameter name="DATE_FROM" class="java.util.Date"/>
	<parameter name="DATE_TO" class="java.util.Date"/>
	<queryString>
		<![CDATA[SELECT
 o.ad_org_id organizationid
 , TO_CHAR(NOW(),'dd/MM/yyyy HH24:MI:SS') printing_date
 , pu.name AS printing_user
 , dt.name dt_name
 , i.documentno
 , i.dateinvoiced
 , bp.name bp_name
 , CASE WHEN 'Y' IN (dt.isreturn, dt.isreversal) AND i.em_scnr_isref_inv = 'Y' THEN ri.documentno END ri_documentno
 , pr.value pr_value
 , pr.name pr_name
 , b.name b_name
 , mo.name mo_name
 , CASE WHEN 'Y' IN (dt.isreturn, dt.isreversal) THEN ABS(il.qtyinvoiced) * -1 ELSE il.qtyinvoiced END qtyinvoiced
 , CASE WHEN 'Y' IN (dt.isreturn, dt.isreversal) THEN ABS(il.priceactual) * -1 ELSE il.priceactual END priceactual
 , CASE WHEN 'Y' IN (dt.isreturn, dt.isreversal) THEN ABS(il.linenetamt) * -1 ELSE il.linenetamt END linenetamt
 , io.documentno io_documentno
 , io.movementdate io_movementdate
 , CASE WHEN 'Y' IN (dt.isreturn, dt.isreversal) THEN ABS(iol.movementqty) * -1 ELSE iol.movementqty END movementqty
 , COALESCE(CASE WHEN 'Y' IN (dt.isreturn, dt.isreversal) THEN ABS(tr.transactioncost) * -1 ELSE tr.transactioncost END, 0) transactioncost
 , CASE WHEN sinvmin_invoicestatus(io.m_inout_id) >= 100 THEN 'SI' ELSE 'NO' END dispatched
FROM c_invoiceline il
 JOIN c_invoice i ON i.c_invoice_id = il.c_invoice_id
 JOIN c_doctype dt ON dt.c_doctype_id = i.c_doctype_id
 JOIN c_bpartner bp ON bp.c_bpartner_id = i.c_bpartner_id
 JOIN m_product pr ON pr.m_product_id = il.m_product_id
 LEFT JOIN m_brand b ON b.m_brand_id = pr.m_brand_id
 LEFT JOIN ssfi_model_prod mo ON mo.ssfi_model_prod_id = pr.em_ssfi_model_prod_id
 LEFT JOIN c_invoice ri ON ri.c_invoice_id = i.em_scnr_invoice_id
 JOIN ad_org o ON o.ad_org_id = i.ad_org_id
 JOIN ad_user pu ON pu.ad_user_id = $P{AD_USER_ID}
 JOIN sinvmin_square_bill sb ON sb.c_invoiceline_id = il.c_invoiceline_id AND sb.m_inoutline_id IS NOT NULL
 JOIN m_inoutline iol ON iol.m_inoutline_id = sb.m_inoutline_id
 JOIN m_inout io ON io.m_inout_id = iol.m_inout_id
 LEFT JOIN m_transaction tr ON tr.m_inoutline_id = iol.m_inoutline_id
WHERE i.issotrx = 'Y' AND dt.em_sswh_implementautoriza = 'Y' AND pr.producttype <> 'S'
 AND i.dateinvoiced BETWEEN $P{DATE_FROM} AND $P{DATE_TO}
 AND (o.ad_org_id = $P{AD_ORG_ID} OR $P{AD_ORG_ID} = '0' OR $P{AD_ORG_ID} IS NULL)
ORDER BY bp.name, i.dateinvoiced, i.documentno, il.line]]>
	</queryString>
	<field name="organizationid" class="java.lang.String"/>
	<field name="printing_date" class="java.lang.String"/>
	<field name="printing_user" class="java.lang.String"/>
	<field name="dt_name" class="java.lang.String"/>
	<field name="documentno" class="java.lang.String"/>
	<field name="dateinvoiced" class="java.sql.Timestamp"/>
	<field name="bp_name" class="java.lang.String"/>
	<field name="ri_documentno" class="java.lang.String"/>
	<field name="pr_value" class="java.lang.String"/>
	<field name="pr_name" class="java.lang.String"/>
	<field name="b_name" class="java.lang.String"/>
	<field name="mo_name" class="java.lang.String"/>
	<field name="qtyinvoiced" class="java.math.BigDecimal"/>
	<field name="priceactual" class="java.math.BigDecimal"/>
	<field name="linenetamt" class="java.math.BigDecimal"/>
	<field name="io_documentno" class="java.lang.String"/>
	<field name="io_movementdate" class="java.sql.Timestamp"/>
	<field name="movementqty" class="java.math.BigDecimal"/>
	<field name="transactioncost" class="java.math.BigDecimal"/>
	<field name="dispatched" class="java.lang.String"/>
	<variable name="total" class="java.math.BigDecimal" calculation="Sum">
		<variableExpression><![CDATA[$F{linenetamt}]]></variableExpression>
	</variable>
	<variable name="totalcosto" class="java.math.BigDecimal" calculation="Sum">
		<variableExpression><![CDATA[$F{transactioncost}.multiply($F{movementqty})]]></variableExpression>
	</variable>
