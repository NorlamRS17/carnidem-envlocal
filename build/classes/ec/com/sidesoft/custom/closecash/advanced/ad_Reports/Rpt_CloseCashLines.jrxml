	<field name="revisado" class="java.lang.String"/>
	<field name="label_reviwer" class="java.lang.String"/>
	<variable name="V_VALOR" class="java.math.BigDecimal" calculation="Sum">
		<variableExpression><![CDATA[$F{valor}]]></variableExpression>
	</variable>
	<variable name="V_CAJA" class="java.math.BigDecimal" calculation="Sum">
		<variableExpression><![CDATA[$F{caja}]]></variableExpression>
	</variable>
	<variable name="V_EFECTIVO" class="java.math.BigDecimal" calculation="Sum">
		<variableExpression><![CDATA[$F{efectivo}]]></variableExpression>
	</variable>
	<variable name="V_TOTALVENTAS" class="java.math.BigDecimal" calculation="Sum">
		<variableExpression><![CDATA[$F{tipo}.equals("FV")?$F{valor}:BigDecimal.ZERO]]></variableExpression>
	</variable>
