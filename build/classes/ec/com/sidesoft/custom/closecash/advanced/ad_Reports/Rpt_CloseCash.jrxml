<?xml version="1.0" encoding="UTF-8"?>
<jasperReport xmlns="http://jasperreports.sourceforge.net/jasperreports" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://jasperreports.sourceforge.net/jasperreports http://jasperreports.sourceforge.net/xsd/jasperreport.xsd" name="Rpt_CloseCash" pageWidth="595" pageHeight="842" columnWidth="555" leftMargin="20" rightMargin="20" topMargin="20" bottomMargin="20" uuid="52d20ef9-6cd8-4496-b52e-bd6425c6b487">
	<property name="ireport.zoom" value="1.771561000000005"/>
	<property name="ireport.x" value="90"/>
	<property name="ireport.y" value="360"/>
	<parameter name="DOCUMENT_ID" class="java.lang.String"/>
	<parameter name="NUMBERFORMAT" class="java.text.DecimalFormat" isForPrompting="false">
		<defaultValueExpression><![CDATA[new DecimalFormat("###,##0.00;-###,##0.00", new DecimalFormatSymbols())]]></defaultValueExpression>
	</parameter>
	<queryString>
		<![CDATA[select
  	a.name as revisado,labels.*,
	cc.closingdate, cc.description, cc.totalsales, cc.totalexpenses, cc.difference,
  	fpm.name,ccl.amount, ccl.description as linedescription,
 	org.ad_org_id as organizationid,

 	(select min(documentno)  as min_doc
from c_invoice ci
where c_doctype_id in
(select c_doctype_sales_id
from sccc_setup scs
where sccc_setup_id in(
select sccc_setup_id
from sccc_cash_clousure cc
where cc.sccc_cash_clousure_id =$P{DOCUMENT_ID})
)
and to_char(ci.dateinvoiced,'dd/MM/yyyy') = (
select to_char(closingdate,'dd/MM/yyyy')
from sccc_cash_clousure cc
where cc.sccc_cash_clousure_id = $P{DOCUMENT_ID}
)) AS "doc_min"
,
(select max(documentno)  as min_doc
from c_invoice ci
where c_doctype_id in
(select c_doctype_sales_id
from sccc_setup scs
where sccc_setup_id in(
select sccc_setup_id
from sccc_cash_clousure cc
where cc.sccc_cash_clousure_id =$P{DOCUMENT_ID} )
)
and to_char(ci.dateinvoiced,'dd/MM/yyyy') = (
select to_char(closingdate,'dd/MM/yyyy')
from sccc_cash_clousure cc
where cc.sccc_cash_clousure_id = $P{DOCUMENT_ID}
)) as "doc_max"
,

(case TO_CHAR(TRIM(TO_CHAR(cc.closingdate, 'DAY')))
	when  TO_CHAR('MONDAY') THEN TO_CHAR('LUNES')
	when  TO_CHAR('TUESDAY') THEN TO_CHAR('MARTES')
	when  TO_CHAR('WEDNESDAY') THEN TO_CHAR('MIERCOLES')
	when  TO_CHAR('THURSDAY') THEN TO_CHAR('JUEVES')
	when  TO_CHAR('FRIDAY') THEN TO_CHAR('VIERNES')
	when  TO_CHAR('SATURDAY') THEN TO_CHAR('SABADO')
	when  TO_CHAR('SUNDAY') THEN TO_CHAR('DOMINGO')
ELSE
	TO_CHAR(now(), 'DAY')
END) AS nom_dia
,(select SCS.NAME
from sccc_setup scs
where sccc_setup_id in(
select sccc_setup_id
from sccc_cash_clousure cc
where cc.sccc_cash_clousure_id = $P{DOCUMENT_ID})
) AS "nom_caja"
from sccc_cash_clousure cc
	left join ad_user a on a.ad_user_id  =cc.createdby
	inner join sccc_cash_clousureline ccl on cc.sccc_cash_clousure_id = ccl.sccc_cash_clousure_id
	inner join fin_paymentmethod fpm on ccl.fin_paymentmethod_id = fpm.fin_paymentmethod_id
	inner join ad_org org on org.ad_org_id = cc.ad_org_id
,(select sescr_get_label_trl('Label_Rpt_CloseCash_reviwer','M','es_ES') as "label_reviwer" from dual) labels
where cc.sccc_cash_clousure_id = $P{DOCUMENT_ID}]]>
	</queryString>
	<field name="revisado" class="java.lang.String"/>
	<field name="label_reviwer" class="java.lang.String"/>
	<field name="closingdate" class="java.sql.Timestamp"/>
	<field name="description" class="java.lang.String"/>
	<field name="totalsales" class="java.math.BigDecimal"/>
	<field name="totalexpenses" class="java.math.BigDecimal"/>
	<field name="difference" class="java.math.BigDecimal"/>
	<field name="name" class="java.lang.String"/>
	<field name="amount" class="java.math.BigDecimal"/>
	<field name="linedescription" class="java.lang.String"/>
	<field name="organizationid" class="java.lang.String"/>
	<field name="doc_min" class="java.lang.String"/>
	<field name="doc_max" class="java.lang.String"/>
	<field name="nom_dia" class="java.lang.String"/>
	<field name="nom_caja" class="java.lang.String"/>
