<?xml version="1.0" encoding="UTF-8"?>
<jasperReport xmlns="http://jasperreports.sourceforge.net/jasperreports" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://jasperreports.sourceforge.net/jasperreports http://jasperreports.sourceforge.net/xsd/jasperreport.xsd" name="SubRpt_PaymentCont" pageWidth="583" pageHeight="300" columnWidth="583" leftMargin="0" rightMargin="0" topMargin="0" bottomMargin="0" uuid="56fc8386-2da2-4294-a368-51721c9c2675">
	<property name="ireport.zoom" value="2.1961500000000043"/>
	<property name="ireport.x" value="0"/>
	<property name="ireport.y" value="0"/>
	<parameter name="DOCUMENT_ID" class="java.lang.String"/>
	<parameter name="V_CONCEPTO" class="java.lang.String"/>
	<queryString>
		<![CDATA[SELECT
A.acctvalue as "cuenta_cont",
to_char(A.description)  as "detalle_cont",
A.amtacctdr as "debito_cont",
A.amtacctcr as "credito_cont"
, case when A.amtacctdr=0 then 2 else 1 end as orderline
from fin_payment P
INNER JOIN ad_org ORG ON ORG.ad_org_id = P.ad_org_id
LEFT JOIN c_doctype D on D.c_doctype_id = P.c_doctype_id
LEFT JOIN c_bpartner B on B.c_bpartner_id = P.c_bpartner_id
LEFT JOIN fin_financial_account F on F.fin_financial_account_id = P.fin_financial_account_id
LEFT JOIN fact_acct A on A.record_id = P.fin_payment_id
LEFT JOIN c_elementvalue E on E.c_elementvalue_id = A.account_id
WHERE P.fin_payment_id = $P{DOCUMENT_ID}
order by 5, A.acctvalue]]>
	</queryString>
	<field name="cuenta_cont" class="java.lang.String"/>
	<field name="detalle_cont" class="java.lang.String"/>
	<field name="debito_cont" class="java.math.BigDecimal"/>
	<field name="credito_cont" class="java.math.BigDecimal"/>
	<field name="orderline" class="java.lang.Integer"/>
	<variable name="sumaDebito" class="java.math.BigDecimal" calculation="Sum">
		<variableExpression><![CDATA[$F{debito_cont}]]></variableExpression>
	</variable>
	<variable name="sumaCredito" class="java.math.BigDecimal" calculation="Sum">
		<variableExpression><![CDATA[$F{credito_cont}]]></variableExpression>
	</variable>
	<variable name="V_SUMDEB" class="java.math.BigDecimal">
		<variableExpression><![CDATA[$V{sumaDebito}]]></variableExpression>
	</variable>
