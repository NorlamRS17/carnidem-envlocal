	<parameter name="DOCUMENT_ID" class="java.lang.String"/>
	<parameter name="BASE_WEB" class="java.lang.String"/>
	<queryString>
		<![CDATA[select cb.name "nombre",m.name as "modelo",c.em_maspmq_serie,c.em_maspmq_documentno
,s.code,s.description,s.quantity,c.ad_org_id as "organizationid"
from C_Project c
left join C_ProjectPhase f on  c.C_Project_id=f.C_Project_id
left join C_Projecttask t on f.C_ProjectPhase_id=t.C_ProjectPhase_id
left join sotpe_reqaddsuplies s on t.C_Projecttask_id=s.C_Projecttask_id
left join c_bpartner cb on c.c_bpartner_id=cb.c_bpartner_id
left join ssfi_model_prod m on c.em_maspmq_model=m.ssfi_model_prod_id
where t.C_Projecttask_id=$P{DOCUMENT_ID}]]>
	</queryString>
