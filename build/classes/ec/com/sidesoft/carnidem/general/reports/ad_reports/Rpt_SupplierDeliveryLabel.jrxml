<?xml version="1.0" encoding="UTF-8"?>
<jasperReport xmlns="http://jasperreports.sourceforge.net/jasperreports" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://jasperreports.sourceforge.net/jasperreports http://jasperreports.sourceforge.net/xsd/jasperreport.xsd" name="Rpt_SupplierDeliveryLabel" pageWidth="108" pageHeight="270" columnWidth="108" leftMargin="0" rightMargin="0" topMargin="0" bottomMargin="0" uuid="b1c8e77e-9248-4fc6-984a-4660188a9501">
	<property name="ireport.zoom" value="2.357947691000003"/>
	<property name="net.sf.jasperreports.print.keep.full.text" value="true"/>
	<property name="ireport.x" value="0"/>
	<property name="ireport.y" value="0"/>
	<parameter name="sscgr_inout_id" class="java.lang.String"/>
	<parameter name="sscgr_product_id" class="java.lang.String">
		<defaultValueExpression><![CDATA[]]></defaultValueExpression>
	</parameter>
	<parameter name="sscgr_ticket" class="java.lang.String">
		<defaultValueExpression><![CDATA["1"]]></defaultValueExpression>
	</parameter>
	<parameter name="sscgr_ticket_safe" class="java.lang.String">
		<defaultValueExpression><![CDATA[($P{sscgr_ticket} != null && $P{sscgr_ticket}.toString().trim().length() > 0) ? $P{sscgr_ticket}.toString().split(";")[0].trim() : "1"]]></defaultValueExpression>
	</parameter>
	<queryString>
		<![CDATA[SELECT data.ad_org_id, data.producto, data.cantidad, data.codigo_compra,
  data.fecha_recepcion, data.fecha_elaboracion, data.fecha_caducidad
FROM (
  SELECT
    io.AD_Org_ID AS ad_org_id,
    mp.name AS producto,
    TRIM(COALESCE(iol.movementqty::text, '') || ' ' || COALESCE(uom.name, '')) AS cantidad,
    COALESCE(asi.description, '') AS codigo_compra,
    to_char(io.movementdate, 'DD/MM/YYYY') AS fecha_recepcion,
    to_char(io.movementdate, 'DD/MM/YYYY') AS fecha_elaboracion,
    CASE
      WHEN mas.isguaranteedate = 'Y' AND mas.guaranteedays IS NOT NULL THEN to_char(io.movementdate + COALESCE(mas.guaranteedays, 0), 'DD/MM/YYYY')
      ELSE NULL
    END AS fecha_caducidad
  FROM M_InOut io
  JOIN M_InOutLine iol ON iol.M_InOut_ID = io.M_InOut_ID AND iol.movementqty <> 0
  JOIN M_Product mp ON mp.M_Product_ID = iol.M_Product_ID
  LEFT JOIN M_AttributeSetInstance asi ON asi.M_AttributeSetInstance_ID = iol.M_AttributeSetInstance_ID
  LEFT JOIN M_AttributeSet mas ON mas.M_AttributeSet_ID = mp.M_AttributeSet_ID
  LEFT JOIN C_UOM uom ON uom.C_UOM_ID = iol.C_UOM_ID
  WHERE io.M_InOut_ID = $P{sscgr_inout_id}
    AND ($P{sscgr_product_id} IS NULL OR $P{sscgr_product_id} = '' OR iol.M_Product_ID = $P{sscgr_product_id})
) data
CROSS JOIN generate_series(1, (
  SELECT CASE
    WHEN COALESCE(TRIM($P{sscgr_ticket_safe}), '') = '' THEN 1
    ELSE GREATEST(1, CAST(TRIM($P{sscgr_ticket_safe}) AS INTEGER))
  END
)) AS s(num)
ORDER BY data.producto, s.num]]>
	</queryString>
