	<field name="cantidad" class="java.lang.String"/>
	<field name="codigo_compra" class="java.lang.String"/>
	<field name="fecha_recepcion" class="java.lang.String"/>
	<field name="fecha_elaboracion" class="java.lang.String"/>
	<field name="fecha_caducidad" class="java.lang.String"/>
