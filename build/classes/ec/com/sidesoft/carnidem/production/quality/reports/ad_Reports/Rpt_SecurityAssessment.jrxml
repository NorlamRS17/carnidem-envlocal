		<defaultValueExpression><![CDATA[new DecimalFormat("###,##0.00;-###,##0.00", new DecimalFormatSymbols())]]></defaultValueExpression>
	</parameter>
	<parameter name="BASE_DESIGN" class="java.lang.String" isForPrompting="false">
		<defaultValueExpression><![CDATA["/opt/openbravo/carnidem/modules/ec.com.sidesoft.carnidem.production.quality.reports/src"]]></defaultValueExpression>
	</parameter>
	<parameter name="AD_User_ID" class="java.lang.String" isForPrompting="false">
		<defaultValueExpression><![CDATA["100"]]></defaultValueExpression>
	</parameter>
	<parameter name="SUBREPORT_DIR" class="java.lang.String" isForPrompting="false">
		<defaultValueExpression><![CDATA["src/ec/com/sidesoft/carnidem/production/quality/reports/ad_Reports/Srpt_Security_Assessment.jrxml"]]></defaultValueExpression>
	</parameter>
	<parameter name="DATE_FROM" class="java.util.Date"/>
	<parameter name="DATE_TO" class="java.util.Date"/>
	<parameter name="Type_safety_monitoring" class="java.lang.String"/>
	<parameter name="Monitoring_type" class="java.lang.String"/>
	<parameter name="Business_partner" class="java.lang.String"/>
	<parameter name="Average" class="java.lang.String"/>
	<parameter name="Summation" class="java.lang.String"/>
	<queryString>
		<![CDATA[SELECT
  sub.org_id,
  sub.org_name,
  sub.printing_user,
  sub.printing_date,
  sub.typemonitor,
  sub.bpname,
  sub.bpid,
  sub.spainTypeMonitor,
  sub.monitorName
FROM (
  SELECT
    o.ad_org_id AS org_id,
    o.name AS org_name,
    u.username AS printing_user,
    TO_CHAR(NOW(),'yyyy-MM-dd HH24:MI:SS') AS printing_date,
    ms.EM_Spquly_Qualitycontroltype AS typemonitor,
    CASE WHEN $P{Business_partner} IS NOT NULL THEN bp.name ELSE '' END AS bpname,
    bp.c_bpartner_id AS bpid,
    COALESCE(art.name, '') AS spainTypeMonitor,
    CASE WHEN $P{Monitoring_type} IS NOT NULL THEN ccp.name ELSE '' END AS monitorName,
    ms.Measuredate,
    ROW_NUMBER() OVER (
      PARTITION BY bp.c_bpartner_id
      ORDER BY ms.Measuredate ASC, bp.name ASC
    ) AS rn
  FROM MA_Measure_Shift ms
  LEFT JOIN c_bpartner bp ON bp.c_bpartner_id = ms.EM_Spquly_Supplier_ID
  LEFT JOIN m_product mp ON mp.m_product_id = ms.EM_Spquly_Product_ID
  JOIN ad_org o ON o.ad_orgtype_id = '1'
  JOIN ad_user u ON u.ad_user_id = $P{AD_User_ID}
  LEFT JOIN MA_CCP_Group ccp ON ccp.MA_CCP_Group_ID = ms.EM_Spquly_Ccp_ID
  LEFT JOIN ad_ref_list arl ON arl.value = ms.EM_Spquly_Qualitycontroltype AND arl.ad_reference_id = '6B8AF41C5C624034840F993F342D321B'
  LEFT JOIN ad_ref_list_trl art ON art.ad_ref_list_id = arl.ad_ref_list_id AND art.ad_language = 'es_ES'
  WHERE
    $P{DATE_FROM} <= ms.Measuredate AND $P{DATE_TO} >= ms.Measuredate
    AND $P{Type_safety_monitoring} = ms.EM_Spquly_Qualitycontroltype
    AND (ms.EM_Spquly_Ccp_ID = $P{Monitoring_type} OR $P{Monitoring_type} IS NULL)
    AND (ms.EM_Spquly_Supplier_ID = $P{Business_partner} OR $P{Business_partner} IS NULL)
    AND ms.EM_Spquly_Supplier_ID IS NOT NULL
    AND ms.em_ssfdc_status = 'CP'
) sub
WHERE sub.rn = 1
ORDER BY sub.Measuredate ASC, sub.bpname ASC
]]>
	</queryString>
