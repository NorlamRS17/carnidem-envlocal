<?xml version="1.0" encoding="UTF-8"?>
<jasperReport xmlns="http://jasperreports.sourceforge.net/jasperreports" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://jasperreports.sourceforge.net/jasperreports http://jasperreports.sourceforge.net/xsd/jasperreport.xsd" name="RptC_Warranty" pageWidth="1323" pageHeight="972" orientation="Landscape" columnWidth="1283" leftMargin="20" rightMargin="20" topMargin="20" bottomMargin="20" uuid="fc392d87-56be-42ec-8283-2b3a1073d061">
	<property name="net.sf.jasperreports.print.keep.full.text" value="true"/>
	<property name="net.sf.jasperreports.export.xls.remove.empty.space.between.columns" value="true"/>
	<property name="net.sf.jasperreports.export.xls.remove.empty.space.between.rows" value="true"/>
	<property name="net.sf.jasperreports.export.xls.wrap.text" value="false"/>
	<property name="net.sf.jasperreports.export.xls.detect.cell.type" value="true"/>
	<property name="net.sf.jasperreports.export.xls.white.page.background" value="false"/>
	<property name="ireport.zoom" value="0.6830134553650732"/>
	<property name="ireport.x" value="0"/>
	<property name="ireport.y" value="0"/>
	<parameter name="Document_ID" class="java.lang.String">
		<defaultValueExpression><![CDATA[]]></defaultValueExpression>
	</parameter>
	<parameter name="DateFrom" class="java.util.Date">
		<defaultValueExpression><![CDATA[]]></defaultValueExpression>
	</parameter>
	<parameter name="DateTo" class="java.util.Date">
		<defaultValueExpression><![CDATA[]]></defaultValueExpression>
	</parameter>
	<parameter name="Status" class="java.lang.String"/>
	<parameter name="DOCTYPE" class="java.lang.String">
		<defaultValueExpression><![CDATA["Reporte de Garantías"]]></defaultValueExpression>
	</parameter>
	<parameter name="c_bpartner_id" class="java.lang.String"/>
	<parameter name="NUMBERFORMAT" class="java.text.DecimalFormat" isForPrompting="false">
		<defaultValueExpression><![CDATA[new DecimalFormat("###,##0.00", new DecimalFormatSymbols())]]></defaultValueExpression>
	</parameter>
	<queryString>
		<![CDATA[select a.documentno, a.name, b.name as contratista, a.amount,c.name as plazo, d.name as administrador,
f.name as formagarantia, g.name as tipogarantia, e.policy_start_date AS iniciopoliza, e.validity_date_policy AS finpoliza,
e.amount_insured montoasegurado, ws.name AS estado

, o.ad_org_id AS organizationid, o.name AS organization, TO_CHAR(NOW(), 'DD/MM/YYYY HH24:MI:SS') AS fecha_actual
/* Inicio Firmas */
, L10.label AS L10_etiqueta, L10.name AS L10_nombre, L10.position AS L10_cargo
, L20.label AS L20_etiqueta, L20.name AS L20_nombre, L20.position AS L20_cargo
, L30.label AS L30_etiqueta, L30.name AS L30_nombre, L30.position AS L30_cargo
/* Fin Firmas */

from ssct_contract a
left join c_bpartner b on a.c_bpartner_id = b.c_bpartner_id
left join ssct_contractterm c on a.ssct_contractterm_id = c.ssct_contractterm_id
left join c_bpartner d on a.c_bpartner_administrator_id = d.c_bpartner_id
left join ssct_warranty e on a.ssct_contract_id = e.ssct_contract_id
left join ssct_warrantyform f on e.ssct_warrantyform_id = f.ssct_warrantyform_id
left join ssct_warrantytypes g on e.ssct_warrantytypes_id = g.ssct_warrantytypes_id
LEFT JOIN ssct_warrantystatus AS ws ON ws.ssct_warrantystatus_id=e.ssct_warrantystatus_id

LEFT JOIN ad_org AS o ON o.ad_org_id=a.ad_org_id
/* Inicio Firmas */
LEFT JOIN (SELECT UPPER(spd.label) AS label, UPPER(spd.name) AS name, UPPER(spd.position) AS position FROM c_doctype AS dt LEFT JOIN scsdc_signaturesperdoc AS spd ON (dt.c_doctype_id=spd.c_doctype_id AND spd.line = 10) WHERE spd.isactive='Y' AND dt.name ILIKE $P{DOCTYPE}) AS L10 ON TRUE
LEFT JOIN (SELECT UPPER(spd.label) AS label, UPPER(spd.name) AS name, UPPER(spd.position) AS position FROM c_doctype AS dt LEFT JOIN scsdc_signaturesperdoc AS spd ON (dt.c_doctype_id=spd.c_doctype_id AND spd.line = 20) WHERE spd.isactive='Y' AND dt.name ILIKE $P{DOCTYPE}) AS L20 ON TRUE
LEFT JOIN (SELECT UPPER(spd.label) AS label, UPPER(spd.name) AS name, UPPER(spd.position) AS position FROM c_doctype AS dt LEFT JOIN scsdc_signaturesperdoc AS spd ON (dt.c_doctype_id=spd.c_doctype_id AND spd.line = 30) WHERE  spd.isactive='Y' AND dt.name ILIKE $P{DOCTYPE}) AS L30 ON TRUE
/* Fin Firmas */

where (a.documentno = $P{Document_ID} or $P{Document_ID} is null)
AND (
	(e.policy_start_date BETWEEN $P{DateFrom} AND $P{DateTo})
	OR (e.validity_date_policy BETWEEN $P{DateFrom} AND $P{DateTo})
	OR ($P{DateFrom} BETWEEN e.policy_start_date AND e.validity_date_policy)
	OR ($P{DateTo} BETWEEN e.policy_start_date AND e.validity_date_policy)
)
and (e.ssct_warrantystatus_id = $P{Status} or $P{Status} is null)
AND (a.c_bpartner_id = $P{c_bpartner_id} OR $P{c_bpartner_id} IS NULL)
order by a.documentno]]>
	</queryString>
