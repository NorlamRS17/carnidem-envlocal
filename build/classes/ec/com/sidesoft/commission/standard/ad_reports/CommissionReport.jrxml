<?xml version="1.0" encoding="UTF-8"?>
<jasperReport xmlns="http://jasperreports.sourceforge.net/jasperreports" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://jasperreports.sourceforge.net/jasperreports http://jasperreports.sourceforge.net/xsd/jasperreport.xsd" name="CommissionReport" pageWidth="828" pageHeight="400" orientation="Landscape" whenNoDataType="NoDataSection" columnWidth="800" leftMargin="14" rightMargin="14" topMargin="14" bottomMargin="14" uuid="cfaf7223-c06e-4591-8e0f-b406a2336150">
	<property name="ireport.zoom" value="1.3636363636363675"/>
	<property name="ireport.x" value="0"/>
	<property name="ireport.y" value="0"/>
	<property name="net.sf.jasperreports.export.xls.detect.cell.type" value="true"/>
	<parameter name="NUMBERFORMAT" class="java.text.DecimalFormat" isForPrompting="false">
		<defaultValueExpression><![CDATA[new DecimalFormat("###,##0.00;-###,##0.00", new DecimalFormatSymbols())]]></defaultValueExpression>
	</parameter>
	<parameter name="AD_Org_ID" class="java.lang.String"/>
	<parameter name="C_BPartner_ID" class="java.lang.String"/>
	<parameter name="C_CommissionRun_ID" class="java.lang.String"/>
	<parameter name="IsNotPayed" class="java.lang.String"/>
	<parameter name="AD_User_ID" class="java.lang.String" isForPrompting="false">
		<defaultValueExpression><![CDATA["100"]]></defaultValueExpression>
	</parameter>
	<queryString>
		<![CDATA[SELECT
 org.ad_org_id organizationid
 , u.username AS username
 , TO_CHAR(NOW(),'YYYY-MM-DD hh:mi:ss am') currentdate
 , c.*
FROM (
  SELECT bp.name bp_name, cd.em_scomst_paid_date paid_date, cd.reference,
   i.documentno||' - '||TO_CHAR(i.dateinvoiced,'DD-MM-YYYY')||' - '||i.grandtotal||' - '||il.line||' - '||il.linenetamt invoiceline,
   cd.info, cd.actualamt, cd.em_scomst_commission_amount commission_amount, ba.name ba_name, cr.documentno,
   cd.em_scomst_dateinvoiced dateinvoiced, cd.em_scomst_duedate duedate
  FROM C_CommissionDetail cd
   JOIN c_invoiceline il ON il.c_invoiceline_id = cd.c_invoiceline_id
   JOIN c_invoice i ON i.c_invoice_id = il.c_invoice_id
   JOIN c_bpartner bp ON bp.c_bpartner_id = i.c_bpartner_id
   JOIN c_commissionamt ca ON ca.c_commissionamt_id = cd.c_commissionamt_id
   JOIN c_commissionrun cr ON cr.c_commissionrun_id = ca.c_commissionrun_id
   JOIN c_commission c ON c.c_commission_id = cr.c_commission_id
   JOIN c_bpartner ba ON ba.c_bpartner_id = c.c_bpartner_id
  WHERE COALESCE($P{IsNotPayed},'N') = 'N'
   AND (cd.ad_org_id = $P{AD_Org_ID} OR $P{AD_Org_ID} = '0')
   AND c.c_bpartner_id = $P{C_BPartner_ID}
   AND cr.c_commissionrun_id = $P{C_CommissionRun_ID}

  UNION

  SELECT bp.name bp_name, paid_date, uc.reference,
   i.documentno||' - '||TO_CHAR(i.dateinvoiced,'DD-MM-YYYY')||' - '||i.grandtotal||' - '||il.line||' - '||il.linenetamt invoiceline,
   uc.info, uc.actualamt, uc.commission_amount, ba.name ba_name, cr.documentno,
   uc.dateinvoiced, uc.duedate
  FROM scomst_unpaid_commission uc
   JOIN c_invoiceline il ON il.c_invoiceline_id = uc.c_invoiceline_id
   JOIN c_invoice i ON i.c_invoice_id = il.c_invoice_id
   JOIN c_bpartner bp ON bp.c_bpartner_id = i.c_bpartner_id
   JOIN c_commissionamt ca ON ca.c_commissionamt_id = uc.c_commissionamt_id
   JOIN c_commissionrun cr ON cr.c_commissionrun_id = ca.c_commissionrun_id
   JOIN c_commission c ON c.c_commission_id = cr.c_commission_id
   JOIN c_bpartner ba ON ba.c_bpartner_id = c.c_bpartner_id
  WHERE COALESCE($P{IsNotPayed},'N') = 'Y'
   AND (uc.ad_org_id = $P{AD_Org_ID} OR $P{AD_Org_ID} = '0')
   AND c.c_bpartner_id = $P{C_BPartner_ID}
   AND cr.c_commissionrun_id = $P{C_CommissionRun_ID}
 ) c
 JOIN ad_user u ON u.ad_user_id = $P{AD_User_ID}
 JOIN ad_org org ON org.ad_org_id = $P{AD_Org_ID}]]>
	</queryString>
	<field name="organizationid" class="java.lang.String"/>
	<field name="username" class="java.lang.String"/>
	<field name="currentdate" class="java.lang.String"/>
	<field name="bp_name" class="java.lang.String"/>
	<field name="paid_date" class="java.sql.Timestamp"/>
	<field name="reference" class="java.lang.String"/>
	<field name="invoiceline" class="java.lang.String"/>
	<field name="info" class="java.lang.String"/>
	<field name="actualamt" class="java.math.BigDecimal"/>
	<field name="commission_amount" class="java.math.BigDecimal"/>
	<field name="ba_name" class="java.lang.String"/>
	<field name="documentno" class="java.lang.String"/>
	<field name="dateinvoiced" class="java.sql.Timestamp"/>
	<field name="duedate" class="java.sql.Timestamp"/>
	<variable name="total1" class="java.math.BigDecimal" calculation="Sum">
		<variableExpression><![CDATA[$F{actualamt}]]></variableExpression>
		<initialValueExpression><![CDATA[]]></initialValueExpression>
	</variable>
	<variable name="total2" class="java.math.BigDecimal" calculation="Sum">
		<variableExpression><![CDATA[$F{commission_amount}]]></variableExpression>
		<initialValueExpression><![CDATA[]]></initialValueExpression>
	</variable>
