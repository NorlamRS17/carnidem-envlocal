<?xml version="1.0" encoding="UTF-8"?>
<jasperReport xmlns="http://jasperreports.sourceforge.net/jasperreports" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://jasperreports.sourceforge.net/jasperreports http://jasperreports.sourceforge.net/xsd/jasperreport.xsd" name="c_purchase_order_vs_purchase_invoice" pageWidth="1363" pageHeight="878" orientation="Landscape" columnWidth="1323" leftMargin="20" rightMargin="20" topMargin="20" bottomMargin="20" uuid="4d129183-9ca3-4e0c-8607-3aa735e236ef">
	<property name="ireport.zoom" value="1.331000000000002"/>
	<property name="ireport.x" value="0"/>
	<property name="ireport.y" value="1"/>
	<property name="ireport.scriptlethandling" value="0"/>
