<?xml version="1.0" encoding="UTF-8"?>
<jasperReport xmlns="http://jasperreports.sourceforge.net/jasperreports" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://jasperreports.sourceforge.net/jasperreports http://jasperreports.sourceforge.net/xsd/jasperreport.xsd" name="Rpt_VehicleDeliveryCertificate" pageWidth="595" pageHeight="842" columnWidth="555" leftMargin="20" rightMargin="20" topMargin="20" bottomMargin="20" uuid="25e714c0-3d3f-4b5f-b279-e4dad8fd407e">
	<property name="ireport.zoom" value="1.4641000000000053"/>
	<property name="ireport.x" value="0"/>
	<property name="ireport.y" value="336"/>
	<parameter name="BASE_DESIGN" class="java.lang.String" isForPrompting="false">
		<defaultValueExpression><![CDATA["/opt/ecuapack/modules/ec.com.sidesoft.workorder.simplified.report/src"]]></defaultValueExpression>
	</parameter>
	<parameter name="DOCUMENT_ID" class="java.lang.String"/>
	<parameter name="SOURCE_PATH" class="java.lang.String" isForPrompting="false">
		<defaultValueExpression><![CDATA[]]></defaultValueExpression>
	</parameter>
	<queryString>
		<![CDATA[Select ap.documentno as "n_orden_servicio"
	, cb.taxid as "cedula"
	, cb.name as "cliente"
	, c.address1 as "direccion"
	, ap.fecha as "fecha"
	, cl.phone as "telefono"
	-- Vehiculos
	, rlvv.name  as "tipo"
	, mp.name as "modelo"
	, ap.numeromotor as "numero_motor"
	, b.name as "marca"
	, y.name as "anio"
	, ap.numerochasis as "numero_chasis"
	, col.name as "color"
	, ap.placa as "placa"
	-- Datos del Conductor
	, ap.nombre as "con_nombre"
	, ap.apellido  as "con_apellido"
	, ap.cedula as "con_cedula"
	, ap.telefono as "con_telefono"
	, ap.celular as "con_celular"
	, mbp.name as "mecanico"
	, ap.orden_trabajo as "orden_trabajo"
	, ap.atindpo_postventa_id as ATINDPO_POSTVENTA_ID
	, ap.descripcioncliente as DESCRIPCION
    , ap.kmhoras
    -- Reprote
    , ap.EM_Satmac_Name as nombre_producto
	, mt.name  as maquina
	, ag.name as agente_com
	, cpp.name as proyecto
	, (SELECT i.TaxID FROM AD_Org o JOIN AD_OrgType t  USING (AD_ORGTYPE_ID) JOIN AD_Orginfo i
	   on i.ad_org_id = o.ad_org_id WHERE IsAcctLegalEntity = 'Y' ) as tax_org
    , (SELECT o.AD_ORG_ID FROM AD_ORG o JOIN AD_OrgType t USING (AD_ORGTYPE_ID) WHERE IsAcctLegalEntity = 'Y' ) as ad_org_id
	, (SELECT o.name FROM AD_ORG o JOIN AD_OrgType t USING (AD_ORGTYPE_ID) WHERE IsAcctLegalEntity = 'Y' ) as org_name
	,coalesce(ap.nombre,'') as nombre_cont
	,coalesce(ap.cedula,'') as cedula_cont
	,coalesce(ap.telefono,'') as tel_cont
	,coalesce(ap.celular,'') as cel_cont
	,coalesce(ap.direccion,'') as dir_cont
	,coalesce(ap.email,'') as email_cl
	,coalesce(cpm.name,'') as payment_term
From atindpo_postventa ap
	Join c_bpartner cb on ap.c_bpartner_id = cb.c_bpartner_id
	Join c_bpartner mbp on mbp.c_bpartner_id = ap.c_bpartner_emp_id
	Join c_bpartner_location cl on cl.c_bpartner_location_id = ap.c_bpartner_location_id
	Join c_location c on c.c_location_id=cl.c_location_id
	Left Join ssfi_model_prod mp on mp.ssfi_model_prod_id = ap.em_sswos_ssfi_model_prod_id
	Left Join m_brand b on b.m_brand_id = ap.em_sswos_m_brand_id
	Left Join sswos_color col on col.sswos_color_id = ap.em_sswos_color_id
	Left Join sswos_year y on y.sswos_year_id = ap.em_sswos_year_id
	Left Join ad_ref_list_v rlvv on rlvv.value = ap.lstipovehiculo and rlvv.ad_language = 'es_ES' and rlvv.ad_reference_id = 'B7D5195562CB492B86E6BB4DFEBD377E'
    LEFT JOIN satmac_machine_type mt on mt.satmac_machine_type_ID = ap.EM_Satmac_Machine_Type_ID
   	LEFT JOIN ad_user ag on ag.ad_user_id = ap.EM_Satmac_Salesrep_ID
  	LEFT JOIN c_project cpp on cpp.c_project_id = ap.EM_Satmac_Project_ID
	LEFT JOIN C_Paymentterm cpm on ap.C_Paymentterm_ID=cpm.C_Paymentterm_ID
Where ap.atindpo_postventa_id = $P{DOCUMENT_ID}]]>
	</queryString>
