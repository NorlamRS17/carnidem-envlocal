	<parameter name="DOCUMENT_ID" class="java.lang.String"/>
	<parameter name="BASE_WEB" class="java.lang.String"/>
	<parameter name="SOURCE_PATH" class="java.lang.String" isForPrompting="false">
		<defaultValueExpression><![CDATA[]]></defaultValueExpression>
	</parameter>
	<queryString>
		<![CDATA[SELECT
	atpv.atindpo_postventa_id
	, atpv.ad_client_id
	, o.name organizacion
	--datos del documento
	, atpv.documentno
	, atpv.docstatus
	, COALESCE(fp.name,'') formaPago
	, TO_CHAR(atpv.fecha,'dd/mm/yyyy') fecha
	, atpv.hora
	, COALESCE(atpv.lstiposervicio,'') lstiposervicio
	--datos  del vehículo
	, COALESCE(atpv.lstipovehiculo,'') lstipovehiculo
	, COALESCE(b.name,'') marca
	, COALESCE(mp.name,'')||'  '||COALESCE(sy.name,'') modeloAnio
	, COALESCE(atpv.numeromotor,'') numeromotor
	, COALESCE(atpv.numerochasis,'') numerochasis
	, COALESCE(atpv.placa,'') placa
	, COALESCE(sc.name,'') lscolor
	, atpv.kmhoras
	, atpv.fechaventa
	, ao.name local_venta
	--datos del cliente
	,COALESCE(cb.name,'') nombre_apellidoCliente
	, cbpl.name direccion_cliente
	, COALESCE(atpv.telefono,'') telefono_cliente
	, COALESCE(atpv.celular,'') celular
	, cl.city ciudad_cliente
	--RUC/CC:
	, COALESCE(cb.value,'') RUC
	, atpv.email email
	, COALESCE(descripcioncliente,'') descripcioncliente
	--datos mecánico responsable
	, COALESCE(cbe.name,'') nombre_apellidoMeca
	, COALESCE(atpv.observacion,'') observacion
	, COALESCE(atpv.orden_trabajo,'') ordentrabajo
FROM atindpo_postventa atpv
	JOIN ad_org o ON o.ad_org_id = atpv.ad_org_id
	LEFT JOIN fin_paymentmethod fp ON fp.fin_paymentmethod_id = atpv.fin_paymentmethod_id
	LEFT JOIN c_bpartner cb ON cb.c_bpartner_id = atpv.c_bpartner_id
	LEFT JOIN c_bpartner cbe ON cbe.c_bpartner_id = atpv.c_bpartner_emp_id
	LEFT JOIN m_brand b on b.m_brand_id = atpv.em_sswos_m_brand_id
	LEFT JOIN ssfi_model_prod mp on mp.ssfi_model_prod_id = atpv.em_sswos_ssfi_model_prod_id
	LEFT JOIN sswos_color sc on atpv.em_sswos_color_id = sc.sswos_color_id
	LEFT JOIN c_bpartner_location cbpl on cbpl.c_bpartner_location_id = atpv.c_bpartner_location_id
	LEFT JOIN c_location cl on cl.c_location_id = cbpl.c_location_id
	LEFT JOIN sswos_year sy on sy.sswos_year_id = atpv.em_sswos_year_id
	LEFT JOIN ad_org ao on ao.ad_org_id = atpv.ad_org_venta_id
WHERE atpv.atindpo_postventa_id = $P{DOCUMENT_ID}]]>
	</queryString>
