	<parameter name="BASE_DESIGN" class="java.lang.String" isForPrompting="false">
		<defaultValueExpression><![CDATA["C:/DesarrolloSS/OpenBravo/Indumot/OpenbravoERP/modules/com.atrums.indumot.formatoimpresion/src"]]></defaultValueExpression>
