	<parameter name="NUMBERFORMAT" class="java.text.DecimalFormat" isForPrompting="false">
		<defaultValueExpression><![CDATA[new DecimalFormat("###,##0.00;-###,##0.00", new DecimalFormatSymbols())]]></defaultValueExpression>
	</parameter>
	<parameter name="BASE_DESIGN" class="java.lang.String" isForPrompting="false">
		<defaultValueExpression><![CDATA[]]></defaultValueExpression>
	</parameter>
	<parameter name="AD_USER_ID" class="java.lang.String">
		<defaultValueExpression><![CDATA[]]></defaultValueExpression>
	</parameter>
	<parameter name="DOCUMENT_ID" class="java.lang.String"/>
	<queryString>
		<![CDATA[SELECT
  reporte.*,
  auditoria.*,
  firmas.*
FROM (
    SELECT
      o.ad_org_id,
      o.name AS organizacion,
      ag.name AS tipoBien,
      sc.name AS subTipoBien,
      a.value As codigo,
      a.description AS descripcion,
      a.em_ssam_add_description AS observaciones,

      CASE
        WHEN a.em_ssam_condition = 'GD' THEN 'Bueno'
        WHEN a.em_ssam_condition = 'BD' THEN 'Malo'
        WHEN a.em_ssam_condition = 'RG' THEN 'Regular'
      END AS estadoConservacion,
      a.em_ssam_model AS modelo,
      a.em_ssar_color AS color,
      a.em_ssam_serie As serie,
      a.em_ssam_brand AS marca,
      a.em_ssar_measurements AS medidas,
      a.em_ssar_other_attributes AS otrosAtributos,

      vc.HV_Datepurchased AS oFechaAdquisicion,
      hv.amortization_percentage AS oPorcentajeDepreciacion,
      vc.HV_Assetvalueamt AS oCostoBien,
      hv.amortizationamt AS oDepreciacionMensual,
      vc.HV_Depreciatedpreviousamt AS oDepreciacionAcumulada,
      vc.HV_Value_In_Books AS oValorLibros,
      vc.HV_Amortizationvalueamt AS oValorDepreciar,
      vc.HV_Residualassetvalueamt AS oValorResidual,
      vc.HV_Uselifemonths AS oVidaUtil,

      vc.NV_Changedate AS rFechaAdplicacion,
      nv.amortizationamt AS rDepreciacionMensual,
      vc.NV_Assetvalueamt AS rCostoBien,
      vc.HV_Value_In_Books AS rValorLibros,
      vc.HV_Depreciatedpreviousamt AS rDepreciacionAcumulada,
      vc.NV_Residualassetvalueamt AS rValorResidual,
      vc.NV_Amortizationvalueamt AS rValorDepreciar,
      vc.NV_Uselifemonths AS rVidaUtil,

      (
        SELECT SUM(aml.amortizationamt)
        FROM a_amortizationline AS aml
          JOIN a_asset AS a ON a.a_asset_id=aml.a_asset_id
          JOIN a_amortization AS am ON am.a_amortization_id=aml.a_amortization_id
        WHERE aml.a_asset_id=vc.a_asset_id
          AND am.startdate <= ((TO_CHAR(vc.NV_Amortizationstartdate, 'yyyy-mm')||'-01')::DATE - '1 MONTH'::INTERVAL)::DATE
      ) AS depreciadoReal,

      bp.name AS custodio,
      '' AS tipoCustodio
    FROM ssarv_value_change AS vc
      JOIN a_asset AS a ON a.a_asset_id=vc.a_asset_id
      LEFT JOIN a_asset_group AS ag ON ag.a_asset_group_id=a.a_asset_group_id
      LEFT JOIN ssasl_subcategory AS sc ON sc.ssasl_subcategory_id=a.em_ssasl_subcategory_id
      LEFT JOIN c_bpartner AS bp ON bp.c_bpartner_id=a.EM_Ssal_Custodio_ID
      LEFT JOIN ad_org AS o ON o.ad_org_id=a.ad_org_id
      LEFT JOIN (
        SELECT aml.a_asset_id, aml.amortization_percentage, aml.amortizationamt, am.startdate, am.enddate
        FROM a_amortizationline AS aml
         JOIN a_asset AS a ON a.a_asset_id=aml.a_asset_id
         JOIN a_amortization AS am ON am.a_amortization_id=aml.a_amortization_id
      ) AS hv ON (hv.a_asset_id=a.a_asset_id AND ((TO_CHAR(vc.NV_Changedate, 'yyyy-mm')||'-01')::DATE - '1 MONTH'::INTERVAL)::DATE = hv.startdate)
      LEFT JOIN (
        SELECT aml.a_asset_id, aml.amortization_percentage, aml.amortizationamt, am.startdate, am.enddate
        FROM a_amortizationline AS aml
         JOIN a_asset AS a ON a.a_asset_id=aml.a_asset_id
         JOIN a_amortization AS am ON am.a_amortization_id=aml.a_amortization_id
      ) AS nv ON (nv.a_asset_id=a.a_asset_id AND (vc.NV_Amortizationstartdate::DATE >= nv.startdate AND vc.NV_Amortizationstartdate::DATE <= nv.enddate))
    WHERE vc.ssarv_value_change_id=$P{DOCUMENT_ID}
  ) AS reporte
  LEFT JOIN (
    SELECT
      'USUARIO: ' || (
        SELECT
          COALESCE(bp.name, u.name)
        FROM ad_user AS u
          LEFT JOIN c_bpartner AS bp ON bp.c_bpartner_id=u.c_bpartner_id
        WHERE
          u.ad_user_id=$P{AD_USER_ID}
       ) AS usuario,
       'FECHA DE IMPRESIÓN: ' || to_char(now(),'DD/MM/YYYY HH24:MI:SS') AS fecha_impresion
  ) AS auditoria ON true
  LEFT JOIN (
    SELECT
      split_part(firmas.etiqueta, '/', 1) as "etiqueta_1",
      split_part(firmas.etiqueta, '/', 2) as "etiqueta_2",
      split_part(firmas.etiqueta, '/', 3) as "etiqueta_3",
      split_part(firmas.nombre, '/', 1) as "nombre_1",
      split_part(firmas.nombre, '/', 2) as "nombre_2",
      split_part(firmas.nombre, '/', 3) as "nombre_3",
      split_part(firmas.cargo, '/', 1) as "cargo_1",
      split_part(firmas.cargo, '/', 2) as "cargo_2",
      split_part(firmas.cargo, '/', 3) as "cargo_3"
    FROM (
      SELECT
        dt.c_doctype_id,
        STRING_AGG(COALESCE(spd.label,''), '/' ORDER BY spd.line ASC) as "etiqueta",
        STRING_AGG(COALESCE(spd.name,''), '/' ORDER BY spd.line ASC) as "nombre",
        STRING_AGG(COALESCE(spd.position,''), '/' ORDER BY spd.line ASC) as "cargo"
      FROM
        c_doctype AS dt
        JOIN scsdc_signaturesperdoc AS spd ON spd.c_doctype_id=dt.c_doctype_id
      WHERE
        dt.name='REVALORIZACIÓN DE BIENES' AND spd.isactive='Y'
      GROUP BY dt.c_doctype_id
    ) AS firmas
  ) AS firmas ON true]]>
	</queryString>
