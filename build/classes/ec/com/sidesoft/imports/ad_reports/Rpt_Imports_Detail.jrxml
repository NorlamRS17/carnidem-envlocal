<?xml version="1.0" encoding="UTF-8"?>
<jasperReport xmlns="http://jasperreports.sourceforge.net/jasperreports" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://jasperreports.sourceforge.net/jasperreports http://jasperreports.sourceforge.net/xsd/jasperreport.xsd" name="Rpt_Imports_Detail" pageWidth="1872" pageHeight="595" orientation="Landscape" columnWidth="1832" leftMargin="20" rightMargin="20" topMargin="20" bottomMargin="20" uuid="9972bd6e-734a-48ba-b0a7-1ff939d3d432">
	<property name="ireport.zoom" value="0.7513148009015881"/>
	<property name="ireport.x" value="0"/>
	<property name="ireport.y" value="0"/>
	<parameter name="AD_USER_ID" class="java.lang.String">
		<defaultValueExpression><![CDATA[]]></defaultValueExpression>
	</parameter>
	<parameter name="DateFrom" class="java.util.Date">
		<defaultValueExpression><![CDATA[]]></defaultValueExpression>
	</parameter>
	<parameter name="DateTo" class="java.util.Date">
		<defaultValueExpression><![CDATA[]]></defaultValueExpression>
	</parameter>
	<parameter name="C_Bpartner_ID" class="java.lang.String">
		<defaultValueExpression><![CDATA[]]></defaultValueExpression>
	</parameter>
	<queryString>
		<![CDATA[SELECT bp.name AS "tercero",
cc.name AS "importacion",
co.description,
CASE 	WHEN co.em_ssip_importstatus = 'NL' THEN 'No liquidado'
	WHEN co.em_ssip_importstatus = 'PL' THEN 'Preliquidado'
	WHEN co.em_ssip_importstatus = 'LL' THEN 'Liquidado'
	ELSE co.em_ssip_importstatus
END AS "liquidado",
co.dateordered,
mt.name AS "mediotransporte",
op.name AS "puertosalida",
ap.name AS "puertollegada",
id.numrefaduana,
id.numberdui,
id.paymentdatedui,
id.releasedatedui,
id.numberchecked,
id.tradingdata,
CASE
	WHEN id.insuranceapplies='Y' THEN 'SI'
	WHEN id.insuranceapplies='N' THEN 'NO'
	ELSE id.insuranceapplies
END AS "aplicaseguros",
id.datedispatch,
id.arrivaldate,
(SELECT COALESCE(cb.name,au.name) FROM ad_user au LEFT JOIN c_bpartner cb ON cb.c_bpartner_id = au.c_bpartner_id WHERE au.ad_user_id=$P{AD_USER_ID}) AS "usuario",
NOW() AS "fechaimpresion",
(SELECT o.ad_org_id FROM ad_org AS o JOIN ad_user AS u ON u.ad_client_id=o.ad_client_id WHERE o.ad_orgtype_id ='1' AND u.ad_user_id=$P{AD_USER_ID}) AS "AD_ORG_ID"
FROM c_order co
LEFT JOIN c_bpartner bp ON co.c_bpartner_id = bp.c_bpartner_id
LEFT JOIN c_campaign cc ON co.c_campaign_id = cc.c_campaign_id
LEFT JOIN ssip_importdata id ON co.c_order_id = id.c_order_id
LEFT JOIN ssip_meanstransport mt ON id.ssip_meanstransport_id = mt.ssip_meanstransport_id
LEFT JOIN ssip_porttype op ON id.outputport = op.ssip_porttype_id
LEFT JOIN ssip_porttype ap ON id.portarrival = ap.ssip_porttype_id
WHERE co.em_ssip_isimports ='Y'
AND ( TO_CHAR($P{DateFrom}) IS NULL OR TO_DATE(co.dateordered,'dd-MM-yyyy') >= TO_DATE(TO_CHAR($P{DateFrom}),'yyyy-MM-dd'))
AND ( TO_CHAR($P{DateTo}) IS NULL OR TO_DATE(co.dateordered,'dd-MM-yyyy') <= TO_DATE(TO_CHAR($P{DateTo}),'yyyy-MM-dd'))
AND (co.c_bpartner_id = $P{C_Bpartner_ID} OR $P{C_Bpartner_ID}IS NULL)
ORDER BY co.dateordered]]>
	</queryString>
