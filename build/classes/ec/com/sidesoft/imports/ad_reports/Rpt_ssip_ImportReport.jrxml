<?xml version="1.0" encoding="UTF-8"?>
<jasperReport xmlns="http://jasperreports.sourceforge.net/jasperreports" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://jasperreports.sourceforge.net/jasperreports http://jasperreports.sourceforge.net/xsd/jasperreport.xsd" name="ImportReport" pageWidth="1008" pageHeight="1067" columnWidth="968" leftMargin="20" rightMargin="20" topMargin="20" bottomMargin="20" uuid="6183df7f-fa65-480f-931f-d6e00570c7a2">
	<property name="ireport.zoom" value="1.2100000000000226"/>
	<property name="ireport.x" value="0"/>
	<property name="ireport.y" value="0"/>
	<parameter name="BASE_DESIGN" class="java.lang.String" isForPrompting="false">
		<defaultValueExpression><![CDATA["/opt/openbravo/ecuapack/modules/ec.com.sidesoft.imports/src"]]></defaultValueExpression>
	</parameter>
	<parameter name="ad_user" class="java.lang.String">
		<defaultValueExpression><![CDATA[]]></defaultValueExpression>
	</parameter>
	<parameter name="documentno" class="java.lang.String"/>
	<queryString>
		<![CDATA[SELECT
ORG.ad_org_id as "organizationid",
ORG.name AS "organization",
cca.value as "importacion",
(select AD_USER.NAME from AD_USER where AD_USER_ID = $P{ad_user}) AS "usuario",
to_char(current_timestamp, 'dd/mm/yyyy HH12:MI:SS') AS "fechaimpresion",
dt.EM_Ssimpcn_Consolidated_Imp consolidated
FROM c_order INV
JOIN c_doctype dt ON dt.c_doctype_id = INV.c_doctypetarget_id
JOIN ad_org ORG ON ORG.ad_org_id = INV.ad_org_id
LEFT JOIN c_campaign cca ON cca.c_campaign_id = INV.c_campaign_id
WHERE INV.em_ssip_isimports = 'Y'
AND INV.documentno = $P{documentno}]]>
	</queryString>
	<field name="organizationid" class="java.lang.String"/>
	<field name="organization" class="java.lang.String"/>
	<field name="importacion" class="java.lang.String"/>
	<field name="usuario" class="java.lang.String"/>
	<field name="fechaimpresion" class="java.lang.String"/>
	<field name="consolidated" class="java.lang.String"/>
	<background>
		<band splitType="Stretch"/>
	</background>
	<title>
		<band height="118" splitType="Stretch">
			<textField pattern="dd/MM/yyyy / HH:mm:ss">
				<reportElement x="716" y="1" width="252" height="20" uuid="c703204c-62a0-44d4-86b0-611b74292386"/>
				<box rightPadding="3"/>
				<textElement textAlignment="Left" verticalAlignment="Middle">
					<font isItalic="true"/>
				</textElement>
				<textFieldExpression><![CDATA["Fecha de Impresión: "+$F{fechaimpresion}]]></textFieldExpression>
			</textField>
			<textField>
				<reportElement x="716" y="21" width="252" height="20" uuid="ef72b9b4-841c-4512-be59-5b0dd8af3c18"/>
				<textElement verticalAlignment="Middle">
					<font isItalic="true"/>
				</textElement>
				<textFieldExpression><![CDATA["Usuario: "+$F{usuario}]]></textFieldExpression>
			</textField>
			<image>
				<reportElement x="0" y="0" width="151" height="61" uuid="581893fd-a9a5-4526-bdc4-f75233a9579e"/>
				<imageExpression><![CDATA[org.openbravo.erpCommon.utility.Utility.showImageLogo("yourcompanylegal", $F{organizationid})]]></imageExpression>
			</image>
			<line>
				<reportElement x="-4" y="-60" width="780" height="1" uuid="27fcefe0-71b1-4012-9c91-f26cd6ac37a5"/>
				<graphicElement>
					<pen lineStyle="Double"/>
				</graphicElement>
			</line>
			<staticText>
				<reportElement x="0" y="95" width="968" height="23" uuid="99467c50-4eae-4459-a18e-98387fc31627"/>
				<box leftPadding="3"/>
				<textElement textAlignment="Center" verticalAlignment="Middle">
					<font isBold="true"/>
				</textElement>
				<text><![CDATA[REPORTE DE IMPORTACION]]></text>
			</staticText>
			<textField>
				<reportElement x="716" y="42" width="252" height="20" uuid="1a0270d3-d41e-42c9-949a-a82ce47bf985"/>
				<textElement verticalAlignment="Middle">
					<font isItalic="true"/>
				</textElement>
				<textFieldExpression><![CDATA["No Documento: "+$P{documentno}]]></textFieldExpression>
			</textField>
			<textField>
				<reportElement x="716" y="63" width="252" height="20" uuid="bf1e6958-6e64-49d5-85a1-84b1dc181478"/>
				<textElement verticalAlignment="Middle">
					<font isItalic="true"/>
				</textElement>
				<textFieldExpression><![CDATA["Importacion: "+$F{importacion}]]></textFieldExpression>
			</textField>
		</band>
	</title>
	<pageHeader>
		<band splitType="Stretch"/>
	</pageHeader>
	<detail>
		<band height="39" splitType="Stretch">
			<subreport>
				<reportElement x="0" y="0" width="967" height="39" uuid="33a4f1a9-8aab-4291-a01b-404cc64e572b">
					<printWhenExpression><![CDATA[$F{consolidated}.equals("N")]]></printWhenExpression>
				</reportElement>
				<subreportParameter name="documentno">
					<subreportParameterExpression><![CDATA[$P{documentno}]]></subreportParameterExpression>
				</subreportParameter>
				<subreportParameter name="ad_user">
					<subreportParameterExpression><![CDATA[$P{ad_user}]]></subreportParameterExpression>
				</subreportParameter>
				<connectionExpression><![CDATA[$P{REPORT_CONNECTION}]]></connectionExpression>
				<subreportExpression><![CDATA[$P{BASE_DESIGN} + "/ec/com/sidesoft/imports/ad_reports/ImportReportDetails.jasper"]]></subreportExpression>
			</subreport>
			<subreport>
				<reportElement x="1" y="0" width="967" height="39" uuid="daf591bc-f95e-48db-8883-31b1f778ad52">
					<printWhenExpression><![CDATA[$F{consolidated}.equals("Y")]]></printWhenExpression>
				</reportElement>
				<subreportParameter name="documentno">
					<subreportParameterExpression><![CDATA[$P{documentno}]]></subreportParameterExpression>
				</subreportParameter>
				<subreportParameter name="ad_user">
					<subreportParameterExpression><![CDATA[$P{ad_user}]]></subreportParameterExpression>
				</subreportParameter>
				<connectionExpression><![CDATA[$P{REPORT_CONNECTION}]]></connectionExpression>
				<subreportExpression><![CDATA[$P{BASE_DESIGN} + "/ec/com/sidesoft/imports/ad_reports/ImportReportConsolidatedDetails.jasper"]]></subreportExpression>
			</subreport>
		</band>
	</detail>
	<columnFooter>
		<band splitType="Stretch"/>
	</columnFooter>
	<pageFooter>
		<band splitType="Stretch"/>
	</pageFooter>
</jasperReport>
