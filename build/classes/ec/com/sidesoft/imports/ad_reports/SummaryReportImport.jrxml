<?xml version="1.0" encoding="UTF-8"?>
<jasperReport xmlns="http://jasperreports.sourceforge.net/jasperreports" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://jasperreports.sourceforge.net/jasperreports http://jasperreports.sourceforge.net/xsd/jasperreport.xsd" name="SummaryReportImport" pageWidth="612" pageHeight="792" columnWidth="555" leftMargin="20" rightMargin="20" topMargin="20" bottomMargin="20">
	<property name="ireport.zoom" value="1.0"/>
	<property name="ireport.x" value="0"/>
	<property name="ireport.y" value="0"/>
	<parameter name="STARTDATE" class="java.util.Date"/>
	<parameter name="ENDDATE" class="java.util.Date"/>
	<queryString>
		<![CDATA[select ord.dateordered, cbp.name as proveedor, cmp.name as import, ordl.orderfob, imp.arancel

from c_order ord

left join c_bpartner cbp on  ord.c_bpartner_id  = cbp.c_bpartner_id

left join c_campaign cmp on cmp.c_campaign_id=ord.c_campaign_id

left join (select c_order_id,sum(priceactual*qtyordered) as orderfob from c_orderline  group by c_order_id) ordl on ordl.c_order_id=ord.c_order_id

left join (select c_order_id,sum(amountnet) as arancel from ssip_costimport  group by c_order_id) imp on imp.c_order_id=ord.c_order_id

where ord.em_ssip_isimports='Y'

and ord.dateordered>=$P{STARTDATE}

and ord.dateordered<=$P{ENDDATE}]]>
	</queryString>
	<field name="dateordered" class="java.sql.Timestamp"/>
	<field name="proveedor" class="java.lang.String"/>
	<field name="import" class="java.lang.String"/>
	<field name="orderfob" class="java.math.BigDecimal"/>
	<field name="arancel" class="java.math.BigDecimal"/>
	<variable name="CIF" class="java.math.BigDecimal" calculation="Sum">
		<variableExpression><![CDATA[$F{orderfob}.add( $F{arancel} )]]></variableExpression>
	</variable>
	<variable name="FOB" class="java.math.BigDecimal" calculation="Sum">
		<variableExpression><![CDATA[$F{orderfob}]]></variableExpression>
	</variable>
	<variable name="ARANC" class="java.math.BigDecimal" calculation="Sum">
		<variableExpression><![CDATA[$F{arancel}]]></variableExpression>
	</variable>
	<background>
		<band splitType="Stretch"/>
	</background>
	<title>
