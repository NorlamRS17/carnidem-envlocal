<?xml version="1.0" encoding="UTF-8"?>
<jasperReport xmlns="http://jasperreports.sourceforge.net/jasperreports" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://jasperreports.sourceforge.net/jasperreports http://jasperreports.sourceforge.net/xsd/jasperreport.xsd" name="ImportReport" pageWidth="968" pageHeight="1067" columnWidth="968" leftMargin="0" rightMargin="0" topMargin="0" bottomMargin="0" uuid="1da5dde7-aca0-4fe0-83fc-d21862e7a8f3">
	<property name="ireport.zoom" value="1.2100000000000228"/>
	<property name="ireport.x" value="0"/>
	<property name="ireport.y" value="0"/>
	<parameter name="ad_user" class="java.lang.String">
		<defaultValueExpression><![CDATA[]]></defaultValueExpression>
	</parameter>
	<parameter name="documentno" class="java.lang.String"/>
	<queryString>
		<![CDATA[(
SELECT
    ci.transactiondate fecha,
    bp.name proovedor,
    ci.documenttype tipodocumento,
    TRIM(REGEXP_REPLACE(TRIM(ci.documentnumber),TRIM(o.documentno),'','g')) facturacompra,
    CASE WHEN ac.name IS NULL THEN '' ELSE ac.name END costoadicional,
    ci.amountnet valor,
    COALESCE(pr.name,jl.description) concepto,
    ci.poreference nofactura
FROM c_order o
    JOIN c_bpartner bp ON bp.c_bpartner_id = o.c_bpartner_id
	JOIN SSIP_Costimport ci ON ci.c_order_id = o.c_order_id
    LEFT JOIN ssip_additionalcosts ac ON ac.ssip_additionalcosts_id = ci.ssip_additionalcosts_id
	JOIN ssimpcn_imp_consol_line icl ON icl.c_campaign_id = o.c_campaign_id
    JOIN ssimpcn_imp_consol_detail icd ON icd.ssimpcn_imp_consol_line_id = icl.ssimpcn_imp_consol_line_id
        AND ROUND(icd.amountnet,2) = ROUND(ci.amountnet,2)
	LEFT JOIN c_invoice i ON TRIM(i.documentno)=SPLIT_PART(ci.documentnumber, ' ', 1)
	LEFT JOIN c_invoiceline il ON il.c_invoice_id = i.c_invoice_id
		AND il.em_ssimpcn_imp_consol_id = icl.ssimpcn_imp_consolidation_id
		AND il.em_ssimpcn_type = 'C'
        AND il.EM_Ssimacc_Dataimport = 'N'
        AND il.c_invoiceline_id = icd.c_invoiceline_id
	LEFT JOIN m_product pr ON pr.m_product_id = il.m_product_id
	LEFT JOIN gl_journalbatch jb ON TRIM(jb.documentno)= SPLIT_PART(ci.documentnumber, ' ', 1)
	LEFT JOIN gl_journal j ON  j.gl_journalbatch_id = jb.gl_journalbatch_id
	LEFT JOIN GL_JournalLine jl ON jl.gl_journal_id = j.gl_journal_id
		AND jl.em_ssimpcn_imp_consol_id = icl.ssimpcn_imp_consolidation_id
		AND jl.em_ssimpcn_type = 'C'
        AND jl.gl_journalline_id = icd.gl_journalline_id
WHERE o.issotrx = 'N' AND COALESCE(il.LineNetAmt, jl.AmtSourceDr) <> 0
    AND o.documentno = $P{documentno}

ORDER BY fecha
)]]>
	</queryString>
	<field name="fecha" class="java.sql.Timestamp"/>
	<field name="proovedor" class="java.lang.String"/>
	<field name="tipodocumento" class="java.lang.String"/>
	<field name="facturacompra" class="java.lang.String"/>
	<field name="costoadicional" class="java.lang.String"/>
	<field name="valor" class="java.math.BigDecimal"/>
	<field name="concepto" class="java.lang.String"/>
	<field name="nofactura" class="java.lang.String"/>
	<variable name="SUM_TOTAL" class="java.math.BigDecimal" calculation="Sum">
		<variableExpression><![CDATA[$F{valor}]]></variableExpression>
	</variable>
