<?xml version="1.0" encoding="UTF-8"?>
<jasperReport xmlns="http://jasperreports.sourceforge.net/jasperreports" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://jasperreports.sourceforge.net/jasperreports http://jasperreports.sourceforge.net/xsd/jasperreport.xsd" name="ImportSpesific_subreport" pageWidth="555" pageHeight="802" columnWidth="555" leftMargin="0" rightMargin="0" topMargin="0" bottomMargin="0">
	<property name="ireport.zoom" value="1.2100000000000002"/>
	<property name="ireport.x" value="0"/>
	<property name="ireport.y" value="0"/>
	<parameter name="DOCUMENT_ID" class="java.lang.String"/>
	<queryString>
		<![CDATA[SELECT cip.c_order_id,cip.documentnumber,cip.documenttype,cip.amountnet, sc.name,sc.additionalcosts

from ssip_costimport cip

left join ssip_additionalcosts sc on cip.ssip_additionalcosts_id=sc.ssip_additionalcosts_id

where cip.c_order_id=$P{DOCUMENT_ID}]]>
	</queryString>
	<field name="c_order_id" class="java.lang.String"/>
	<field name="documentnumber" class="java.lang.String"/>
	<field name="documenttype" class="java.lang.String"/>
	<field name="amountnet" class="java.math.BigDecimal"/>
	<field name="name" class="java.lang.String"/>
	<field name="additionalcosts" class="java.lang.String"/>
	<variable name="TSUM" class="java.math.BigDecimal" calculation="Sum">
		<variableExpression><![CDATA[$F{amountnet}]]></variableExpression>
	</variable>
	<group name="c_order_id">
		<groupExpression><![CDATA[$F{c_order_id}]]></groupExpression>
	</group>
