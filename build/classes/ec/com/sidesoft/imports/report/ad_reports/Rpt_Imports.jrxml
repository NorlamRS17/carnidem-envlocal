<?xml version="1.0" encoding="UTF-8"?>
<jasperReport xmlns="http://jasperreports.sourceforge.net/jasperreports" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://jasperreports.sourceforge.net/jasperreports http://jasperreports.sourceforge.net/xsd/jasperreport.xsd" name="Rpt_Imports" pageWidth="802" pageHeight="595" orientation="Landscape" columnWidth="802" leftMargin="0" rightMargin="0" topMargin="0" bottomMargin="0" uuid="dafba891-7695-403b-a776-ff0f26172d23">
	<property name="ireport.zoom" value="1.210000000000002"/>
	<property name="ireport.x" value="504"/>
	<property name="ireport.y" value="0"/>
	<parameter name="DATE_TO" class="java.util.Date"/>
	<parameter name="C_ORDER_ID" class="java.lang.String"/>
	<parameter name="REPORT_TYPE" class="java.lang.String" isForPrompting="false"/>
	<parameter name="AD_USER_ID" class="java.lang.String" isForPrompting="false">
		<parameterDescription><![CDATA["100"]]></parameterDescription>
	</parameter>
	<queryString>
		<![CDATA[select
co.documentno as documento
, to_char(co.dateordered,'dd/MM/yyyy') as fecha_orden
, cbp.name as tercero
,cc.value as importacion
,coalesce(sum(col.Taxbaseamt),0) as costo_origen
,coalesce((repp.linenetamt),0) as costo_importacion
,coalesce(sum(col.EM_Ssipice_Value_Ice),0) as ice
, coalesce(sum(col.Taxbaseamt),0) + coalesce((repp.linenetamt),0) + coalesce(sum(col.EM_Ssipice_Value_Ice),0) as importe_total
from c_order co
join c_orderline col on col.c_order_id = co.c_order_id
join c_bpartner cbp on cbp.c_bpartner_id = co.c_bpartner_id
LEFT join (
select sum(amountnet) as amountnet,  c_order_id
from SSIP_Costimport
group by c_order_id
) sci on sci.c_order_id = co.c_order_id
join C_Campaign cc on cc.C_Campaign_ID = co.C_Campaign_ID
left join (

	select
	value
	,C_Campaign_id
	,sum(linenetamt) as linenetamt
	from
	(
		select
		cc.value
		,cc.C_Campaign_id
		,sum(cil.linenetamt * ( case when cd.docbasetype = 'APC' and cd.isreversal = 'Y' then -1 else 1 end)) as linenetamt
		from  C_Campaign cc
		join c_invoiceline cil on cc.C_Campaign_id = cil.em_ssip_campaign_id
		join c_invoice ci on ci.c_invoice_id = cil.c_invoice_id
		join c_doctype cd on cd.c_doctype_id = ci.c_doctype_id
		where cil.em_ssip_importtype ='Y'
		group by cc.value
		,cc.C_Campaign_id
		union all
		select
		cc.value
		,cc.C_Campaign_id
		,gjl.AmtSourceDr as linenetamt
		from C_Campaign cc
		left join GL_JournalLine gjl on cc.C_Campaign_id = gjl.C_Campaign_id
		where
		gjl.EM_Ssip_Importcosts ='Y'
	) compaing
	group by value
	,C_Campaign_id

) repp on repp.C_Campaign_ID = co.C_Campaign_ID
where EM_Ssip_Importstatus ='NL'

and co.issotrx ='N'
and cc.isactive='Y'
AND (cc.C_Campaign_ID = $P{C_ORDER_ID} OR COALESCE(TO_CHAR($P{C_ORDER_ID}),'')='' )
AND  (CO.DATEORDERED < $P{DATE_TO} or COALESCE(TO_CHAR($P{DATE_TO}),'')='' )
group by co.documentno
, to_char(co.dateordered,'dd/MM/yyyy')
, cbp.name
,cc.value
,repp.linenetamt
order by 1 asc]]>
	</queryString>
	<field name="documento" class="java.lang.String"/>
	<field name="fecha_orden" class="java.lang.String"/>
	<field name="tercero" class="java.lang.String"/>
	<field name="importacion" class="java.lang.String"/>
	<field name="costo_origen" class="java.math.BigDecimal"/>
	<field name="costo_importacion" class="java.math.BigDecimal"/>
	<field name="ice" class="java.math.BigDecimal"/>
	<field name="importe_total" class="java.math.BigDecimal"/>
	<variable name="v_CostoOrigen" class="java.math.BigDecimal" calculation="Sum">
		<variableExpression><![CDATA[$F{costo_origen}]]></variableExpression>
	</variable>
	<variable name="v_CostoImportaciones" class="java.math.BigDecimal" calculation="Sum">
		<variableExpression><![CDATA[$F{costo_importacion}]]></variableExpression>
	</variable>
	<variable name="v_ICE" class="java.math.BigDecimal" calculation="Sum">
		<variableExpression><![CDATA[$F{ice}]]></variableExpression>
	</variable>
	<variable name="v_ImporteTotal" class="java.math.BigDecimal" calculation="Sum">
		<variableExpression><![CDATA[$F{importe_total}]]></variableExpression>
	</variable>
