<?xml version="1.0" encoding="UTF-8"?>
<jasperReport xmlns="http://jasperreports.sourceforge.net/jasperreports" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://jasperreports.sourceforge.net/jasperreports http://jasperreports.sourceforge.net/xsd/jasperreport.xsd" name="Rpt_SubImportCost" pageWidth="505" pageHeight="842" whenNoDataType="BlankPage" columnWidth="505" leftMargin="0" rightMargin="0" topMargin="0" bottomMargin="0" isFloatColumnFooter="true" uuid="cfaf7223-c06e-4591-8e0f-b406a2336150">
	<property name="ireport.zoom" value="1.5"/>
	<property name="ireport.x" value="0"/>
	<property name="ireport.y" value="0"/>
	<property name="net.sf.jasperreports.export.xls.detect.cell.type" value="true"/>
	<property name="net.sf.jasperreports.export.xls.sheet.names.all" value="Reporte de Stock Nacional"/>
	<parameter name="NUMBERFORMAT" class="java.text.DecimalFormat" isForPrompting="false">
		<defaultValueExpression><![CDATA[new DecimalFormat("###,##0.00;-###,##0.00", new DecimalFormatSymbols())]]></defaultValueExpression>
	</parameter>
	<parameter name="ad_org_id" class="java.lang.String" isForPrompting="false"/>
	<parameter name="AD_USER_ID" class="java.lang.String" isForPrompting="false"/>
	<parameter name="costimport_id" class="java.lang.String">
		<defaultValueExpression><![CDATA[]]></defaultValueExpression>
	</parameter>
	<queryString>
		<![CDATA[select
coalesce(p.name,e.value||'-'||upper(e.name)) as detalle,
bp.name as tercero,
coalesce(i.POReference,j.documentno) as documento,
case when im.amountnet<0 then  (CASE WHEN jl.C_Campaign_id = c.C_Campaign_id THEN jl.AmtSourceDr
		   ELSE li.LineNetAmt 
		   END) *-1
else  (CASE WHEN jl.C_Campaign_id = c.C_Campaign_id THEN jl.AmtSourceDr
		   ELSE li.LineNetAmt 
		   END)
		    end as valor,
2 as orden

from c_order o
--inner join c_orderline ol on ol.c_order_id=o.c_order_id
left join C_Campaign c on c.C_Campaign_ID=o.C_Campaign_ID
left join SSIP_Costimport im on im.c_order_id=o.c_order_id
left join c_invoice i on trim(i.documentno)=SPLIT_PART(im.documentnumber, ' ', 1)
left join c_invoiceline li on i.c_invoice_id=li.c_invoice_id
left join m_product p on p.m_product_id=li.m_product_id
left join c_bpartner bp on bp.c_bpartner_id=i.c_bpartner_id
left join GL_JournalBatch jb on trim(jb.documentno)= SPLIT_PART(im.documentnumber, ' ', 1)
left join GL_Journal j on jb.GL_JournalBatch_id=j.GL_JournalBatch_id
left join GL_JournalLine jl on jl.GL_Journal_id=j.GL_Journal_id
left join C_ValidCombination vg on vg.C_ValidCombination_ID=jl.C_ValidCombination_ID
left join c_elementvalue e on e.c_elementvalue_id=vg.Account_ID

where o.issotrx='N'
AND o.c_order_id=(select c_order_id from SSIP_Costimport where SSIP_Costimport_id=$P{costimport_id})
AND (jl.c_campaign_id)=o.C_Campaign_ID
AND coalesce(li.LineNetAmt,jl.AmtSourceDr)<>0

UNION
select coalesce(p.name) as detalle,
bp.name as tercero,
coalesce(i.POReference,i.documentno) as documento,
CASE WHEN d.isreversal='Y' then coalesce(li.LineNetAmt,0)*-1
ELSE coalesce(li.LineNetAmt,0) END
as valor,
1 as orden
from c_invoiceline li
left join c_invoice i on i.c_invoice_id=li.c_invoice_id
left join c_doctype d on d.c_doctype_id=i.c_doctype_id
inner join m_product p on p.m_product_id=li.m_product_id
left join c_bpartner bp on bp.c_bpartner_id=i.c_bpartner_id
left join C_Campaign c on c.c_campaign_id=li.EM_Ssip_Campaign_ID
where c.C_Campaign_id=(select C_Campaign_id from c_order where c_order_id=(select c_order_id from SSIP_Costimport where SSIP_Costimport_id=$P{costimport_id}))
order by orden,documento,detalle]]>
	</queryString>
