<?xml version="1.0" encoding="UTF-8"?>
<jasperReport xmlns="http://jasperreports.sourceforge.net/jasperreports" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://jasperreports.sourceforge.net/jasperreports http://jasperreports.sourceforge.net/xsd/jasperreport.xsd" name="Rpt_conciliation_monthly" pageWidth="1116" pageHeight="595" orientation="Landscape" columnWidth="1076" leftMargin="20" rightMargin="20" topMargin="20" bottomMargin="20" uuid="e25a2cf3-48fe-4801-b0bc-f2ff001a494f">
	<property name="ireport.zoom" value="2.0"/>
	<property name="ireport.x" value="216"/>
	<property name="ireport.y" value="192"/>
	<property name="net.sf.jasperreports.export.xls.detect.cell.type" value="true"/>
	<parameter name="Fin_Financial_Account_ID" class="java.lang.String">
		<defaultValueExpression><![CDATA[]]></defaultValueExpression>
	</parameter>
	<parameter name="Bank_Balance" class="java.lang.String">
		<defaultValueExpression><![CDATA[]]></defaultValueExpression>
	</parameter>
	<parameter name="Initial_Balance" class="java.lang.String">
		<defaultValueExpression><![CDATA[]]></defaultValueExpression>
	</parameter>
	<parameter name="startdate" class="java.lang.String"/>
	<parameter name="enddate" class="java.lang.String"/>
	<queryString>
		<![CDATA[select
account.*, rep.*,
case when $P{Initial_Balance} is not null then to_number( $P{Initial_Balance} )
	when $P{Initial_Balance} is null and (select count(startingbalance) from (
	select startingbalance
     from fin_reconciliation frc
     where trunc(dateto) BETWEEN trunc(to_date($P{startdate})) AND trunc(to_date(to_date($P{enddate})))
     and frc.Docstatus = 'CO'
     and fin_financial_account_id = $P{Fin_Financial_Account_ID}
	 limit 1)
	as cont) = 1 then
	(select startingbalance
     from fin_reconciliation frc
     where trunc(dateto) BETWEEN trunc(to_date($P{startdate}))AND trunc(to_date($P{enddate}))
     and frc.Docstatus = 'CO'
     and fin_financial_account_id = $P{Fin_Financial_Account_ID}
	 limit 1
	)
else
coalesce(
(select InitialBalance from fin_financial_account
 where fin_financial_account_id = $P{Fin_Financial_Account_ID})
,0) end as saldo_inicial,

case when split_part(signatures.etiquetas, ',-,', 1) != '' then
split_part(signatures.etiquetas, ',-,', 1)
else
'N'
end as "label_firma_1",

case when split_part( signatures.etiquetas, ',-,', 2) != '' then
split_part(signatures.etiquetas, ',-,', 2)
else
'N'
end as "label_firma_2",

case when split_part( signatures.etiquetas, ',-,', 3) != '' then
split_part(signatures.etiquetas, ',-,', 3)
else
'N'
end as "label_firma_3",

case when split_part(signatures.nombres, ',-,', 1) != '' then
split_part(signatures.nombres, ',-,', 1)
else
'N'
end as "nombre_firma_1",

case when split_part(signatures.nombres, ',-,', 2) != '' then
split_part(signatures.nombres, ',-,', 2)
else
'N'
end as "nombre_firma_2",

case when split_part(signatures.nombres, ',-,', 3) != '' then
split_part(signatures.nombres, ',-,', 3)
else
'N'
end as "nombre_firma_3",

case when split_part(signatures.cargos, ',-,', 1) != '' then
split_part(signatures.cargos, ',-,', 1)
else
'N'
end as "nombre_cargos_1",

case when split_part(signatures.cargos, ',-,', 2) != '' then
split_part(signatures.cargos, ',-,', 2)
else
'N'
end as "nombre_cargos_2",

case when split_part(signatures.cargos, ',-,', 3) != '' then
split_part(signatures.cargos, ',-,', 3)
else
'N'
end as "nombre_cargos_3"
from
(select ft.Fin_Financial_Account_ID,ft.dateacct,
ft.Statementdate as DIA, ft.EM_Sscccin_Reference as DCTO_Y_NRO, fp.documentNo as CTE_ING_EGR,
fp.description as CONCEPTO, cb.name as BENEFICIARIO,
CASE
    WHEN ft.Trxtype = 'BPD' AND ft.Status = 'RPPC' THEN ft.Depositamt
    ELSE 0
END AS INGRESOS,
CASE
    WHEN ft.Trxtype = 'BPW' AND ft.Status = 'RPPC' THEN ft.Paymentamt
    ELSE 0
END AS EGREROS,
CASE
    WHEN ft.Trxtype = 'BPD' AND ft.Status = 'RDNC' THEN ft.Depositamt
    ELSE 0
END AS DEP_NO_CONCILIADO,
CASE
    WHEN ft.Trxtype = 'BPW' AND ft.Status = 'PWNC' THEN ft.Paymentamt
    ELSE 0
END AS CHQ_NO_CONCILIADO,
ft.Status as ESTADO,
to_number($P{Bank_Balance}) as saldo,
trunc(to_date($P{startdate}))as startdate,
trunc(to_date($P{enddate}))as enddate,
 ( SELECT (CASE
              WHEN to_char(trunc(to_date($P{startdate})), 'mm') = '01' THEN 'ENERO'
              WHEN to_char(trunc(to_date($P{startdate})), 'mm') = '02' THEN 'FEBRERO'
              WHEN to_char(trunc(to_date($P{startdate})), 'mm') = '03' THEN 'MARZO'
              WHEN to_char(trunc(to_date($P{startdate})), 'mm') = '04' THEN 'ABRIL'
              WHEN to_char(trunc(to_date($P{startdate})), 'mm') = '05' THEN 'MAYO'
              WHEN to_char(trunc(to_date($P{startdate})), 'mm') = '06' THEN 'JUNIO'
              WHEN to_char(trunc(to_date($P{startdate})), 'mm') = '07' THEN 'JULIO'
              WHEN to_char(trunc(to_date($P{startdate})), 'mm') = '08' THEN 'AGOSTO'
              WHEN to_char(trunc(to_date($P{startdate})), 'mm') = '09' THEN 'SEPTIEMBRE'
              WHEN to_char(trunc(to_date($P{startdate})), 'mm') = '10' THEN 'OCTUBRE'
              WHEN to_char(trunc(to_date($P{startdate})), 'mm') = '11' THEN 'NOVIEMBRE'
              WHEN to_char(trunc(to_date($P{startdate})), 'mm') = '12' THEN 'DICIEMBRE'
              ELSE to_char(NULL)
              END || ' DEL ') || to_char(trunc(to_date($P{startdate})), 'yyyy') AS mes_aniog
 				)  as mes_aniop, ft.description
from FIN_Finacc_Transaction ft left join fin_payment fp on ft.fin_payment_id = fp.fin_payment_id
 left join c_bpartner cb on cb.c_bpartner_id = ft.c_bpartner_id
where trunc(ft.Statementdate) BETWEEN trunc(to_date($P{startdate})) AND trunc(to_date($P{enddate}))
and ft.Fin_Financial_Account_ID = $P{Fin_Financial_Account_ID}
and ft.Trxtype in('BPD','BPW')
and ft.Status in('RPPC','RDNC','PWNC')
 ) rep, (
Select
			z.c_doctype_id
			, STRING_AGG(COALESCE(y.label,''),to_char(',-,') ORDER BY y.line ASC) as "etiquetas"
			, STRING_AGG(COALESCE(y.name,''),to_char(',-,') ORDER BY y.line ASC) as "nombres"
			, STRING_AGG(COALESCE(y.position,''),to_char(',-,') ORDER BY y.line ASC) as "cargos"
		From c_doctype z join scsdc_signaturesperdoc y on y.c_doctype_id = z.c_doctype_id
		where z.name = 'Reporte Conciliación Automatico Mensual'
		GROUP BY z.c_doctype_id
) signatures, (
select name,genericaccountno from fin_financial_account
	where fin_financial_account_id = $P{Fin_Financial_Account_ID}
) account
order by DIA]]>
	</queryString>
	<field name="name" class="java.lang.String"/>
	<field name="genericaccountno" class="java.lang.String"/>
	<field name="fin_financial_account_id" class="java.lang.String"/>
	<field name="dateacct" class="java.sql.Timestamp"/>
	<field name="dia" class="java.sql.Timestamp"/>
	<field name="dcto_y_nro" class="java.lang.String"/>
	<field name="cte_ing_egr" class="java.lang.String"/>
	<field name="concepto" class="java.lang.String"/>
	<field name="beneficiario" class="java.lang.String"/>
	<field name="ingresos" class="java.math.BigDecimal"/>
	<field name="egreros" class="java.math.BigDecimal"/>
	<field name="dep_no_conciliado" class="java.math.BigDecimal"/>
	<field name="chq_no_conciliado" class="java.math.BigDecimal"/>
	<field name="estado" class="java.lang.String"/>
	<field name="saldo" class="java.math.BigDecimal"/>
	<field name="startdate" class="java.sql.Date"/>
	<field name="enddate" class="java.sql.Date"/>
	<field name="mes_aniop" class="java.lang.String"/>
	<field name="description" class="java.lang.String"/>
	<field name="saldo_inicial" class="java.math.BigDecimal"/>
	<field name="label_firma_1" class="java.lang.String"/>
	<field name="label_firma_2" class="java.lang.String"/>
	<field name="label_firma_3" class="java.lang.String"/>
	<field name="nombre_firma_1" class="java.lang.String"/>
	<field name="nombre_firma_2" class="java.lang.String"/>
	<field name="nombre_firma_3" class="java.lang.String"/>
	<field name="nombre_cargos_1" class="java.lang.String"/>
	<field name="nombre_cargos_2" class="java.lang.String"/>
	<field name="nombre_cargos_3" class="java.lang.String"/>
	<variable name="V_Ingresos" class="java.math.BigDecimal" calculation="Sum">
		<variableExpression><![CDATA[$F{ingresos}]]></variableExpression>
	</variable>
	<variable name="V_Egresos" class="java.math.BigDecimal" calculation="Sum">
		<variableExpression><![CDATA[$F{egreros}]]></variableExpression>
	</variable>
	<variable name="V_Saldo_FInal" class="java.math.BigDecimal">
		<variableExpression><![CDATA[( ((($F{saldo_inicial}).add($V{V_Ingresos})).subtract($V{V_Egresos})
)!=null ? (($F{saldo_inicial}).add($V{V_Ingresos})).subtract($V{V_Egresos})
 : 0 )]]></variableExpression>
		<initialValueExpression><![CDATA[]]></initialValueExpression>
	</variable>
	<variable name="V_Diferencias" class="java.math.BigDecimal">
		<variableExpression><![CDATA[($F{saldo}).subtract($V{V_Saldo_FInal})]]></variableExpression>
	</variable>
	<variable name="V_DepNo_Conciliado" class="java.math.BigDecimal" calculation="Sum">
		<variableExpression><![CDATA[$F{dep_no_conciliado}]]></variableExpression>
	</variable>
	<variable name="V_ChNC" class="java.math.BigDecimal" calculation="Sum">
		<variableExpression><![CDATA[( $F{chq_no_conciliado}!=null ? $F{chq_no_conciliado} : 0.00 )]]></variableExpression>
	</variable>
	<variable name="V_Saldo_Libros" class="java.math.BigDecimal">
		<variableExpression><![CDATA[( ((($V{V_Saldo_FInal}).add($V{V_DepNo_Conciliado})).subtract($V{V_ChNC})
)!=null ? ((($V{V_Saldo_FInal}).add($V{V_DepNo_Conciliado})).subtract($V{V_ChNC})
) : 0 )]]></variableExpression>
	</variable>
