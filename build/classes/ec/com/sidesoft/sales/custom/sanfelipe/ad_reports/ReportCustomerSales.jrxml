	<parameter name="NUMBERFORMAT" class="java.text.DecimalFormat" isForPrompting="false">
		<defaultValueExpression><![CDATA[new DecimalFormat("###,##0.00;-###,##0.00", new DecimalFormatSymbols())]]></defaultValueExpression>
	</parameter>
	<parameter name="DATEFORMAT" class="java.text.SimpleDateFormat" isForPrompting="false">
		<defaultValueExpression><![CDATA[new SimpleDateFormat("dd/MM/yyyy")]]></defaultValueExpression>
	</parameter>
	<parameter name="AD_User_ID" class="java.lang.String" isForPrompting="false">
		<defaultValueExpression><![CDATA["100"]]></defaultValueExpression>
	</parameter>
	<parameter name="Cutoffdate" class="java.util.Date">
		<defaultValueExpression><![CDATA[]]></defaultValueExpression>
	</parameter>
	<parameter name="aux_CutOffDate" class="java.lang.String" isForPrompting="false">
		<defaultValueExpression><![CDATA[($P{Cutoffdate} == null || $P{Cutoffdate}.equals("")) ? "" : "AND TO_CHAR(BP.CREATED,'dd/MM/yyyy')::date <= '" + new SimpleDateFormat("dd/MM/yyyy").format($P{Cutoffdate})+"'::date"]]></defaultValueExpression>
	</parameter>
	<parameter name="Created" class="java.util.Date" isForPrompting="false"/>
	<parameter name="aux_Created" class="java.lang.String" isForPrompting="false">
		<defaultValueExpression><![CDATA[($P{Created} == null || $P{Created}.equals("")) ? "" : "AND BP.CREATED <= TO_DATE('" + new java.sql.Date($P{Created}.getTime()) + "', 'YYYY-MM-DD') AND BP.CREATED >= TO_DATE('" + new java.sql.Date($P{Created}.getTime()) + "', 'YYYY-MM-DD') "]]></defaultValueExpression>
	</parameter>
	<parameter name="c_bpartner_id" class="java.lang.String"/>
	<parameter name="aux_customer" class="java.lang.String" isForPrompting="false">
		<defaultValueExpression><![CDATA[($P{c_bpartner_id} == null || $P{c_bpartner_id}.equals("")) ? " " : " AND bp.C_BPARTNER_ID = '" + $P{c_bpartner_id} +"'"]]></defaultValueExpression>
	</parameter>
	<parameter name="user1_id" class="java.lang.String"/>
	<parameter name="aux_canal" class="java.lang.String" isForPrompting="false">
		<defaultValueExpression><![CDATA[($P{user1_id} == null || $P{user1_id}.equals("")) ? " " : " AND si.user1_id = '" + $P{user1_id} +"'"]]></defaultValueExpression>
	</parameter>
	<queryString>
		<![CDATA[select o.ad_org_id as org_id, o.name as org_name,
     'Openbravo' as printing_user, TO_CHAR(NOW(),'dd/MM/yyyy HH24:MI:SS') as printing_date,
      to_date(bp.created) as "Fecha creacion cliente",
       bp.taxid as "Identificacion",
	   bp.name as "Cliente",
	 to_date((select dateinvoiced from c_invoice si inner join c_doctype dt
		 on si.c_doctype_id = dt.c_doctype_id
	     where si.issotrx='Y' and dt.isreturn='N' and si.docstatus='CO'
		   and si.c_bpartner_id = bp.c_bpartner_id $P!{aux_canal}
		 order by si.dateinvoiced desc limit 1)) as "Ultima fecha fact venta",
        coalesce((now()::date-(select dateinvoiced from c_invoice si inner join c_doctype dt
		 on si.c_doctype_id = dt.c_doctype_id
	     where si.issotrx='Y' and dt.isreturn='N' and si.docstatus='CO'
		   and si.c_bpartner_id = bp.c_bpartner_id $P!{aux_canal}
		 order by si.dateinvoiced desc limit 1)::date),0) as "Dias sin actividad",
       coalesce((select si.grandtotal from c_invoice si inner join c_doctype dt
		 on si.c_doctype_id = dt.c_doctype_id
	     where si.issotrx='Y' and dt.isreturn='N' and si.docstatus='CO'
		   and si.c_bpartner_id = bp.c_bpartner_id $P!{aux_canal}
		 order by si.dateinvoiced desc limit 1),0) as "Monto de ultima factura venta",
       coalesce((select sum(si.grandtotal) from c_invoice si inner join c_doctype dt
		 on si.c_doctype_id = dt.c_doctype_id
	     where si.issotrx='Y' and dt.isreturn='N' and si.docstatus='CO'
		   and si.c_bpartner_id = bp.c_bpartner_id $P!{aux_canal}
		 group by si.c_bpartner_id),0) as "Ventas totales",
coalesce((select cc.name from c_bpartner part
		 left join user1 cc on part.em_ssfc_user1_id=cc.user1_id
		where part.name=bp.name limit 1),'') as "Canal",



CASE
WHEN bp.EM_Sspsi_Origin='A'
THEN 'ACTIVACIONES'
WHEN bp.EM_Sspsi_Origin='EW'
THEN 'E COMMERCE- PAGINA WEB'
WHEN bp.EM_Sspsi_Origin='SN'
THEN 'REDES SOCIALES'
WHEN bp.EM_Sspsi_Origin='RA'
THEN 'RECI APP'
WHEN bp.EM_Sspsi_Origin='D'
THEN 'DONACIONES'
WHEN bp.EM_Sspsi_Origin='SA'
THEN 'ALIANZA ESTATÉGICA'
WHEN bp.EM_Sspsi_Origin='AS'
THEN 'AUTOVENTA'
END Origen

from c_bpartner bp join ad_org o on o.ad_orgtype_id = '1'
join c_bp_group bpg on bpg.c_bp_group_id=bp.c_bp_group_id
where bp.iscustomer='Y' and bp.isactive='Y'
and (bp.em_ssfc_user1_id=$P{user1_id}  or $P{user1_id} is null )
AND 1=1
AND bpg.c_bp_group_id='7578D9F0F80947D0A1F7399BB95DD003'
$P!{aux_CutOffDate}
$P!{aux_Created}
$P!{aux_customer}
order by "Fecha creacion cliente" desc]]>
	</queryString>
	<field name="org_id" class="java.lang.String"/>
	<field name="org_name" class="java.lang.String"/>
	<field name="printing_user" class="java.lang.String"/>
	<field name="printing_date" class="java.lang.String"/>
	<field name="Fecha creacion cliente" class="java.util.Date"/>
	<field name="Identificacion" class="java.lang.String"/>
	<field name="Cliente" class="java.lang.String"/>
	<field name="Ultima fecha fact venta" class="java.util.Date"/>
	<field name="Dias sin actividad" class="java.lang.Integer"/>
	<field name="Monto de ultima factura venta" class="java.math.BigDecimal"/>
	<field name="Ventas totales" class="java.math.BigDecimal"/>
	<field name="Canal" class="java.lang.String"/>
	<field name="Origen" class="java.lang.String"/>
	<variable name="TOTAL_SALES" class="java.math.BigDecimal" calculation="Sum">
		<variableExpression><![CDATA[$F{Ventas totales}]]></variableExpression>
	</variable>
	<variable name="Cliente" class="java.lang.String">
		<variableExpression><![CDATA[($P{c_bpartner_id} == null || $P{c_bpartner_id}.equals("")) ? " " :$F{Cliente}]]></variableExpression>
	</variable>
	<variable name="promedio_idas_inactividad" class="java.math.BigDecimal" calculation="Average">
		<variableExpression><![CDATA[$F{Dias sin actividad}]]></variableExpression>
	</variable>
