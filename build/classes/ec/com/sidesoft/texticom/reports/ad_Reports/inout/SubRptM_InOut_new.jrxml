	<style name="GroupHeader_DarkGray" mode="Opaque" forecolor="#FFFFFF" backcolor="#555555" vAlign="Middle" fontName="Bitstream Vera Sans" fontSize="14">
		<box leftPadding="5"/>
	</style>
	<style name="GroupHeader_Gray" mode="Opaque" backcolor="#999999"/>
	<style name="Detail_Line">
		<conditionalStyle>
			<conditionExpression><![CDATA[new Boolean($V{REPORT_COUNT}.intValue()%2==1)]]></conditionExpression>
			<style mode="Opaque" backcolor="#CCCCCC"/>
		</conditionalStyle>
	</style>
	<style name="Total_Gray" mode="Opaque" forecolor="#000000" backcolor="#CCCCCC"/>
	<parameter name="BASE_WEB" class="java.lang.String" isForPrompting="false"/>
	<parameter name="DOCUMENT_ID" class="java.lang.String">
		<defaultValueExpression><![CDATA["'1000069'"]]></defaultValueExpression>
	</parameter>
	<parameter name="NUMBERFORMAT" class="java.text.DecimalFormat" isForPrompting="false"/>
	<parameter name="M_Product_ID" class="java.lang.String"/>
	<queryString>
		<![CDATA[select
sum(coalesce(movementqty,0)) as "movementqty",
rep.order as "order",
poreference as "poreference"
from
(
SELECT io.ad_org_id AS organizationid
  , io.documentno
  , COALESCE(iol.movementqty,0) AS movementqty
  , bp.name AS bpartner
  , p.value AS product_code
  , p.name AS product_name
  , COALESCE(p.em_sscrtxt_units_per_box,0) AS units_per_box
  , o.documentno AS order
  , (COALESCE(iol.movementqty,0)/CASE WHEN COALESCE(p.em_sscrtxt_units_per_box,0)=0 THEN 1 ELSE p.em_sscrtxt_units_per_box END)::INTEGER AS full_boxes_total
  , CASE WHEN COALESCE(p.em_sscrtxt_units_per_box,0)*(COALESCE(iol.movementqty,0)/CASE WHEN COALESCE(p.em_sscrtxt_units_per_box,0)=0 THEN 1 ELSE p.em_sscrtxt_units_per_box END)::INTEGER<COALESCE(iol.movementqty,0) THEN 1 ELSE 0 END AS partial_boxes_total
  , CASE WHEN COALESCE(p.em_sscrtxt_units_per_box,0)*(COALESCE(iol.movementqty,0)/CASE WHEN COALESCE(p.em_sscrtxt_units_per_box,0)=0 THEN 1 ELSE p.em_sscrtxt_units_per_box END)::INTEGER<COALESCE(iol.movementqty,0) THEN iol.movementqty ELSE 0 END AS partial_boxes
, o.poreference
FROM m_inout AS io
  JOIN m_inoutline AS iol ON iol.m_inout_id=io.m_inout_id
  JOIN c_bpartner AS bp ON bp.c_bpartner_id=io.c_bpartner_id
  JOIN m_product AS p ON p.m_product_id=iol.m_product_id
  LEFT JOIN c_orderline AS ol ON ol.c_orderline_id=iol.c_orderline_id
  LEFT JOIN c_order AS o ON o.c_order_id=ol.c_order_id
WHERE io.m_inout_id=$P{DOCUMENT_ID} AND iol.m_product_id=$P{M_Product_ID}
ORDER BY p.value, o.documentno
) rep
group by  rep.order , poreference]]>
	</queryString>
	<field name="movementqty" class="java.math.BigDecimal"/>
	<field name="order" class="java.lang.String"/>
	<field name="poreference" class="java.lang.String"/>
	<background>
		<band splitType="Stretch"/>
	</background>
