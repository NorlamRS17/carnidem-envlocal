					<rightPen lineWidth="0.5"/>
				</box>
				<textElement textAlignment="Center" verticalAlignment="Middle"/>
				<textFieldExpression><![CDATA[$F{poreference}]]></textFieldExpression>
			</textField>
		</band>
	</detail>
</jasperReport>
