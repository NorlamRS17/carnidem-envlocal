<?xml version="1.0" encoding="UTF-8"?>
<jasperReport xmlns="http://jasperreports.sourceforge.net/jasperreports" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://jasperreports.sourceforge.net/jasperreports http://jasperreports.sourceforge.net/xsd/jasperreport.xsd" name="Rpt_ComplianceProductionProjection" pageWidth="1630" pageHeight="842" columnWidth="1590" leftMargin="20" rightMargin="20" topMargin="20" bottomMargin="20" uuid="825909cf-4ec9-4186-9bc1-db4574496272">
	<property name="ireport.zoom" value="1.8181818181818281"/>
	<property name="ireport.x" value="1355"/>
	<property name="ireport.y" value="0"/>
	<property name="net.sf.jasperreports.export.xls.detect.cell.type" value="true"/>
	<parameter name="NUMBERFORMAT" class="java.text.DecimalFormat" isForPrompting="false">
		<defaultValueExpression><![CDATA[new DecimalFormat("###,##0.00;-###,##0.00", new DecimalFormatSymbols())]]></defaultValueExpression>
	</parameter>
	<parameter name="NUMBERDECIMAL" class="java.lang.Integer" isForPrompting="false">
		<defaultValueExpression><![CDATA[2]]></defaultValueExpression>
	</parameter>
	<parameter name="StartDate" class="java.util.Date">
		<defaultValueExpression><![CDATA[]]></defaultValueExpression>
	</parameter>
	<parameter name="EndDate" class="java.util.Date">
		<defaultValueExpression><![CDATA[]]></defaultValueExpression>
	</parameter>
	<parameter name="MA_Processplan_ID" class="java.lang.String">
		<defaultValueExpression><![CDATA[]]></defaultValueExpression>
	</parameter>
	<parameter name="MA_Workrequirement_ID" class="java.lang.String"/>
	<queryString>
		<![CDATA[SELECT
 documentno
, producto
, organization
, MA_WRPhase_id
, cant_planificada
, cant_producida
, cant_prod_conf
, cant_prod_no_conf
, doc_parte_fab
,( case when  turno = 'M' then 'T1'
           when  turno = 'T' then 'T2'
           when  turno ='SSCRTXT_NIGTH'  then 'T3'
else ' ' end  )as turno
, cant_entregada
, cant_conforme
, cant_no_conf
, cumplimiento_global
, cumplim_cant_prod  as cumplim_producida
, cumplim_cant_prod_conf   as cumplim_conforme
, cumplim_cant_prod_no_conf  as cumplim_no_conforme
, round((case when cant_producida>0 and total_prod>0 then
	cant_producida/total_prod
	else 0
  end)*100,2) as dist_prod
, line
,unidad
,fechacreacion
,now() as fechaimpresion
,parada
,Planificado_Parada
,Producido_Parada
,No_conforme_parada
,(Producido_Parada-No_conforme_parada) as Conforme_parada
from
(SELECT
MAWR.Conversionrate as parada
,MAWR.EM_Ssprod_Secondqtystop as Planificado_Parada
,MAP.Donequantity as Producido_Parada
,cant_rechazada2 as No_conforme_parada
,MAWR.documentno  as documentno
,MAPP.name as producto
,MAPP.ad_org_id as organization
,MAP.MA_WRPhase_id
,MAP.Quantity as cant_planificada
,coalesce(total.cat_produccion2,0) as cant_producida
,coalesce(total.cant_conforme2,0) as cant_prod_conf
,(coalesce(total.cat_produccion2,0) - coalesce(total.cant_conforme2,0)) as cant_prod_no_conf
, '' as doc_parte_fab
, '' as turno
, null as cant_entregada
, null  as cant_no_conf
, null as cant_conforme
, null cumplimiento_global

, round((case when MAP.Quantity>0 and coalesce(total.cat_produccion2,0)>0 then
	coalesce(total.cat_produccion2/MAP.Quantity,0) else 0
  end)*100,2) as cumplim_cant_prod

, round((case when MAP.Quantity>0 and coalesce(total.cant_conforme2,0)>0 then
	coalesce(total.cant_conforme2/MAP.Quantity,0) else 0
  end)*100,2) as cumplim_cant_prod_conf

  , round((case when MAP.Quantity>0 and coalesce((coalesce(total.cat_produccion2,0) - coalesce(total.cant_conforme2,0)) ,0)>0 then
	 coalesce((coalesce(total.cat_produccion2,0) - coalesce(total.cant_conforme2,0)),0)/MAP.Quantity  else 0
  end)*100,2) as cumplim_cant_prod_no_conf
,'1'  as line
, cal.cat_producida as total_prod
,MAPP.Secondaryunit as unidad
, mawr.startdate  as fechacreacion
FROM MA_WorkRequirement MAWR
JOIN MA_Processplan MAPP on MAPP.MA_Processplan_ID = MAWR.MA_Processplan_ID
JOIN MA_WRPhase MAP on MAP.MA_WorkRequirement_id = MAWR.MA_WorkRequirement_id
left join (

	select
	mpp.MA_Wrphase_ID
	, sum(mpp.ProductionQty) as cat_produccion2
	, sum(mpp.Rejectedquantity) as cant_rechazada2
	, sum(mpp.ProductionQty) - sum(mpp.Rejectedquantity) as cant_conforme2
	from M_ProductionPlan mpp
	join m_production mprod on mprod.m_production_id = mpp.m_production_id
	group by mpp.MA_Wrphase_ID

)  total on total.MA_Wrphase_ID = MAP.MA_Wrphase_ID
, (
	select
	sum(mpp.ProductionQty) as cat_producida
	from M_ProductionPlan mpp
	join m_production mprod on mprod.m_production_id = mpp.m_production_id
	where MA_WRPhase_id in (SELECT
			          distinct MAPc.MA_WRPhase_id as cat_producida
				FROM MA_WorkRequirement MAWRc
				INNER JOIN MA_Processplan MAPPc on MAPPc.MA_Processplan_ID = MAWRc.MA_Processplan_ID
				INNER JOIN MA_WRPhase MAPc on MAPc.MA_WorkRequirement_id = MAWRc.MA_WorkRequirement_id
				WHERE MAPPc.MA_Processplan_ID = $P{MA_Processplan_ID}
				AND  MAWRc.StartDate BETWEEN $P{StartDate} and $P{EndDate}
				and (MAWRc.MA_WorkRequirement_id = $P{MA_Workrequirement_ID} or $P{MA_Workrequirement_ID} is null)
			)
) cal
WHERE MAPP.MA_Processplan_ID = $P{MA_Processplan_ID}
AND MAWR.StartDate BETWEEN $P{StartDate} and $P{EndDate}
and (MAWR.MA_WorkRequirement_id = $P{MA_Workrequirement_ID} or $P{MA_Workrequirement_ID} is null)

union all
SELECT
MAWR.Conversionrate as parada
,MAWR.EM_Ssprod_Secondqtystop as Planificado_Parada
,MAP.Donequantity as Producido_Parada
,cant_rechazada2 as No_conforme_parada
,MAWR.documentno  as documentno
,MAPP.name as producto
,MAPP.ad_org_id as organization
,MAP.MA_WRPhase_id
, 0 as cant_planificada
,0 as cant_producida
,0 as cant_prod_conf
,0 as cant_prod_no_conf
, rep.documento_pf as doc_parte_fab
, rep.turno
, rep.cat_produccion as cant_entregada
, rep.cant_rechazada as cant_no_conf
, coalesce(rep.cat_produccion,0) - coalesce(rep.cant_rechazada,0)  as cant_conforme
, round((case when (coalesce(rep.cat_produccion,0) - coalesce(rep.cant_rechazada,0))>0 and MAP.Quantity>0 then
	(coalesce(rep.cat_produccion,0) - coalesce(rep.cant_rechazada,0))/MAP.Quantity else 0
   end)*100,2) cumplimiento_global

, 0 as cumplim_cant_prod
, 0 as cumplim_cant_prod_conf
, 0 as cumplim_cant_prod_no_conf
,'2'  as line
, cal.cat_producida as total_prod
,MAPP.Secondaryunit as unidad
, mawr.startdate  as fechacreacion
FROM MA_WorkRequirement MAWR
JOIN MA_Processplan MAPP on MAPP.MA_Processplan_ID = MAWR.MA_Processplan_ID
JOIN MA_WRPhase MAP on MAP.MA_WorkRequirement_id = MAWR.MA_WorkRequirement_id
left join (
select
mpp.MA_Wrphase_ID
, mprod.documentno as documento_pf
, mpp.ProductionQty as cat_produccion
, mpp.Rejectedquantity as cant_rechazada
, mpp.EM_Sscrtxt_Shift  as turno
from M_ProductionPlan mpp
join m_production mprod on mprod.m_production_id = mpp.m_production_id
) rep on rep.MA_Wrphase_ID = MAP.MA_Wrphase_ID
left join (

	select
	mpp.MA_Wrphase_ID
	, sum(mpp.ProductionQty) as cat_produccion2
	, sum(mpp.Rejectedquantity) as cant_rechazada2
	from M_ProductionPlan mpp
	join m_production mprod on mprod.m_production_id = mpp.m_production_id
	group by mpp.MA_Wrphase_ID


)  total on total.MA_Wrphase_ID = MAP.MA_Wrphase_ID
,(
select
sum(mpp.ProductionQty) as cat_producida
from M_ProductionPlan mpp
join m_production mprod on mprod.m_production_id = mpp.m_production_id
where MA_WRPhase_id in 	(SELECT
			   distinct MAPc.MA_WRPhase_id as cat_producida
			 FROM MA_WorkRequirement MAWRc
			 INNER JOIN MA_Processplan MAPPc on MAPPc.MA_Processplan_ID = MAWRc.MA_Processplan_ID
			 INNER JOIN MA_WRPhase MAPc on MAPc.MA_WorkRequirement_id = MAWRc.MA_WorkRequirement_id
			 WHERE MAPPc.MA_Processplan_ID = $P{MA_Processplan_ID}
			 AND  MAWRc.StartDate BETWEEN $P{StartDate} and $P{EndDate}
			and (MAWRc.MA_WorkRequirement_id = $P{MA_Workrequirement_ID} or $P{MA_Workrequirement_ID} is null)
			)
) cal
WHERE MAPP.MA_Processplan_ID = $P{MA_Processplan_ID}
AND MAWR.StartDate BETWEEN $P{StartDate} and $P{EndDate}
and (MAWR.MA_WorkRequirement_id = $P{MA_Workrequirement_ID} or $P{MA_Workrequirement_ID} is null)
) rep
order by documentno, line]]>
	</queryString>
	<field name="documentno" class="java.lang.String"/>
	<field name="producto" class="java.lang.String"/>
	<field name="organization" class="java.lang.String"/>
	<field name="ma_wrphase_id" class="java.lang.String"/>
	<field name="cant_planificada" class="java.math.BigDecimal"/>
	<field name="cant_producida" class="java.math.BigDecimal"/>
	<field name="cant_prod_conf" class="java.math.BigDecimal"/>
	<field name="cant_prod_no_conf" class="java.math.BigDecimal"/>
	<field name="doc_parte_fab" class="java.lang.String"/>
	<field name="turno" class="java.lang.String"/>
	<field name="cant_entregada" class="java.math.BigDecimal"/>
	<field name="cant_conforme" class="java.math.BigDecimal"/>
	<field name="cant_no_conf" class="java.math.BigDecimal"/>
	<field name="cumplimiento_global" class="java.math.BigDecimal"/>
	<field name="cumplim_producida" class="java.math.BigDecimal"/>
	<field name="cumplim_conforme" class="java.math.BigDecimal"/>
	<field name="cumplim_no_conforme" class="java.math.BigDecimal"/>
	<field name="dist_prod" class="java.math.BigDecimal"/>
	<field name="line" class="java.lang.String"/>
	<field name="unidad" class="java.lang.String"/>
	<field name="fechacreacion" class="java.sql.Timestamp"/>
	<field name="fechaimpresion" class="java.sql.Timestamp"/>
	<field name="parada" class="java.math.BigDecimal"/>
	<field name="planificado_parada" class="java.math.BigDecimal"/>
	<field name="producido_parada" class="java.math.BigDecimal"/>
	<field name="no_conforme_parada" class="java.math.BigDecimal"/>
	<field name="conforme_parada" class="java.math.BigDecimal"/>
	<variable name="v_dist_prod" class="java.lang.String"/>
	<variable name="total_cant_Planif" class="java.math.BigDecimal" calculation="Sum">
		<variableExpression><![CDATA[$F{cant_planificada}]]></variableExpression>
	</variable>
	<variable name="total_cant_Producida" class="java.math.BigDecimal" calculation="Sum">
		<variableExpression><![CDATA[$F{cant_producida}]]></variableExpression>
	</variable>
	<variable name="total_cumplimiento" class="java.lang.Double">
		<variableExpression><![CDATA[Double.parseDouble($V{total_cant_Planif}.toString())> Double.parseDouble("0")
&& Double.parseDouble( $V{total_cant_Producida}.toString())> Double.parseDouble("0")
?

(Double.parseDouble( $V{total_cant_Producida}.toString())/Double.parseDouble($V{total_cant_Planif}.toString()))*100 :
Double.parseDouble("0")]]></variableExpression>
	</variable>
	<variable name="Distrubu_prod" class="java.lang.String" calculation="Sum">
		<variableExpression><![CDATA[$F{dist_prod}]]></variableExpression>
	</variable>
	<variable name="Total_Dis_prod" class="java.math.BigDecimal" calculation="Sum">
		<variableExpression><![CDATA[$F{dist_prod}]]></variableExpression>
	</variable>
	<variable name="supertotal_Cumplim" class="java.lang.String">
		<variableExpression><![CDATA[]]></variableExpression>
	</variable>
	<variable name="total_parada" class="java.math.BigDecimal" calculation="Sum">
		<variableExpression><![CDATA[$F{parada}]]></variableExpression>
	</variable>
	<variable name="total_planificado_parada" class="java.math.BigDecimal" calculation="Sum">
		<variableExpression><![CDATA[$F{planificado_parada}]]></variableExpression>
	</variable>
	<variable name="total_producido_parada" class="java.math.BigDecimal" calculation="Sum">
		<variableExpression><![CDATA[$F{producido_parada}]]></variableExpression>
	</variable>
	<variable name="total_confome_parada" class="java.math.BigDecimal" calculation="Sum">
		<variableExpression><![CDATA[$F{conforme_parada}]]></variableExpression>
	</variable>
