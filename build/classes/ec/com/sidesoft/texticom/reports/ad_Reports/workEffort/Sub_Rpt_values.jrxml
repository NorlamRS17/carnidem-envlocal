	<import value="net.sf.jasperreports.engine.*"/>
	<import value="java.util.*"/>
	<import value="net.sf.jasperreports.engine.data.*"/>
	<parameter name="document_id" class="java.lang.String"/>
	<parameter name="BASE_DESIGN" class="java.lang.String" isForPrompting="false">
		<defaultValueExpression><![CDATA["/opt/EntornosOP/webapps/indumot/src-loc/design"]]></defaultValueExpression>
	</parameter>
	<queryString>
		<![CDATA[SELECT p.ma_workrequirement_id ,
(coalesce(pl.productionqty,0)-coalesce(pl.rejectedquantity,0)) as qty,
coalesce(pl.rejectedquantity,0) as rejectedquantity,
pl.productionqty as total
FROM m_productionplan pl
LEFT JOIN ma_wrphase p on p.ma_wrphase_id=pl.ma_wrphase_id
WHERE m_production_id=$P{document_id}]]>
	</queryString>
	<field name="ma_workrequirement_id" class="java.lang.String"/>
	<field name="qty" class="java.math.BigDecimal"/>
	<field name="rejectedquantity" class="java.math.BigDecimal"/>
	<field name="total" class="java.math.BigDecimal"/>
	<variable name="REPORT_PAGE" class="java.lang.Integer" resetType="None" incrementType="Page">
		<variableExpression><![CDATA[$V{PAGE_NUMBER}]]></variableExpression>
	</variable>
