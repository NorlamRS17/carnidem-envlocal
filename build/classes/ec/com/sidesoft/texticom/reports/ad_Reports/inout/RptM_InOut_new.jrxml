	<field name="partial_boxes_total" class="java.lang.Integer"/>
	<field name="partial_boxes" class="java.math.BigDecimal"/>
	<variable name="vTotalUnits" class="java.math.BigDecimal" resetType="Group" resetGroup="Product" calculation="Sum">
		<variableExpression><![CDATA[$F{movementqty}]]></variableExpression>
	</variable>
	<variable name="vTotalQuantities" class="java.math.BigDecimal" calculation="Sum">
		<variableExpression><![CDATA[$F{movementqty}]]></variableExpression>
	</variable>
	<variable name="vTotalBoxes" class="java.math.BigDecimal" calculation="Sum">
		<variableExpression><![CDATA[$F{full_boxes_total}.add(new BigDecimal($F{partial_boxes_total}))]]></variableExpression>
	</variable>
