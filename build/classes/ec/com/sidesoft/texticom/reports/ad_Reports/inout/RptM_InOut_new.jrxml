	</parameter>
	<queryString>
		<![CDATA[SELECT *
  , TRUNC(movementqty/CASE WHEN units_per_box=0 THEN 1 ELSE units_per_box END,0) AS full_boxes_total
  , CASE WHEN units_per_box*TRUNC(movementqty/CASE WHEN units_per_box=0 THEN 1 ELSE units_per_box END,0)<movementqty THEN 1 ELSE 0 END AS partial_boxes_total
  , CASE WHEN units_per_box*TRUNC(movementqty/CASE WHEN units_per_box=0 THEN 1 ELSE units_per_box END,0)<movementqty THEN movementqty-units_per_box*TRUNC(movementqty/CASE WHEN units_per_box=0 THEN 1 ELSE units_per_box END,0) ELSE 0 END AS partial_boxes
FROM (
  SELECT io.ad_org_id AS organizationid
    , io.documentno
    , SUM(COALESCE(iol.movementqty,0)) AS movementqty
    , bp.name AS bpartner
    , s.name AS shipper
    , COALESCE(u.firstname,'')||' '||COALESCE(u.lastname,'') AS user
    , s.description AS license_plate
    , p.m_product_id
    , p.value AS product_code
    , p.name AS product_name
    , COALESCE(p.em_sscrtxt_units_per_box,0) AS units_per_box
  FROM m_inout AS io
    JOIN m_inoutline AS iol ON iol.m_inout_id=io.m_inout_id
    JOIN c_bpartner AS bp ON bp.c_bpartner_id=io.c_bpartner_id
    LEFT JOIN m_shipper AS s ON s.m_shipper_id=io.em_slci_shipper_id
    JOIN ad_user AS u ON u.ad_user_id=io.createdby
    JOIN m_product AS p ON p.m_product_id=iol.m_product_id
    LEFT JOIN c_orderline AS ol ON ol.c_orderline_id=iol.c_orderline_id
    LEFT JOIN c_order AS o ON o.c_order_id=ol.c_order_id
  WHERE io.m_inout_id=$P{DOCUMENT_ID}
  GROUP BY io.ad_org_id, io.documentno, bp.name, s.name, u.firstname, u.lastname, s.description, p.m_product_id, p.value, p.name, p.em_sscrtxt_units_per_box
) AS tmp
ORDER BY product_code]]>
	</queryString>
