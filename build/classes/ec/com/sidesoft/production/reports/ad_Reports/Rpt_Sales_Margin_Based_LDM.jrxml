<?xml version="1.0" encoding="UTF-8"?>
<jasperReport xmlns="http://jasperreports.sourceforge.net/jasperreports" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://jasperreports.sourceforge.net/jasperreports http://jasperreports.sourceforge.net/xsd/jasperreport.xsd" name="Rpt_Sales_Margin_Based_LDM" pageWidth="1335" pageHeight="595" orientation="Landscape" columnWidth="1295" leftMargin="20" rightMargin="20" topMargin="20" bottomMargin="20">
	<property name="ireport.zoom" value="0.9090909090909131"/>
	<property name="ireport.x" value="234"/>
	<property name="ireport.y" value="0"/>
	<parameter name="Ad_User_ID" class="java.lang.String">
		<defaultValueExpression><![CDATA[]]></defaultValueExpression>
	</parameter>
	<parameter name="Ad_Org_ID" class="java.lang.String">
		<defaultValueExpression><![CDATA[]]></defaultValueExpression>
	</parameter>
	<parameter name="Datefrom" class="java.util.Date">
		<defaultValueExpression><![CDATA[]]></defaultValueExpression>
	</parameter>
	<parameter name="Dateto" class="java.util.Date">
		<defaultValueExpression><![CDATA[]]></defaultValueExpression>
	</parameter>
	<parameter name="M_Product_Category_ID" class="java.lang.String">
		<defaultValueExpression><![CDATA[]]></defaultValueExpression>
	</parameter>
	<parameter name="M_Product_ID" class="java.lang.String">
		<defaultValueExpression><![CDATA[]]></defaultValueExpression>
	</parameter>
	<queryString>
		<![CDATA[SELECT sq.*,(sq.costounitario*sq.cantidad) as "costototal",
(sq.total/sq.cantidad) as "preciounitario",
(sq.total-(sq.costounitario*sq.cantidad)) as "utilidad",
TO_DATE(now()) as "fecha",
(SELECT coalesce(cbp.name,adu.name) FROM ad_user adu left join c_bpartner cbp ON
adu.c_bpartner_id = cbp.c_bpartner_id WHERE adu.ad_user_id=$P{Ad_User_ID}) as "usuario",
COALESCE($P{Ad_Org_ID},organizacionlegalid) as "organizacionid",
COALESCE(organizacionnombre,organizacionlegalnombre) as "orgname"
,TO_CHAR(ROUND(((sq.total/sq.cantidad)-sq.costounitario)/(sq.total/sq.cantidad)*100))||'%' as "margen_porcentaje"
FROM
(SELECT ao.name as "organizacion",
pc.value as "codigocategoria",
pc.name as "categoria",
mp.value as "codigoproducto",
mp.name as "producto",
COALESCE(ue.name,uo.name) as "unidad",
sum(cl.qtyinvoiced) as "cantidad",
sum(cl.linenetamt) as "total",
sescr_cost_at_date(mp.m_product_id,ci.dateinvoiced) as "costounitario",
(SELECT name FROM ad_org WHERE ad_org_id =$P{Ad_Org_ID}) as "organizacionnombre",
(SELECT ao.name FROM ad_org ao
INNER JOIN ad_orgtype ot ON ao.ad_orgtype_id = ot.ad_orgtype_id WHERE isacctlegalentity ='Y') as "organizacionlegalnombre",
(SELECT ao.ad_org_id FROM ad_org ao
INNER JOIN ad_orgtype ot ON ao.ad_orgtype_id = ot.ad_orgtype_id WHERE isacctlegalentity ='Y') as "organizacionlegalid"
,ci.dateinvoiced as "dateinvoiced"
FROM c_invoice ci
INNER JOIN ad_org ao ON ao.ad_org_id = ci.ad_org_id
INNER JOIN c_invoiceline cl ON cl.c_invoice_id = ci.c_invoice_id
INNER JOIN m_product mp ON mp.m_product_id = cl.m_product_id
LEFT JOIN m_product_category pc ON pc.m_product_category_id = mp.m_product_category_id
LEFT JOIN c_uom uo ON uo.c_uom_id = mp.c_uom_id
LEFT JOIN c_uom_trl ue ON ue.c_uom_id = uo.c_uom_id
WHERE ci.issotrx='Y' AND ci.docstatus='CO'
AND cl.qtyinvoiced <>0
AND ci.dateinvoiced >=$P{Datefrom} AND ci.dateinvoiced <= $P{Dateto}
AND (ci.ad_org_id = $P{Ad_Org_ID} OR $P{Ad_Org_ID} IS NULL)
AND (pc.m_product_category_id = $P{M_Product_Category_ID} OR $P{M_Product_Category_ID} IS NULL)
AND (mp.m_product_id = $P{M_Product_ID} OR $P{M_Product_ID} IS NULL)
GROUP BY
ao.name, ci.dateinvoiced, mp.m_product_id,pc.value,pc.name,COALESCE(ue.name,uo.name)
ORDER BY ao.name,pc.name ,mp.name) sq
WHERE sq.cantidad <>0]]>
	</queryString>
