		<variableExpression><![CDATA[$F{inward_qty_wh}.subtract( $F{inward_qty} )]]></variableExpression>
	</variable>
	<variable name="rendimient" class="java.math.BigDecimal">
		<variableExpression><![CDATA[]]></variableExpression>
	</variable>
