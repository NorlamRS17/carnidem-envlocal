			<textField isStretchWithOverflow="true" isBlankWhenNull="true">
				<reportElement x="256" y="0" width="98" height="20" isPrintWhenDetailOverflows="true" uuid="34914383-5e35-4a65-b9f0-342ea2e3568d"/>
				<textElement>
					<font fontName="DejaVu Sans" size="7"/>
				</textElement>
				<textFieldExpression><![CDATA[$F{dateacct_leave}]]></textFieldExpression>
			</textField>
			<textField isStretchWithOverflow="true" isBlankWhenNull="true">
				<reportElement x="64" y="40" width="290" height="20" isPrintWhenDetailOverflows="true" uuid="99ad9cd4-9088-457c-8656-3b56f3e2f483"/>
				<textElement>
					<font fontName="DejaVu Sans" size="7"/>
				</textElement>
				<textFieldExpression><![CDATA[(new java.text.SimpleDateFormat("dd/MM/yyyy")).format($F{stardate})  + " - " +  (new java.text.SimpleDateFormat("dd/MM/yyyy")).format($F{enddate})  + " - " +  $F{type_name}]]></textFieldExpression>
			</textField>
			<textField isStretchWithOverflow="true" isBlankWhenNull="true">
				<reportElement x="105" y="0" width="87" height="20" isPrintWhenDetailOverflows="true" uuid="826b3893-1145-42bb-b4bf-8d8413c1110f"/>
				<textElement>
					<font fontName="DejaVu Sans" size="7"/>
				</textElement>
				<textFieldExpression><![CDATA[$F{documentno}]]></textFieldExpression>
			</textField>
		</band>
	</title>
